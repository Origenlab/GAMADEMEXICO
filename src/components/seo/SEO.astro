---
// =============================================================================
// SEO.astro — Componente centralizado de meta tags
// Úsalo dentro de <head> para evitar duplicar la lógica en cada layout.
// Actualmente llamado desde Base.astro vía props inline; este componente
// permite llamarlo de forma independiente desde páginas que no usen Base.
// =============================================================================

import { SITE_URL, SITE_NAME, OG_IMAGE_DEFAULT, BRAND_COLOR, GEO } from '../../lib/config';
import { toAbsoluteImageUrl } from '../../lib/images';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogTitle?: string;
  ogDescription?: string;
  ogImage?: string;
  ogType?: string;
  twitterTitle?: string;
  twitterDescription?: string;
  noindex?: boolean;
  structuredData?: object[];
}

const {
  title,
  description,
  canonical,
  ogTitle,
  ogDescription,
  ogImage,
  ogType = 'website',
  twitterTitle,
  twitterDescription,
  noindex = false,
  structuredData = [],
} = Astro.props;

// Clamp description a ≤160 caracteres
const metaDescription =
  description && description.length > 160
    ? description.slice(0, 157).replace(/\s+\S*$/, '').trim() + '…'
    : description;

const pathname = Astro.url.pathname.replace(/\.html$/, '').replace(/\/$/, '') || '/';
const canonicalUrl = canonical || `${SITE_URL}${pathname}`;
const ogImageUrl = ogImage ? toAbsoluteImageUrl(ogImage, SITE_URL) : toAbsoluteImageUrl(OG_IMAGE_DEFAULT, SITE_URL);
const ogImageType = ogImageUrl.endsWith('.avif')
  ? 'image/avif'
  : ogImageUrl.endsWith('.webp')
    ? 'image/webp'
    : ogImageUrl.endsWith('.png')
      ? 'image/png'
      : 'image/jpeg';
---

<title>{title}</title>
<meta name="description" content={metaDescription}>
{noindex
  ? <meta name="robots" content="noindex, follow">
  : <meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1">
}
<link rel="canonical" href={canonicalUrl}>

<!-- Geo meta tags -->
<meta name="geo.region" content={GEO.region}>
<meta name="geo.placename" content={GEO.placename}>
<meta name="geo.position" content={`${GEO.latitude};${GEO.longitude}`}>
<meta name="ICBM" content={`${GEO.latitude}, ${GEO.longitude}`}>

<!-- Open Graph -->
<meta property="og:title" content={ogTitle || title}>
<meta property="og:description" content={ogDescription || metaDescription}>
<meta property="og:type" content={ogType}>
<meta property="og:url" content={canonicalUrl}>
<meta property="og:image" content={ogImageUrl}>
<meta property="og:image:width" content="1200">
<meta property="og:image:height" content="630">
<meta property="og:image:type" content={ogImageType}>
<meta property="og:image:alt" content={`Equipos contra incendios ${SITE_NAME}: monitores, boquillas, mangueras, válvulas y gabinetes`}>
<meta property="og:site_name" content={SITE_NAME}>
<meta property="og:locale" content="es_MX">

<!-- Twitter Cards -->
<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:site" content="@gamademexico">
<meta name="twitter:creator" content="@gamademexico">
<meta name="twitter:title" content={twitterTitle || ogTitle || title}>
<meta name="twitter:description" content={twitterDescription || ogDescription || metaDescription}>
<meta name="twitter:image" content={ogImageUrl}>
<meta name="twitter:image:alt" content={`Equipos contra incendios ${SITE_NAME}`}>

<!-- Favicons -->
<link rel="icon" href="/favicon.ico" sizes="any">
<link rel="icon" href="/icon.svg" type="image/svg+xml">
<link rel="apple-touch-icon" href="/icon.png">
<link rel="manifest" href="/site.webmanifest">
<meta name="theme-color" content={BRAND_COLOR}>

<!-- JSON-LD Structured Data -->
{structuredData.map((data) => (
  <script type="application/ld+json" set:html={JSON.stringify(data)} />
))}
