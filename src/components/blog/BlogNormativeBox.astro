---
// =============================================================================
// BlogNormativeBox — Caja de marco normativo
// Uso: artículos de tipo "normativo" donde la norma aplicable, la obligación
//      y el riesgo de incumplimiento son los datos más buscados por el lector.
// GEO: bloque citable de alta densidad semántica para extractos de IA.
// =============================================================================

interface Props {
  norma: string;          // e.g. "NFPA 25 · NOM-002-STPS-2010"
  obliga: string;         // Qué obliga a hacer la norma (1–2 líneas)
  consecuencia: string;   // Riesgo o sanción por incumplimiento (1–2 líneas)
  vigencia?: string;      // Opcional: edición o año vigente e.g. "NFPA 25 edición 2023"
}

const { norma, obliga, consecuencia, vigencia } = Astro.props;
---

<aside class="blog-normative" aria-label="Marco normativo aplicable">
  <div class="blog-normative__header">
    <span class="blog-normative__icon" aria-hidden="true">⚖️</span>
    <div>
      <span class="blog-normative__label">Marco normativo</span>
      <p class="blog-normative__norm">{norma}</p>
      {vigencia && <span class="blog-normative__vigencia">{vigencia}</span>}
    </div>
  </div>
  <dl class="blog-normative__body">
    <div class="blog-normative__row">
      <dt class="blog-normative__term">Obliga a</dt>
      <dd class="blog-normative__detail">{obliga}</dd>
    </div>
    <div class="blog-normative__row blog-normative__row--risk">
      <dt class="blog-normative__term">Riesgo de incumplimiento</dt>
      <dd class="blog-normative__detail">{consecuencia}</dd>
    </div>
  </dl>
</aside>

<style>
  .blog-normative {
    margin: var(--spacing-xl) 0;
    border: 1px solid #e8c84a;
    border-left: 4px solid #c8a000;
    border-radius: var(--border-radius);
    background: #fffbea;
    overflow: hidden;
  }

  .blog-normative__header {
    display: flex;
    align-items: flex-start;
    gap: var(--spacing-md);
    padding: var(--spacing-md) var(--spacing-lg);
    background: #fff5c0;
    border-bottom: 1px solid #e8c84a;
  }

  .blog-normative__icon {
    font-size: 1.25rem;
    flex-shrink: 0;
    margin-top: 0.125rem;
  }

  .blog-normative__label {
    display: block;
    font-size: 0.6875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: #7a6000;
    margin-bottom: 0.2rem;
  }

  .blog-normative__norm {
    margin: 0;
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-secondary);
    line-height: 1.3;
  }

  .blog-normative__vigencia {
    display: inline-block;
    margin-top: 0.2rem;
    font-size: 0.75rem;
    color: #7a6000;
  }

  .blog-normative__body {
    padding: var(--spacing-md) var(--spacing-lg);
    margin: 0;
    display: grid;
    gap: var(--spacing-sm);
  }

  .blog-normative__row {
    display: grid;
    grid-template-columns: 10rem 1fr;
    gap: 0.75rem;
    align-items: baseline;
    padding-bottom: var(--spacing-sm);
    border-bottom: 1px solid #f0e090;
  }

  .blog-normative__row:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }

  .blog-normative__row--risk .blog-normative__term {
    color: #9b1c1c;
  }

  .blog-normative__row--risk .blog-normative__detail {
    color: #7f1d1d;
  }

  .blog-normative__term {
    font-size: 0.8125rem;
    font-weight: 700;
    color: #5a4a00;
    margin: 0;
  }

  .blog-normative__detail {
    font-size: 0.9rem;
    color: var(--color-text);
    margin: 0;
    line-height: 1.6;
  }

  @media (max-width: 640px) {
    .blog-normative__row {
      grid-template-columns: 1fr;
      gap: 0.25rem;
    }

    .blog-normative__header,
    .blog-normative__body {
      padding: var(--spacing-md);
    }
  }
</style>
