---
// =============================================================================
// BlogSidebar - Sidebar profesional para artículos
// Sigue el patrón de ProductSidebar con estilos de subcategory.css
// =============================================================================

import { CATEGORY_LABELS, CATEGORY_SLUGS } from '../../lib/blogHelpers';
import { CATEGORY_MAP, WHATSAPP_NUMBER } from '../../lib/config';

interface TOCItem {
  id: string;
  text: string;
  level: number;
}

interface SidebarPostLink {
  title: string;
  href: string;
  categoryLabel?: string;
}

interface HubLink {
  title: string;
  href: string;
  description?: string;
}

interface Props {
  headings?: TOCItem[];
  tags?: Map<string, number>;
  categoryPosts?: SidebarPostLink[];
  featuredPosts?: SidebarPostLink[];
  recentPosts?: SidebarPostLink[];
  recentPostsTitle?: string;
  interlinkHubs?: HubLink[];
  interestModules?: HubLink[];
  showCTA?: boolean;
  layoutVariant?: 'article' | 'home' | 'category' | 'tag';
  categorySlug?: string;
  ctaTitulo?: string;
  ctaTexto?: string;
  whatsappNumero?: string;
  telefonoDisplay?: string;
}

const {
  headings = [],
  tags,
  categoryPosts = [],
  featuredPosts = [],
  recentPosts = [],
  recentPostsTitle = 'Publicaciones Recientes',
  interlinkHubs = [],
  interestModules = [],
  showCTA = true,
  layoutVariant = 'article',
  categorySlug,
  ctaTitulo = 'Cotización Rápida',
  ctaTexto = 'Respuesta en menos de 24 horas con precio y disponibilidad.',
  whatsappNumero = WHATSAPP_NUMBER || '5215565298240',
  telefonoDisplay = '55 6529 8240',
} = Astro.props;

const hasContent =
  headings.length > 0 ||
  (tags && tags.size > 0) ||
  showCTA ||
  categoryPosts.length > 0 ||
  featuredPosts.length > 0 ||
  recentPosts.length > 0 ||
  interestModules.length > 0;

// Categorías para navegación
const categorias = Object.entries(CATEGORY_LABELS).map(([slug, nombre]) => ({
  slug,
  nombre,
  urlSlug: CATEGORY_SLUGS[slug] || slug,
}));

// Filtrar headings h2 y h3
const filteredHeadings = headings.filter(h => h.level === 2 || h.level === 3);

const categoryEntry = Object.entries(CATEGORY_SLUGS).find(([, slug]) => slug === categorySlug);
const currentCategoryKey = categoryEntry?.[0];
const currentCategoryName = currentCategoryKey
  ? (CATEGORY_LABELS[currentCategoryKey] || currentCategoryKey)
  : 'esta categoría';

const categoryLandingUrl = currentCategoryKey && currentCategoryKey in CATEGORY_MAP
  ? CATEGORY_MAP[currentCategoryKey as keyof typeof CATEGORY_MAP].url
  : '/blog';

const defaultHubLinks: HubLink[] = [
  {
    title: `Catálogo de ${currentCategoryName}`,
    href: categoryLandingUrl,
    description: 'Revisa modelos, aplicaciones y especificaciones por proyecto.',
  },
  {
    title: 'Todos los Equipos Contra Incendios',
    href: '/equipos',
    description: 'Explora soluciones completas para industria, comercio e infraestructura.',
  },
  {
    title: 'Directorio de Empresas Certificadas',
    href: '/empresas-certificadas',
    description: 'Consulta empresas con sistemas contra incendios verificados en México.',
  },
  {
    title: 'Asesoría Técnica Especializada',
    href: '/servicios/asesoria',
    description: 'Validación técnica para selección, integración y cumplimiento.',
  },
  {
    title: 'Solicitar Cotización Empresarial',
    href: '/servicios/cotizaciones',
    description: 'Atención comercial con propuesta técnica y tiempos de entrega.',
  },
];

const hubLinks = interlinkHubs.length > 0 ? interlinkHubs : defaultHubLinks;

const fallbackInterestModules: HubLink[] = [
  {
    title: 'Cumplimiento normativo contra incendios',
    href: '/blog/gabinetes-hidrantes-contra-incendios/requisitos-legales-equipos-contra-incendios-mexico-empresas',
    description: 'Lineamientos y documentación para empresas en México.',
  },
  {
    title: 'Mantenimiento de equipos contra incendios',
    href: '/servicios/mantenimiento',
    description: 'Planes de verificación, trazabilidad y continuidad operativa.',
  },
  {
    title: 'Asesoría y suministro para empresas',
    href: '/servicios/asesoria',
    description: 'Soporte técnico para selección e integración de equipos.',
  },
];

const interestByCategory: Record<string, HubLink[]> = {
  monitores: [
    {
      title: 'Lineamientos de monitores',
      href: '/blog/monitores-contra-incendios/lineamientos-monitor-contra-incendios-mexico',
      description: 'Criterios técnicos y de cumplimiento para instalación.',
    },
    {
      title: 'Auditoría de monitores',
      href: '/blog/monitores-contra-incendios/auditoria-monitores-contra-incendios-empresas-mexico',
      description: 'Checklist operativo para validar desempeño y evidencia.',
    },
    {
      title: 'Manual técnico para empresas',
      href: '/blog/monitores-contra-incendios/manual-tecnico-monitores-contra-incendios-empresas',
      description: 'Selección, uso y requisitos para operación industrial.',
    },
  ],
  boquillas: [
    {
      title: 'Cumplimiento legal de boquillas',
      href: '/blog/boquillas-contra-incendios/cumplimiento-legal-boquillas-contra-incendios-mexico-2026',
      description: 'Marco de referencia para auditoría y seguridad industrial.',
    },
    {
      title: 'Ingeniería de boquillas',
      href: '/blog/boquillas-contra-incendios/ingenieria-boquillas-contra-incendios-proyectos-industriales',
      description: 'Especificación técnica para proyectos corporativos.',
    },
    {
      title: 'Brigadas y sistemas fijos',
      href: '/blog/boquillas-contra-incendios/boquillas-contra-incendios-brigadas-sistemas-fijos',
      description: 'Aplicación práctica en respuesta inicial y operación.',
    },
  ],
  mangueras: [
    {
      title: 'Lineamientos para mangueras',
      href: '/blog/mangueras-contra-incendios/lineamientos-mangueras-contra-incendios-empresas-mexico',
      description: 'Requisitos técnicos y operativos para empresas.',
    },
    {
      title: 'Cómo elegir mangueras',
      href: '/blog/mangueras-contra-incendios/como-elegir-manguera-contra-incendios',
      description: 'Selección por riesgo, presión y aplicación real.',
    },
    {
      title: 'Mantenimiento especializado',
      href: '/servicios/mantenimiento',
      description: 'Servicio para conservar trazabilidad y desempeño.',
    },
  ],
  valvulas: [
    {
      title: 'Normativa NFPA para válvulas',
      href: '/blog/valvulas-contra-incendios/normativa-nfpa-valvulas-contra-incendios',
      description: 'Puntos clave para cumplimiento y operación segura.',
    },
    {
      title: 'Mantenimiento del sistema',
      href: '/servicios/mantenimiento',
      description: 'Inspección y control preventivo de componentes críticos.',
    },
    {
      title: 'Asesoría de integración',
      href: '/servicios/asesoria',
      description: 'Compatibilidad de válvulas con red y equipos.',
    },
  ],
  'gabinetes-hidrantes': [
    {
      title: 'Requisitos legales empresariales',
      href: '/blog/gabinetes-hidrantes-contra-incendios/requisitos-legales-equipos-contra-incendios-mexico-empresas',
      description: 'Documentación y pasos para estar en regla.',
    },
    {
      title: 'Inspección de Protección Civil',
      href: '/blog/gabinetes-hidrantes-contra-incendios/inspeccion-proteccion-civil-equipos-contra-incendios-empresas-mexico',
      description: 'Qué revisan y cómo preparar evidencia técnica.',
    },
    {
      title: 'Programa interno y equipos',
      href: '/blog/gabinetes-hidrantes-contra-incendios/programa-interno-equipos-contra-incendios-empresas-mexico',
      description: 'Estrategia integral para cumplimiento operativo.',
    },
  ],
  'conexiones-herrajes': [
    {
      title: 'Conexiones y herrajes',
      href: '/conexiones-herrajes-contra-incendios',
      description: 'Catálogo técnico para compatibilidad hidráulica.',
    },
    {
      title: 'Todos los equipos contra incendios',
      href: '/equipos',
      description: 'Explora soluciones complementarias por categoría.',
    },
    {
      title: 'Asesoría técnica para integración',
      href: '/servicios/asesoria',
      description: 'Soporte para selección y configuración del sistema.',
    },
  ],
};

const resolvedInterestModules = interestModules.length > 0
  ? interestModules
  : (currentCategoryKey ? (interestByCategory[currentCategoryKey] || fallbackInterestModules) : fallbackInterestModules);
---

{hasContent && (
  <aside class={`blog-sidebar blog-sidebar--${layoutVariant}`}>
    {/* TOC Widget */}
    {filteredHeadings.length > 0 && (
      <div class="sidebar-widget sidebar-widget--toc">
        <div class="sidebar-widget__header">
          <h3 class="sidebar-widget__title">En este artículo</h3>
        </div>
        <nav class="sidebar-toc" aria-label="Tabla de contenidos">
          <ul class="sidebar-toc__list">
            {filteredHeadings.map((heading) => (
              <li class={`sidebar-toc__item sidebar-toc__item--level-${heading.level}`}>
                <a href={`#${heading.id}`} class="sidebar-toc__link">
                  <span class="sidebar-toc__indicator"></span>
                  <span class="sidebar-toc__text">{heading.text}</span>
                </a>
              </li>
            ))}
          </ul>
        </nav>
      </div>
    )}

    {/* Enlaces de la categoría actual */}
    {categoryPosts.length > 0 && (
      <div class="sidebar-widget sidebar-widget--category-posts">
        <div class="sidebar-widget__header">
          <h3 class="sidebar-widget__title">Más sobre {currentCategoryName}</h3>
          <p class="sidebar-widget__subtitle">Guías técnicas recomendadas</p>
        </div>
        <ul class="sidebar-links" aria-label={`Guías recomendadas sobre ${currentCategoryName}`}>
          {categoryPosts.slice(0, 5).map((post) => (
            <li class="sidebar-links__item">
              <a href={post.href} class="sidebar-links__link">
                <span class="sidebar-links__title">{post.title}</span>
                <span class="sidebar-links__meta">Leer guía técnica →</span>
              </a>
            </li>
          ))}
        </ul>
      </div>
    )}

    {/* Lecturas destacadas para interlinking transversal */}
    {featuredPosts.length > 0 && (
      <div class="sidebar-widget sidebar-widget--featured">
        <div class="sidebar-widget__header">
          <h3 class="sidebar-widget__title">Lecturas Destacadas</h3>
          <p class="sidebar-widget__subtitle">Contenido técnico de alto valor</p>
        </div>
        <ul class="sidebar-links" aria-label="Lecturas destacadas del blog">
          {featuredPosts.slice(0, 4).map((post) => (
            <li class="sidebar-links__item">
              <a href={post.href} class="sidebar-links__link">
                <span class="sidebar-links__title">{post.title}</span>
                {post.categoryLabel && <span class="sidebar-links__meta">{post.categoryLabel}</span>}
              </a>
            </li>
          ))}
        </ul>
      </div>
    )}

    {/* Publicaciones recientes */}
    {recentPosts.length > 0 && (
      <div class="sidebar-widget sidebar-widget--recent">
        <div class="sidebar-widget__header">
          <h3 class="sidebar-widget__title">{recentPostsTitle}</h3>
          <p class="sidebar-widget__subtitle">Últimos contenidos del blog técnico</p>
        </div>
        <ul class="sidebar-links" aria-label="Publicaciones recientes del blog">
          {recentPosts.slice(0, 6).map((post) => (
            <li class="sidebar-links__item">
              <a href={post.href} class="sidebar-links__link">
                <span class="sidebar-links__title">{post.title}</span>
                {post.categoryLabel && <span class="sidebar-links__meta">{post.categoryLabel}</span>}
              </a>
            </li>
          ))}
        </ul>
      </div>
    )}

    {/* CTA Widget - Highlight */}
    {showCTA && (
      <div class="sidebar-widget sidebar-widget--highlight sidebar-widget--cta">
        <div class="sidebar-widget__header">
          <h3 class="sidebar-widget__title">{ctaTitulo}</h3>
        </div>
        <p class="sidebar-widget__text">{ctaTexto}</p>
        <div class="sidebar-widget__actions">
          <a href="#cotizar" class="btn btn--primary btn--sm btn--full">Solicitar Cotización</a>
          <a href={`https://wa.me/${whatsappNumero}`} class="btn btn--outline btn--sm btn--full" target="_blank" rel="noopener">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            WhatsApp Directo
          </a>
        </div>
        <p class="sidebar-widget__phone">Tel: <a href={`tel:+52${telefonoDisplay.replace(/\s/g, '')}`}>{telefonoDisplay}</a></p>
      </div>
    )}

    {/* Módulos de interés por categoría */}
    <div class="sidebar-widget sidebar-widget--interest">
      <div class="sidebar-widget__header">
        <h3 class="sidebar-widget__title">Módulos de Interés</h3>
        <p class="sidebar-widget__subtitle">Bloques prioritarios para cumplimiento y operación</p>
      </div>
      <ul class="sidebar-hub" aria-label="Módulos de interés del sitio">
        {resolvedInterestModules.map((link) => (
          <li class="sidebar-hub__item">
            <a href={link.href} class="sidebar-hub__link">
              <span class="sidebar-hub__title">{link.title}</span>
              {link.description && <span class="sidebar-hub__desc">{link.description}</span>}
            </a>
          </li>
        ))}
      </ul>
    </div>

    {/* Rutas estratégicas de navegación */}
    <div class="sidebar-widget sidebar-widget--hub">
      <div class="sidebar-widget__header">
        <h3 class="sidebar-widget__title">Rutas Estratégicas</h3>
        <p class="sidebar-widget__subtitle">Accesos directos a recursos clave del sitio</p>
      </div>
      <ul class="sidebar-hub" aria-label="Rutas estratégicas del sitio">
        {hubLinks.map((link) => (
          <li class="sidebar-hub__item">
            <a href={link.href} class="sidebar-hub__link">
              <span class="sidebar-hub__title">{link.title}</span>
              {link.description && <span class="sidebar-hub__desc">{link.description}</span>}
            </a>
          </li>
        ))}
      </ul>
    </div>

    {/* Categorías Widget */}
    <div class="sidebar-widget sidebar-widget--categories">
      <div class="sidebar-widget__header">
        <h3 class="sidebar-widget__title">Categorías del Blog</h3>
      </div>
      <nav class="sidebar-nav" aria-label="Categorías del blog">
        <ul class="sidebar-nav__list">
          {categorias.map((cat) => (
            <li class="sidebar-nav__item">
              <a
                href={`/blog/${cat.urlSlug}`}
                class={`sidebar-nav__link ${categorySlug === cat.urlSlug ? 'sidebar-nav__link--active' : ''}`}
              >
                <span class="sidebar-nav__indicator"></span>
                <span class="sidebar-nav__text">{cat.nombre}</span>
              </a>
            </li>
          ))}
        </ul>
      </nav>
      <a href="/blog" class="sidebar-widget__back">← Ver todos los artículos</a>
    </div>

    {/* Tags Widget */}
    {tags && tags.size > 0 && (
      <div class="sidebar-widget sidebar-widget--tags">
        <div class="sidebar-widget__header">
          <h3 class="sidebar-widget__title">Etiquetas Populares</h3>
        </div>
        <div class="sidebar-tags">
          {[...tags.entries()].slice(0, 12).map(([tag, count]) => (
            <a href={`/blog/tag/${encodeURIComponent(tag)}`} class="sidebar-tags__item">
              {tag}
              <span class="sidebar-tags__count">{count}</span>
            </a>
          ))}
        </div>
      </div>
    )}

    {/* Slot para contenido adicional */}
    <slot />
  </aside>
)}

<style>
  .blog-sidebar {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    position: sticky;
    top: 2rem;
  }

  /* SIDEBAR WIDGET - Exactamente como ProductSidebar */
  .sidebar-widget {
    background: var(--color-white);
    border-radius: var(--border-radius);
    padding: 1.25rem;
    border: 1px solid var(--color-border);
  }

  .sidebar-widget--highlight {
    background: linear-gradient(135deg, var(--color-secondary) 0%, #1a365d 100%);
    color: white;
    border: none;
  }

  .sidebar-widget--highlight .sidebar-widget__title {
    color: white;
  }

  .sidebar-widget--highlight .sidebar-widget__text {
    color: rgba(255, 255, 255, 0.85);
  }

  .sidebar-widget__header {
    margin-bottom: 1rem;
    padding-bottom: 0.75rem;
    border-bottom: 2px solid var(--color-primary);
  }

  .sidebar-widget--highlight .sidebar-widget__header {
    border-bottom-color: rgba(255, 255, 255, 0.3);
  }

  .sidebar-widget__title {
    font-size: 0.9375rem;
    font-weight: 700;
    color: var(--color-secondary);
    margin: 0;
  }

  .sidebar-widget__subtitle {
    margin: 0.35rem 0 0;
    font-size: 0.75rem;
    color: var(--color-text-light);
    line-height: 1.45;
  }

  .sidebar-widget__text {
    font-size: 0.875rem;
    color: var(--color-text-light);
    margin: 0 0 1rem;
    line-height: 1.5;
  }

  .sidebar-widget__actions {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .sidebar-widget__actions .btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
  }

  .sidebar-widget__actions .btn--outline {
    border-color: rgba(255, 255, 255, 0.5);
    color: white;
  }

  .sidebar-widget__actions .btn--outline:hover {
    background: rgba(255, 255, 255, 0.1);
    border-color: white;
  }

  .sidebar-widget__phone {
    font-size: 0.8125rem;
    text-align: center;
    margin: 1rem 0 0;
    color: rgba(255, 255, 255, 0.85);
  }

  .sidebar-widget__phone a {
    color: white;
    font-weight: 600;
    text-decoration: none;
  }

  .sidebar-widget__back {
    display: block;
    text-align: center;
    font-size: 0.8125rem;
    color: var(--color-primary);
    text-decoration: none;
    padding-top: 1rem;
    border-top: 1px solid var(--color-border);
    margin-top: 0.5rem;
    transition: color 0.2s;
  }

  .sidebar-widget__back:hover {
    color: var(--color-secondary);
  }

  /* ENLACES EDITORIALES */
  .sidebar-links {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .sidebar-links__item {
    margin: 0;
  }

  .sidebar-links__link {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    padding: 0.75rem 0.875rem;
    border-radius: 8px;
    border: 1px solid var(--color-border);
    background: var(--color-white);
    text-decoration: none;
    transition: all 0.2s;
  }

  .sidebar-links__link:hover {
    border-color: var(--color-primary);
    background: #fef7f7;
  }

  .sidebar-links__title {
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--color-secondary);
    line-height: 1.35;
  }

  .sidebar-links__link:hover .sidebar-links__title {
    color: var(--color-primary);
  }

  .sidebar-links__meta {
    font-size: 0.6875rem;
    color: var(--color-text-light);
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }

  /* HUB ESTRATEGICO */
  .sidebar-hub {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .sidebar-hub__item {
    margin: 0;
  }

  .sidebar-hub__link {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    padding: 0.75rem 0.875rem;
    border-radius: 8px;
    background: linear-gradient(180deg, #f8fafc 0%, #eef2f7 100%);
    border: 1px solid #dbe4ef;
    text-decoration: none;
    transition: all 0.2s;
  }

  .sidebar-hub__link:hover {
    border-color: #9ab0c8;
    transform: translateY(-1px);
  }

  .sidebar-hub__title {
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--color-secondary);
    line-height: 1.35;
  }

  .sidebar-hub__desc {
    font-size: 0.75rem;
    color: var(--color-text-light);
    line-height: 1.4;
  }

  /* SIDEBAR TOC */
  .sidebar-toc__list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .sidebar-toc__link {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.5rem 0.75rem;
    border-radius: 6px;
    text-decoration: none;
    color: var(--color-text);
    background: var(--color-accent);
    transition: all 0.2s;
    font-size: 0.8125rem;
    line-height: 1.4;
  }

  .sidebar-toc__link:hover {
    background: var(--color-border);
    color: var(--color-primary);
  }

  .sidebar-toc__link.is-active {
    background: #fde9ec;
    color: var(--color-primary);
    border-left: 3px solid var(--color-primary);
    padding-left: calc(0.75rem - 3px);
  }

  .sidebar-toc__link.is-active .sidebar-toc__indicator {
    background: var(--color-primary);
  }

  .sidebar-toc__item--level-3 .sidebar-toc__link {
