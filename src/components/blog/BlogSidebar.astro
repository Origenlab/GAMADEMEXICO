<script is:inline>
  (() => {
    const sidebar = document.querySelector('.blog-sidebar');
    if (!sidebar) return;

    const tocLinks = Array.from(sidebar.querySelectorAll('.sidebar-toc__link'));
    if (!tocLinks.length) return;

    const clearActive = () => {
      tocLinks.forEach((link) => link.classList.remove('is-active'));
    };

    const setActiveById = (id) => {
      if (!id) return;
      clearActive();
      const active = sidebar.querySelector(`.sidebar-toc__link[href="#${id}"]`);
      if (active) active.classList.add('is-active');
    };

    const fromHash = () => {
      const id = window.location.hash.replace('#', '');
      if (id) setActiveById(id);
    };

    window.addEventListener('hashchange', fromHash);
    fromHash();

    const headingTargets = tocLinks
      .map((link) => {
        const targetId = (link.getAttribute('href') || '').replace('#', '');
        return document.getElementById(targetId);
      })
      .filter(Boolean);

    if (!('IntersectionObserver' in window) || !headingTargets.length) return;

    let activeHeading = '';
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            activeHeading = entry.target.id;
          }
        });
        if (activeHeading) setActiveById(activeHeading);
      },
      {
        rootMargin: '-30% 0px -55% 0px',
        threshold: 0,
      }
    );

    headingTargets.forEach((heading) => observer.observe(heading));
  })();
</script>
