---
// =============================================================================
// BlogChecklist — Lista de verificación técnica
// Uso: artículos de mantenimiento, inspección, cumplimiento normativo.
//      Renderiza una lista de ítems con checkboxes visuales (no interactivos).
// GEO: patrón altamente citable por sistemas de IA como lista estructurada.
// =============================================================================

interface ChecklistItem {
  texto: string;
  nota?: string;         // Aclaración opcional debajo del ítem
  critico?: boolean;     // Marca el ítem en rojo si es crítico de seguridad
}

interface Props {
  titulo?: string;                    // Título del bloque (opcional)
  items: ChecklistItem[];
  fuente?: string;                    // Referencia normativa e.g. "NFPA 25 · Cap. 13"
  frecuencia?: string;                // e.g. "Inspección mensual"
}

const { titulo, items, fuente, frecuencia } = Astro.props;
---

<div class="blog-checklist">
  {(titulo || frecuencia) && (
    <div class="blog-checklist__header">
      {frecuencia && <span class="blog-checklist__freq">{frecuencia}</span>}
      {titulo && <h3 class="blog-checklist__title">{titulo}</h3>}
    </div>
  )}
  <ul class="blog-checklist__list" role="list">
    {items.map((item) => (
      <li class={`blog-checklist__item${item.critico ? ' blog-checklist__item--critical' : ''}`}>
        <span class="blog-checklist__check" aria-hidden="true">
          {item.critico ? '⚠' : '✓'}
        </span>
        <span class="blog-checklist__content">
          <span class="blog-checklist__texto">{item.texto}</span>
          {item.nota && <span class="blog-checklist__nota">{item.nota}</span>}
        </span>
      </li>
    ))}
  </ul>
  {fuente && (
    <p class="blog-checklist__fuente">Referencia: {fuente}</p>
  )}
</div>

<style>
  .blog-checklist {
    margin: var(--spacing-xl) 0;
    border: 1px solid var(--color-border);
    border-radius: var(--border-radius);
    overflow: hidden;
    background: var(--color-white);
  }

  .blog-checklist__header {
    padding: var(--spacing-md) var(--spacing-lg);
    background: var(--color-secondary);
    display: flex;
    align-items: center;
    gap: var(--spacing-sm);
  }

  .blog-checklist__freq {
    display: inline-block;
    padding: 0.2rem 0.625rem;
    background: var(--color-primary);
    color: white;
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.75px;
    text-transform: uppercase;
    border-radius: 3px;
    flex-shrink: 0;
  }

  .blog-checklist__title {
    margin: 0;
    font-size: 0.9375rem;
    font-weight: 600;
    color: white;
  }

  .blog-checklist__list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .blog-checklist__item {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    padding: 0.75rem var(--spacing-lg);
    border-bottom: 1px solid var(--color-border);
  }

  .blog-checklist__item:last-child {
    border-bottom: none;
  }

  .blog-checklist__item--critical {
    background: #fff5f5;
  }

  .blog-checklist__check {
    flex-shrink: 0;
    width: 1.375rem;
    height: 1.375rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    font-size: 0.75rem;
    font-weight: 700;
    margin-top: 0.0625rem;
    background: color-mix(in srgb, var(--color-primary) 10%, white);
    color: var(--color-primary);
    border: 1px solid color-mix(in srgb, var(--color-primary) 25%, white);
  }

  .blog-checklist__item--critical .blog-checklist__check {
    background: #fee2e2;
    color: #dc2626;
    border-color: #fca5a5;
  }

  .blog-checklist__content {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .blog-checklist__texto {
    font-size: 0.9rem;
    color: var(--color-text);
    line-height: 1.5;
    font-weight: 500;
  }

  .blog-checklist__item--critical .blog-checklist__texto {
    color: #7f1d1d;
    font-weight: 600;
  }

  .blog-checklist__nota {
    font-size: 0.8125rem;
    color: var(--color-text-light);
    line-height: 1.4;
  }

  .blog-checklist__fuente {
    padding: var(--spacing-sm) var(--spacing-lg);
    margin: 0;
    font-size: 0.75rem;
    color: var(--color-text-light);
    background: var(--color-accent);
    border-top: 1px solid var(--color-border);
  }

  @media (max-width: 640px) {
    .blog-checklist__item,
    .blog-checklist__header,
    .blog-checklist__fuente {
      padding-left: var(--spacing-md);
      padding-right: var(--spacing-md);
    }
  }
</style>
