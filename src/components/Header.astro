---
import { getOptimizedImageUrl } from '../lib/images';
import { NAV_ITEMS, isDropdown } from '../data/navigation';
import type { NavItemDropdown, NavLink } from '../data/navigation';

interface Props {
  activePage?: string;
}

const { activePage = '' } = Astro.props;
const logoUrl = getOptimizedImageUrl('/img/gama-de-mexico.avif', {
  width: 400,
  quality: 82,
  strip: 'all',
});

// Modificadores CSS del mega-menu por ruta (servicios → 'services', blog → 'blog')
const MEGA_MENU_MODIFIER: Record<string, string> = {
  '/servicios': 'services',
  '/blog': 'blog',
};

/**
 * Para el mobile nav: busca un enlace "ver todos" que apunte a la raíz del item.
 * Si ninguna subcategoría lo tiene, usa el primaryLink del CTA.
 * Equipos → undefined (cada subcategoría va a su propia página, no a /equipos).
 */
function getMobileViewAll(item: NavItemDropdown): NavLink | undefined {
  for (const sub of item.subcategories) {
    if (sub.viewAll?.href === item.href) return sub.viewAll;
  }
  return item.cta?.primaryLink;
}
---

<a href="#main-content" class="skip-link">Saltar al contenido principal</a>

<header class="header" id="header" role="banner">
  <div class="container">

    <div class="header__logo">
      <a href="/" aria-label="Gama de México - Inicio">
        <img
          src={logoUrl}
          alt="Gama de México - Venta de Equipos Contra Incendios | Distribuidor Elkhart Brass"
          class="header__logo-img"
          width="200"
          height="60"
          loading="eager"
          decoding="async"
          fetchpriority="high"
        >
      </a>
    </div>

    <nav class="nav-desktop" role="navigation" aria-label="Navegación principal">
      <ul class="nav-desktop__list">
        {NAV_ITEMS.map((item) => {
          const slug = item.href.slice(1);
          if (isDropdown(item)) {
            const modifier = MEGA_MENU_MODIFIER[item.href];
            const megaClass = `mega-menu${modifier ? ` mega-menu--${modifier}` : ''}`;
            return (
              <li class="nav-desktop__item">
                <a
                  href={item.href}
                  class={`nav-desktop__link${activePage === slug ? ' nav-desktop__link--active' : ''}`}
                  aria-haspopup="true"
                  aria-expanded="false"
                >
                  {item.label} <span class="nav-desktop__arrow" aria-hidden="true">&#9660;</span>
                </a>
                <div class={megaClass} role="menu" aria-label={item.label}>
                  {item.subcategories.map((sub) => (
                    <div class="mega-menu__category">
                      <h3 class="mega-menu__title">{sub.title}</h3>
                      <ul class="mega-menu__list">
                        {sub.links.map((link) => (
                          <li><a href={link.href} class="mega-menu__link" role="menuitem">{link.label}</a></li>
                        ))}
                      </ul>
                      {sub.viewAll && (
                        <a href={sub.viewAll.href} class="mega-menu__view-all">{sub.viewAll.label} &rarr;</a>
                      )}
                    </div>
                  ))}
                  {item.cta && (
                    <div class="mega-menu__category mega-menu__category--cta">
                      <h3 class="mega-menu__title">{item.cta.title}</h3>
                      <p class="mega-menu__desc">{item.cta.description}</p>
                      <a href={item.cta.primaryLink.href} class="btn btn--primary btn--sm">{item.cta.primaryLink.label}</a>
                      {item.cta.secondaryHref && (
                        <a href={item.cta.secondaryHref} class="mega-menu__whatsapp" target="_blank" rel="noopener nofollow external">
                          {item.cta.secondaryLabel}
                        </a>
                      )}
                    </div>
                  )}
                </div>
              </li>
            );
          } else {
            return (
              <li class="nav-desktop__item">
                <a href={item.href} class="nav-desktop__link">{item.label}</a>
              </li>
            );
          }
        })}
      </ul>
    </nav>

    <a href="https://wa.me/5215565298240" class="btn btn--primary btn--sm header__cta" target="_blank" rel="noopener nofollow external" aria-label="Cotizar por WhatsApp">Cotizar por WhatsApp</a>

    <button class="hamburger" id="hamburger" aria-label="Abrir menú de navegación" aria-expanded="false" aria-controls="mobile-nav">
      <span class="hamburger__line"></span>
      <span class="hamburger__line"></span>
      <span class="hamburger__line"></span>
    </button>
  </div>
</header>

<div class="mobile-overlay" id="mobile-overlay" aria-hidden="true" inert></div>

<nav class="mobile-nav" id="mobile-nav" role="navigation" aria-label="Navegación móvil" aria-hidden="true" inert>
  <ul>
    {NAV_ITEMS.map((item) => {
      const slug = item.href.slice(1);
      if (isDropdown(item)) {
        const mobileViewAll = getMobileViewAll(item);
        return (
          <li class="mobile-nav__item">
            <button
              class="mobile-nav__link"
              aria-expanded="false"
              aria-controls={`mobile-submenu-${slug}`}
              id={`mobile-toggle-${slug}`}
            >
              {item.label} <span class="mobile-nav__arrow" aria-hidden="true">&#9660;</span>
            </button>
            <div
              class="mobile-nav__submenu"
              id={`mobile-submenu-${slug}`}
              role="region"
              aria-labelledby={`mobile-toggle-${slug}`}
            >
              {item.subcategories.map((sub) => (
                <div class="mobile-nav__subcategory">
                  <div class="mobile-nav__subtitle">{sub.title}</div>
                  {sub.links.map((link) => (
                    <a href={link.href} class="mobile-nav__sublink">{link.label}</a>
                  ))}
                </div>
              ))}
              {mobileViewAll && (
                <a href={mobileViewAll.href} class="mobile-nav__sublink mobile-nav__sublink--all">
                  {mobileViewAll.label} &rarr;
                </a>
              )}
            </div>
          </li>
        );
      } else {
        return (
          <li class="mobile-nav__item">
            <a href={item.href} class="mobile-nav__link">{item.label}</a>
          </li>
        );
      }
    })}
  </ul>
  <div class="mobile-nav__cta">
    <a href="https://wa.me/5215565298240" class="btn btn--primary" target="_blank" rel="noopener nofollow external" aria-label="Cotizar por WhatsApp">Cotizar por WhatsApp</a>
  </div>
</nav>

<style>
  /* Header */
  .header {
    background-color: var(--color-white);
    height: var(--header-height);
    position: sticky;
    top: 0;
    z-index: 1000;
    transition: box-shadow var(--transition-base);
    border-bottom: 1px solid var(--color-border);
  }

  .header--scrolled {
    box-shadow: var(--shadow-md);
  }

  .header .container {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 100%;
  }

  .header__logo {
    flex-shrink: 0;
  }

  .header__logo a {
    display: block;
  }

  .header__logo-img {
    width: 200px;
    height: auto;
    max-height: 60px;
    object-fit: contain;
  }

  .header__cta {
    display: none;
  }

  /* Desktop Navigation */
  .nav-desktop {
    display: none;
  }

  .nav-desktop__list {
    display: flex;
    align-items: center;
    gap: 0;
  }

  .nav-desktop__item {
    position: relative;
  }

  .nav-desktop__link {
    display: flex;
    align-items: center;
    gap: 0.3rem;
    padding: 0.5rem 1rem;
    font-size: var(--font-size-sm);
    font-weight: 500;
    color: var(--color-text);
    transition: color var(--transition-fast);
    white-space: nowrap;
  }

  .nav-desktop__link:hover,
  .nav-desktop__link--active {
    color: var(--color-primary);
  }

  .nav-desktop__arrow {
    font-size: 10px;
    transition: transform var(--transition-fast);
  }

  .nav-desktop__item:hover .nav-desktop__arrow {
    transform: rotate(180deg);
  }

  /* Mega Menu */
  .mega-menu {
    position: absolute;
    top: 100%;
    left: 50%;
    transform: translateX(-50%);
    background: var(--color-white);
    border: 1px solid var(--color-border);
    border-top: 3px solid var(--color-primary);
    border-radius: 0 0 var(--border-radius) var(--border-radius);
    box-shadow: var(--shadow-lg);
    padding: var(--spacing-lg);
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--spacing-lg);
    min-width: 720px;
    opacity: 0;
    visibility: hidden;
    transform: translateX(-50%) translateY(10px);
    transition: all var(--transition-base);
    pointer-events: none;
  }

  .nav-desktop__item:hover .mega-menu,
  .nav-desktop__item:focus-within .mega-menu {
    opacity: 1;
    visibility: visible;
    transform: translateX(-50%) translateY(0);
    pointer-events: auto;
  }

  .mega-menu__category {
    padding: var(--spacing-sm);
  }

  .mega-menu__title {
    font-size: var(--font-size-sm);
    font-weight: 700;
    color: var(--color-secondary);
    padding-bottom: 0.5rem;
    margin-bottom: 0.75rem;
    border-bottom: 2px solid var(--color-primary);
  }

  .mega-menu__list {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .mega-menu__link {
    font-size: var(--font-size-xs);
    color: var(--color-text-light);
    padding: 0.25rem 0;
    transition: color var(--transition-fast);
  }

  .mega-menu__link:hover {
    color: var(--color-primary);
  }

  .mega-menu__view-all {
    display: inline-block;
    margin-top: 0.75rem;
    font-size: var(--font-size-xs);
    font-weight: 600;
    color: var(--color-primary);
  }

  .mega-menu__view-all:hover {
    color: var(--color-primary-dark);
  }

  /* Mega Menu - Services variant (2 subcats + CTA = 3 cols) */
  .mega-menu--services {
    grid-template-columns: 1fr 1fr 1.2fr;
    min-width: 680px;
  }

  /* Mega Menu - Blog variant (1 subcat + CTA = 2 cols) */
  .mega-menu--blog {
    grid-template-columns: 1fr 1.2fr;
    min-width: 480px;
  }

  .mega-menu__category--cta {
    background: linear-gradient(135deg, rgba(196, 30, 58, 0.05) 0%, rgba(196, 30, 58, 0.1) 100%);
    border-radius: var(--border-radius);
    padding: var(--spacing-md);
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .mega-menu__desc {
    font-size: var(--font-size-xs);
    color: var(--color-text-light);
    line-height: 1.5;
  }

  .mega-menu__whatsapp {
    font-size: var(--font-size-xs);
    color: var(--color-text-light);
    margin-top: auto;
    transition: color var(--transition-fast);
  }

  .mega-menu__whatsapp:hover {
    color: #25D366;
  }

  /* Hamburger */
  .hamburger {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    width: 44px;
    height: 44px;
    gap: 5px;
    z-index: 1100;
  }

  .hamburger__line {
    width: 24px;
    height: 2px;
    background: var(--color-secondary);
    transition: all var(--transition-base);
    border-radius: 2px;
  }

  .hamburger--active .hamburger__line:nth-child(1) {
    transform: rotate(45deg) translate(5px, 5px);
  }

  .hamburger--active .hamburger__line:nth-child(2) {
    opacity: 0;
  }

  .hamburger--active .hamburger__line:nth-child(3) {
    transform: rotate(-45deg) translate(5px, -5px);
  }

  /* Mobile Overlay */
  .mobile-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.5);
    z-index: 1050;
    opacity: 0;
    visibility: hidden;
    transition: all var(--transition-base);
  }

  .mobile-overlay--active {
    opacity: 1;
    visibility: visible;
  }

  /* Mobile Navigation */
  .mobile-nav {
    position: fixed;
    top: 0;
    right: 0;
    width: 320px;
    max-width: 85vw;
    height: 100vh;
    background: var(--color-white);
    z-index: 1060;
    transform: translateX(100%);
    transition: transform var(--transition-slow);
    overflow-y: auto;
    padding: var(--spacing-2xl) var(--spacing-md) var(--spacing-lg);
  }

  .mobile-nav--active {
    transform: translateX(0);
  }

  .mobile-nav__item {
    border-bottom: 1px solid var(--color-border);
  }

  .mobile-nav__link {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--spacing-sm) 0;
    font-size: var(--font-size-base);
    font-weight: 500;
    color: var(--color-text);
  }

  .mobile-nav__link:hover {
    color: var(--color-primary);
  }

  .mobile-nav__arrow {
    transition: transform var(--transition-fast);
    font-size: 12px;
  }

  .mobile-nav__arrow--open {
    transform: rotate(180deg);
  }

  .mobile-nav__submenu {
    display: none;
    padding-bottom: var(--spacing-sm);
  }

  .mobile-nav__submenu--open {
    display: block;
  }

  .mobile-nav__subcategory {
    margin-bottom: var(--spacing-sm);
  }

  .mobile-nav__subtitle {
    font-size: var(--font-size-sm);
    font-weight: 700;
    color: var(--color-secondary);
    padding: 0.25rem 0;
  }

  .mobile-nav__sublink {
    display: block;
    font-size: var(--font-size-sm);
    color: var(--color-text-light);
    padding: 0.35rem 0 0.35rem var(--spacing-sm);
  }

  .mobile-nav__sublink:hover {
    color: var(--color-primary);
  }

  .mobile-nav__sublink--all {
    font-weight: 600;
    color: var(--color-primary);
    margin-top: var(--spacing-sm);
    border-top: 1px solid var(--color-border);
    padding-top: var(--spacing-sm);
  }

  .mobile-nav__sublink--all:hover {
    color: var(--color-primary-dark);
  }

  .mobile-nav__cta {
    margin-top: var(--spacing-lg);
  }

  .mobile-nav__cta .btn {
    width: 100%;
  }

  /* Desktop (1024px+) */
  @media (min-width: 1024px) {
    .nav-desktop {
      display: block;
    }

    .hamburger {
      display: none;
    }

    .header__cta {
      display: inline-flex;
      flex-shrink: 0;
    }
  }

  /* Large Desktop (1200px+) */
  @media (min-width: 1200px) {
    .mega-menu {
      grid-template-columns: repeat(3, 1fr);
      min-width: 780px;
    }
  }

  /* Print */
  @media print {
    .header {
      display: none !important;
    }
  }
</style>
