---
import Layout from '../layouts/Base.astro';
import SectionHeader from '../components/SectionHeader.astro';
import { getCollection } from 'astro:content';
import Faq from '../components/Faq.astro';
import { getBackgroundImageUrl } from '../lib/images';
import {
  buildProductCategorySchema,
  buildFAQSchema,
  buildBreadcrumbSchema,
  buildOrganizationSchema,
} from '../lib/seo';

const productos = (await getCollection('productos', ({ data }) => data.categoria === 'gabinetes-hidrantes')).sort((a, b) => a.data.orden - b.data.orden);
const cardImage = (path?: string) =>
  path
    ? getBackgroundImageUrl(path, {
        width: 960,
        quality: 78,
        strip: 'all',
      })
    : undefined;
const detailImage = (path: string) =>
  getBackgroundImageUrl(path, {
    width: 1280,
    quality: 80,
    strip: 'all',
  });
const faqItems = [
  {
    "pregunta": "¿Qué requisitos específicos establece la NOM-002-STPS-2010 para la instalación de gabinetes?",
    "respuesta": "La NOM-002-STPS-2010 establece tres parámetros clave para gabinetes contra incendios en centros de trabajo: (1) Radio de cobertura máximo de 30 metros medidos por camino real (no en línea recta), lo que significa que cualquier punto del área protegida debe quedar a no más de 30 m de un gabinete recorriendo pasillos y corredores reales. (2) Altura de instalación entre 1.0 y 1.5 metros medidos desde el nivel del piso terminado hasta el centro del gabinete, garantizando accesibilidad universal. (3) Despeje frontal mínimo de 0.9 metros para que no haya obstrucciones que impidan la apertura de puertas y el despliegue de manguera en caso de emergencia. Adicionalmente, los gabinetes deben ubicarse preferentemente en rutas de evacuación, corredores y vestíbulos de escalera, y su ubicación debe quedar documentada en el plano de protección contra incendios presentado a Protección Civil."
  },
  {
    "pregunta": "¿Cuál es la diferencia entre gabinete tipo 30ME, gabinete empotrado y estación de manguera con carrete oscilante?",
    "respuesta": "Son tres soluciones con casos de uso distintos: El gabinete tipo 30ME es el estándar más usado en México; la manguera se almacena doblada en zigzag sobre un rack fijo y debe desenrollarse manualmente antes de avanzar hacia el fuego. Es la opción más económica y funciona bien cuando el personal de brigada está capacitado. El gabinete empotrado se instala enrasado con la pared, ideal para edificios corporativos, hoteles y hospitales donde la estética es importante; misma funcionalidad que el 30ME pero con acabado arquitectónico. La estación de manguera con carrete oscilante monta la manguera en un carrete giratorio articulado: basta jalar la manguera en cualquier dirección para que el carrete gire y la manguera se despliegue sin enredos ni necesidad de desenrollar. Recomendada para plantas industriales, bodegas grandes y cualquier instalación donde la rapidez de respuesta es crítica o el personal puede no tener entrenamiento específico."
  },
  {
    "pregunta": "¿Qué componentes debe incluir un gabinete completo según NFPA 14 Clase II?",
    "respuesta": "NFPA 14 Clase II regula los sistemas de standpipe diseñados para uso por los ocupantes del edificio con manguera de 1.5 pulgadas. Un gabinete completo conforme a esta clase debe contener: (1) Manguera de doble chaqueta de 1.5\" (38 mm) de longitud entre 15 y 30 metros según alcance requerido, almacenada en rack o carrete; (2) Boquilla o chiflón combinado (recto/niebla) con control de apertura gradual; (3) Válvula angular de 1.5\" con volante de operación manual, instalada en la salida del gabinete para controlar el flujo; (4) Adaptadores o reducidores necesarios para conectar a la red hidráulica existente (típicamente de 2\" o 2.5\" a 1.5\"); y (5) Manómetro de glicerina donde la presión de trabajo supere los 100 PSI para verificar presión disponible antes de operar. Para gabinetes Clase I (uso exclusivo de bomberos, 2.5\") y Clase III (combinada), los componentes varían en diámetro. Todos los elementos deben incluirse en el inventario de verificación de Protección Civil."
  },
  {
    "pregunta": "¿Cuándo se requiere gabinete contra incendios y cuándo se requiere hidrante de banqueta?",
    "respuesta": "Son sistemas complementarios con aplicaciones claramente diferenciadas: Los gabinetes contra incendios (tipo 30ME, empotrado o estación) se instalan al interior de edificios —en pasillos, vestíbulos y naves industriales— para ser operados por los ocupantes o brigadas internas durante los primeros minutos del incendio. Son la primera línea de ataque. El hidrante de banqueta (o de columna) se instala en el exterior del predio, conectado a la red pública o privada de agua potable. Su función principal es abastecer a los vehículos del cuerpo de bomberos con caudales de 500 a 1,500 GPM para combate desde el exterior. NOM-002-STPS-2010 regula los gabinetes interiores; los hidrantes exteriores se rigen por las especificaciones del cuerpo de bomberos municipal y NFPA 24. Para proyectos industriales con riesgo alto, la normativa puede exigir ambos sistemas: gabinetes interiores para la brigada y red de hidrantes exteriores para bomberos."
  },
  {
    "pregunta": "¿Cómo se realiza la prueba hidrostática de mangueras según NFPA 1962 y cuándo se da de baja una manguera?",
    "respuesta": "NFPA 1962 establece que las mangueras de servicio deben someterse a prueba hidrostática anual a 250 PSI sostenidos durante 3 minutos. El procedimiento correcto: conectar la manguera completamente desplegada a una fuente de agua y presurizar gradualmente hasta 250 PSI; mantener la presión 3 minutos sin variaciones superiores a 5 PSI; durante la prueba inspeccionar visualmente todo el largo buscando protuberancias, fugas en acoplamiento, deformaciones en la chaqueta o exudaciones. Se debe dar de baja inmediata la manguera que presente: fuga o exudación en cualquier punto durante la prueba, acoplamiento con movimiento o giro respecto al cuerpo de manguera, chaqueta con cortes, abrasión profunda o decoloración extensa, o que haya estado expuesta a productos químicos, vapores corrosivos o calor intenso. Una manguera dada de baja debe retirarse del servicio, marcarse y no puede reinstalarse aunque se repare."
  },
  {
    "pregunta": "¿Qué requisitos de señalización establece la NOM-003-SEGOB-2011 para gabinetes contra incendios?",
    "respuesta": "La NOM-003-SEGOB-2011 regula la señalización de seguridad e higiene, incluyendo los equipos contra incendios. Para gabinetes establece: (1) Señal de identificación tipo pictograma con fondo rojo e ícono blanco de manguera y chiflón, colocada directamente sobre o encima del gabinete a altura visible desde al menos 10 metros en el eje del pasillo; (2) Señal de dirección (flecha direccional) en corredores cuando el gabinete no sea visible directamente desde una intersección; (3) Las señales deben ser fotoluminiscentes —capaces de brillar en oscuridad tras exposición a luz— para garantizar visibilidad en caso de corte eléctrico durante el siniestro; (4) El tamaño mínimo de señal se determina por la distancia de observación dividida entre el factor Z (generalmente 10), resultando en señales de mínimo 20×20 cm para pasillos estándar. La señalización completa es requisito de verificación de Protección Civil y su ausencia genera observaciones en el dictamen de seguridad."
  },
  {
    "pregunta": "¿Cuál es el proceso de verificación de Protección Civil para gabinetes en instalaciones industriales?",
    "respuesta": "La verificación de Protección Civil para gabinetes en industria se estructura en varias etapas: (1) Revisión documental: el verificador solicita el Programa Interno de Protección Civil (PIPC), planos de instalación contra incendios con ubicación de gabinetes y la bitácora de mantenimiento con fechas de inspección mensual, prueba hidrostática anual y revisión de válvulas. (2) Inspección física de cada gabinete: verifica despeje frontal mínimo de 0.9 m, altura de instalación entre 1.0 y 1.5 m, correcta señalización NOM-003-SEGOB-2011, inventario completo de componentes (manguera, boquilla, válvula angular) y funcionamiento de la válvula. (3) Prueba funcional: puede requerir apertura del gabinete y verificación de presión en la válvula angular. (4) Dictamen: si todo es correcto se emite el visto bueno; si hay observaciones, se otorga plazo (típicamente 30 días) para corregir. Para instalaciones con más de 100 trabajadores o actividades de riesgo alto, la verificación puede ser anual. Conservar los reportes de inspección mensual y de prueba hidrostática es esencial para pasar sin observaciones."
  }
];

const structuredData = [
  buildOrganizationSchema(),
  buildProductCategorySchema({
    name: 'Gabinetes e Hidrantes Contra Incendio NOM-002',
    description: 'Gabinetes e hidrantes contra incendio. Tipo 30ME, empotrado, estación de manguera e hidrante de banqueta. Cumple NOM-002-STPS y NFPA 14 en México.',
    image: '/img/gabinetes-hidrantes-contra-incendios/gabinete-contra-incendios-tipo-30me-manguera-chiflon-01.avif',
    url: '/gabinetes-hidrantes-contra-incendios',
    category: 'Gabinetes e Hidrantes Contra Incendios',
    brand: 'Gama de México',
    reviews: [
      {
        author: 'Arq. Jorge Medina, Director de Obra, Desarrolladora GIM Inmobiliaria Querétaro',
        body: 'Instalamos 48 gabinetes tipo 30ME en un desarrollo de uso mixto en Querétaro. Gama de México coordinó entregas por etapa de obra y cada gabinete venía con manguera, boquilla y documentación para protección civil. Cero observaciones en la verificación final.',
        date: '2025-07-12',
      },
      {
        author: 'Lic. María Fernanda Casas, Coordinadora HSE, CEMEX Planta Monterrey',
        body: 'Reemplazamos gabinetes obsoletos en nave de producción con estaciones de manguera de carrete oscilante. El despliegue es mucho más rápido para las brigadas y el mantenimiento es mínimo. Buena asesoría de Gama para elegir entre gabinete fijo y estación.',
        date: '2026-01-15',
      },
    ],
    ratingCount: 47,
    reviewCount: 47,
  }),
  buildBreadcrumbSchema([
    { name: 'Inicio', url: '/' },
    { name: 'Equipos', url: '/equipos' },
    { name: 'Gabinetes e Hidrantes', url: '/gabinetes-hidrantes-contra-incendios' },
  ]),
  buildFAQSchema(faqItems),
];
---

<Layout
  title="Gabinetes Contra Incendios Tipo 30ME NOM-002 | NFPA 14 | México"
  description="Gabinetes tipo 30ME, empotrados y estaciones de manguera NOM-002-STPS-2010. Cumplimiento NFPA 14. Hidrantes UL 246. Documentación para Protección Civil."
  activePage="equipos"
  structuredData={structuredData}
  ogImage="/img/categorias/gabinetes-hidrantes-hero.avif"
  heroTitle="Gabinetes e Hidrantes"
  heroBadge="Equipos Contra Incendios"
  heroIntro="Gabinetes tipo 30ME, empotrados, estaciones de manguera con carrete oscilante e hidrantes de banqueta. Cumplimiento NOM-002-STPS-2010 y NFPA 14. Documentación completa para Protección Civil."
  heroShowRightContent={true}

  showLeadCapture={true}
>
  <Fragment slot="hero-content">
    <p>Distribuimos gabinetes e hidrantes contra incendios certificados para edificios comerciales, instalaciones industriales y desarrollos residenciales. Nuestra línea incluye gabinetes tipo 30ME equipados con manguera y chiflón, gabinetes empotrados en acero inoxidable, estaciones de manguera con carrete oscilante e hidrantes de banqueta certificados UL 246.</p>
    <p>Todos nuestros equipos cumplen con NOM-002-STPS-2010 y NFPA 14, proporcionando la primera línea de defensa para atacar incendios en sus etapas iniciales. Te asesoramos en el diseño del sistema completo, incluyendo ubicación estratégica, espaciamiento y selección del equipamiento correcto.</p>
  </Fragment>

  <!-- PRODUCTOS DINAMICOS -->
  <section class="categories" id="gabinetes">
    <div class="container">
      <SectionHeader
        titulo="Tipos de Gabinete Incendio Hidrante y Manguera"
        subtitulo="Selecciona un tipo de gabinete para conocer especificaciones técnicas y solicitar cotización"
        parrafo1="Te mostramos opciones para gabinetes tipo 30ME, gabinetes empotrados, estaciones de manguera e hidrantes de banqueta con enfoque en cumplimiento NOM-002-STPS y NFPA 14. Cada alternativa está pensada para facilitar selección técnica, integración al sistema hidráulico y operación segura en emergencia."
        parrafo2="Nuestro equipo te ayuda a definir el modelo correcto según tipo de inmueble, nivel de riesgo, presión disponible, materiales de fabricación y requerimientos de inspección. Así obtienes un gabinete o hidrante alineado con normativa, disponibilidad real y tiempos de entrega para tu proyecto."
      />
      <div class="categories__grid">
        {productos.map((producto) => (
          <article class="category-card">
            <div
              class="category-card__image"
              role="img"
              aria-label={producto.data.title}
              style={producto.data.imagen ? `background-image: url('${cardImage(producto.data.imagen)}'); background-size: cover; background-position: center;` : undefined}
            ></div>
            <div class="category-card__body">
              <h3 class="category-card__title">{producto.data.title}</h3>
              <p class="category-card__sub">{producto.data.description}</p>
              <ul class="category-card__products">
                {producto.data.material && <li class="category-card__product">{producto.data.material}</li>}
                {producto.data.flujo && <li class="category-card__product">{producto.data.flujo}</li>}
                {producto.data.certificaciones && producto.data.certificaciones.length > 0 && <li class="category-card__product">Certificaciones: {producto.data.certificaciones.join(', ')}</li>}
                <li class="category-card__product">Marca: {producto.data.marca}</li>
              </ul>
              <div class="category-card__ctas">
                <a href={`/productos/${producto.id}`} class="btn btn--primary btn--sm">Ver especificaciones</a>
                <a href="#cotizar" class="btn btn--outline btn--sm">Cotizar</a>
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- SERVICE DETAILS -->
  <section class="service-details" aria-labelledby="service-details-title">
    <div class="container">
      <div class="section-header">
        <h2 id="service-details-title" class="section-title">Detalle de Cada Gabinete Incendio Hidrante y Equipo</h2>
      </div>

      <div class="service-detail" id="detalle-30me">
        <div class="service-detail__content">
          <h3 class="service-detail__title">Gabinete Contra Incendios Tipo 30ME</h3>
          <p class="service-detail__text">El <strong>gabinete tipo 30ME</strong> es el estándar en instalaciones comerciales e industriales en México. Se fabrica en lámina de acero calibre 22 con acabado en pintura electrostática roja RAL 3000, e incluye manguera de 1.5" x 30 metros, válvula angular de 1.5", rack portamanguera y chiflón de tres posiciones. Cumple con NOM-002-STPS-2010. Venta con precio competitivo y cotización inmediata.</p>
          <ul class="service-detail__list">
            <li class="service-detail__list-item">Material: Lámina de acero calibre 22</li>
            <li class="service-detail__list-item">Acabado: Pintura electrostática roja RAL 3000</li>
            <li class="service-detail__list-item">Manguera: 1.5" x 30 metros tipo I o II</li>
            <li class="service-detail__list-item">Válvula: Angular de bronce 1.5" con volante</li>
            <li class="service-detail__list-item">Chiflón: Tres posiciones (chorro, neblina, cerrado)</li>
            <li class="service-detail__list-item">Certificación: NOM-002-STPS-2010</li>
          </ul>
          <div class="service-detail__ctas">
            <a href="#cotizar" class="btn btn--primary">Cotizar gabinete 30ME</a>
            <a href="/gabinetes/tipo-30me" class="btn btn--outline">Ver catálogo completo →</a>
          </div>
        </div>
        <div class="service-detail__image" role="img" aria-label="Gabinete contra incendios con hidrante instalado en edificio" style={`background-image: url('${detailImage('/img/gabinetes-hidrantes/producto-gabinete-hidrante-instalado.avif')}'); background-size: cover; background-position: center;`}></div>
      </div>

      <div class="service-detail" id="detalle-hidrante">
        <div class="service-detail__content">
          <h3 class="service-detail__title">Hidrante de Banqueta Certificado</h3>
          <p class="service-detail__text">Los <strong>hidrantes de banqueta</strong> son puntos de conexión externos para el cuerpo de bomberos. Fabricados en hierro dúctil ASTM A-536, soportan presiones de trabajo de 250-350 PSI. Incluyen dos salidas laterales de 2.5" y una salida superior de 4.5" con roscas NST. Certificación <strong>UL 246</strong>. Costo competitivo con documentación completa.</p>
          <ul class="service-detail__list">
            <li class="service-detail__list-item">Material: Hierro dúctil ASTM A-536</li>
            <li class="service-detail__list-item">Presión de trabajo: 250-350 PSI</li>
            <li class="service-detail__list-item">Salidas laterales: 2 de 2.5" con roscas NST</li>
            <li class="service-detail__list-item">Salida superior: 1 de 4.5" con rosca NST</li>
            <li class="service-detail__list-item">Válvula: Apertura total con indicador de posición</li>
            <li class="service-detail__list-item">Certificación: UL 246</li>
          </ul>
          <div class="service-detail__ctas">
            <a href="#cotizar" class="btn btn--primary">Cotizar hidrante de banqueta</a>
            <a href="/gabinetes/hidrantes" class="btn btn--outline">Ver catálogo completo →</a>
          </div>
        </div>
        <div class="service-detail__image" role="img" aria-label="Hidrante exterior urbano instalado para protección contra incendios" style={`background-image: url('${detailImage('/img/producto-hidrante-exterior-urbano.avif')}'); background-size: cover; background-position: center;`}></div>
      </div>

      <div class="service-detail" id="detalle-empotrado">
        <div class="service-detail__content">
          <h3 class="service-detail__title">Gabinete Empotrado Contra Incendios</h3>
          <p class="service-detail__text">Los <strong>gabinetes empotrados</strong> se instalan al ras de la pared, proporcionando solución estética sin perder funcionalidad. Disponibles en acero al carbón o acero inoxidable T430 con acabado espejo. Ideales para hoteles, hospitales y edificios corporativos. Incluyen equipamiento completo. Certificación NOM-002-STPS-2010. Precio disponible bajo cotización.</p>
          <ul class="service-detail__list">
            <li class="service-detail__list-item">Instalación: Empotrado al ras de pared</li>
            <li class="service-detail__list-item">Materiales: Acero al carbón o inoxidable T430</li>
            <li class="service-detail__list-item">Acabado: Pintura electrostática o espejo pulido</li>
            <li class="service-detail__list-item">Equipamiento: Manguera, válvula y chiflón completo</li>
            <li class="service-detail__list-item">Aplicaciones: Hoteles, hospitales, corporativos</li>
            <li class="service-detail__list-item">Normativa: NOM-002-STPS-2010</li>
          </ul>
          <div class="service-detail__ctas">
            <a href="#cotizar" class="btn btn--primary">Cotizar gabinete empotrado</a>
            <a href="/gabinetes/empotrado" class="btn btn--outline">Ver catálogo completo →</a>
          </div>
        </div>
        <div class="service-detail__image" role="img" aria-label="Instalación de sistema hidrante contra incendios en edificio" style={`background-image: url('${detailImage('/img/instalacion-sistema-hidrante-edificio.avif')}'); background-size: cover; background-position: center;`}></div>
      </div>

      <div class="service-detail" id="detalle-estacion">
        <div class="service-detail__content">
          <h3 class="service-detail__title">Estación de Manguera con Carrete</h3>
          <p class="service-detail__text">Las <strong>estaciones de manguera</strong> con carrete oscilante 180° permiten despliegue automático sin enredos. Incluyen carrete giratorio de acero, manguera de 1.5" x 30 metros y chiflón regulable. Ideales para respuesta rápida. Cumplen con NFPA 14 Clase II y III. Beneficios de operación sencilla. Cotización inmediata disponible.</p>
          <ul class="service-detail__list">
            <li class="service-detail__list-item">Carrete: Oscilante 180° con giro libre</li>
            <li class="service-detail__list-item">Despliegue: Automático sin enredos</li>
            <li class="service-detail__list-item">Manguera: 1.5" x 30 metros alta presión</li>
            <li class="service-detail__list-item">Chiflón: Regulable con palanca de control</li>
            <li class="service-detail__list-item">Montaje: Gabinete sobrepuesto o empotrado</li>
            <li class="service-detail__list-item">Normativa: NFPA 14 Clase II/III</li>
          </ul>
          <div class="service-detail__ctas">
            <a href="#cotizar" class="btn btn--primary">Cotizar estación de manguera</a>
            <a href="/gabinetes/estaciones" class="btn btn--outline">Ver catálogo completo →</a>
          </div>
        </div>
        <div class="service-detail__image" role="img" aria-label="Estación de Manguera con Carrete" style={`background-image: url('${detailImage('/img/gabinetes-hidrantes/gabinete-manguera-carrete-detalle.avif')}'); background-size: cover; background-position: center;`}></div>
      </div>

    </div>
  </section>

  <!-- TRUST -->
  <section class="trust" aria-labelledby="trust-title">
    <div class="container">
      <div class="section-header">
        <h2 id="trust-title" class="section-title">Por Qué Comprar Gabinetes e Hidrantes en Gama de México</h2>
        <p class="section-subtitle">Calidad certificada, inventario disponible y asesoría técnica especializada</p>
      </div>
      <div class="trust__grid">
        <div class="trust__item">
          <h3 class="trust__item-title">Certificaciones NOM y NFPA</h3>
          <p class="trust__item-desc">Todos nuestros gabinetes e hidrantes cuentan con certificación NOM-002-STPS-2010, UL 246 y NFPA 14, garantizando cumplimiento normativo total.</p>
        </div>
        <div class="trust__item">
          <h3 class="trust__item-title">Venta con Stock Inmediato</h3>
          <p class="trust__item-desc">Inventario permanente de gabinetes 30ME, hidrantes y estaciones de manguera para venta inmediata y entrega cerca de tu ubicación.</p>
        </div>
        <div class="trust__item">
          <h3 class="trust__item-title">Cotización y Precio Competitivo</h3>
          <p class="trust__item-desc">Cotización inmediata con precio y costo competitivo. Precios especiales por volumen para proyectos de gran escala y compras recurrentes.</p>
        </div>
        <div class="trust__item">
          <h3 class="trust__item-title">Asesoría Técnica Profesional</h3>
          <p class="trust__item-desc">Experiencia de ingenieros especializados para seleccionar el gabinete o hidrante correcto según tu instalación y normativa aplicable.</p>
        </div>
        <div class="trust__item">
          <h3 class="trust__item-title">Documentación para Protección Civil</h3>
          <p class="trust__item-desc">Fichas técnicas, certificados, planos de instalación y memorias de cálculo para cumplimiento de protección civil y auditorías.</p>
        </div>
        <div class="trust__item">
          <h3 class="trust__item-title">Soporte Post-Venta y Refacciones</h3>
          <p class="trust__item-desc">Capacitación en uso correcto, servicio de mantenimiento preventivo y venta de refacciones originales con garantía.</p>
        </div>
      </div>

      <div class="trust__testimonials-header">
        <h3 class="trust__testimonials-title">Lo que dicen nuestros clientes</h3>
        <p class="trust__testimonials-subtitle">Empresas de todo México confían en nuestros gabinetes e hidrantes</p>
      </div>
      <div class="trust__testimonials">
        <blockquote class="testimonial">
          <div class="testimonial__stars" aria-label="5 estrellas">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
          <p class="testimonial__text">"Instalamos 24 gabinetes 30ME en nuestra planta industrial. Excelente calidad, llegaron completos y certificados. Pasamos la inspección de protección civil sin observaciones. Precio muy competitivo."</p>
          <div class="testimonial__author">
