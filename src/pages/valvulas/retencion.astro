---
import Layout from '../../layouts/Base.astro';
import '../../styles/subcategory.css';
import { getCollection } from 'astro:content';
import SubcategoryProductCard from '../../components/SubcategoryProductCard.astro';
import ProductSidebar from '../../components/ProductSidebar.astro';
import RelatedProductsGrid from '../../components/RelatedProductsGrid.astro';
import CotizacionForm from '../../components/CotizacionForm.astro';
import Faq from '../../components/Faq.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import { buildProductCategorySchema, buildBreadcrumbSchema, buildFAQSchema, buildOrganizationSchema } from '../../lib/seo';


// 1. Obtener todos los productos de la categoría válvulas
const todosProductos = (await getCollection('productos', ({ data }) =>
  data.categoria === 'valvulas'
)).sort((a, b) => a.data.orden - b.data.orden);

// 2. Filtrar por subcategoría: Válvula de Retención (Check)
const productosSubcategoria = todosProductos.filter(p => p.data.subcategoria === 'retencion');

// 3. Obtener otros productos para sección de relacionados
const otrosProductos = todosProductos.filter(p => !productosSubcategoria.includes(p));

// 4. Definir subcategorías para navegación
const subcategorias = [
  { slug: 'compuerta', nombre: 'Válvula de Compuerta OS&Y', descripcion: 'Aislamiento en líneas principales', activo: false },
  { slug: 'globo', nombre: 'Válvula de Globo', descripcion: 'Control preciso de presión', activo: false },
  { slug: 'retencion', nombre: 'Válvula de Retención', descripcion: 'Prevención de reflujo', activo: true },
  { slug: 'mariposa', nombre: 'Válvula Mariposa', descripcion: 'Apertura rápida 90°', activo: false },
];
const faqItems = [
  { pregunta: '¿Para qué se usa una válvula de retención en sistemas contra incendios?', respuesta: 'La válvula de retención (check valve) permite el flujo de agua en una sola dirección. En sistemas contra incendios se instala para evitar el retorno de agua desde el sistema al suministro municipal (prevención de contaminación), para mantener la presión en sistemas de agua a presión (pre-acción y diluvio) y en la descarga de bombas para evitar el flujo inverso cuando la bomba para.' },
  { pregunta: '¿Qué tipo de válvula de retención se usa en el suministro municipal?', respuesta: 'Para la conexión entre el suministro municipal de agua y un sistema contra incendios, NFPA 13 requiere un ensamble de prevención de retroceso (backflow preventer) que puede incluir una válvula de retención de doble check o un reductor de presión con check. El tipo específico depende del nivel de riesgo definido por la autoridad local del agua. Asesoramos en la selección e instalación de estos dispositivos.' },
  { pregunta: '¿Con qué frecuencia se debe probar una válvula de retención?', respuesta: 'Conforme a NFPA 25, las válvulas de retención en sistemas contra incendios se deben probar anualmente para verificar que cierran correctamente y no presentan fugas inversas. Los ensambles de prevención de retroceso conectados al suministro municipal tienen requisitos adicionales de prueba definidos por la autoridad local del agua, generalmente también anuales.' },
];

const structuredData = [
  buildOrganizationSchema(),
  buildProductCategorySchema({
    name: 'Válvula de Retención para Sistemas Contra Incendios',
    description: 'Válvula de retención check para sistemas contra incendios. Prevención de retroceso. Bronce y hierro. NFPA 13 y 25. México.',
    image: '/img/valvulas-contra-incendios/valvula-check-swing-bridada-contra-incendios-ambiente-bombas-27.avif',
    url: '/valvulas/retencion',
    category: 'Válvulas Contra Incendios',
    brand: 'Elkhart Brass',
    reviewAuthor: 'Ing. Carlos Mendoza',
    reviewBody: 'Excelente calidad y respaldo técnico de Gama de México. Equipos certificados con entrega puntual.',
    reviewDate: '2025-03-15',
    ratingCount: 32,
    reviewCount: 32,
  }),
  buildBreadcrumbSchema([
    { name: 'Inicio', url: '/' },
    { name: 'Equipos', url: '/equipos' },
    { name: 'Válvulas Contra Incendios', url: '/valvulas-contra-incendios' },
  ]),
  buildFAQSchema(faqItems),
];

---

<Layout
  structuredData={structuredData}
  title="Válvula Retención Check | Venta México"
  description="Válvula retención check tipo columpio para tubería. Sello EPDM, presión 175-350 PSI. Certificadas UL 312 y FM. Control de flujo. México."
  activePage="equipos"
  heroTitle="Válvula de Retención"
  heroIntro="Válvulas check para prevención de reflujo en sistemas contra incendio. Su mecanismo de clapeta o disco permite el flujo en una sola dirección, protegiendo bombas, medidores y equipos sensibles del contraflujo que puede ocurrir por diferencias de presión."
  heroBadge="Válvulas Contra Incendios"
  heroMetrics={[
    { valor: "350", texto: "PSI máxima" },
    { valor: "Columpio/Disco", texto: "Tipos" },
    { valor: "UL 312", texto: "Certificación" }
  ]}
  heroPrimaryText="Ver Catálogo"
  heroPrimaryLink="#catalogo"
  heroSecondaryText="Solicitar Cotización"
  heroSecondaryLink="#cotizar"
  heroShowRightContent={true}
>

  <!-- HERO CONTENT -->
  <Fragment slot="hero-content">
    <p>La <strong>válvula de retención</strong> (check valve) es componente esencial en sistemas contra incendio para prevenir el reflujo de agua que puede dañar bombas, contaminar suministros o causar lecturas erróneas en medidores de flujo. Disponibles en configuración de columpio (swing check) para flujo horizontal o disco con resorte (spring check) para instalación en cualquier orientación. El cierre automático por gravedad o resorte garantiza protección inmediata ante caídas de presión.</p>
    <p><strong>Gama de México</strong> distribuye válvulas de retención certificadas UL 312 y FM en hierro dúctil, bronce y acero inoxidable. Ofrecemos conexiones bridadas, roscadas y ranuradas en diámetros de 2" a 12". Aplicaciones típicas incluyen: descarga de bombas contra incendio, conexión de siamesas, retorno de sistemas de prueba y protección de líneas de suministro municipal.</p>
  </Fragment>
  <!-- BREADCRUMB -->
  <Breadcrumb />



  <!-- CONTENT + SIDEBAR -->
  <section class="subcat-content">
    <div class="container">
      <div class="subcat-layout">

        <!-- MAIN CONTENT -->
        <main class="subcat-main">
          <div class="catalog-header">
            <div class="catalog-header__text">
              <h2 class="catalog-header__title">Catálogo de Válvulas de Retención Check</h2>
              <p class="catalog-header__desc">Selecciona el modelo que mejor se adapte a tu sistema contra incendios</p>
            </div>
            <div class="catalog-header__count">
              <span class="catalog-header__number">{productosSubcategoria.length}</span>
              <span class="catalog-header__label">producto{productosSubcategoria.length !== 1 ? 's' : ''}</span>
            </div>
          </div>

          <!-- Products Grid -->
          <div class="categories__grid">
            {productosSubcategoria.map((producto) => (
              <SubcategoryProductCard
                title={producto.data.title}
                description={producto.data.description}
                brand={producto.data.marca}
                image={producto.data.imagen}
                productSlug={producto.id}
                flow={producto.data.flujo}
                material={producto.data.material}
                certifications={producto.data.certificaciones}
              />
            ))}
          </div>

          <!-- Empty State -->
          {productosSubcategoria.length === 0 && (
            <div class="catalog-empty">
              <div class="catalog-empty__icon">🔍</div>
              <h3 class="catalog-empty__title">Próximamente más opciones</h3>
              <p class="catalog-empty__text">Estamos agregando más válvulas de retención de diferentes marcas y especificaciones. Mientras tanto, solicita una cotización personalizada.</p>
              <a href="#cotizar" class="btn btn--primary">Solicitar Cotización</a>
            </div>
          )}

          <!-- Tech Info -->
          <div class="tech-info">
            <h3 class="tech-info__title">Especificaciones Técnicas de Válvulas de Retención</h3>
            <div class="tech-info__grid">
              <div class="tech-info__item">
                <span class="tech-info__label">Presión de trabajo</span>
                <span class="tech-info__value">175-350 PSI</span>
              </div>
              <div class="tech-info__item">
                <span class="tech-info__label">Relación prueba</span>
                <span class="tech-info__value">2:1</span>
              </div>
              <div class="tech-info__item">
                <span class="tech-info__label">Diámetros disponibles</span>
                <span class="tech-info__value">2" a 12"</span>
              </div>
              <div class="tech-info__item">
                <span class="tech-info__label">Tipo</span>
                <span class="tech-info__value">Columpio (Swing)</span>
              </div>
              <div class="tech-info__item">
                <span class="tech-info__label">Material cuerpo</span>
                <span class="tech-info__value">Hierro fundido / dúctil</span>
              </div>
              <div class="tech-info__item">
                <span class="tech-info__label">Instalación</span>
                <span class="tech-info__value">Horizontal o vertical</span>
              </div>
            </div>
          </div>

          <!-- CTA Final -->
          <div class="subcat-cta-final">
            <div class="subcat-cta-final__content">
              <h3 class="subcat-cta-final__title">¿No encuentras el diámetro o configuración que necesitas?</h3>
              <p class="subcat-cta-final__desc">Tenemos acceso al catálogo completo de Elkhart Brass. Contáctanos para válvulas con puertos de manómetro, asientos especiales o diámetros grandes.</p>
            </div>
            <a href="#cotizar" class="btn btn--primary">Solicitar Cotización Especial</a>
          </div>
        </main>

        <!-- SIDEBAR -->
        <ProductSidebar
          navTitulo="Tipos de Válvulas"
          subcategorias={subcategorias}
          baseUrl="/valvulas"
          backLinkHref="/valvulas-contra-incendios"
          backLinkTexto="Ver todas las válvulas"
          certificaciones={[
            { siglas: "FM", nombre: "Factory Mutual" },
            { siglas: "UL", nombre: "UL Listed" },
            { siglas: "NOM", nombre: "NOM-002-STPS" }
          ]}
          marcas={["Nibco", "Kennedy", "Milwaukee", "Apollo"]}
          aplicaciones={[
            "Prevención de reflujo",
            "Sistemas de bombeo",
            "Redes contra incendio",
            "Protección de equipos"
          ]}
          productosRelacionados={[
            { href: "/gabinetes-hidrantes-contra-incendios", nombre: "Gabinetes e Hidrantes" },
            { href: "/mangueras-contra-incendios", nombre: "Mangueras Contra Incendios" },
            { href: "/boquillas-contra-incendios", nombre: "Boquillas Contra Incendios" },
            { href: "/conexiones-herrajes-contra-incendios", nombre: "Conexiones y Herrajes" }
          ]}
        />

      </div>
    </div>
  </section>

  <!-- RELATED PRODUCTS -->
  <RelatedProductsGrid
    titulo="Otras Válvulas Contra Incendios"
    subtitulo="Explora más opciones para tu sistema de protección"
    productos={otrosProductos}
    maxProductos={3}
    verTodosLink="/valvulas-contra-incendios"
    verTodosTexto="Ver todas las válvulas"
  />

  <CotizacionForm
    titulo="Cotiza Válvulas de Retención"
    tipoEquipo="Válvulas"
    pagina="Válvulas de Retención"
  />


  <!-- FAQ -->
  <section class="faq-section" id="faq" aria-labelledby="faq-title">
    <div class="container">
      <h2 id="faq-title" class="section-title">Preguntas Frecuentes</h2>
      <Faq items={faqItems} id="faq" />
    </div>
  </section>

</Layout>

<style>
  .faq-section {
    padding: var(--spacing-2xl, 4rem) 0;
    background: var(--color-surface, #fff);
  }
  .faq-section .section-title {
    font-size: var(--text-2xl, 1.75rem);
    font-weight: 700;
    margin-bottom: 2rem;
    text-align: center;
  }
</style>
