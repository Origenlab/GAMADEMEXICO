---
import Layout from '../layouts/Base.astro';
import { getCollection } from 'astro:content';
import Faq from '../components/Faq.astro';
import { getBackgroundImageUrl } from '../lib/images';
import {
  buildProductCategorySchema,
  buildFAQSchema,
  buildBreadcrumbSchema,
  buildOrganizationSchema,
} from '../lib/seo';

const productos = (await getCollection('productos', ({ data }) => data.categoria === 'valvulas')).sort((a, b) => a.data.orden - b.data.orden);
const cardImage = (path?: string) =>
  path
    ? getBackgroundImageUrl(path, {
        width: 960,
        quality: 78,
        strip: 'all',
      })
    : undefined;
const detailImage = (path: string) =>
  getBackgroundImageUrl(path, {
    width: 1280,
    quality: 80,
    strip: 'all',
  });
const faqItems = [
  {
    "pregunta": "¿Qué tipos de válvulas contra incendios venden en Gama de México?",
    "respuesta": "Ofrecemos cuatro tipos principales de válvulas para sistemas contra incendio: 1) Válvulas de compuerta OS&Y (Outside Screw and Yoke) con vástago exterior para indicación visual de posición, ideales para líneas principales; 2) Válvulas de globo en configuraciones angular y recta para control preciso de presión y flujo; 3) Válvulas de retención tipo swing para prevención automática de retorno de flujo en líneas de bombas; y 4) Válvulas mariposa indicadoras con tamper switch para apertura rápida en diámetros grandes. Todas cuentan con certificaciones UL y FM, fabricación en hierro dúctil o bronce, y documentación técnica completa del fabricante."
  },
  {
    "pregunta": "¿Cuál es la diferencia entre una válvula OS&Y y una válvula común?",
    "respuesta": "La principal diferencia está en el vástago exterior. En una válvula OS&Y (Outside Screw and Yoke), el vástago roscado se extiende hacia afuera del cuerpo cuando la válvula se abre y se retrae cuando se cierra, permitiendo verificación visual instantánea de la posición sin necesidad de operarla. Esto cumple con los requisitos de NFPA 13 que exige supervisión visual o electrónica en válvulas de control principal. Además, las válvulas OS&Y para sistemas contra incendio están fabricadas con materiales específicos (hierro dúctil o bronce), certificadas para presiones de trabajo de 175 a 350 PSI, y cuentan con listado UL/FM que garantiza cumplimiento con estándares de la industria. Las válvulas comunes de plomería no cumplen estos requisitos y no son aptas para aplicaciones de protección contra incendios."
  },
  {
    "pregunta": "¿Qué presión de trabajo soportan las válvulas contra incendios?",
    "respuesta": "Las válvulas contra incendios están disponibles en diferentes rangos de presión según la aplicación: 175 PSI (aplicaciones residenciales y comerciales ligeras), 200 PSI (edificios comerciales estándar), 250 PSI (instalaciones industriales), y 300-350 PSI (aplicaciones de alto riesgo y sistemas de bombeo de alta presión). La presión de trabajo debe seleccionarse considerando la presión máxima del sistema más un margen de seguridad. Por ejemplo, si tu sistema opera normalmente a 150 PSI, debes especificar válvulas con clasificación mínima de 200 PSI. Nuestros asesores técnicos te ayudan a determinar la especificación correcta según el diseño hidráulico de tu proyecto y los requisitos de la bomba contra incendio."
  },
  {
    "pregunta": "¿Para qué sirve una válvula de retención (check valve) en sistemas contra incendio?",
    "respuesta": "La válvula de retención previene el retorno de flujo en el sistema, protegiendo equipos críticos y manteniendo la dirección correcta del agua. Su aplicación principal es en las líneas de descarga de bombas contra incendio: cuando la bomba arranca, el agua fluye hacia el sistema y el disco interno de la válvula se abre automáticamente; cuando la bomba se detiene, el disco se cierra por gravedad evitando que el agua regrese y dañe los impulsores, sellos mecánicos y motor de la bomba. También se utilizan en conexiones de bomberos (FDC) para evitar que el agua del sistema drene hacia la conexión exterior, y en sistemas de tanques elevados para prevenir vaciado por gravedad. El diseño tipo swing opera completamente por gravedad —sin requerir electricidad ni actuación manual— y el sello EPDM garantiza cierre hermético incluso después de años de servicio."
  },
  {
    "pregunta": "¿Qué diámetros de válvulas contra incendios tienen disponibles?",
    "respuesta": "Manejamos un rango completo de diámetros para cubrir todas las aplicaciones en sistemas contra incendio: 2.5\" y 3\" para derivaciones y gabinetes contra incendio, 4\" y 6\" para redes secundarias y alimentación de rociadores, 8\" y 10\" para líneas principales de edificios de mediana y gran altura, y 12\" para instalaciones industriales de alto caudal. La disponibilidad específica de cada diámetro varía según el tipo de válvula: las OS&Y están disponibles en todo el rango (2.5\" a 12\"), las de globo típicamente hasta 6\", las de retención desde 3\" hasta 12\", y las mariposa desde 4\" hasta 12\". Mantenemos stock permanente de los diámetros más solicitados (3\", 4\" y 6\") para entregas inmediatas; diámetros especiales pueden requerir tiempos de entrega adicionales que te informamos en la cotización."
  },
  {
    "pregunta": "¿Las válvulas vienen con certificaciones UL y FM?",
    "respuesta": "Sí. Todas nuestras válvulas contra incendios cuentan con certificaciones UL (Underwriters Laboratories) y FM (Factory Mutual), dos de los estándares de seguridad más reconocidos a nivel internacional. Específicamente: válvulas de compuerta y mariposa cuentan con UL Listed y FM Approved según normas NFPA 13 y 14; válvulas de retención tienen listado UL 312 específico para check valves. Con cada válvula entregamos la documentación completa: ficha técnica del fabricante, declaración de conformidad, certificados UL/FM y manual de instalación. Esta documentación es fundamental para pasar verificaciones de protección civil, auditorías de aseguradoras, procesos de licitación y certificación de edificios. Todo se entrega en español, impreso o digital según prefieras."
  },
  {
    "pregunta": "¿Cómo puedo solicitar una cotización de válvulas contra incendios?",
    "respuesta": "Puedes cotizar de tres formas rápidas: 1) Formulario en esta página (se envía directo a nuestro WhatsApp), 2) WhatsApp directo al 55 6529 8240, o 3) Llamada al 55 1543 7164 o email a ventas@gamademexico.com. Solo necesitamos saber: tipo de válvula requerida (compuerta OS&Y, globo, retención o mariposa), diámetro(s) necesarios, cantidad aproximada, presión de trabajo del sistema y ubicación de entrega. Si no estás seguro del tipo o especificación correcta, nuestros ingenieros te asesoran sin costo para seleccionar exactamente lo que tu proyecto necesita según NFPA 13, 14 o 20. Respondemos en menos de 24 horas con precios, disponibilidad inmediata y opciones de envío. Para proyectos de gran escala preparamos cotizaciones corporativas con precios especiales por volumen."
  }
];

const structuredData = [
  buildOrganizationSchema(),
  buildProductCategorySchema({
    name: 'Válvulas Contra Incendios Certificadas UL/FM',
    description: 'Válvulas contra incendio certificadas UL y FM. Tipo compuerta OS&Y, globo, retención y mariposa para sistemas de protección activa NFPA en México.',
    image: '/img/valvulas-contra-incendios/valvula-check-swing-bridada-contra-incendios-hierro-ductil-16.avif',
    url: '/valvulas-contra-incendios',
    category: 'Válvulas Contra Incendios',
    brand: 'Elkhart Brass',
    reviewAuthor: 'Ing. Roberto Méndez',
    reviewBody: 'Excelente calidad en válvulas OS&Y y check. Documentación UL/FM completa para nuestra auditoría de Protección Civil. Entrega puntual y asesoría técnica que sí resuelve.',
    reviewDate: '2025-03-10',
    ratingCount: 52,
    reviewCount: 52,
  }),
  buildBreadcrumbSchema([
    { name: 'Inicio', url: '/' },
    { name: 'Equipos', url: '/equipos' },
    { name: 'Válvulas Contra Incendios', url: '/valvulas-contra-incendios' },
  ]),
  buildFAQSchema(faqItems),
];
---

<Layout
  title="Válvulas Contra Incendios Certificadas UL/FM | Gama de México"
  description="Válvulas contra incendio OS&Y, globo, retención y mariposa con certificación UL y FM. Stock inmediato, asesoría NFPA y envíos nacionales. Cotiza hoy."
  activePage="equipos"
  structuredData={structuredData}
  ogImage="/img/categorias/valvulas-contra-incendios-hero.avif"
  heroTitle="Válvulas Contra Incendios"
  heroBadge="Equipos Contra Incendios"
  heroShowRightContent={true}
  heroImage="/img/categorias/valvulas-contra-incendios-hero.avif"

  showLeadCapture={true}
>
  <Fragment slot="hero-content">
    <p>Distribuimos válvulas contra incendios certificadas UL y FM para sistemas de protección activa en edificios comerciales e instalaciones industriales. Nuestra línea incluye válvulas de compuerta OS&Y con indicación visual de posición, válvulas de globo para control de flujo, válvulas de retención tipo swing y válvulas mariposa con switch supervisor.</p>
    <p>Cada válvula cumple con los estándares NFPA 13, 14 y 20, garantizando operación confiable en condiciones de emergencia. Te asesoramos en la selección del tipo, diámetro y especificación correcta según el diseño hidráulico de tu proyecto y requisitos de aseguradoras.</p>
  </Fragment>

  <!-- BREADCRUMB -->
  <nav class="breadcrumb" aria-label="Navegación de migas de pan">
    <div class="container">
      <ol class="breadcrumb__list">
        <li class="breadcrumb__item"><a href="/" class="breadcrumb__link">Inicio</a></li>
        <li class="breadcrumb__item"><a href="/equipos" class="breadcrumb__link">Equipos</a></li>
        <li class="breadcrumb__item breadcrumb__item--active" aria-current="page">Válvulas Contra Incendios</li>
      </ol>
    </div>
  </nav><!-- PRODUCTOS DINAMICOS -->
  <section class="categories" id="valvulas">
    <div class="container">
      <div class="section-header">
        <h2 class="section-title">Tipo de Válvula Contra Incendio con Certificación UL Industrial</h2>
        <p class="section-subtitle">Catálogo de válvulas sistema contra incendio con certificación NFPA para control y protección</p>
      </div>
      <div class="categories__grid">
        {productos.map((producto) => (
          <article class="category-card">
            <div
              class="category-card__image"
              role="img"
              aria-label={producto.data.title}
              style={producto.data.imagen ? `background-image: url('${cardImage(producto.data.imagen)}'); background-size: cover; background-position: center;` : undefined}
            ></div>
            <div class="category-card__body">
              <h3 class="category-card__title">{producto.data.title}</h3>
              <p class="category-card__sub">{producto.data.description}</p>
              <ul class="category-card__products">
                {producto.data.material && <li class="category-card__product">{producto.data.material}</li>}
                {producto.data.flujo && <li class="category-card__product">{producto.data.flujo}</li>}
                {producto.data.certificaciones && producto.data.certificaciones.length > 0 && <li class="category-card__product">Certificaciones: {producto.data.certificaciones.join(', ')}</li>}
                <li class="category-card__product">Marca: {producto.data.marca}</li>
              </ul>
              <div class="category-card__ctas">
                <a href={`/productos/${producto.id}`} class="btn btn--primary btn--sm">Ver especificaciones</a>
                <a href="#cotizar" class="btn btn--outline btn--sm">Cotizar</a>
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- DETALLES DE PRODUCTOS -->
  <section class="service-details" aria-labelledby="service-details-title">
    <div class="container">
      <div class="section-header">
        <h2 id="service-details-title" class="section-title">Especificaciones Técnicas por Tipo de Válvula Sistema Industrial</h2>
      </div>

      <div class="service-detail" id="detalle-compuerta">
        <div class="service-detail__content">
          <h3 class="service-detail__title">Válvula de Compuerta OS&Y (Outside Screw and Yoke)</h3>
          <p class="service-detail__text">La válvula de compuerta con vástago exterior y yugo es el estándar en sistemas contra incendio para control de flujo en líneas principales. El diseño OS&Y permite verificación visual instantánea de la posición de la válvula: cuando el vástago está extendido, la válvula está abierta; cuando está retraído, está cerrada. Este indicador visual es crítico para inspecciones y cumplimiento normativo.</p>
          <ul class="service-detail__list">
            <li class="service-detail__list-item">Indicación visual de posición (vástago exterior)</li>
            <li class="service-detail__list-item">Cumplimiento NFPA 13 para redes principales</li>
            <li class="service-detail__list-item">Presiones de trabajo: 175, 200, 250 y 350 PSI</li>
            <li class="service-detail__list-item">Diámetros disponibles: 2.5", 3", 4", 6", 8", 10", 12"</li>
            <li class="service-detail__list-item">Fabricación en hierro dúctil y bronce</li>
            <li class="service-detail__list-item">Certificaciones UL y FM Listed</li>
          </ul>
          <div class="service-detail__ctas">
            <a href="/valvulas/compuerta" class="btn btn--outline">Ver catálogo completo</a>
            <a href="#cotizar" class="btn btn--primary">Cotizar válvula de compuerta</a>
          </div>
        </div>
        <div class="service-detail__image" role="img" aria-label="Válvula de compuerta OS&Y para sistemas contra incendio" style={`background-image: url('${detailImage('/img/valvulas-contra-incendios/valvula-compuerta-osy-ranurada-contra-incendios-vista-frontal-16.avif')}'); background-size: cover; background-position: center;`}></div>
      </div>

      <div class="service-detail" id="detalle-globo">
        <div class="service-detail__content">
          <h3 class="service-detail__title">Válvula de Globo para Control de Flujo</h3>
          <p class="service-detail__text">Las válvulas de globo permiten el control preciso de presión y flujo mediante estrangulamiento gradual. Su diseño interno, con un disco que cierra contra un asiento, ofrece regulación fina del caudal —fundamental en sistemas donde se requiere ajuste de presión sin interrumpir completamente el flujo. Disponibles en configuraciones angular y recta para adaptarse a diferentes trayectorias de tubería.</p>
          <ul class="service-detail__list">
            <li class="service-detail__list-item">Control preciso de presión y flujo</li>
            <li class="service-detail__list-item">Diseño angular y recto (straight pattern)</li>
            <li class="service-detail__list-item">Aplicación en líneas de alimentación y derivaciones</li>
            <li class="service-detail__list-item">Presión de trabajo hasta 300 PSI</li>
            <li class="service-detail__list-item">Construcción en bronce y hierro dúctil</li>
            <li class="service-detail__list-item">Vástago no ascendente (interior)</li>
          </ul>
          <div class="service-detail__ctas">
            <a href="/valvulas/globo" class="btn btn--outline">Ver catálogo completo</a>
            <a href="#cotizar" class="btn btn--primary">Cotizar válvula de globo</a>
          </div>
        </div>
        <div class="service-detail__image" role="img" aria-label="Válvula de globo para regulación de flujo en sistemas contra incendio" style={`background-image: url('${detailImage('/img/valvulas-contra-incendios/valvula-globo-bridada-acero-inoxidable-contra-incendios-fondo-blanco-01.avif')}'); background-size: cover; background-position: center;`}></div>
      </div>

      <div class="service-detail" id="detalle-retencion">
        <div class="service-detail__content">
          <h3 class="service-detail__title">Válvula de Retención (Check Valve) tipo Swing</h3>
          <p class="service-detail__text">La válvula de retención previene el retorno de flujo en sistemas hidráulicos, protegiendo equipos de bombeo y garantizando la dirección correcta del agua. El diseño tipo swing (columpio) opera mediante gravedad: el disco interno se abre con el flujo hacia adelante y se cierra automáticamente cuando el flujo se detiene o intenta revertir, sin requerir actuación manual o eléctrica.</p>
          <ul class="service-detail__list">
            <li class="service-detail__list-item">Prevención de retorno (backflow prevention)</li>
            <li class="service-detail__list-item">Operación automática por gravedad</li>
            <li class="service-detail__list-item">Diseño tipo swing (disco oscilante)</li>
            <li class="service-detail__list-item">Sello EPDM resistente a temperatura</li>
            <li class="service-detail__list-item">Listado UL 312 (válvulas de retención)</li>
            <li class="service-detail__list-item">Instalación horizontal y vertical</li>
          </ul>
          <div class="service-detail__ctas">
            <a href="/valvulas/retencion" class="btn btn--outline">Ver catálogo completo</a>
            <a href="#cotizar" class="btn btn--primary">Cotizar válvula de retención</a>
          </div>
        </div>
        <div class="service-detail__image" role="img" aria-label="Válvula de retención check swing para sistemas contra incendio" style={`background-image: url('${detailImage('/img/valvulas-contra-incendios/valvula-check-swing-bridada-contra-incendios-hierro-ductil-16.avif')}'); background-size: cover; background-position: center;`}></div>
      </div>

      <div class="service-detail" id="detalle-mariposa">
        <div class="service-detail__content">
          <h3 class="service-detail__title">Válvula Mariposa Indicadora (Butterfly Valve)</h3>
          <p class="service-detail__text">Las válvulas mariposa ofrecen apertura rápida (90° de rotación) en diámetros grandes, ideal para líneas principales de alimentación y conexiones a bombas. El diseño con indicador de posición supervisado (tamper switch) permite monitoreo remoto del estado de la válvula, enviando señales de alarma al panel de control cuando se detecta manipulación no autorizada.</p>
          <ul class="service-detail__list">
            <li class="service-detail__list-item">Apertura rápida de 90° (cuarto de vuelta)</li>
            <li class="service-detail__list-item">Indicador visual y switch supervisor (tamper)</li>
            <li class="service-detail__list-item">Sello bubble-tight (hermético)</li>
            <li class="service-detail__list-item">Diámetros grandes: 4" a 12"</li>
            <li class="service-detail__list-item">Aplicación en líneas principales y bombas</li>
            <li class="service-detail__list-item">Certificación UL y FM Approved</li>
          </ul>
          <div class="service-detail__ctas">
            <a href="/valvulas/mariposa" class="btn btn--outline">Ver catálogo completo</a>
            <a href="#cotizar" class="btn btn--primary">Cotizar válvula mariposa</a>
          </div>
        </div>
        <div class="service-detail__image" role="img" aria-label="Válvula mariposa indicadora para sistemas contra incendio" style={`background-image: url('${detailImage('/img/valvulas-contra-incendios/valvula-mariposa-indicadora-contra-incendios-tamper-switch-fondo-blanco-01.avif')}'); background-size: cover; background-position: center;`}></div>
      </div>

    </div>
  </section>

  <!-- TRUST -->
  <section class="trust" aria-labelledby="trust-title">
    <div class="container">
      <div class="section-header">
        <h2 id="trust-title" class="section-title">Por Qué Comprar Válvulas Contra Incendio con Certificación UL NFPA</h2>
        <p class="section-subtitle">Sistema industrial, control, protección y mantenimiento que ningún otro proveedor te ofrece</p>
      </div>
      <div class="trust__grid">
        <div class="trust__item">
          <h3 class="trust__item-title">Certificaciones UL y FM Listed</h3>
          <p class="trust__item-desc">Todas nuestras válvulas cuentan con certificaciones UL (Underwriters Laboratories) y FM (Factory Mutual), garantizando cumplimiento con NFPA 13, 14 y 20.</p>
        </div>
        <div class="trust__item">
          <h3 class="trust__item-title">Fabricación en hierro dúctil y bronce</h3>
          <p class="trust__item-desc">Materiales de alta resistencia a corrosión, diseñados para soportar presiones extremas y operar en condiciones ambientales adversas durante décadas.</p>
        </div>
        <div class="trust__item">
          <h3 class="trust__item-title">Inventario disponible en México</h3>
          <p class="trust__item-desc">Stock permanente de válvulas de compuerta OS&Y, globo, retención y mariposa en los diámetros más solicitados para entregas inmediatas.</p>
        </div>
        <div class="trust__item">
          <h3 class="trust__item-title">Asesoría técnica especializada</h3>
          <p class="trust__item-desc">Ingenieros con experiencia en diseño de sistemas contra incendio te ayudan a seleccionar el tipo, diámetro y especificación correcta según tu proyecto.</p>
        </div>
        <div class="trust__item">
          <h3 class="trust__item-title">Documentación para protección civil</h3>
          <p class="trust__item-desc">Fichas técnicas, certificados UL/FM y especificaciones del fabricante para respaldar verificaciones, auditorías y procesos de licitación.</p>
        </div>
        <div class="trust__item">
          <h3 class="trust__item-title">Precios corporativos por volumen</h3>
          <p class="trust__item-desc">Cotizaciones especiales para proyectos de gran escala, constructoras y compras recurrentes con descuentos por volumen.</p>
        </div>
      </div>

      <div class="trust__testimonials-header">
        <h3 class="trust__testimonials-title">Lo que dicen nuestros clientes sobre nuestras válvulas</h3>
        <p class="trust__testimonials-subtitle">Empresas de todo México confían en nuestras válvulas para sus sistemas contra incendio</p>
      </div>
      <div class="trust__testimonials">
        <blockquote class="testimonial">
          <div class="testimonial__stars" aria-label="5 estrellas">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
          <p class="testimonial__text">"Instalamos válvulas de compuerta OS&Y en una red principal de 8 pulgadas para una planta industrial. La calidad de fabricación es excepcional, el vástago exterior permite verificación visual inmediata y la documentación UL que nos entregaron pasó sin problemas la inspección de protección civil."</p>
          <div class="testimonial__author">
            <div class="testimonial__avatar"></div>
            <div class="testimonial__info">
              <span class="testimonial__name">Ing. Roberto Castillo M.</span>
              <span class="testimonial__role">Jefe de Mantenimiento</span>
              <span class="testimonial__company">Planta Manufacturera, Querétaro</span>
            </div>
          </div>
        </blockquote>
        <blockquote class="testimonial">
          <div class="testimonial__stars" aria-label="5 estrellas">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
          <p class="testimonial__text">"Necesitábamos válvulas de retención para proteger las bombas contra incendio de un edificio corporativo. Gama de México nos asesoró en la selección correcta del tipo swing y el sello EPDM ha funcionado perfectamente durante dos años de operación continua."</p>
          <div class="testimonial__author">
            <div class="testimonial__avatar"></div>
            <div class="testimonial__info">
              <span class="testimonial__name">Ing. Patricia Rojas S.</span>
              <span class="testimonial__role">Coordinadora de Infraestructura</span>
              <span class="testimonial__company">Corporativo Empresarial, CDMX</span>
            </div>
          </div>
        </blockquote>
        <blockquote class="testimonial">
          <div class="testimonial__stars" aria-label="5 estrellas">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
          <p class="testimonial__text">"Equipamos cinco proyectos con válvulas mariposa indicadoras certificadas FM. El switch supervisor integrado permite monitoreo remoto desde el panel de alarmas y el sello hermético garantiza cero fugas. Producto de calidad con respaldo técnico real."</p>
          <div class="testimonial__author">
            <div class="testimonial__avatar"></div>
            <div class="testimonial__info">
              <span class="testimonial__name">Ing. Carlos Mendoza R.</span>
              <span class="testimonial__role">Director de Proyectos</span>
              <span class="testimonial__company">Firma de Ingeniería, Monterrey</span>
            </div>
          </div>
        </blockquote>
