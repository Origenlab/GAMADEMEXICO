---
import Layout from '../layouts/Base.astro';
import SectionHeader from '../components/SectionHeader.astro';
import { getCollection } from 'astro:content';
import { getBackgroundImageUrl } from '../lib/images';
import Faq from '../components/Faq.astro';
import {
  buildProductCategorySchema,
  buildFAQSchema,
  buildBreadcrumbSchema,
  buildOrganizationSchema,
} from '../lib/seo';

const productos = (await getCollection('productos', ({ data }) => data.categoria === 'boquillas')).sort((a, b) => a.data.orden - b.data.orden);
const cdnImage = (path: string) =>
  getBackgroundImageUrl(path, {
    width: 960,
    quality: 80,
    strip: 'all',
  });
const faqItems = [
  {
    "pregunta": "¿Qué es el chiflón de 3 pasos en boquillas contra incendios?",
    "respuesta": "El chiflón de 3 pasos permite seleccionar tres patrones de agua: chorro directo para máximo alcance, niebla para enfriamiento y cortina para protección personal. Las boquillas con chiflón incluyen selector de flujo ajustable, construcción en bronce fundido y válvula de cierre total con empaque de neopreno. Disponibles en modelos tipo pistola y turbo jet."
  },
  {
    "pregunta": "¿Por qué elegir boquillas de bronce fundido?",
    "respuesta": "Las boquillas de bronce fundido ofrecen resistencia superior a la corrosión para aplicaciones industriales. Incluyen chiflón de 3 pasos para patrones de agua regulables, selector de flujo ajustable y válvula de cierre total con empaque de neopreno. Ideal para ambientes químicos, petroquímicos y refinerías. Disponibles en modelos turbo jet y tipo pistola."
  },
  {
    "pregunta": "¿Cómo funciona el selector de flujo en boquillas?",
    "respuesta": "El selector de flujo permite ajustar el caudal GPM según la aplicación específica. En boquillas tipo pistola el ajuste es manual, en turbo jet es automático para mantener presión constante. Combinado con chiflón de 3 pasos ofrece control total de los patrones de agua. Válvula de cierre total con empaque de neopreno garantiza sellado hermético. Construcción en bronce fundido disponible."
  },
  {
    "pregunta": "¿Qué patrones de agua ofrecen las boquillas contra incendios?",
    "respuesta": "Los patrones de agua disponibles mediante chiflón de 3 pasos son: chorro directo para máximo alcance y penetración, niebla para enfriamiento y protección térmica, y cortina para defensa del operador. El selector de flujo controla el caudal GPM. Construcción en bronce fundido con cierre total mediante empaque de neopreno. Modelos turbo jet disponibles."
  },
  {
    "pregunta": "¿Qué ventajas tiene el cierre total con neopreno?",
    "respuesta": "La válvula de cierre total con empaque de neopreno proporciona sellado hermético instantáneo, evitando fugas y permitiendo control preciso del flujo. Compatible con boquillas de bronce fundido y aluminio. Funciona con chiflón de 3 pasos, selector de flujo y todos los patrones de agua. Disponible en modelos turbo jet y tipo pistola."
  },
  {
    "pregunta": "¿Qué diferencia hay entre boquilla tipo pistola y turbo jet?",
    "respuesta": "Las boquillas tipo pistola tienen selector de flujo manual y chiflón de 3 pasos con ajuste fijo. Las turbo jet ajustan automáticamente para mantener presión constante cuando varía el caudal. Ambas ofrecen patrones de agua regulables, cierre total con neopreno y opciones en bronce fundido o aluminio forjado."
  },
  {
    "pregunta": "¿Qué tipos de boquillas contra incendios venden?",
    "respuesta": "Vendemos boquillas con chiflón de 3 pasos: tipo pistola con selector de flujo manual, turbo jet con ajuste automático, industriales en bronce fundido y certificadas UL/FM. Todas incluyen patrones de agua regulables, cierre total con empaque de neopreno y documentación completa para auditorías."
  }
];

const structuredData = [
  buildOrganizationSchema(),
  buildProductCategorySchema({
    name: 'Boquillas Contra Incendios Chiflón 3 Pasos',
    description: 'Boquillas contra incendios con chiflón de 3 pasos, turbo jet y tipo pistola. Bronce fundido, selector de flujo. Certificadas UL/FM Elkhart Brass.',
    image: '/img/boquillas-contra-incendios/boquilla-tipo-pistola-contra-incendios-estacion-bomberos-01.avif',
    url: '/boquillas-contra-incendios',
    category: 'Boquillas Contra Incendios',
    brand: 'Elkhart Brass',
    reviewAuthor: 'Cap. Luis Hernández',
    reviewBody: 'Las boquillas Elkhart Brass son las mejores que hemos probado. El chiflón de 3 pasos facilita el trabajo de nuestras brigadas. Servicio y entrega impecables por parte de Gama de México.',
    reviewDate: '2025-05-22',
    ratingCount: 47,
    reviewCount: 47,
  }),
  buildBreadcrumbSchema([
    { name: 'Inicio', url: '/' },
    { name: 'Equipos', url: '/equipos' },
    { name: 'Boquillas Contra Incendios', url: '/boquillas-contra-incendios' },
  ]),
  buildFAQSchema(faqItems),
];
---

<Layout
  title="Boquillas Contra Incendios Certificadas UL/FM | Gama de México"
  description="Boquillas contra incendio chiflón, turbo jet y pistola Elkhart Brass. Bronce fundido, selector de flujo. Certificadas UL/FM. Envío nacional. Cotiza aquí."
  activePage="equipos"
  structuredData={structuredData}
  heroTitle="Boquillas Contra Incendios para Brigadas y Sistemas Fijos"
  heroIntro="Control preciso de patrones de agua con chiflón de 3 pasos, selector de flujo ajustable y construcción en bronce fundido. Equipos tipo pistola, turbo jet e industriales certificados UL/FM."
  heroBadge="Boquillas Contra Incendios"
  heroMetrics={[
    { valor: "3", texto: "Patrones de agua" },
    { valor: "325", texto: "GPM máximo" },
    { valor: "UL/FM", texto: "Certificaciones disponibles" }
  ]}
  heroPrimaryText="Ver Catálogo"
  heroPrimaryLink="#boquillas"
  heroSecondaryText="Solicitar Cotización"
  heroSecondaryLink="#cotizar"
  heroShowRightContent={true}

  showLeadCapture={true}
>
  <Fragment slot="hero-content">
    <p>Distribuimos boquillas contra incendios de alto rendimiento para brigadas industriales, cuerpos de bomberos y sistemas fijos. Nuestra línea incluye boquillas tipo pistola con chiflón de 3 pasos, modelos turbo jet con ajuste automático de presión, opciones industriales en bronce fundido y versiones certificadas UL/FM para proyectos con requisitos normativos estrictos.</p>
    <p>Cada boquilla ofrece control preciso de patrones de agua y selector de flujo ajustable, permitiendo adaptar la descarga según la situación de emergencia. Te asesoramos en la selección del modelo correcto por caudal, presión de trabajo y certificación requerida para tu aplicación específica.</p>
  </Fragment>

  <!-- PRODUCTOS DINAMICOS -->
  <section class="categories" id="boquillas">
    <div class="container">
      <SectionHeader
        titulo="Catálogo de Boquillas Contra Incendios por Tipo"
        subtitulo="Selecciona un tipo de boquilla para conocer especificaciones técnicas y solicitar cotización"
        idTitulo="boquillas-title"
        parrafo1="Nuestro catálogo integra boquillas contra incendios de marcas líderes como Elkhart Brass, Akron Brass y Task Force Tips. Cada tipo de boquilla está diseñado para aplicaciones específicas: brigadas industriales, cuerpos de bomberos, sistemas fijos y proyectos que requieren certificaciones UL y FM."
        parrafo2="Trabajamos con plantas industriales, cuerpos de bomberos, firmas de ingeniería e instaladores certificados que requieren equipos con documentación completa para cumplimiento normativo y verificaciones de Protección Civil."
      />
      <div class="categories__grid">
        <article class="category-card">
          <div class="category-card__image" role="img" aria-label="Boquilla Tipo Pistola" style={`background-image: url('${cdnImage('/img/boquillas-contra-incendios/boquilla-tipo-pistola-contra-incendios-estacion-bomberos-01.avif')}'); background-size: cover; background-position: center;`}></div>
          <div class="category-card__body">
            <h3 class="category-card__title">Boquilla Tipo Pistola</h3>
            <p class="category-card__sub">Chiflón de 3 pasos con selector de flujo ajustable de 15 a 250 GPM</p>
            <ul class="category-card__products">
              <li class="category-card__product">Chiflón 3 pasos: chorro, niebla, cortina</li>
              <li class="category-card__product">Selector de flujo: 15 - 250 GPM</li>
              <li class="category-card__product">Certificaciones: UL, FM</li>
              <li class="category-card__product">Multimarca disponible</li>
            </ul>
            <div class="category-card__ctas">
              <a href="/boquillas/tipo-pistola" class="btn btn--primary btn--sm">Ver catálogo</a>
              <a href="#cotizar" class="btn btn--outline btn--sm">Cotizar</a>
            </div>
          </div>
        </article>
        <article class="category-card">
          <div class="category-card__image" role="img" aria-label="Boquilla Turbo Jet" style={`background-image: url('${cdnImage('/img/boquillas-contra-incendios/boquilla-turbo-jet-frontal.avif')}'); background-size: cover; background-position: center;`}></div>
          <div class="category-card__body">
            <h3 class="category-card__title">Boquilla Turbo Jet</h3>
            <p class="category-card__sub">Ajuste automático de presión con caudal de 60 a 325 GPM</p>
            <ul class="category-card__products">
              <li class="category-card__product">Presión constante automática</li>
              <li class="category-card__product">Caudal: 60 - 325 GPM</li>
              <li class="category-card__product">Certificaciones: UL, FM</li>
              <li class="category-card__product">Patrones de agua regulables</li>
            </ul>
            <div class="category-card__ctas">
              <a href="/boquillas/turbo-jet" class="btn btn--primary btn--sm">Ver catálogo</a>
              <a href="#cotizar" class="btn btn--outline btn--sm">Cotizar</a>
            </div>
          </div>
        </article>
        <article class="category-card">
          <div class="category-card__image" role="img" aria-label="Boquilla Industrial" style={`background-image: url('${cdnImage('/img/boquillas-contra-incendios/boquilla-industrial-bronce-marino-npsh-2-pulgadas-frontal.avif')}'); background-size: cover; background-position: center;`}></div>
          <div class="category-card__body">
            <h3 class="category-card__title">Boquilla Industrial</h3>
            <p class="category-card__sub">Bronce fundido para ambientes corrosivos y aplicaciones severas</p>
            <ul class="category-card__products">
              <li class="category-card__product">Bronce fundido anti-corrosión</li>
              <li class="category-card__product">UL 401 Class A/B/C</li>
              <li class="category-card__product">Resistencia a vapores químicos</li>
              <li class="category-card__product">Cierre total con neopreno</li>
            </ul>
            <div class="category-card__ctas">
              <a href="/boquillas/industrial" class="btn btn--primary btn--sm">Ver catálogo</a>
              <a href="#cotizar" class="btn btn--outline btn--sm">Cotizar</a>
            </div>
          </div>
        </article>
        <article class="category-card">
          <div class="category-card__image" role="img" aria-label="Boquilla Certificada" style={`background-image: url('${cdnImage('/img/boquillas-contra-incendios/boquilla-pistola-select-o-flow-frontal.avif')}'); background-size: cover; background-position: center;`}></div>
          <div class="category-card__body">
            <h3 class="category-card__title">Boquilla Certificada UL/FM</h3>
            <p class="category-card__sub">Doble certificación para proyectos con requisitos normativos estrictos</p>
            <ul class="category-card__products">
              <li class="category-card__product">Certificación UL y FM</li>
              <li class="category-card__product">Cumple NFPA 1964</li>
              <li class="category-card__product">Marcado láser permanente</li>
              <li class="category-card__product">Documentación completa</li>
            </ul>
            <div class="category-card__ctas">
              <a href="/boquillas/certificada" class="btn btn--primary btn--sm">Ver catálogo</a>
              <a href="#cotizar" class="btn btn--outline btn--sm">Cotizar</a>
            </div>
          </div>
        </article>
      </div>
    </div>
  </section>

  <!-- PRODUCT DETAILS -->
  <section class="service-details" aria-labelledby="service-details-title">
    <div class="container">
      <SectionHeader
        titulo="Detalle de Cada Tipo de Boquilla Contra Incendios"
        subtitulo="Conoce las características técnicas y aplicaciones de cada configuración"
        idTitulo="service-details-title"
      />

      <div class="service-detail" id="detalle-pistola">
        <div class="service-detail__content">
          <h3 class="service-detail__title">Boquilla Tipo Pistola — Chiflón 3 Pasos con Selector de Flujo</h3>
          <p class="service-detail__text">La boquilla contra incendios Phantom XD con <strong>chiflón de 3 pasos</strong> ofrece <strong>selector de flujo entre 15 y 250 GPM</strong> con <strong>patrones de agua</strong>: chorro directo, niebla regulable y cortina. Construcción en <strong>bronce fundido</strong> y aluminio forjado con válvula de <strong>cierre total</strong> y empaque de <strong>neopreno</strong>. El mango ergonómico proporciona control preciso. Múltiples marcas disponibles con precio bajo cotización.</p>
          <ul class="service-detail__list">
            <li class="service-detail__list-item">Chiflón de 3 pasos: chorro, niebla y cortina</li>
            <li class="service-detail__list-item">Selector de flujo de 15 a 250 GPM ajustable</li>
            <li class="service-detail__list-item">Construcción en bronce fundido y aluminio forjado</li>
            <li class="service-detail__list-item">Cierre total con empaque de neopreno</li>
            <li class="service-detail__list-item">Patrones de agua regulables para cada aplicación</li>
            <li class="service-detail__list-item">Marcas: Elkhart Brass, Akron, Task Force Tips</li>
          </ul>
          <div class="service-detail__ctas">
            <a href="/boquillas/tipo-pistola" class="btn btn--primary">Ver catálogo completo</a>
            <a href="#cotizar" class="btn btn--outline">Cotizar</a>
          </div>
        </div>
        <div class="service-detail__image" role="img" aria-label="Boquilla tipo pistola contra incendios profesional" style={`background-image: url('${cdnImage('/img/boquillas-contra-incendios/boquilla-tipo-pistola-contra-incendios-certificada-fm-15.avif')}'); background-size: cover; background-position: center;`}></div>
      </div>

      <div class="service-detail" id="detalle-turbo-jet">
        <div class="service-detail__content">
          <h3 class="service-detail__title">Boquilla Turbo Jet — Patrones de Agua con Presión Constante</h3>
          <p class="service-detail__text">La boquilla <strong>turbo jet</strong> Select-O-Matic XD mantiene <strong>presión constante con caudal de 60 a 325 GPM</strong>. Sistema patentado de resorte externo para ajuste automático del <strong>selector de flujo</strong>. <strong>Patrones de agua</strong> regulables con <strong>cierre total</strong> mediante empaque de <strong>neopreno</strong>. Ideal para combatir incendios donde la presión varía. Múltiples marcas disponibles.</p>
          <ul class="service-detail__list">
            <li class="service-detail__list-item">Turbo jet con selector de flujo 60 a 325 GPM</li>
            <li class="service-detail__list-item">Patrones de agua con ajuste automático</li>
            <li class="service-detail__list-item">Cierre total con empaque de neopreno</li>
            <li class="service-detail__list-item">Construcción en bronce fundido y aluminio</li>
            <li class="service-detail__list-item">Chiflón 3 pasos: chorro, niebla, cortina</li>
            <li class="service-detail__list-item">Marcas: Elkhart Brass, Akron, Task Force Tips</li>
          </ul>
          <div class="service-detail__ctas">
            <a href="/boquillas/turbo-jet" class="btn btn--primary">Ver catálogo completo</a>
            <a href="#cotizar" class="btn btn--outline">Cotizar</a>
          </div>
        </div>
        <div class="service-detail__image" role="img" aria-label="Boquilla turbo jet Select-O-Matic XD Elkhart Brass" style={`background-image: url('${cdnImage('/img/boquillas-contra-incendios/boquilla-turbo-jet-lateral.avif')}'); background-size: cover; background-position: center;`}></div>
      </div>

      <div class="service-detail" id="detalle-industrial">
        <div class="service-detail__content">
          <h3 class="service-detail__title">Boquilla Industrial — Bronce Fundido para Ambientes Severos</h3>
          <p class="service-detail__text">La boquilla contra incendios serie 205-B en <strong>bronce fundido</strong> está diseñada para <strong>aplicaciones industriales con ambientes corrosivos</strong>. <strong>Chiflón de 3 pasos</strong> con <strong>patrones de agua</strong> regulables y <strong>selector de flujo</strong>. Certificación UL 401 Class A/B/C, válvula de <strong>cierre total</strong> con empaque de <strong>neopreno</strong>. Construcción robusta con alta resistencia a la corrosión.</p>
          <ul class="service-detail__list">
            <li class="service-detail__list-item">Construcción en bronce fundido anti-corrosión</li>
            <li class="service-detail__list-item">Chiflón de 3 pasos: chorro, niebla, cortina</li>
            <li class="service-detail__list-item">Selector de flujo para diferentes aplicaciones</li>
            <li class="service-detail__list-item">Cierre total con empaque de neopreno sellado</li>
            <li class="service-detail__list-item">Patrones de agua ajustables UL 401 Class A/B/C</li>
            <li class="service-detail__list-item">Ideal para plantas químicas y petroquímicas</li>
          </ul>
          <div class="service-detail__ctas">
            <a href="/boquillas/industrial" class="btn btn--primary">Ver catálogo completo</a>
            <a href="#cotizar" class="btn btn--outline">Cotizar</a>
          </div>
        </div>
        <div class="service-detail__image" role="img" aria-label="Boquilla industrial serie 205-B Elkhart Brass" style={`background-image: url('${cdnImage('/img/boquillas-contra-incendios/boquilla-industrial-bronce-marino-npsh-2-pulgadas-lateral.avif')}'); background-size: cover; background-position: center;`}></div>
      </div>

      <div class="service-detail" id="detalle-certificada">
        <div class="service-detail__content">
          <h3 class="service-detail__title">Boquilla Certificada — Selector de Flujo con Certificación UL y FM</h3>
          <p class="service-detail__text">La boquilla contra incendios Chief XD ofrece <strong>selector de flujo certificado de 150 a 250 GPM</strong> con doble certificación UL y FM. Construcción en <strong>bronce fundido</strong> con <strong>chiflón de 3 pasos</strong> y <strong>patrones de agua</strong> regulables. Válvula de <strong>cierre total</strong> con empaque de <strong>neopreno</strong>. Marcado láser permanente para verificación. Precio competitivo con documentación para auditorías.</p>
          <ul class="service-detail__list">
            <li class="service-detail__list-item">Selector de flujo certificado 150, 200 y 250 GPM</li>
            <li class="service-detail__list-item">Construcción en bronce fundido resistente</li>
            <li class="service-detail__list-item">Chiflón de 3 pasos: chorro, niebla, cortina</li>
            <li class="service-detail__list-item">Cierre total con empaque de neopreno</li>
            <li class="service-detail__list-item">Patrones de agua certificados UL y FM</li>
            <li class="service-detail__list-item">Documentación completa NFPA 1964</li>
          </ul>
          <div class="service-detail__ctas">
            <a href="/boquillas/certificada" class="btn btn--primary">Ver catálogo completo</a>
            <a href="#cotizar" class="btn btn--outline">Cotizar</a>
          </div>
        </div>
        <div class="service-detail__image" role="img" aria-label="Boquilla certificada Chief XD Elkhart Brass" style={`background-image: url('${cdnImage('/img/boquillas-contra-incendios/boquilla-pistola-select-o-flow-lateral.avif')}'); background-size: cover; background-position: center;`}></div>
      </div>

    </div>
  </section>

  <!-- TRUST -->
  <section class="trust" aria-labelledby="trust-title">
    <div class="container">
      <SectionHeader
        titulo="Por Qué Comprar Boquillas Contra Incendios en Gama de México"
        subtitulo="Calidad certificada, inventario disponible y asesoría técnica especializada"
        idTitulo="trust-title"
      />
      <div class="trust__grid">
        <div class="trust__item">
          <h3 class="trust__item-title">Chiflón de 3 Pasos Profesional</h3>
          <p class="trust__item-desc">Boquillas contra incendios con chiflón de 3 pasos para patrones de agua: chorro directo, niebla y cortina. Control preciso del flujo para cada situación de emergencia.</p>
        </div>
        <div class="trust__item">
          <h3 class="trust__item-title">Construcción en Bronce Fundido</h3>
          <p class="trust__item-desc">Boquillas en bronce fundido resistente a la corrosión. Construcción robusta que garantiza durabilidad y confiabilidad en aplicaciones industriales severas.</p>
        </div>
        <div class="trust__item">
          <h3 class="trust__item-title">Selector de Flujo Ajustable</h3>
          <p class="trust__item-desc">Selector de flujo que permite ajustar el caudal GPM según la aplicación. Patrones de agua regulables con control preciso del volumen de descarga.</p>
        </div>
        <div class="trust__item">
          <h3 class="trust__item-title">Cierre Total con Neopreno</h3>
          <p class="trust__item-desc">Válvula de cierre total con empaque de neopreno para sellado hermético. Sistema confiable que evita fugas y permite control instantáneo del flujo.</p>
        </div>
        <div class="trust__item">
          <h3 class="trust__item-title">Boquillas Turbo Jet Certificadas</h3>
          <p class="trust__item-desc">Línea completa de boquillas turbo jet con certificación UL y FM. Selector de flujo automático para presión constante en todo el rango de caudal.</p>
        </div>
        <div class="trust__item">
          <h3 class="trust__item-title">Documentación para Auditorías</h3>
          <p class="trust__item-desc">Certificados UL/FM originales, fichas técnicas en español, manuales y cartas de conformidad con NOM-002-STPS incluidos.</p>
        </div>
      </div>

      <SectionHeader
        titulo="Lo que dicen nuestros clientes"
        subtitulo="Empresas de todo México confían en nuestras boquillas contra incendios"
        idTitulo="testimonials-title"
      />
      <div class="trust__testimonials">
        <blockquote class="testimonial">
          <div class="testimonial__stars" aria-label="5 estrellas">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
          <p class="testimonial__text">"Las boquillas Phantom XD son superiores a cualquier otra marca. La construcción forjada es evidente en la solidez del producto y el control de flujo es muy preciso. Equipamos a toda la brigada industrial y el desempeño ha sido excelente. El precio fue muy competitivo."</p>
          <div class="testimonial__author">
            <div class="testimonial__avatar"></div>
            <div class="testimonial__info">
              <span class="testimonial__name">Ing. Roberto Méndez</span>
              <span class="testimonial__role">Jefe de Brigada Industrial</span>
              <span class="testimonial__company">Planta Automotriz, Guanajuato</span>
            </div>
          </div>
        </blockquote>
        <blockquote class="testimonial">
          <div class="testimonial__stars" aria-label="5 estrellas">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
          <p class="testimonial__text">"Compramos Select-O-Matic XD para nuestras unidades y el ajuste automático de presión funciona perfectamente. Ya no tenemos que preocuparnos por variaciones de presión. Gama de México nos entregó con factura y documentación completa. Cotización rápida y precio justo."</p>
          <div class="testimonial__author">
            <div class="testimonial__avatar"></div>
            <div class="testimonial__info">
              <span class="testimonial__name">Cap. Fernando Ruiz</span>
              <span class="testimonial__role">Comandante de Estación</span>
              <span class="testimonial__company">Cuerpo de Bomberos, Guadalajara</span>
            </div>
          </div>
        </blockquote>
        <blockquote class="testimonial">
          <div class="testimonial__stars" aria-label="5 estrellas">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
