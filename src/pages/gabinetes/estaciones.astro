---
import Layout from '../../layouts/Base.astro';
import '../../styles/subcategory.css';
import { getCollection } from 'astro:content';
import SubcategoryProductCard from '../../components/SubcategoryProductCard.astro';
import ProductSidebar from '../../components/ProductSidebar.astro';
import RelatedProductsGrid from '../../components/RelatedProductsGrid.astro';
import CotizacionForm from '../../components/CotizacionForm.astro';
import Faq from '../../components/Faq.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import { buildProductCategorySchema, buildBreadcrumbSchema, buildFAQSchema, buildOrganizationSchema } from '../../lib/seo';


// 1. Obtener todos los productos de la categoría gabinetes-hidrantes
const todosProductos = (await getCollection('productos', ({ data }) =>
  data.categoria === 'gabinetes-hidrantes'
)).sort((a, b) => a.data.orden - b.data.orden);

// 2. Filtrar por subcategoría: Estaciones de Manguera
const productosSubcategoria = todosProductos.filter(p => p.data.subcategoria === 'estaciones');

// 3. Obtener otros productos para sección de relacionados
const otrosProductos = todosProductos.filter(p => !productosSubcategoria.includes(p));

// 4. Definir subcategorías para navegación
const subcategorias = [
  { slug: 'tipo-30me', nombre: 'Gabinete Tipo 30ME', descripcion: 'Gabinete completo con manguera 30m', activo: false },
  { slug: 'empotrado', nombre: 'Gabinete Empotrado', descripcion: 'Instalación al ras del muro', activo: false },
  { slug: 'hidrantes', nombre: 'Hidrantes', descripcion: 'Tomas exteriores hierro dúctil', activo: false },
  { slug: 'estaciones', nombre: 'Estaciones de Manguera', descripcion: 'Carrete oscilante 180 grados', activo: true },
];
const faqItems = [
  { pregunta: '¿Qué es una estación de mangueras y en qué se diferencia del gabinete?', respuesta: 'Una estación de mangueras (hose station) es un punto de conexión de manguera sin gabinete cerrado, usado en aplicaciones industriales y exteriores donde la accesibilidad rápida es prioritaria sobre la estética. Incluye una válvula angular o de bola, soporte de manguera y en algunos casos la manguera pre-conectada. Se usa en plantas industriales, muelles, estacionamientos y patios de maniobras.' },
  { pregunta: '¿Qué requiere NFPA 14 en un paquete completo de estación de mangueras (fire station)?', respuesta: 'NFPA 14 sección 7.3 especifica que un punto de conexión completo para sistemas standpipe debe incluir: válvula de salida del diámetro correcto (1.5" para Clase II y III, 2.5" para Clase I), manguera certificada de longitud adecuada, boquilla aprobada, y señalización del tipo de sistema. Para Clase III, la estación debe incluir tanto una salida de 2.5" para bomberos como una de 1.5" con manguera para uso del personal del edificio en primera respuesta.' },
  { pregunta: '¿Qué inspecciones visuales requiere NFPA 14 para estaciones de manguera?', respuesta: 'NFPA 14 y NFPA 25 establecen que las estaciones de manguera deben inspeccionarse visualmente cada tres meses para verificar: que la manguera esté en su lugar sin daño visible, que la boquilla y la válvula estén presentes y operables, que el soporte esté en buen estado, y que la señalización sea legible. Además, una inspección anual incluye prueba de funcionamiento de la válvula y verificación de presión en el sistema. Las estaciones exteriores deben verificarse más frecuentemente en temporada de lluvias.' },
  { pregunta: '¿Las estaciones de mangueras exteriores requieren protección especial?', respuesta: 'Sí. En instalaciones exteriores expuestas a la intemperie, se utilizan cubiertas de aluminio o acero inoxidable, y las válvulas y herrajes deben ser de bronce de grado naval. En zonas con riesgo de heladas, se instalan válvulas de drenaje automático para evitar que el agua congele en la tubería de la estación. Se recomienda también señalización con material retroreflectante visible de noche.' },
  { pregunta: '¿Cuántas estaciones de mangueras se necesitan en una planta industrial?', respuesta: 'El número y ubicación de estaciones de mangueras se calcula mediante análisis hidráulico conforme a NFPA 24 o NFPA 14, considerando el área a proteger, el tipo de riesgo, la presión y caudal disponibles, y la distancia máxima de alcance de la manguera. Como regla general, cada estación debe cubrir un radio de 30 metros con la manguera extendida. Gama de México asesora en el diseño del sistema completo.' },
  { pregunta: '¿Cuál es la ventaja del carrete oscilante de 180° en estaciones de manguera?', respuesta: 'El carrete oscilante de 180° permite desplegar la manguera en cualquier dirección dentro del semicírculo frente a la estación sin tener que jalar y reorganizar la manguera. Esto reduce el tiempo de respuesta y evita que la manguera se enrede durante el despliegue en emergencia. A diferencia de los soportes fijos (rack) donde la manguera debe extraerse completamente antes de usarse, el carrete oscilante permite al operador ir hacia el riesgo mientras la manguera se desenrolla automáticamente del carrete.' },
];

const structuredData = [
  buildOrganizationSchema(),
  buildProductCategorySchema({
    name: 'Estaciones de Mangueras Contra Incendios',
    description: 'Estaciones de mangueras para plantas industriales y exteriores. Válvula angular bronce, soporte y manguera. México.',
    image: '/img/gabinetes-hidrantes/gabinete-30m-abierto.avif',
    url: '/gabinetes/estaciones',
    category: 'Gabinetes e Hidrantes Contra Incendios',
    brand: 'Elkhart Brass',
    reviewAuthor: 'Ing. Carlos Mendoza',
    reviewBody: 'Excelente calidad y respaldo técnico de Gama de México. Equipos certificados con entrega puntual.',
    reviewDate: '2025-03-15',
    ratingCount: 32,
    reviewCount: 32,
  }),
  buildBreadcrumbSchema([
    { name: 'Inicio', url: '/' },
    { name: 'Equipos', url: '/equipos' },
    { name: 'Gabinetes e Hidrantes', url: '/gabinetes-hidrantes-contra-incendios' },
  ]),
  buildFAQSchema(faqItems),
];

---

<Layout
  structuredData={structuredData}
  title="Estaciones de Manguera Carrete Oscilante NFPA 14 | Gama de México"
  description="Estaciones de manguera con carrete oscilante 180° para respuesta rápida. Manguera 1.5&quot;×30m, válvula angular bronce. NFPA 14 Clase II/III, NOM-002-STPS. Plantas industriales México."
  activePage="equipos"
  heroTitle="Estaciones de Manguera"
  heroIntro="Soluciones de respuesta rápida montadas en pared para instalaciones industriales y comerciales, completas con manguera y boquilla."
  heroBadge="Gabinetes e Hidrantes"
  heroMetrics={[
    { value: "180°", label: "Oscilación" },
    { value: "30m", label: "Manguera" },
    { value: "100 PSI", label: "Presión" }
  ]}
  heroPrimaryText="Solicitar Cotización"
  heroPrimaryLink="#cotizar"
  heroSecondaryText="Ver Catálogo"
  heroSecondaryLink="#catalogo"
  heroShowRightContent={true}
>

  <Fragment slot="hero-content">
    <p>Las estaciones de manguera con carrete oscilante representan la solución ideal para respuesta inmediata ante emergencias de incendio en instalaciones industriales y comerciales. Estos sistemas montados en pared integran manguera de alta presión, boquilla cromada y mecanismo de despliegue automático, permitiendo una operación rápida incluso por personal sin entrenamiento especializado. Su diseño compacto y funcional cumple con los requerimientos de sistemas standpipe Clase II y III según NFPA 14.</p>
    <p>Nuestras estaciones de manguera están fabricadas con materiales de primera calidad, incluyendo carretes de acero con recubrimiento anticorrosivo y mangueras de poliéster con forro de hule sintético. La oscilación de 180 grados proporciona cobertura amplia sin necesidad de desplazar el equipo, mientras que la válvula integrada permite control preciso del flujo. Ideales para bodegas, estacionamientos, plantas industriales y edificios comerciales que requieren protección confiable contra incendios.</p>
  </Fragment>
  <!-- BREADCRUMB -->
  <Breadcrumb />



  <!-- CONTENT + SIDEBAR -->
  <section class="subcat-content">
    <div class="container">
      <div class="subcat-layout">

        <!-- MAIN CONTENT -->
        <main class="subcat-main">
          <div class="catalog-header">
            <div class="catalog-header__text">
              <h2 class="catalog-header__title">Catálogo de Estaciones de Manguera</h2>
              <p class="catalog-header__desc">Selecciona el modelo que mejor se adapte a tu instalación</p>
            </div>
            <div class="catalog-header__count">
              <span class="catalog-header__number">{productosSubcategoria.length}</span>
              <span class="catalog-header__label">producto{productosSubcategoria.length !== 1 ? 's' : ''}</span>
            </div>
          </div>

          <!-- Products Grid -->
          <div class="categories__grid">
            {productosSubcategoria.map((producto) => (
              <SubcategoryProductCard
                title={producto.data.title}
                description={producto.data.description}
                brand={producto.data.marca}
                image={producto.data.imagen}
                productSlug={producto.id}
                flow={producto.data.flujo}
                material={producto.data.material}
                certifications={producto.data.certificaciones}
              />
            ))}
          </div>

          {productosSubcategoria.length === 0 && (
            <div class="catalog-empty">
              <div class="catalog-empty__icon">🔍</div>
              <h3 class="catalog-empty__title">Próximamente más opciones</h3>
              <p class="catalog-empty__text">Estamos agregando más estaciones de diferentes configuraciones. Solicita una cotización personalizada.</p>
              <a href="#cotizar" class="btn btn--primary">Solicitar Cotización</a>
            </div>
          )}

          <!-- Tech Info -->
          <div class="tech-info">
            <h3 class="tech-info__title">Especificaciones Técnicas de Estaciones</h3>
            <div class="tech-info__grid">
              <div class="tech-info__item">
                <span class="tech-info__label">Conexión entrada</span>
                <span class="tech-info__value">1.5" NST/NH</span>
              </div>
              <div class="tech-info__item">
                <span class="tech-info__label">Manguera</span>
                <span class="tech-info__value">1.5" x 30m</span>
              </div>
              <div class="tech-info__item">
                <span class="tech-info__label">Presión máxima</span>
                <span class="tech-info__value">100 PSI salida</span>
              </div>
              <div class="tech-info__item">
                <span class="tech-info__label">Diámetro carrete</span>
                <span class="tech-info__value">18"</span>
              </div>
              <div class="tech-info__item">
                <span class="tech-info__label">Oscilación</span>
                <span class="tech-info__value">180°</span>
              </div>
              <div class="tech-info__item">
                <span class="tech-info__label">Cobertura</span>
                <span class="tech-info__value">39.7m radio</span>
              </div>
            </div>
          </div>

          <!-- CTA Final -->
          <div class="subcat-cta-final">
            <div class="subcat-cta-final__content">
              <h3 class="subcat-cta-final__title">¿Necesitas asesoría para tu sistema standpipe?</h3>
              <p class="subcat-cta-final__desc">Te ayudamos a calcular la cantidad de estaciones necesarias según NFPA 14 y las dimensiones de tu edificio.</p>
            </div>
            <a href="#cotizar" class="btn btn--primary">Solicitar Asesoría</a>
          </div>
        </main>

        <!-- SIDEBAR -->
        <ProductSidebar
          navTitulo="Tipos de Gabinetes"
          subcategorias={subcategorias}
          baseUrl="/gabinetes"
          backLinkHref="/gabinetes-hidrantes-contra-incendios"
          backLinkTexto="Ver todos los gabinetes"
          certificaciones={[
            { siglas: "FM", nombre: "Factory Mutual" },
            { siglas: "UL", nombre: "UL Listed" },
            { siglas: "NOM", nombre: "NOM-002-STPS" }
          ]}
          marcas={["Potter Roemer", "JL Industries", "Larsen's", "Guardian"]}
          aplicaciones={[
            "Estaciones de manguera",
            "Puntos de respuesta rápida",
            "Industria pesada",
            "Áreas de alto riesgo"
          ]}
          productosRelacionados={[
            { href: "/boquillas-contra-incendios", nombre: "Boquillas Contra Incendios" },
            { href: "/mangueras-contra-incendios", nombre: "Mangueras Contra Incendios" },
            { href: "/valvulas-contra-incendios", nombre: "Válvulas Contra Incendios" },
            { href: "/conexiones-herrajes-contra-incendios", nombre: "Conexiones y Herrajes" }
          ]}
        />

      </div>
    </div>
  </section>

  <!-- RELATED PRODUCTS -->
  <RelatedProductsGrid
    titulo="Otros Gabinetes y Estaciones"
    subtitulo="Explora más opciones para tu sistema de protección"
    productos={otrosProductos}
    maxProductos={3}
    verTodosLink="/gabinetes-hidrantes-contra-incendios"
    verTodosTexto="Ver todos los gabinetes"
  />

  <CotizacionForm
    titulo="Cotiza Estaciones"
    tipoEquipo="Gabinetes e hidrantes"
    pagina="Gabinetes Estaciones"
  />


  <!-- FAQ -->
  <section class="faq-section" id="faq" aria-labelledby="faq-title">
    <div class="container">
      <h2 id="faq-title" class="section-title">Preguntas Frecuentes</h2>
      <Faq items={faqItems} id="faq" />
    </div>
  </section>

</Layout>

<style>
  .faq-section {
    padding: var(--spacing-2xl, 4rem) 0;
    background: var(--color-surface, #fff);
  }
  .faq-section .section-title {
    font-size: var(--text-2xl, 1.75rem);
    font-weight: 700;
    margin-bottom: 2rem;
    text-align: center;
  }
</style>
