---
import Layout from '../../layouts/Base.astro';
import '../../styles/subcategory.css';
import { getCollection } from 'astro:content';
import SubcategoryProductCard from '../../components/SubcategoryProductCard.astro';
import ProductSidebar from '../../components/ProductSidebar.astro';
import RelatedProductsGrid from '../../components/RelatedProductsGrid.astro';
import CotizacionForm from '../../components/CotizacionForm.astro';
import Faq from '../../components/Faq.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import { buildProductCategorySchema, buildBreadcrumbSchema, buildFAQSchema, buildOrganizationSchema } from '../../lib/seo';


// 1. Obtener todos los productos de la categoría gabinetes-hidrantes
const todosProductos = (await getCollection('productos', ({ data }) =>
  data.categoria === 'gabinetes-hidrantes'
)).sort((a, b) => a.data.orden - b.data.orden);

// 2. Filtrar por subcategoría: Hidrantes de Banqueta
const productosSubcategoria = todosProductos.filter(p => p.data.subcategoria === 'hidrantes');

// 3. Obtener otros productos para sección de relacionados
const otrosProductos = todosProductos.filter(p => !productosSubcategoria.includes(p));

// 4. Definir subcategorías para navegación
const subcategorias = [
  { slug: 'tipo-30me', nombre: 'Gabinete Tipo 30ME', descripcion: 'Gabinete completo con manguera 30m', activo: false },
  { slug: 'empotrado', nombre: 'Gabinete Empotrado', descripcion: 'Instalación al ras del muro', activo: false },
  { slug: 'hidrantes', nombre: 'Hidrantes', descripcion: 'Tomas exteriores hierro dúctil', activo: true },
  { slug: 'estaciones', nombre: 'Estaciones de Manguera', descripcion: 'Carrete oscilante 180 grados', activo: false },
];
const faqItems = [
  { pregunta: '¿Cuál es la diferencia entre un hidrante de banqueta y un hidrante de muro?', respuesta: 'El hidrante de banqueta (pillar hydrant) se instala en el exterior, al ras del suelo, con sus bocas de conexión a 60-90 cm de altura, para uso de los bomberos desde la calle. El hidrante de muro (wall hydrant) se instala empotrado en la fachada de un edificio o barda, protegiendo la conexión del tráfico. Ambos tipos se conectan a la red de agua contra incendios y funcionan como puntos de abastecimiento para camiones y líneas de ataque.' },
  { pregunta: '¿Qué presión y caudal debe tener un hidrante para cumplir con NFPA?', respuesta: 'NFPA 24 establece que los hidrantes en sistemas privados deben proveer al menos 250 GPM a 20 PSI de presión residual en el hidrante más desfavorable del sistema. Para sistemas de múltiples hidrantes operando simultáneamente, la demanda puede superar los 1,000 GPM. El diseño hidráulico del sistema determina el diámetro de la tubería principal necesario para cumplir estos parámetros.' },
  { pregunta: '¿Los hidrantes privados requieren prueba periódica?', respuesta: 'Sí. Conforme a NFPA 25, los hidrantes privados deben inspeccionarse visualmente cada 3 años como mínimo, y someterse a prueba de flujo para verificar condición operativa. En zonas sísmicas o con suelos expansivos, se recomienda inspección anual. La prueba incluye apertura y cierre del hidrante, verificación de drenaje automático y medición de presión y caudal de descarga.' },
];

const structuredData = [
  buildOrganizationSchema(),
  buildProductCategorySchema({
    name: 'Hidrantes Contra Incendios para Instalaciones Privadas',
    description: 'Hidrantes de banqueta y muro para instalaciones privadas. NFPA 24. Bronce y fierro fundido. Cotización México.',
    image: '/img/gabinetes-hidrantes/gabinete-30m-abierto.avif',
    url: '/gabinetes/hidrantes',
    category: 'Gabinetes e Hidrantes Contra Incendios',
    brand: 'Elkhart Brass',
    reviewAuthor: 'Ing. Carlos Mendoza',
    reviewBody: 'Excelente calidad y respaldo técnico de Gama de México. Equipos certificados con entrega puntual.',
    reviewDate: '2025-03-15',
    ratingCount: 32,
    reviewCount: 32,
  }),
  buildBreadcrumbSchema([
    { name: 'Inicio', url: '/' },
    { name: 'Equipos', url: '/equipos' },
    { name: 'Gabinetes e Hidrantes', url: '/gabinetes-hidrantes-contra-incendios' },
  ]),
  buildFAQSchema(faqItems),
];

---

<Layout
  structuredData={structuredData}
  title="Hidrantes de Banqueta Hierro Dúctil | Gama de México"
  description='Hidrantes de banqueta hierro dúctil ASTM A-536, 250-350 PSI. Certificados UL 246, AWWA C502/C503. Barril seco y húmedo. Envío nacional. Cotiza hoy.'
  activePage="equipos"
  heroTitle="Hidrantes Contra Incendio"
  heroIntro="Hidrantes de banqueta para uso industrial y municipal, disponibles en configuraciones de barril seco y húmedo con certificaciones UL y FM."
  heroBadge="Gabinetes e Hidrantes"
  heroMetrics={[
    { value: "350 PSI", label: "Presión Max" },
    { value: "UL/FM", label: "Certificado" },
    { value: "AWWA", label: "Norma" }
  ]}
  heroPrimaryText="Solicitar Cotización"
  heroPrimaryLink="#cotizar"
  heroSecondaryText="Ver Catálogo"
  heroSecondaryLink="#catalogo"
  heroShowRightContent={true}
>

  <Fragment slot="hero-content">
    <p>Los hidrantes contra incendio son componentes críticos en la infraestructura de protección contra incendios para aplicaciones industriales y municipales. Fabricados en hierro dúctil ASTM A-536 con salidas de bronce ASTM B-62, nuestros hidrantes ofrecen la resistencia y durabilidad necesarias para servicio continuo en condiciones exigentes. Disponibles en configuraciones de barril seco para climas fríos y barril húmedo para instalaciones donde el congelamiento no es preocupación, con presiones de trabajo de 250 a 350 PSI.</p>
    <p>Cada hidrante cuenta con certificaciones UL 246, AWWA C502/C503 y NSF 61, garantizando cumplimiento con los estándares más estrictos de la industria. El recubrimiento epóxico interior y exterior proporciona protección superior contra la corrosión, mientras que el vástago de acero inoxidable asegura operación confiable a lo largo de los años. Ideales para redes de agua municipales, parques industriales, refinerías, plantas químicas y cualquier instalación que requiera acceso a agua de alta presión para combate de incendios.</p>
  </Fragment>
  <!-- BREADCRUMB -->
  <Breadcrumb />



  <!-- CONTENT + SIDEBAR -->
  <section class="subcat-content">
    <div class="container">
      <div class="subcat-layout">

        <!-- MAIN CONTENT -->
        <main class="subcat-main">
          <div class="catalog-header">
            <div class="catalog-header__text">
              <h2 class="catalog-header__title">Catálogo de Hidrantes de Banqueta</h2>
              <p class="catalog-header__desc">Selecciona el modelo que mejor se adapte a tu instalación</p>
            </div>
            <div class="catalog-header__count">
              <span class="catalog-header__number">{productosSubcategoria.length}</span>
              <span class="catalog-header__label">producto{productosSubcategoria.length !== 1 ? 's' : ''}</span>
            </div>
          </div>

          <!-- Products Grid -->
          <div class="categories__grid">
            {productosSubcategoria.map((producto) => (
              <SubcategoryProductCard
                title={producto.data.title}
                description={producto.data.description}
                brand={producto.data.marca}
                image={producto.data.imagen}
                productSlug={producto.id}
                flow={producto.data.flujo}
                material={producto.data.material}
                certifications={producto.data.certificaciones}
              />
            ))}
          </div>

          {productosSubcategoria.length === 0 && (
            <div class="catalog-empty">
              <div class="catalog-empty__icon">🔍</div>
              <h3 class="catalog-empty__title">Próximamente más opciones</h3>
              <p class="catalog-empty__text">Estamos agregando más hidrantes de diferentes configuraciones. Solicita una cotización personalizada.</p>
              <a href="#cotizar" class="btn btn--primary">Solicitar Cotización</a>
            </div>
          )}

          <!-- Tech Info -->
          <div class="tech-info">
            <h3 class="tech-info__title">Especificaciones Técnicas de Hidrantes</h3>
            <div class="tech-info__grid">
              <div class="tech-info__item">
                <span class="tech-info__label">Presión trabajo</span>
                <span class="tech-info__value">250-350 PSI</span>
              </div>
              <div class="tech-info__item">
                <span class="tech-info__label">Salidas 2.5"</span>
                <span class="tech-info__value">2 x NST (7.5 TPI)</span>
              </div>
              <div class="tech-info__item">
                <span class="tech-info__label">Salida bomba</span>
                <span class="tech-info__value">4.5" NST (4 TPI)</span>
              </div>
              <div class="tech-info__item">
                <span class="tech-info__label">Entrada</span>
                <span class="tech-info__value">6" ANSI B16.1</span>
              </div>
              <div class="tech-info__item">
                <span class="tech-info__label">Cuerpo</span>
                <span class="tech-info__value">Hierro dúctil</span>
              </div>
              <div class="tech-info__item">
                <span class="tech-info__label">Recubrimiento</span>
                <span class="tech-info__value">Epóxico</span>
              </div>
            </div>
          </div>

          <!-- CTA Final -->
          <div class="subcat-cta-final">
            <div class="subcat-cta-final__content">
              <h3 class="subcat-cta-final__title">¿Necesitas hidrantes para un proyecto municipal?</h3>
              <p class="subcat-cta-final__desc">Ofrecemos volumen para proyectos de redes de agua municipales e industriales con certificaciones completas.</p>
            </div>
            <a href="#cotizar" class="btn btn--primary">Solicitar Cotización Mayoreo</a>
          </div>
        </main>

        <!-- SIDEBAR -->
        <ProductSidebar
          navTitulo="Tipos de Gabinetes"
          subcategorias={subcategorias}
          baseUrl="/gabinetes"
          backLinkHref="/gabinetes-hidrantes-contra-incendios"
          backLinkTexto="Ver todos los gabinetes"
          certificaciones={[
            { siglas: "FM", nombre: "Factory Mutual" },
            { siglas: "UL", nombre: "UL Listed" },
            { siglas: "NOM", nombre: "NOM-002-STPS" }
          ]}
          marcas={["Potter Roemer", "JL Industries", "Kennedy", "Mueller"]}
          aplicaciones={[
            "Hidrantes de pared",
            "Tomas de agua",
            "Redes contra incendio",
            "Instalaciones industriales"
          ]}
          productosRelacionados={[
            { href: "/boquillas-contra-incendios", nombre: "Boquillas Contra Incendios" },
            { href: "/mangueras-contra-incendios", nombre: "Mangueras Contra Incendios" },
            { href: "/valvulas-contra-incendios", nombre: "Válvulas Contra Incendios" },
            { href: "/conexiones-herrajes-contra-incendios", nombre: "Conexiones y Herrajes" }
          ]}
        />

      </div>
    </div>
  </section>

  <!-- RELATED PRODUCTS -->
  <RelatedProductsGrid
    titulo="Otros Gabinetes y Estaciones"
    subtitulo="Explora más opciones para tu sistema de protección"
    productos={otrosProductos}
    maxProductos={3}
    verTodosLink="/gabinetes-hidrantes-contra-incendios"
    verTodosTexto="Ver todos los gabinetes"
  />

  <CotizacionForm
    titulo="Cotiza Hidrantes"
    tipoEquipo="Gabinetes e hidrantes"
    pagina="Gabinetes Hidrantes"
  />


  <!-- FAQ -->
  <section class="faq-section" id="faq" aria-labelledby="faq-title">
    <div class="container">
      <h2 id="faq-title" class="section-title">Preguntas Frecuentes</h2>
      <Faq items={faqItems} id="faq" />
    </div>
  </section>

</Layout>

<style>
  .faq-section {
    padding: var(--spacing-2xl, 4rem) 0;
    background: var(--color-surface, #fff);
  }
  .faq-section .section-title {
    font-size: var(--text-2xl, 1.75rem);
    font-weight: 700;
    margin-bottom: 2rem;
    text-align: center;
  }
</style>
