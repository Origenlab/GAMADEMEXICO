---
import Layout from '../../layouts/Base.astro';
import '../../styles/services-shared.css';
import Faq from '../../components/Faq.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import LeadCapture from '../../components/LeadCapture.astro';
import { buildOrganizationSchema, buildFAQSchema, buildBreadcrumbSchema } from '../../lib/seo';
import { SITE_NAME, SITE_URL, WHATSAPP_NUMBER } from '../../lib/config';

// Schemas Service + Offer por categoría (precio B2B a cotizar; rangos de referencia de mercado donde disponibles)
const serviceSchemas = [
  {
    '@context': 'https://schema.org',
    '@type': 'Service',
    name: 'Válvulas Contra Incendios',
    description: 'Válvulas OS&Y, angulares, de compuerta y de control certificadas UL/FM para sistemas contra incendios en México. Distribución autorizada Elkhart Brass y Potter Roemer.',
    url: `${SITE_URL}/valvulas-contra-incendios`,
    provider: { '@type': 'Organization', name: SITE_NAME, url: SITE_URL },
    areaServed: { '@type': 'Country', name: 'México' },
    offers: {
      '@type': 'Offer',
      availability: 'https://schema.org/InStock',
      priceCurrency: 'USD',
      priceSpecification: {
        '@type': 'PriceSpecification',
        minPrice: 400,
        maxPrice: 2000,
        priceCurrency: 'USD',
        description: 'Válvulas OS&Y 4" UL/FM con precio referencial de mercado desde ~$400 USD según fabricante (distribuidores México). Rango amplio: diámetro (1.5"–8"), tipo (OS&Y/angular/compuerta/mariposa) y certificación (UL vs FM). Facturación en MXN al tipo de cambio del día.',
      },
      seller: { '@type': 'Organization', name: SITE_NAME, url: SITE_URL },
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'Service',
    name: 'Boquillas y Bocas de Incendio',
    description: 'Boquillas de chorro, niebla y espuma certificadas UL/FM. Bocas de incendio equipadas para sistemas contra incendios industriales y comerciales en México.',
    url: `${SITE_URL}/boquillas-contra-incendios`,
    provider: { '@type': 'Organization', name: SITE_NAME, url: SITE_URL },
    areaServed: { '@type': 'Country', name: 'México' },
    offers: {
      '@type': 'Offer',
      availability: 'https://schema.org/InStock',
      priceCurrency: 'MXN',
      priceSpecification: {
        '@type': 'PriceSpecification',
        minPrice: 3000,
        maxPrice: 5000,
        priceCurrency: 'MXN',
        description: 'Bocas de incendio equipadas: $3,000–$5,000 MXN por unidad (precio de mercado verificado en distribuidores México). Boquillas industriales premium Elkhart Brass (Master Stream, X-Stream) se listan desde $3,085 USD en distribuidores especializados. Facturación en MXN al tipo de cambio.',
      },
      seller: { '@type': 'Organization', name: SITE_NAME, url: SITE_URL },
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'Service',
    name: 'Monitores Contra Incendios',
    description: 'Monitores fijos y portátiles de alta capacidad (250 a 2500 GPM) certificados UL/FM. Modelos manuales y oscilantes para industria pesada, aeropuertos y terminales de combustible.',
    url: `${SITE_URL}/monitores-contra-incendios`,
    provider: { '@type': 'Organization', name: SITE_NAME, url: SITE_URL },
    areaServed: { '@type': 'Country', name: 'México' },
    offers: {
      '@type': 'Offer',
      availability: 'https://schema.org/InStock',
      priceCurrency: 'USD',
      priceSpecification: {
        '@type': 'PriceSpecification',
        minPrice: 6599,
        maxPrice: 39207,
        priceCurrency: 'USD',
        description: 'Monitores Elkhart Brass listados por distribuidores en México: Copperhead 1,250 GPM FM Approved desde $6,599 USD; Monitor Elevado Manual desde $39,207 USD. Precios de referencia de distribuidores especializados + IVA. Facturación en MXN al tipo de cambio del día.',
      },
      seller: { '@type': 'Organization', name: SITE_NAME, url: SITE_URL },
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'Service',
    name: 'Mangueras Contra Incendios',
    description: 'Mangueras certificadas UL/FM en diámetros 1.5" a 3", cubiertas de poliéster y caucho NBR. Para uso industrial, comercial y uso bomberil conforme NFPA 1961.',
    url: `${SITE_URL}/mangueras-contra-incendios`,
    provider: { '@type': 'Organization', name: SITE_NAME, url: SITE_URL },
    areaServed: { '@type': 'Country', name: 'México' },
    offers: {
      '@type': 'Offer',
      availability: 'https://schema.org/InStock',
      priceCurrency: 'MXN',
      priceSpecification: {
        '@type': 'PriceSpecification',
        minPrice: 1500,
        maxPrice: 3500,
        priceCurrency: 'MXN',
        description: 'Manguera 30m × 1.5" IPT 200 PSI: precio referencial de mercado desde ~$1,833 MXN por pieza (distribuidores México). Rango completo $1,500–$3,500 MXN según diámetro (1.5"–3"), longitud (15–30m) y tipo de cubierta (poliéster o hule).',
      },
      seller: { '@type': 'Organization', name: SITE_NAME, url: SITE_URL },
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'Service',
    name: 'Conexiones y Herrajes Contra Incendios',
    description: 'Acoplamientos NST y Storz, adaptadores, llaves de manguera, tomas siamesas y accesorios certificados UL/FM para sistemas contra incendios en México.',
    url: `${SITE_URL}/conexiones-herrajes-contra-incendios`,
    provider: { '@type': 'Organization', name: SITE_NAME, url: SITE_URL },
    areaServed: { '@type': 'Country', name: 'México' },
    offers: {
      '@type': 'Offer',
      availability: 'https://schema.org/InStock',
      priceCurrency: 'MXN',
      priceSpecification: {
        '@type': 'PriceSpecification',
        minPrice: 700,
        maxPrice: 2500,
        priceCurrency: 'MXN',
        description: 'Herrajes NST con precio referencial de mercado desde ~$750 MXN por pieza: válvulas angulares NST desde ~$747 MXN, acoplamientos rígidos desde ~$791 MXN (distribuidores México). Tomas siamesas con tapones, cadena y disco tienen costo mayor por complejidad.',
      },
      seller: { '@type': 'Organization', name: SITE_NAME, url: SITE_URL },
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'Service',
    name: 'Gabinetes e Hidrantes Contra Incendios',
    description: 'Gabinetes murales y de empotrar, hidrantes industriales y columnas hidrantes certificados UL/FM para edificios comerciales, industriales y plantas.',
    url: `${SITE_URL}/gabinetes-hidrantes-contra-incendios`,
    provider: { '@type': 'Organization', name: SITE_NAME, url: SITE_URL },
    areaServed: { '@type': 'Country', name: 'México' },
    offers: {
      '@type': 'Offer',
      availability: 'https://schema.org/InStock',
      priceCurrency: 'MXN',
      priceSpecification: {
        '@type': 'PriceSpecification',
        minPrice: 1527,
        maxPrice: 2500,
        priceCurrency: 'MXN',
        description: 'Gabinetes empotrados para manguera de 30m: precio referencial de mercado $1,527–$2,395 MXN con IVA incluido (distribuidores especializados México: COGARSA, Extinflam/Vallen). Precio de gabinete solo; manguera y boquilla se cotizan por separado.',
      },
      seller: { '@type': 'Organization', name: SITE_NAME, url: SITE_URL },
    },
  },
];

const faqItems = [
  {
    pregunta: '¿Cuánto cuestan las boquillas contra incendios en México?',
    respuesta: 'Las bocas de incendio equipadas estándar tienen un precio de referencia de mercado verificado de $3,000 a $5,000 MXN por unidad (distribuidores especializados México). Las boquillas industriales Elkhart Brass de alto caudal —Master Stream y X-Stream— se listan en distribuidores en México entre $3,085 y $4,429 USD, al ser equipos de importación. La boquilla Auto Eductora HF-350 de 350 GPM se lista en $3,389 USD. El precio exacto depende del tipo de descarga (chorro, niebla, espuma), certificación UL o FM, y caudal requerido.',
  },
  {
    pregunta: '¿Cuánto cuesta equipar un piso completo con sistema contra incendios?',
    respuesta: 'Según referencias del mercado en México, el costo de equipamiento por piso para un sistema contra incendios (sin instalación) empieza desde $6,500 MXN para configuraciones básicas. El costo real varía significativamente según el área del piso, tipo de riesgo (NFPA ligero, ordinario o extra), certificaciones requeridas por aseguradora, número de bocas de incendio, válvulas de control y tipo de mangueras. Solicita cotización con los planos del proyecto para un presupuesto preciso.',
  },
  {
    pregunta: '¿Los equipos Elkhart Brass se cotizan en pesos o dólares?',
    respuesta: 'Los equipos Elkhart Brass son producto de importación con precio base en dólares americanos (USD). Sin embargo, cotizamos y facturamos en pesos mexicanos (MXN) al tipo de cambio del día. Las cotizaciones tienen una vigencia de 15 a 30 días dada la variación cambiaria. Para proyectos de largo plazo, recomendamos confirmar la orden dentro del período de vigencia para fijar el precio en MXN.',
  },
  {
    pregunta: '¿Los precios de los equipos incluyen IVA?',
    respuesta: 'No. Todos los precios de lista y cotizaciones se expresan sin IVA. El IVA (16%) se agrega en la factura CFDI 4.0 como concepto separado. En la cotización formal siempre desglosamos: precio unitario, subtotal, IVA y total con IVA para transparencia completa ante cualquier comité de compras o proceso de licitación.',
  },
  {
    pregunta: '¿Qué factores determinan el precio de una válvula contra incendios?',
    respuesta: 'Los principales factores de precio en válvulas son: diámetro de conexión (desde 1.5" hasta 8"), tipo de operación (OS&Y, angular, mariposa, compuerta), material del cuerpo (bronce fundido, hierro dúctil, acero inoxidable), certificación requerida (UL Listed o FM Approved — FM tiene costo superior) y presión de trabajo (175 PSI o 300 PSI). Como referencia de mercado verificada: una válvula OS&Y de compuerta 4" UL/FM marca Duyar se lista en distribuidores mexicanos a $432 USD + IVA. Las válvulas angulares Elkhart Brass modelo U-30 se listan en distribuidores especializados a $757 USD. Válvulas de mayor diámetro o con certificación FM Approved tienen costo proporcionalmente superior.',
  },
  {
    pregunta: '¿Qué diferencia de precio hay entre equipos UL Listed y FM Approved?',
    respuesta: 'Los equipos con certificación FM Approved generalmente tienen un costo entre 10% y 30% superior a los certificados solo UL Listed. Esto refleja el proceso de certificación FM, que es más estricto y está orientado a instalaciones de riesgo extra (petroquímicas, terminales de combustible, almacenes de alto valor). Para instalaciones comerciales estándar que requieren solo UL, el costo es menor. La certificación requerida depende de la aseguradora y el tipo de riesgo del proyecto.',
  },
  {
    pregunta: '¿Hacen descuentos por volumen o para proyectos grandes?',
    respuesta: 'Sí. Manejamos precios diferenciados para compras de 10 piezas o más en la misma categoría, para proyectos de gran escala y para clientes con pedidos recurrentes. Para proyectos de 50 piezas o más, asignamos un ejecutivo de cuenta con condiciones especiales. Para distribuidores que revenden o integran equipos en sus proyectos, existen condiciones de mayorista. En todos los casos, indica el volumen en tu solicitud para que el asesor incluya las condiciones de precio correctas.',
  },
  {
    pregunta: '¿Tienen financiamiento o crédito para la compra de equipos?',
    respuesta: 'Para clientes empresariales con volumen regular ofrecemos crédito a 30 días previa apertura de cuenta. Para proyectos de mayor envergadura evaluamos esquemas a 60 días. Requerimos información fiscal (constancia SAT, referencias comerciales) para la apertura de crédito. Los pagos se realizan por transferencia bancaria, depósito o tarjeta empresarial. El crédito aplica para clientes recurrentes; las primeras órdenes generalmente requieren pago anticipado.',
  },
];

const structuredData = [
  buildOrganizationSchema(),
  ...serviceSchemas,
  buildFAQSchema(faqItems),
  buildBreadcrumbSchema([
    { name: 'Inicio', url: '/' },
    { name: 'Precios', url: '/precios' },
  ]),
];
---

<Layout
  title="Precios de Equipos Contra Incendios UL/FM en México"
  description="Precios de equipos contra incendios UL/FM en México: válvulas, boquillas, monitores, mangueras y conexiones. Cotización formal con CFDI 4.0 en 24h."
  activePage="servicios"
  structuredData={structuredData}
  ogImage="/img/og-gama-mexico-equipos-contra-incendios.jpg"
  heroTitle="Precios de Equipos Contra Incendios en México"
  heroIntro="Todos los equipos son a cotizar según especificaciones del proyecto. Recibe cotización formal con precios actualizados, disponibilidad real y documentación técnica en menos de 24 horas."
  heroBadge="Precios y Cotización"
  heroMetrics={[
    { valor: '<24h', texto: 'Respuesta garantizada' },
    { valor: 'UL/FM', texto: 'Equipos certificados' },
    { valor: 'MXN', texto: 'Cotización en pesos' },
  ]}
  heroPrimaryText="Solicitar Cotización"
  heroPrimaryLink={`https://wa.me/${WHATSAPP_NUMBER}?text=Hola,%20necesito%20cotización%20de%20equipos%20contra%20incendios`}
  heroSecondaryText="Ver Catálogo"
  heroSecondaryLink="/equipos"
  heroShowRightContent={true}
  showLeadCapture={false}
>
  <Fragment slot="hero-content">
    <p>Como distribuidores autorizados de <strong>Elkhart Brass</strong> en México, suministramos equipos con certificación FM Approved y UL Listed para proyectos industriales, comerciales y de gobierno. Todos los precios son a cotizar: el costo varía según modelo, especificación técnica y volumen.</p>
    <p>En esta página encontrarás información sobre los factores que determinan el precio de cada categoría de equipo, preguntas frecuentes de costo y cómo solicitar tu cotización formal en menos de 24 horas.</p>
  </Fragment>

  <!-- CATEGORÍAS DE EQUIPO -->
  <section class="service-sections" id="categorias" aria-labelledby="categorias-title">
    <div class="container">
      <SectionHeader
        titulo="Categorías de Equipo y Factores de Precio"
        subtitulo="El costo de cada equipo depende del modelo, certificación y especificación técnica de tu proyecto"
        idTitulo="categorias-title"
        parrafo1="No publicamos lista de precios fijos porque los equipos Elkhart Brass se cotizan según especificaciones exactas: diámetro, presión de trabajo, material del cuerpo, tipo de rosca (NST o Storz), certificación requerida (UL o FM) y cantidad. Dos válvulas del mismo tipo pueden tener precios muy distintos si una es de bronce 4'' UL y la otra es de hierro dúctil 6'' FM."
        parrafo2="A continuación explicamos los factores de precio de cada categoría para que puedas preparar mejor tu solicitud de cotización."
      />

      <!-- VÁLVULAS -->
      <div class="service-block" id="valvulas">
        <div class="service-block__header">
          <div class="service-block__icon" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M12 1v4M12 19v4M4.22 4.22l2.83 2.83M16.95 16.95l2.83 2.83M1 12h4M19 12h4M4.22 19.78l2.83-2.83M16.95 7.05l2.83-2.83"/></svg>
          </div>
          <div class="service-block__title-wrap">
            <h3 class="service-block__title">Válvulas Contra Incendios</h3>
            <p class="service-block__subtitle">OS&amp;Y, angulares, compuerta y mariposa — referencia de mercado: OS&amp;Y 4" UL/FM desde ~$432 USD en distribuidores México</p>
          </div>
        </div>
        <div class="service-block__content">
          <div class="service-block__text">
            <p>Las válvulas contra incendios tienen el mayor rango de precios del portafolio porque existen docenas de modelos. La diferencia principal de costo está en el <strong>diámetro (1.5" a 8")</strong>, el <strong>tipo de válvula</strong> (OS&amp;Y para supervisión, angular para boca de incendio, compuerta para línea principal) y la <strong>certificación</strong> (UL Listed o FM Approved).</p>
            <p>Distribuimos válvulas <strong>Elkhart Brass y Potter Roemer</strong> con stock permanente en CDMX y Querétaro. Para proyectos con licitación, entregamos documentación técnica completa con la cotización.</p>
          </div>
          <div class="service-block__features">
            <div class="feature-card">
              <h4 class="feature-card__title">Válvulas OS&amp;Y</h4>
              <p class="feature-card__desc">Para control supervisado con señal al panel. Diámetros 2.5" a 6". Precio varía por diámetro y certificación.</p>
            </div>
            <div class="feature-card">
              <h4 class="feature-card__title">Válvulas Angulares</h4>
              <p class="feature-card__desc">Para bocas de incendio equipadas (BIE). 1.5" y 2.5" en bronce. Certificadas UL/FM.</p>
            </div>
            <div class="feature-card">
              <h4 class="feature-card__title">Válvulas Compuerta</h4>
              <p class="feature-card__desc">Para líneas principales de distribución. Desde 2" hasta 8". Bridadas o ranuradas.</p>
            </div>
            <div class="feature-card">
              <h4 class="feature-card__title">Válvulas Mariposa</h4>
              <p class="feature-card__desc">Para instalaciones con espacio reducido. Ranuradas y bridadas. Certificadas FM en modelos industriales.</p>
            </div>
          </div>
          <div class="service-block__list">
            <h4 class="service-block__list-title">Factores que determinan el precio:</h4>
            <ul class="check-list">
              <li class="check-list__item">Diámetro nominal (1.5" a 8") — el factor de mayor impacto</li>
              <li class="check-list__item">Tipo de conexión: roscada, bridada o ranurada (Victaulic)</li>
              <li class="check-list__item">Certificación: UL Listed vs FM Approved (FM tiene costo superior)</li>
              <li class="check-list__item">Material del cuerpo: bronce, hierro dúctil o acero inoxidable</li>
              <li class="check-list__item">Presión de trabajo: hasta 175 PSI o hasta 300 PSI</li>
              <li class="check-list__item">Incluye supervisión eléctrica (tamper switch)</li>
            </ul>
          </div>
          <div class="service-block__cta">
            <p class="service-block__cta-text">¿Tienes el diámetro y modelo requerido?</p>
            <a
              href={`https://wa.me/${WHATSAPP_NUMBER}?text=Hola,%20necesito%20cotización%20de%20válvulas%20contra%20incendios`}
              class="btn btn--primary btn--sm"
              target="_blank"
              rel="noopener nofollow external"
            >Cotizar válvulas</a>
          </div>
        </div>
      </div>

      <!-- BOQUILLAS -->
      <div class="service-block" id="boquillas">
        <div class="service-block__header">
          <div class="service-block__icon" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m22 8-6 4 6 4V8Z"/><rect x="2" y="6" width="14" height="12" rx="2" ry="2"/></svg>
          </div>
          <div class="service-block__title-wrap">
            <h3 class="service-block__title">Boquillas y Bocas de Incendio</h3>
            <p class="service-block__subtitle">Desde $3,000 MXN — precio de referencia de mercado por unidad equipada</p>
          </div>
        </div>
        <div class="service-block__content">
          <div class="service-block__text">
            <p>Las boquillas y bocas de incendio tienen un rango de mercado referencial de <strong>$3,000 a $5,000 MXN por unidad</strong> para modelos equipados estándar (boca de incendio con manguera y boquilla 1.5" UL). Las boquillas de espuma para instalaciones industriales o de alto riesgo tienen un costo considerablemente mayor por sus especificaciones técnicas adicionales.</p>
            <p>Todos los modelos <strong>Elkhart Brass</strong> incluyen documentación técnica, certificado de conformidad UL/FM y fichas de instalación. Para bocas de incendio equipadas (BIE), indicar si el precio debe incluir gabinete y manguera o solo la boquilla.</p>
          </div>
          <div class="service-block__features">
            <div class="feature-card feature-card--highlight">
              <h4 class="feature-card__title">Boquillas de Chorro</h4>
              <p class="feature-card__desc">Chorro sólido y niebla combinada. Para uso general en bocas de incendio equipadas. Estándar NST.</p>
            </div>
            <div class="feature-card feature-card--highlight">
              <h4 class="feature-card__title">Boquillas Automáticas</h4>
              <p class="feature-card__desc">Apertura automática por temperatura para sistemas automáticos. Certificadas UL. Mayor costo por componente sensible.</p>
            </div>
            <div class="feature-card">
              <h4 class="feature-card__title">Boquillas de Espuma</h4>
              <p class="feature-card__desc">Para sistemas de espuma (NFPA 11). Aplicación petroquímica y almacenes. Precio superior por especialización.</p>
            </div>
            <div class="feature-card">
              <h4 class="feature-card__title">Boquillas Monitores</h4>
              <p class="feature-card__desc">Boquillas de alto caudal para monitores fijos y portátiles. Configuración de caudal ajustable en obra.</p>
            </div>
          </div>
          <div class="service-block__cta">
            <p class="service-block__cta-text">¿Cuántas boquillas necesitas y de qué tipo?</p>
            <a
              href={`https://wa.me/${WHATSAPP_NUMBER}?text=Hola,%20necesito%20cotización%20de%20boquillas%20contra%20incendios`}
              class="btn btn--primary btn--sm"
              target="_blank"
              rel="noopener nofollow external"
            >Cotizar boquillas</a>
          </div>
        </div>
      </div>

      <!-- MONITORES -->
      <div class="service-block" id="monitores">
        <div class="service-block__header">
          <div class="service-block__icon" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8z"/><path d="M12 8v8M8 12h8"/></svg>
          </div>
          <div class="service-block__title-wrap">
            <h3 class="service-block__title">Monitores Contra Incendios</h3>
            <p class="service-block__subtitle">Alta gama industrial — Copperhead Elkhart Brass 1,250 GPM desde $6,599 USD (referencia distribuidores México)</p>
          </div>
        </div>
        <div class="service-block__content">
          <div class="service-block__text">
            <p>Los monitores contra incendios son los equipos de mayor precio en el portafolio por su complejidad y caudales (250 a 2,500 GPM). Como referencia de mercado verificada: el monitor <strong>Copperhead 8593-03X-294 Elkhart Brass</strong> (1,250 GPM, FM Approved, rotación 360°) se lista en distribuidores especializados en México a <strong>$6,599 USD</strong>; los monitores elevados manuales llegan a $39,207 USD. Precios en USD por ser equipo de importación; facturación en MXN al tipo de cambio del día.</p>
            <p>Distribuimos la línea completa <strong>Elkhart Brass y Akron Brass</strong>: portátiles, de carrete, fijos en base giratoria, oscilantes automáticos y remotos. El rango es amplio según capacidad y aplicación — terminales de combustible, aeropuertos, plantas petroquímicas y almacenes de alto riesgo.</p>
          </div>
