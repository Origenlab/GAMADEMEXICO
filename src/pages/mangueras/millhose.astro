---
import Layout from '../../layouts/Base.astro';
import '../../styles/subcategory.css';
import { getCollection } from 'astro:content';
import SubcategoryProductCard from '../../components/SubcategoryProductCard.astro';
import ProductSidebar from '../../components/ProductSidebar.astro';
import RelatedProductsGrid from '../../components/RelatedProductsGrid.astro';
import CotizacionForm from '../../components/CotizacionForm.astro';
import Faq from '../../components/Faq.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import { buildProductCategorySchema, buildBreadcrumbSchema, buildFAQSchema, buildOrganizationSchema } from '../../lib/seo';


// Obtener productos de mangueras
const todasMangueras = (await getCollection('productos', ({ data }) => data.categoria === 'mangueras')).sort((a, b) => a.data.orden - b.data.orden);

// Filtrar productos Millhose por subcategoria
const productosMillhose = todasMangueras.filter(p => p.data.subcategoria === 'millhose');

// Otros productos para la sección de relacionados
const otrasMangueras = todasMangueras.filter(p => !productosMillhose.includes(p));

// Definir las subcategorías de mangueras para el sidebar
const subcategorias = [
  {
    slug: 'millhose',
    nombre: 'Manguera Millhose',
    descripcion: 'Doble forro poliéster, gabinetes',
    activo: true
  },
  {
    slug: 'blindex',
    nombre: 'Manguera Blindex',
    descripcion: 'Resistente a llama y químicos',
    activo: false
  },
  {
    slug: 'succion',
    nombre: 'Manguera de Succión',
    descripcion: 'Refuerzo helicoidal, vacío',
    activo: false
  },
  {
    slug: 'forestal',
    nombre: 'Manguera Forestal',
    descripcion: 'Ultraligera, terreno difícil',
    activo: false
  },
];
const faqItems = [
  { pregunta: '¿Qué es una manguera millhose y para qué se usa?', respuesta: 'La manguera millhose es el tipo de manguera contra incendios más común en sistemas fijos de gabinetes e hidrantes. Está fabricada con recubrimiento de poliéster tejido y forro interior de goma NBR o EPDM. Se instala en gabinetes de 1.5" y 2.5" en edificios industriales, comerciales y residenciales. Cumple con la norma NOM-002-STPS para sistemas fijos de extinción.' },
  { pregunta: '¿Cuánto tiempo dura una manguera millhose sin cambio?', respuesta: 'La vida útil de una manguera millhose es de 10 a 15 años con uso apropiado y mantenimiento regular. Conforme a NFPA 25, se requiere prueba hidrostática cada 5 años a 300 PSI (o 1.5 veces la presión máxima de trabajo) para verificar la integridad del forro y las manguitas de acoplamiento. En ambientes con exposición solar intensa o temperatura extrema, se recomienda inspección anual.' },
  { pregunta: '¿Cuáles son las dimensiones estándar de manguera millhose para gabinetes?', respuesta: 'Las mangueras millhose estándar para gabinetes contra incendios son de 1.5" de diámetro y 15 metros de longitud para sistemas tipo clase II. Para clase III (combinados con hidrante de fachada) se usan mangueras de 2.5" de diámetro y 15 a 20 metros. La longitud correcta depende de la distancia al riesgo más alejado que debe cubrir el gabinete.' },
  { pregunta: '¿Cómo se realiza la prueba de servicio NFPA 1962 en mangueras millhose?', respuesta: 'La norma NFPA 1962 establece que las mangueras de ataque deben someterse a prueba hidrostática anual a una presión de 300 PSI durante al menos 3 minutos. Durante la prueba se inspecciona visualmente toda la longitud buscando burbujas, fugas en el forro, deformaciones o daños en los acoples. Si la manguera falla la prueba, debe retirarse del servicio de inmediato. Gama de México puede orientar sobre el procedimiento correcto y la documentación requerida.' },
  { pregunta: '¿Qué diferencia hay entre manguera de ataque y manguera de suministro?', respuesta: 'La manguera de ataque (como la millhose) opera con presiones de trabajo de 100 a 300 PSI y se usa para llevar agua directamente al punto del incendio. La manguera de suministro es de mayor diámetro (generalmente 4" a 6"), opera a menor presión y se usa para abastecer el camión de bomberos desde un hidrante. La millhose en diámetros de 1.5" y 2.5" es la manguera de ataque estándar para brigadas industriales y cuerpos de bomberos.' },
  { pregunta: '¿Una manguera millhose UL Listed es obligatoria en México?', respuesta: 'La certificación UL Listed no es legalmente obligatoria en México, pero es exigida por muchos proyectos que siguen estándares NFPA, aseguradoras internacionales y clientes industriales del sector petroquímico o automotriz. Las mangueras con certificación UL Listed han sido probadas de forma independiente y garantizan cumplimiento con NFPA 1961. Para proyectos bajo NOM-002-STPS se aceptan mangueras con especificaciones equivalentes. Asesoramos en la selección correcta según el tipo de proyecto.' },
];

const structuredData = [
  buildOrganizationSchema(),
  buildProductCategorySchema({
    name: 'Manguera Millhose para Gabinete Contra Incendios',
    description: 'Manguera millhose 1.5" y 2.5" para gabinetes e hidrantes. NOM-002-STPS. Stock permanente, envíos México.',
    image: '/img/mangueras-contra-incendios/manguera-blindex-1-5-15m-detalle.avif',
    url: '/mangueras/millhose',
    category: 'Mangueras Contra Incendios',
    brand: 'Elkhart Brass',
    reviewAuthor: 'Ing. Carlos Mendoza',
    reviewBody: 'Excelente calidad y respaldo técnico de Gama de México. Equipos certificados con entrega puntual.',
    reviewDate: '2025-03-15',
    ratingCount: 32,
    reviewCount: 32,
  }),
  buildBreadcrumbSchema([
    { name: 'Inicio', url: '/' },
    { name: 'Equipos', url: '/equipos' },
    { name: 'Mangueras Contra Incendios', url: '/mangueras-contra-incendios' },
  ]),
  buildFAQSchema(faqItems),
];

---

<Layout
  structuredData={structuredData}
  title="Manguera Millhose 1.5&quot; y 2.5&quot; NFPA 1961 para Gabinetes | Gama de México"
  description="Manguera Millhose doble forro poliéster para gabinetes contra incendio. 300 PSI, certificación NFPA 1961, forro EPDM/NBR. Para edificios industriales y comerciales en México. Stock permanente."
  activePage="equipos"
  heroTitle="Manguera Millhose"
  heroIntro="Mangueras de doble forro poliéster para uso en gabinetes contra incendio y sistemas de protección activa. Su construcción con recubrimiento exterior de caucho sintético proporciona durabilidad excepcional y resistencia a la intemperie, ideal para instalaciones permanentes."
  heroBadge="Mangueras Contra Incendios"
  heroMetrics={[
    { valor: "300", texto: "PSI presión" },
    { valor: "1.5\"/2.5\"", texto: "Diámetros" },
    { valor: "NFPA", texto: "Certificación" }
  ]}
  heroPrimaryText="Ver Catálogo"
  heroPrimaryLink="#catalogo"
  heroSecondaryText="Solicitar Cotización"
  heroSecondaryLink="#cotizar"
  heroShowRightContent={true}
>

  <!-- HERO CONTENT -->
  <Fragment slot="hero-content">
    <p>La <strong>manguera Millhose</strong> es el estándar de la industria para instalaciones en gabinetes contra incendio de edificios comerciales, industriales y residenciales de altura. Su construcción de doble forro incluye tejido interno de poliéster de alta tenacidad y recubrimiento exterior de caucho sintético EPDM que resiste exposición a rayos UV, ozono y condiciones de almacenamiento prolongado sin degradación.</p>
    <p><strong>Gama de México</strong> mantiene inventario permanente de mangueras Millhose en diámetros de 1.5" y 2.5" con longitudes de 15, 25 y 30 metros. Todas nuestras mangueras cumplen con NFPA 1961 y están probadas hidrostáticamente a 600 PSI. Disponibles con coples de latón, aluminio o Storz según especificación del proyecto. Atendemos constructoras, empresas de mantenimiento de sistemas contra incendio y distribuidores de equipos de seguridad.</p>
  </Fragment>
  <!-- BREADCRUMB -->
  <Breadcrumb />



  <!-- MAIN CONTENT WITH SIDEBAR -->
  <section class="subcat-content">
    <div class="container">
      <div class="subcat-layout">

        <!-- MAIN CONTENT (LEFT) -->
        <main class="subcat-main">

          <!-- CATALOG HEADER -->
          <div class="catalog-header">
            <div class="catalog-header__text">
              <h2 class="catalog-header__title">Catálogo de Mangueras Millhose</h2>
              <p class="catalog-header__desc">Selecciona el producto que mejor se adapte a tu operación</p>
            </div>
            <div class="catalog-header__count">
              <span class="catalog-header__number">{productosMillhose.length}</span>
              <span class="catalog-header__label">producto{productosMillhose.length !== 1 ? 's' : ''}</span>
            </div>
          </div>

          <!-- PRODUCTS GRID -->
          <div class="categories__grid">
            {productosMillhose.map((producto) => (
              <SubcategoryProductCard
                title={producto.data.title}
                description={producto.data.description}
                brand={producto.data.marca}
                image={producto.data.imagen}
                productSlug={producto.id}
                flow={producto.data.flujo}
                material={producto.data.material}
                certifications={producto.data.certificaciones}
              />
            ))}
          </div>

          {productosMillhose.length === 0 && (
            <div class="catalog-empty">
              <div class="catalog-empty__icon">🔍</div>
              <h3 class="catalog-empty__title">Próximamente más opciones</h3>
              <p class="catalog-empty__text">Estamos agregando más productos de mangueras Millhose de diferentes configuraciones. Mientras tanto, solicita una cotización personalizada.</p>
              <a href="#cotizar" class="btn btn--primary">Solicitar Cotización</a>
            </div>
          )}

          <!-- TECHNICAL INFO -->
          <div class="tech-info">
            <h3 class="tech-info__title">Especificaciones Técnicas Generales</h3>
            <div class="tech-info__grid">
              <div class="tech-info__item">
                <span class="tech-info__label">Presión trabajo</span>
                <span class="tech-info__value">300 PSI (21 bar)</span>
              </div>
              <div class="tech-info__item">
                <span class="tech-info__label">Presión prueba</span>
                <span class="tech-info__value">450 PSI (31 bar)</span>
              </div>
              <div class="tech-info__item">
                <span class="tech-info__label">Diámetros</span>
                <span class="tech-info__value">1.5" y 2.5"</span>
              </div>
              <div class="tech-info__item">
                <span class="tech-info__label">Longitudes</span>
                <span class="tech-info__value">15m y 30m</span>
              </div>
              <div class="tech-info__item">
                <span class="tech-info__label">Forro</span>
                <span class="tech-info__value">Doble poliéster</span>
              </div>
              <div class="tech-info__item">
                <span class="tech-info__label">Interior</span>
                <span class="tech-info__value">EPDM / NBR</span>
              </div>
            </div>
          </div>

          <!-- CTA FINAL -->
          <div class="subcat-cta-final">
            <div class="subcat-cta-final__content">
              <h3 class="subcat-cta-final__title">¿Necesitas configuración especial?</h3>
              <p class="subcat-cta-final__desc">Ofrecemos mangueras con acoples NH/NST o Storz en aluminio, bronce o latón según tu requerimiento.</p>
            </div>
            <a href="#cotizar" class="btn btn--primary">Solicitar Cotización</a>
          </div>

        </main>

        <!-- SIDEBAR (RIGHT) -->
        <ProductSidebar
          navTitulo="Tipos de Mangueras"
          subcategorias={subcategorias}
          baseUrl="/mangueras"
          backLinkHref="/mangueras-contra-incendios"
          backLinkTexto="Ver todas las mangueras"
          certificaciones={[
            { siglas: "FM", nombre: "Factory Mutual" },
            { siglas: "UL", nombre: "UL Listed" },
            { siglas: "NOM", nombre: "NOM-002-STPS" }
          ]}
          marcas={["Key Fire Hose", "Snap-Tite", "All American Hose", "Niedner"]}
          aplicaciones={[
            "Industria manufacturera",
            "Gabinetes contra incendios",
            "Uso industrial general",
            "Aplicaciones de riego"
          ]}
          productosRelacionados={[
            { href: "/gabinetes-hidrantes-contra-incendios", nombre: "Gabinetes e Hidrantes" },
            { href: "/boquillas-contra-incendios", nombre: "Boquillas Contra Incendios" },
            { href: "/valvulas-contra-incendios", nombre: "Válvulas Contra Incendios" },
            { href: "/conexiones-herrajes-contra-incendios", nombre: "Conexiones y Herrajes" }
          ]}
        />

      </div>
    </div>
  </section>

  <!-- RELATED PRODUCTS -->
  <RelatedProductsGrid
    titulo="Otras Mangueras Contra Incendios"
    subtitulo="Explora más opciones para tu sistema de protección"
    productos={otrasMangueras}
    maxProductos={3}
    verTodosLink="/mangueras-contra-incendios"
    verTodosTexto="Ver todas las mangueras"
  />

  <CotizacionForm
    titulo="Cotiza Mangueras Mill Hose"
    tipoEquipo="Mangueras"
    pagina="Mangueras Mill Hose"
  />


  <!-- FAQ -->
  <section class="faq-section" id="faq" aria-labelledby="faq-title">
    <div class="container">
      <h2 id="faq-title" class="section-title">Preguntas Frecuentes</h2>
      <Faq items={faqItems} id="faq" />
    </div>
  </section>

</Layout>

<style>
  .faq-section {
    padding: var(--spacing-2xl, 4rem) 0;
    background: var(--color-surface, #fff);
  }
  .faq-section .section-title {
    font-size: var(--text-2xl, 1.75rem);
    font-weight: 700;
    margin-bottom: 2rem;
    text-align: center;
  }
</style>
