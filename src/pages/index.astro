---
import Layout from '../layouts/Base.astro';
import SectionHeader from '../components/SectionHeader.astro';
import ServiceCard from '../components/ServiceCard.astro';
import CategoryCard from '../components/CategoryCard.astro';
import Faq from '../components/Faq.astro';
import BlogRecent from '../components/blog/BlogRecent.astro';
import {
  buildOrganizationSchema,
  buildLocalBusinessSchema,
  buildWebSiteSchema,
  buildFAQSchema,
} from '../lib/seo';

// FAQ data (usada en el HTML y en el schema)
const faqItems = [
  {
    pregunta: '¿Cómo puedo solicitar una cotización de equipos contra incendios en Gama de México?',
    respuesta: 'Puedes solicitar tu cotización a través de nuestro formulario en línea (se envía directo a WhatsApp), escribiéndonos al WhatsApp 55 6529 8240, o llamando al 55 1543 7164. Solo necesitamos el tipo de equipo, las cantidades aproximadas y la ubicación de entrega. Respondemos en menos de 24 horas.',
  },
  {
    pregunta: '¿Qué tipos de equipos contra incendios venden?',
    respuesta: 'Manejamos un catálogo completo en seis categorías: Monitores (tipo corazón, cuello de cisne, certificados y UL Listed), Boquillas (tipo pistola, turbo jet y certificadas), Mangueras (millhose, blindex y de succión), Válvulas (compuerta, globo y angular), Conexiones y herrajes de bronce (chiflones, adaptadores, coples, toma siamesa, conexión Y), y Gabinetes e hidrantes (tipo 30ME e hidrante de banqueta).',
  },
  {
    pregunta: '¿Realizan envíos de equipos contra incendios a todo México?',
    respuesta: 'Sí, realizamos envíos a toda la República Mexicana. Operamos desde Ciudad de México (Santa Fe) y Querétaro, lo que permite coordinar logística eficiente al centro, norte y sureste del país.',
  },
  {
    pregunta: '¿Ofrecen asesoría técnica para elegir equipos contra incendios?',
    respuesta: 'Sí. Nuestros asesores técnicos evalúan tipo de riesgo, normativa aplicable (NOM-002-STPS, protección civil), especificaciones hidráulicas y de diseño para recomendarte los componentes exactos. La asesoría es gratuita y sin compromiso.',
  },
  {
    pregunta: '¿Los equipos contra incendios que venden tienen certificaciones?',
    respuesta: 'Sí. Como distribuidores autorizados de Elkhart Brass contamos con monitores y boquillas certificados UL (Underwriters Laboratories) y FM (Factory Mutual). Proporcionamos documentación técnica para verificaciones de protección civil.',
  },
  {
    pregunta: '¿Dónde se ubican las sucursales de Gama de México?',
    respuesta: 'Tenemos dos sucursales: Prol. Paseo de la Reforma 1015, Piso 1, Santa Fe, 01376 Ciudad de México, y Avenida Constituyentes 120, Santiago de Querétaro, 76030. Horario: lunes a domingo de 6:00 a 16:00 horas.',
  },
  {
    pregunta: '¿Qué sectores o industrias atiende Gama de México?',
    respuesta: 'Atendemos plantas manufactureras, industria química y petroquímica, terminales de almacenamiento, centros de datos, constructoras, hospitales, hoteles, corporativos, firmas de ingeniería, instaladores certificados y brigadas de protección civil. Ofrecemos venta unitaria y cotizaciones corporativas.',
  },
];

const structuredData = [
  buildOrganizationSchema(),
  buildLocalBusinessSchema(),
  buildWebSiteSchema(),
  buildFAQSchema(faqItems),
];
---

<Layout
  title="Equipos Contra Incendios México | Gama de México"
  description="Distribuidor Elkhart Brass México. Monitores, boquillas, mangueras, válvulas y gabinetes contra incendios certificados UL/FM. Envíos nacionales."
  activePage="inicio"
  structuredData={structuredData}
  showLeadCapture={true}
  heroTitle="Equipos Contra Incendios en México"
  heroIntro="Suministro profesional de equipos certificados para protección industrial, comercial y residencial. Asesoría técnica, inventario y logística nacional para proyectos críticos."
  heroBadge="Distribuidor Autorizado Elkhart Brass"
  heroMetrics={[
    { valor: "UL/FM", texto: "Equipos certificados" },
    { valor: "24h", texto: "Respuesta cotización" },
    { valor: "Nacional", texto: "Cobertura envíos" }
  ]}
  heroPrimaryText="Solicitar Cotización"
  heroPrimaryLink="#cotizar"
  heroSecondaryText="Ver Catálogo de Equipos"
  heroSecondaryLink="#equipos"
  heroShowRightContent={true}
>

  <!-- HERO CONTENT -->
  <Fragment slot="hero-content">
    <p><strong>Gama de México</strong> distribuye monitores Elkhart Brass Copperhead y Stinger (hasta 2,000 GPM), boquillas turbo jet y tipo pistola, mangueras Blindex de cuatro capas para petroquímica, válvulas OS&Y certificadas UL/FM y conexiones de bronce con toma siamesa FDC. Todo cumple NFPA 13, 14 y 24. Cada pieza viene con ficha técnica del fabricante, certificados de conformidad y la documentación que protección civil y aseguradoras piden en verificaciones.</p>
    <p>Nuestra sucursal en Santa Fe, CDMX, atiende zona metropolitana y sur del país. Desde Querétaro (Av. Constituyentes 120) cubrimos el corredor del Bajío, las plantas automotrices de Aguascalientes y San Luis Potosí, y coordinamos envíos al norte. Si tu proyecto necesita especificar equipo contra incendio para una refinería, un centro de datos, una nave industrial o un edificio en construcción, te ayudamos a definir modelo, diámetro, presión y material según el riesgo real de tu instalación.</p>
  </Fragment>

  <!-- CATEGORIAS -->
  <section class="categories" id="equipos" aria-labelledby="categories-title">
    <div class="container">
      <SectionHeader
        titulo="Catálogo de Equipos Contra Incendios: Monitores, Boquillas, Mangueras y Más"
        subtitulo="Equipos certificados UL y FM de Elkhart Brass. Selecciona una categoría para conocer productos y solicitar cotización"
        idTitulo="categories-title"
        parrafo1="Monitores para control perimetral, boquillas para dirección de flujo, mangueras de descarga e industriales, válvulas de compuerta y globo, conexiones de bronce y gabinetes para instalaciones fijas. Todo con certificación UL y FM de Elkhart Brass — el fabricante que lleva 120 años haciendo equipo que aguanta condiciones reales de operación."
        parrafo2="Cada producto viene con ficha técnica del fabricante, certificados de conformidad y compatibilidad con sistemas contra incendios existentes. Si tu proyecto necesita documentación para protección civil o aseguradoras, la tenemos."
      />
      <div class="categories__grid">
        <CategoryCard
          titulo="Monitores Contra Incendios"
          subtitulo="Lanzadores de agua para protección perimetral"
          enlace="/monitores-contra-incendios"
          imagen="/img/monitores-contra-incendios/monitor-tipo-corazon-contra-incendios-industrial-tres-cuartos-10.avif"
          subcategorias={[
            { nombre: "Monitor tipo corazón", enlace: "/monitores/tipo-corazon" },
            { nombre: "Monitor cuello de cisne", enlace: "/monitores/cuello-cisne" },
            { nombre: "Monitor certificado FM", enlace: "/monitores/certificado-fm" },
            { nombre: "Monitor UL Listed", enlace: "/monitores/ul-listed" }
          ]}
        />
        <CategoryCard
          titulo="Boquillas Contra Incendios"
          subtitulo="Control y dirección de flujo de agua"
          enlace="/boquillas-contra-incendios"
          imagen="/img/boquillas-contra-incendios/boquilla-tipo-pistola-contra-incendios-estacion-bomberos-01.avif"
          subcategorias={[
            { nombre: "Boquilla tipo pistola", enlace: "/boquillas/tipo-pistola" },
            { nombre: "Boquilla turbo jet", enlace: "/boquillas/turbo-jet" },
            { nombre: "Boquilla industrial", enlace: "/boquillas/industrial" },
            { nombre: "Boquilla certificada", enlace: "/boquillas/certificada" }
          ]}
        />
        <CategoryCard
          titulo="Mangueras Contra Incendios"
          subtitulo="Conducción de agua a presión industrial"
          enlace="/mangueras-contra-incendios"
          imagen="/img/mangueras-contra-incendios/manguera-forestal-contra-incendios-vista-lateral-06.avif"
          subcategorias={[
            { nombre: "Manguera Millhose", enlace: "/mangueras/millhose" },
            { nombre: "Manguera Blindex", enlace: "/mangueras/blindex" },
            { nombre: "Manguera de succión", enlace: "/mangueras/succion" },
            { nombre: "Manguera forestal", enlace: "/mangueras/forestal" }
          ]}
        />
        <CategoryCard
          titulo="Válvulas Contra Incendios"
          subtitulo="Control de flujo hidráulico en sistemas contra incendio"
          enlace="/valvulas-contra-incendios"
          imagen="/img/valvulas-contra-incendios/valvula-check-swing-bridada-contra-incendios-hierro-ductil-16.avif"
          subcategorias={[
            { nombre: "Válvula de compuerta OS&Y", enlace: "/valvulas/compuerta" },
            { nombre: "Válvula de globo", enlace: "/valvulas/globo" },
            { nombre: "Válvula de retención", enlace: "/valvulas/retencion" },
            { nombre: "Válvula mariposa", enlace: "/valvulas/mariposa" }
          ]}
        />
        <CategoryCard
          titulo="Conexiones y Herrajes de Bronce"
          subtitulo="Acoplamiento y distribución para redes contra incendio"
          enlace="/conexiones-herrajes-contra-incendios"
          imagen="/img/conexiones-herrajes/toma-siamesa-2a-plain-frontal.avif"
          subcategorias={[
            { nombre: "Adaptadores de bronce", enlace: "/conexiones/adaptadores" },
            { nombre: "Conexión Y (Wye)", enlace: "/conexiones/wye" },
            { nombre: "Toma siamesa FDC", enlace: "/conexiones/siamesa" },
            { nombre: "Coples y reducciones", enlace: "/conexiones/coples" },
            { nombre: "Chiflones de tres pasos", enlace: "/conexiones/chiflones" },
            { nombre: "Accesorios y herrajes", enlace: "/conexiones/accesorios" }
          ]}
        />
        <CategoryCard
          titulo="Gabinetes e Hidrantes"
          subtitulo="Almacenamiento y toma de agua para edificios e industria"
          enlace="/gabinetes-hidrantes-contra-incendios"
          imagen="/img/gabinetes-hidrantes/gabinete-manguera-producto-frontal.avif"
          subcategorias={[
            { nombre: "Gabinete tipo 30ME", enlace: "/gabinetes/tipo-30me" },
            { nombre: "Gabinete empotrado", enlace: "/gabinetes/empotrado" },
            { nombre: "Hidrantes", enlace: "/gabinetes/hidrantes" },
            { nombre: "Estaciones de manguera", enlace: "/gabinetes/estaciones" }
          ]}
        />
      </div>
    </div>
  </section>

  <!-- SERVICIOS -->
  <section class="services" id="servicios" aria-labelledby="services-title">
    <div class="container">
      <SectionHeader
        titulo="Servicios de Venta y Asesoría en Equipos Contra Incendios"
        subtitulo="Venta, asesoría técnica y logística de equipos contra incendios para el sector industrial, comercial y residencial en México"
        enlaceTexto="Ver todos los servicios"
        enlaceUrl="/servicios"
        idTitulo="services-title"
        parrafo1="Además de vender equipo, te ayudamos a especificarlo. Nuestros asesores técnicos revisan las condiciones de tu instalación: capacidad hidráulica, tipo de riesgo, normativa NOM aplicable y requisitos de tu aseguradora. El objetivo es que compres exactamente lo que necesitas, sin sobreespecificar ni quedarte corto."
        parrafo2="Atendemos desde un reemplazo de válvula para mantenimiento preventivo hasta cotizaciones completas para plantas industriales o licitaciones gubernamentales. Todo con documentación técnica, certificados de origen y respaldo para verificaciones de protección civil."
      />
      <div class="services__grid">
        <ServiceCard
          id="garantia"
          titulo="Garantía y Respaldo Técnico"
          descripcion="Todos nuestros equipos incluyen <strong>garantía del fabricante</strong> y respaldo técnico real. Documentación completa, <strong>certificados UL y FM</strong>, fichas técnicas oficiales y soporte postventa para verificaciones de protección civil."
          enlace="/servicios/garantia"
          imagen="/img/asesora-certificacion-elkhart-brass-equipos-contra-incendios.avif"
        />
        <ServiceCard
          id="asesoria"
          titulo="Asesoría Técnica Especializada"
          descripcion="Ingenieros especializados te ayudan a seleccionar <strong>equipos contra incendios</strong> según las especificaciones de tu proyecto, tipo de riesgo y <strong>normativa NOM</strong> aplicable. Asesoría sin costo para sistemas de protección contra incendios."
          enlace="/servicios/asesoria"
          imagen="/img/ingenieros-obra-civil-planos-sistema-contra-incendios.avif"
        />
        <ServiceCard
          id="empresas"
          titulo="Atención a Empresas y Proyectos"
          descripcion="Servicio dedicado para <strong>constructoras, instaladores certificados, plantas industriales</strong> y proyectos de gran escala. Cotizaciones para <strong>licitaciones</strong>, obras gubernamentales y desarrollos inmobiliarios en toda la República Mexicana."
          enlace="/servicios/empresas"
          imagen="/img/licitacion-gobierno-proyecto-contra-incendios.avif"
        />
        <ServiceCard
          id="mantenimiento"
          titulo="Suministro para Mantenimiento"
          descripcion="Reposición de <strong>piezas, refacciones y accesorios</strong> para mantenimiento preventivo y correctivo de <strong>sistemas contra incendios</strong> existentes. Disponibilidad de válvulas, conexiones, mangueras y herrajes de bronce para reparaciones inmediatas."
          enlace="/servicios/mantenimiento"
          imagen="/img/tecnico-almacen-valvulas-bronce-equipos-contra-incendios.avif"
        />
        <ServiceCard
          id="envios"
          titulo="Logística y Envíos Nacionales"
          descripcion="<strong>Envíos de equipos contra incendios a toda la República Mexicana</strong>. Coordinamos entregas directas a obra, planta industrial o almacén. Embalaje especializado para monitores, válvulas y equipos de alto valor."
          enlace="/servicios/envios"
          imagen="/img/supervisor-logistica-envio-valvulas-contra-incendios.avif"
        />
        <ServiceCard
          id="cotizaciones"
          titulo="Cotizaciones Corporativas"
          descripcion="Procesos de <strong>cotización y facturación</strong> para compras corporativas, licitaciones públicas y proyectos gubernamentales. Precios competitivos en <strong>venta al mayoreo de equipos contra incendios</strong> con distribución directa."
          enlace="/servicios/cotizaciones"
          imagen="/img/director-gama-mexico-showroom-elkhart-brass-premium.avif"
        />
      </div>
    </div>
  </section>

  <!-- TRUST -->
  <section class="trust" aria-labelledby="trust-title">
    <div class="container">
      <SectionHeader
        titulo="Por Qué Elegir a Gama de México como tu Proveedor de Equipos Contra Incendios"
        subtitulo="Distribuidor autorizado Elkhart Brass con cobertura nacional, asesoría técnica y disponibilidad inmediata"
        idTitulo="trust-title"
        parrafo1="Si tu proveedor te entrega equipo sin certificación vigente o sin la documentación que pide protección civil, el problema termina siendo tuyo. En Gama de México trabajamos con producto original Elkhart Brass, con certificaciones UL y FM, y conocemos las normativas mexicanas: NOM-002-STPS, requisitos de aseguradoras y estándares NFPA."
        parrafo2="Operamos desde CDMX y Querétaro con inventario permanente de lo que más se usa. Eso significa entregas más rápidas y menos esperas de importación. Si necesitas algo especial, lo gestionamos directo con el fabricante."
      />
      <div class="trust__grid">
        <div class="trust__item">
          <h3 class="trust__item-title">Experiencia comprobada</h3>
          <p class="trust__item-desc">Años atendiendo al sector industrial, comercial y de construcción en México con soluciones confiables.</p>
        </div>
        <div class="trust__item">
          <h3 class="trust__item-title"><a href="/servicios/garantia">Calidad garantizada</a></h3>
          <p class="trust__item-desc">Distribuidores autorizados Elkhart Brass. Equipos con <a href="/servicios/garantia#certificados-ul-fm">certificaciones UL y FM</a>, garantía de funcionamiento en cada producto.</p>
        </div>
        <div class="trust__item">
          <h3 class="trust__item-title">Asesoría técnica real</h3>
          <p class="trust__item-desc">No solo vendemos: te ayudamos a seleccionar lo correcto para tu proyecto específico y sus requerimientos.</p>
        </div>
        <div class="trust__item">
          <h3 class="trust__item-title">Disponibilidad inmediata</h3>
          <p class="trust__item-desc">Inventario constante de los productos más solicitados para entregas rápidas y sin demoras.</p>
        </div>
        <div class="trust__item">
          <h3 class="trust__item-title">Cobertura nacional</h3>
          <p class="trust__item-desc">Envíos a toda la República Mexicana con opciones de logística coordinada a tu obra o instalación.</p>
        </div>
        <div class="trust__item">
          <h3 class="trust__item-title">Atención personalizada</h3>
          <p class="trust__item-desc">Un asesor asignado que conoce tu proyecto y da seguimiento puntual a cada requerimiento.</p>
        </div>
      </div>

      <div class="trust__testimonials-header">
        <h3 class="trust__testimonials-title">Lo que dicen nuestros clientes</h3>
        <p class="trust__testimonials-subtitle">Empresas de todo México confían en Gama de México para sus equipos contra incendios</p>
      </div>
      <div class="trust__testimonials">
        <blockquote class="testimonial testimonial--verified">
          <div class="testimonial__stars" aria-label="5 estrellas">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
          <p class="testimonial__text">"Gama de México nos asesoró de manera profesional para implementar nuestro sistema contra incendios con equipos certificados UL y FM. El proceso de cotización fue transparente, la entrega puntual y el seguimiento técnico excepcional. Como empresa de ingeniería, valoramos trabajar con proveedores que entienden la importancia de las certificaciones y la normatividad."</p>
          <div class="testimonial__author">
            <div class="testimonial__avatar testimonial__avatar--logo">
              <img src="/img/clientes/proyecto-red-logo.svg" alt="Logo Proyecto Red" width="40" height="40" loading="lazy" />
            </div>
            <div class="testimonial__info">
              <span class="testimonial__name">Ing. Juan Carlos Rodríguez</span>
              <span class="testimonial__role">Director de Proyectos</span>
              <a href="https://proyectored.com.mx/" target="_blank" rel="noopener" class="testimonial__company-link">Proyecto Red</a>
            </div>
          </div>
        </blockquote>
        <blockquote class="testimonial testimonial--verified">
          <div class="testimonial__stars" aria-label="5 estrellas">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
          <p class="testimonial__text">"Como empresa especializada en mantenimiento de extintores, requerimos proveedores que manejen equipos con certificaciones reales. Gama de México nos surte válvulas, mangueras y conexiones Elkhart Brass con documentación completa. Siempre tienen stock y la asesoría técnica es seria."</p>
          <div class="testimonial__author">
            <div class="testimonial__avatar testimonial__avatar--logo">
              <img src="/img/clientes/mantenimiento-extintores-logo.svg" alt="Logo Mantenimiento de Extintores" width="40" height="40" loading="lazy" />
            </div>
            <div class="testimonial__info">
              <span class="testimonial__name">Ing. Roberto Sánchez M.</span>
              <span class="testimonial__role">Gerente de Operaciones</span>
              <a href="https://mantenimientodeextintores.mx/" target="_blank" rel="noopener" class="testimonial__company-link">Mantenimiento de Extintores</a>
            </div>
          </div>
        </blockquote>
        <blockquote class="testimonial testimonial--verified">
          <div class="testimonial__stars" aria-label="5 estrellas">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
          <p class="testimonial__text">"Necesitábamos consolidar chiflones, adaptadores, coples y tomas siamesas con un solo proveedor. Gama de México tenía todo en inventario con certificaciones UL y FM. La cotización llegó el mismo día y el envío se coordinó sin contratiempos. Un aliado estratégico para nuestro negocio de seguridad industrial."</p>
          <div class="testimonial__author">
            <div class="testimonial__avatar testimonial__avatar--logo">
              <img src="/img/clientes/equipo-seguridad-industrial-logo.svg" alt="Logo Equipo de Seguridad Industrial" width="40" height="40" loading="lazy" />
            </div>
            <div class="testimonial__info">
              <span class="testimonial__name">Lic. Fernando García T.</span>
              <span class="testimonial__role">Director Comercial</span>
              <a href="https://equipo-de-seguridad-industrial.com/" target="_blank" rel="noopener" class="testimonial__company-link">Equipo de Seguridad Industrial</a>
            </div>
          </div>
        </blockquote>
        <blockquote class="testimonial testimonial--verified">
          <div class="testimonial__stars" aria-label="5 estrellas">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
          <p class="testimonial__text">"En el sector de maquinaria de construcción, la seguridad contra incendios es crítica. Gama de México nos provee monitores y boquillas certificadas UL para nuestros talleres y patios de equipos. Excelente asesoría técnica y disponibilidad de productos Elkhart Brass."</p>
          <div class="testimonial__author">
            <div class="testimonial__avatar testimonial__avatar--logo">
              <img src="/img/clientes/maquinas-construccion-logo.svg" alt="Logo Máquinas de Construcción" width="40" height="40" loading="lazy" />
            </div>
            <div class="testimonial__info">
              <span class="testimonial__name">Ing. Arturo Méndez V.</span>
              <span class="testimonial__role">Gerente de Seguridad</span>
              <a href="https://maquinasdeconstruccion.com/" target="_blank" rel="noopener" class="testimonial__company-link">Máquinas de Construcción</a>
            </div>
          </div>
        </blockquote>
        <blockquote class="testimonial testimonial--verified">
          <div class="testimonial__stars" aria-label="5 estrellas">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
          <p class="testimonial__text">"Nuestras instalaciones de calentadores solares requieren sistemas de protección contra incendios confiables. Gama de México nos suministró gabinetes, válvulas y mangueras con toda la documentación para cumplir con protección civil. Servicio profesional y entregas puntuales."</p>
          <div class="testimonial__author">
            <div class="testimonial__avatar testimonial__avatar--logo">
              <img src="/img/clientes/calentadores-solares-logo.svg" alt="Logo De Calentadores Solares" width="40" height="40" loading="lazy" />
            </div>
            <div class="testimonial__info">
              <span class="testimonial__name">Ing. Laura Martínez R.</span>
              <span class="testimonial__role">Directora de Instalaciones</span>
              <a href="https://decalentadoressolares.com/" target="_blank" rel="noopener" class="testimonial__company-link">De Calentadores Solares</a>
            </div>
          </div>
        </blockquote>
        <blockquote class="testimonial testimonial--verified">
          <div class="testimonial__stars" aria-label="5 estrellas">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
          <p class="testimonial__text">"En seguridad privada, la protección contra incendios es parte integral de nuestros servicios. Gama de México nos provee válvulas de compuerta, mangueras y equipos certificados con respaldo técnico real. Excelente relación comercial y tiempos de respuesta inmediatos."</p>
          <div class="testimonial__author">
            <div class="testimonial__avatar testimonial__avatar--logo">
              <img src="/img/clientes/seguridad-privada-mx-logo.svg" alt="Logo Seguridad Privada MX" width="40" height="40" loading="lazy" />
            </div>
            <div class="testimonial__info">
              <span class="testimonial__name">Lic. Carlos Ramírez H.</span>
              <span class="testimonial__role">Director de Operaciones</span>
              <a href="https://seguridadprivadamx.com/" target="_blank" rel="noopener" class="testimonial__company-link">Seguridad Privada MX</a>
            </div>
          </div>
        </blockquote>
