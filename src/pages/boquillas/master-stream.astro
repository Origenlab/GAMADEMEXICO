---
import Layout from '../../layouts/Base.astro';
import '../../styles/subcategory.css';
import { getCollection } from 'astro:content';
import SubcategoryProductCard from '../../components/SubcategoryProductCard.astro';
import ProductSidebar from '../../components/ProductSidebar.astro';
import RelatedProductsGrid from '../../components/RelatedProductsGrid.astro';
import CotizacionForm from '../../components/CotizacionForm.astro';
import Faq from '../../components/Faq.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import { buildProductCategorySchema, buildBreadcrumbSchema, buildFAQSchema, buildOrganizationSchema } from '../../lib/seo';


// Obtener productos de boquillas
const todasBoquillas = (await getCollection('productos', ({ data }) => data.categoria === 'boquillas')).sort((a, b) => a.data.orden - b.data.orden);

// Filtrar boquillas master stream
const productosMasterStream = todasBoquillas.filter(p => p.data.subcategoria === 'boquillas-master-stream');

// Otros productos para la seccion de relacionados
const otrasBoquillas = todasBoquillas.filter(p => !productosMasterStream.includes(p));

// Subcategorias de boquillas para el sidebar
const subcategorias = [
  {
    slug: 'tipo-pistola',
    nombre: 'Boquilla Tipo Pistola',
    descripcion: 'Control ergonómico seleccionable',
    activo: false
  },
  {
    slug: 'turbo-jet',
    nombre: 'Boquilla Turbo Jet',
    descripcion: 'Máximo alcance y penetración',
    activo: false
  },
  {
    slug: 'industrial',
    nombre: 'Boquilla Industrial',
    descripcion: 'Alto caudal para industria',
    activo: false
  },
  {
    slug: 'certificada',
    nombre: 'Boquilla Certificada',
    descripcion: 'Certificación UL/FM',
    activo: false
  },
  {
    slug: 'handline',
    nombre: 'Boquillas Handline XD',
    descripcion: 'Chief XD, Phantom XD',
    activo: false
  },
  {
    slug: 'master-stream',
    nombre: 'Master Stream',
    descripcion: 'X-Stream, gran caudal',
    activo: true
  },
];

const faqItems = [
  { pregunta: '¿Qué es una boquilla master stream?', respuesta: 'Una boquilla master stream es una boquilla de gran caudal diseñada para montarse en monitores fijos o portátiles, no para operación manual con manguera. Manejan flujos de 500 a 2,000 GPM o más, y se usan para ataque defensivo en incendios de gran magnitud, protección perimetral de tanques y enfriamiento de estructuras. Son el complemento indispensable de los monitores industriales.' },
  { pregunta: '¿Qué boquillas master stream maneja Elkhart Brass?', respuesta: 'Elkhart Brass fabrica la línea X-Stream de boquillas master stream, disponibles en configuraciones de chorro sólido, niebla y combinadas. Los modelos varían según el caudal requerido (500 a 2,000 GPM) y el tipo de monitor donde se instalan. Gama de México asesora en la selección del modelo correcto según tu monitor y sistema hidráulico.' },
  { pregunta: '¿Las boquillas master stream son compatibles con espuma AFFF?', respuesta: 'Sí. Las boquillas master stream Elkhart Brass son compatibles con agua, espuma AFFF y FFFP. Para aplicaciones con espuma, se recomienda usar modelos con patrones de descarga que maximicen la expansión de la espuma sobre la superficie del combustible. Verificamos la compatibilidad del modelo con tu sistema de proporción antes de cotizar.' },
  { pregunta: '¿Para qué aplicaciones industriales de alto flujo se usan las boquillas master stream?', respuesta: 'Las boquillas master stream de 500 a 2,000 GPM son el estándar para: protección perimetral de parques de tanques de hidrocarburos, cortinas de agua en cargaderos y muelles, deck guns en camiones de bomberos de respuesta a grandes incendios, torres de enfriamiento en reactores petroquímicos, y sistemas fijos de diluvio bajo NFPA 15. También se usan en sistemas de espuma de alta expansión para hangares de aviación bajo NFPA 11. En todas estas aplicaciones, la selección correcta del patrón de descarga (chorro sólido para alcance o niebla para enfriamiento) define la efectividad de la protección.' },
  { pregunta: '¿Cómo se integran las boquillas master stream con monitores industriales?', respuesta: 'Las boquillas master stream X-Stream de Elkhart Brass están diseñadas para integrarse directamente con los monitores de la misma marca: Vulcan, Copperhead y la serie EXM2, mediante conexiones estándar de 2.5", 3" y 4" NHT o bridadas. La selección de la boquilla debe coincidir con el caudal nominal del monitor y la presión de diseño del sistema hidráulico. Una boquilla subdimensionada generará velocidades de salida insuficientes; una sobredimensionada puede provocar cavitación. Gama de México verifica la curva hidráulica del sistema completo antes de confirmar la selección de boquilla y monitor.' },
  { pregunta: '¿Qué alcance y cobertura logran las boquillas master stream en deck gun o monitor portátil?', respuesta: 'En configuración de chorro sólido, las boquillas master stream X-Stream de Elkhart Brass a 500 GPM y 100 PSI alcanzan distancias horizontales de 80 a 100 metros, suficientes para ataque defensivo desde fuera de la zona de peligro. En configuración de niebla (30°-90°), el alcance se reduce pero la cobertura de área aumenta para enfriamiento de superficies. Los deck guns montados en camión de bomberos con caudal de 1,000 GPM pueden cubrir hasta 150 metros de alcance. Gama de México proporciona las tablas de rendimiento hidráulico de cada modelo para que el ingeniero de diseño pueda calcular el posicionamiento correcto de los monitores.' },
];

const structuredData = [
  buildOrganizationSchema(),
  buildProductCategorySchema({
    name: 'Boquillas Master Stream Elkhart Brass',
    description: 'Boquillas master stream X-Stream Elkhart Brass para monitores industriales. 500-2,000 GPM. Chorro sólido y niebla. Distribuidor México.',
    image: '/img/boquillas-contra-incendios/elkhart-chief-xd-boq-01.avif',
    url: '/boquillas/master-stream',
    category: 'Boquillas Contra Incendios',
    brand: 'Elkhart Brass',
    reviewAuthor: 'Ing. Ricardo Solis',
    reviewBody: 'Las X-Stream funcionan perfecto en nuestros monitores de terminal. Gama de México nos ayudó a seleccionar el patrón correcto.',
    reviewDate: '2025-09-05',
    ratingCount: 18,
    reviewCount: 18,
  }),
  buildBreadcrumbSchema([
    { name: 'Inicio', url: '/' },
    { name: 'Equipos', url: '/equipos' },
    { name: 'Boquillas Contra Incendios', url: '/boquillas-contra-incendios' },
    { name: 'Master Stream', url: '/boquillas/master-stream' },
  ]),
  buildFAQSchema(faqItems),
];

---

<Layout
  structuredData={structuredData}
  title="Boquillas Master Stream X-Stream Elkhart Brass | 500-2000 GPM Monitores | NFPA 15 México"
  description="Boquillas master stream X-Stream Elkhart Brass para monitores industriales y deck gun. 500-2,000 GPM, alcance 100m+. Compatibles AFFF/FFFP. Cumple NFPA 15. Refinerías, terminales y petroquímicas en México."
  activePage="equipos"
  heroTitle="Boquillas Master Stream"
  heroIntro="Boquillas master stream X-Stream de Elkhart Brass para monitores fijos, portátiles y deck gun. Caudales de 500 a 2,000 GPM con alcance hasta 100+ metros. Conformes con NFPA 15. Compatibles con AFFF y FFFP. Para protección perimetral de tanques, refinerías y terminales de almacenamiento en México."
  heroBadge="Boquillas Contra Incendios"
  heroMetrics={[
    { valor: "2,000", texto: "GPM máximo" },
    { valor: "X-Stream", texto: "Línea Elkhart" },
    { valor: "AFFF", texto: "Compatible espuma" }
  ]}
  heroPrimaryText="Ver Catálogo"
  heroPrimaryLink="#catalogo"
  heroSecondaryText="Solicitar Cotización"
  heroSecondaryLink="#cotizar"
  heroShowRightContent={true}
>

  <!-- HERO CONTENT -->
  <Fragment slot="hero-content">
    <p>Las <strong>boquillas master stream</strong> son el componente que define el rendimiento de un monitor contra incendios. A diferencia de las boquillas handline que opera un bombero con manguera, las master stream se montan directamente en monitores fijos o portátiles y manejan caudales que superan los 500 GPM — hasta 2,000 GPM en los modelos industriales.</p>
    <p>En <strong>Gama de México</strong> distribuimos la línea X-Stream de Elkhart Brass, diseñada para integrarse con los monitores Vulcan, Copperhead y la serie EXM2. Asesoramos en la selección de la boquilla correcta según el caudal requerido, presión disponible, tipo de agente extintor y patrón de descarga necesario para tu aplicación específica.</p>
  </Fragment>
  <!-- BREADCRUMB -->
  <Breadcrumb />


  <!-- MAIN CONTENT WITH SIDEBAR -->
  <section class="subcat-content">
    <div class="container">
      <div class="subcat-layout">

        <!-- MAIN CONTENT (LEFT) -->
        <main class="subcat-main">

          <!-- CATALOG HEADER -->
          <div class="catalog-header" id="catalogo">
            <div class="catalog-header__text">
              <h2 class="catalog-header__title">Boquillas Master Stream para Monitores</h2>
              <p class="catalog-header__desc">Boquillas de gran caudal X-Stream de Elkhart Brass</p>
            </div>
            <div class="catalog-header__count">
              <span class="catalog-header__number">{productosMasterStream.length}</span>
              <span class="catalog-header__label">producto{productosMasterStream.length !== 1 ? 's' : ''}</span>
            </div>
          </div>

          <!-- PRODUCTS GRID -->
          <div class="categories__grid">
            {productosMasterStream.map((producto) => (
              <SubcategoryProductCard
                title={producto.data.title}
                description={producto.data.description}
                brand={producto.data.marca}
                image={producto.data.imagen}
                productSlug={producto.id}
                flow={producto.data.flujo}
                material={producto.data.material}
                certifications={producto.data.certificaciones}
              />
            ))}
          </div>

          {productosMasterStream.length === 0 && (
            <div class="catalog-empty">
              <div class="catalog-empty__icon">🔍</div>
              <h3 class="catalog-empty__title">Próximamente más opciones</h3>
              <p class="catalog-empty__text">Estamos agregando fichas de boquillas master stream. Solicita cotización con especificaciones de tu monitor.</p>
              <a href="#cotizar" class="btn btn--primary">Solicitar Cotización</a>
            </div>
          )}

          <!-- TECHNICAL INFO -->
          <div class="tech-info">
            <h3 class="tech-info__title">Especificaciones Técnicas Generales</h3>
            <div class="tech-info__grid">
              <div class="tech-info__item">
                <span class="tech-info__label">Caudal</span>
                <span class="tech-info__value">500 - 2,000 GPM</span>
              </div>
              <div class="tech-info__item">
                <span class="tech-info__label">Presión</span>
                <span class="tech-info__value">80 - 150 PSI</span>
              </div>
              <div class="tech-info__item">
                <span class="tech-info__label">Patrones</span>
                <span class="tech-info__value">Chorro / Niebla</span>
              </div>
              <div class="tech-info__item">
                <span class="tech-info__label">Montaje</span>
                <span class="tech-info__value">Monitores fijos</span>
              </div>
              <div class="tech-info__item">
                <span class="tech-info__label">Material</span>
                <span class="tech-info__value">Aluminio / Bronce</span>
              </div>
              <div class="tech-info__item">
                <span class="tech-info__label">Agente</span>
                <span class="tech-info__value">Agua / AFFF / FFFP</span>
              </div>
            </div>
          </div>

        </main>

        <!-- SIDEBAR (RIGHT) -->
        <ProductSidebar
          navTitulo="Tipos de Boquillas"
          subcategorias={subcategorias}
          baseUrl="/boquillas"
          backLinkHref="/boquillas-contra-incendios"
          backLinkTexto="Ver todas las boquillas"
          certificaciones={[
            { siglas: "FM", nombre: "Factory Mutual" },
            { siglas: "UL", nombre: "UL Listed" },
            { siglas: "NOM", nombre: "NOM-002-STPS" }
          ]}
          marcas={["Elkhart Brass", "Akron Brass", "Task Force Tips", "POK"]}
          aplicaciones={[
            "Monitores industriales",
            "Protección perimetral",
            "Terminales de almacenamiento",
            "Refinerías",
            "Hangares de aviación"
          ]}
          productosRelacionados={[
            { href: "/monitores-contra-incendios", nombre: "Monitores Contra Incendios" },
            { href: "/mangueras-contra-incendios", nombre: "Mangueras Contra Incendios" },
            { href: "/valvulas-contra-incendios", nombre: "Válvulas Contra Incendios" },
            { href: "/conexiones-herrajes-contra-incendios", nombre: "Conexiones y Herrajes" }
          ]}
        />

      </div>
    </div>
  </section>

  <!-- RELATED PRODUCTS -->
  <RelatedProductsGrid
    titulo="Otras Boquillas Contra Incendios"
    subtitulo="Boquillas handline, industriales y certificadas"
    productos={otrasBoquillas}
    maxProductos={3}
    verTodosLink="/boquillas-contra-incendios"
    verTodosTexto="Ver todas las boquillas"
  />

  <CotizacionForm
    titulo="Cotiza Boquillas Master Stream"
    tipoEquipo="Boquillas"
    pagina="Boquillas Master Stream"
  />


  <!-- FAQ -->
  <section class="faq-section" id="faq" aria-labelledby="faq-title">
    <div class="container">
      <h2 id="faq-title" class="section-title">Preguntas Frecuentes</h2>
      <Faq items={faqItems} id="faq" />
    </div>
  </section>

</Layout>

<style>
  .faq-section {
    padding: var(--spacing-2xl, 4rem) 0;
    background: var(--color-surface, #fff);
  }
  .faq-section .section-title {
    font-size: var(--text-2xl, 1.75rem);
    font-weight: 700;
    margin-bottom: 2rem;
    text-align: center;
  }
</style>
