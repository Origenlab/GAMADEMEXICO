---
import Layout from '../../layouts/Base.astro';
import '../../styles/subcategory.css';
import { getCollection } from 'astro:content';
import SubcategoryProductCard from '../../components/SubcategoryProductCard.astro';
import ProductSidebar from '../../components/ProductSidebar.astro';
import RelatedProductsGrid from '../../components/RelatedProductsGrid.astro';
import CotizacionForm from '../../components/CotizacionForm.astro';
import Faq from '../../components/Faq.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import { buildProductCategorySchema, buildBreadcrumbSchema, buildFAQSchema, buildOrganizationSchema } from '../../lib/seo';


// 1. Obtener todos los productos de la categoría conexiones-herrajes
const todosProductos = (await getCollection('productos', ({ data }) =>
  data.categoria === 'conexiones-herrajes'
)).sort((a, b) => a.data.orden - b.data.orden);

// 2. Filtrar por subcategoría: Chiflones de Tres Pasos
const productosSubcategoria = todosProductos.filter(p => p.data.subcategoria === 'chiflones');

// 3. Obtener otros productos para sección de relacionados
const otrosProductos = todosProductos.filter(p => !productosSubcategoria.includes(p));

// 4. Definir subcategorías para navegación
const subcategorias = [
  { slug: 'adaptadores', nombre: 'Adaptadores de Bronce', descripcion: 'Conversión entre roscas NH, NPT, Storz', activo: false },
  { slug: 'wye', nombre: 'Conexión Y (Wye)', descripcion: 'Derivación en dos salidas', activo: false },
  { slug: 'siamesa', nombre: 'Toma Siamesa FDC', descripcion: 'Conexión para bomberos', activo: false },
  { slug: 'coples', nombre: 'Coples y Reducciones', descripcion: 'Conexión rápida Storz', activo: false },
  { slug: 'chiflones', nombre: 'Chiflones de Tres Pasos', descripcion: 'Control de patrón de descarga', activo: true },
  { slug: 'accesorios', nombre: 'Accesorios y Herrajes', descripcion: 'Tapones, caps, niples', activo: false },
];
const faqItems = [
  { pregunta: '¿Qué es un chiflón de manguera y para qué se usa?', respuesta: 'El chiflón es el adaptador terminal de una manguera contra incendios que conecta la manguera al hidrante, gabinete o bomba. Es el accesorio más crítico del sistema de mangueras porque debe garantizar una conexión hermética bajo presión. Los chiflones estándar tienen rosca NST (National Standard Thread) o roscas compatibles con los sistemas de la ciudad donde se instalan.' },
  { pregunta: '¿Qué material es mejor para chiflones: aluminio o bronce?', respuesta: 'Para uso general en edificios e industria, el bronce es el material preferido por su mayor resistencia a la corrosión, especialmente en ambientes costeros o industriales. El aluminio es más ligero y económico, siendo adecuado para brigadas móviles y equipos portátiles donde el peso es prioritario. En sistemas fijos permanentes instalados en exteriores o ambientes húmedos, siempre recomendamos bronce.' },
  { pregunta: '¿Cómo se determina el tamaño correcto del chiflón?', respuesta: 'El tamaño del chiflón debe coincidir exactamente con el diámetro de la manguera y el tipo de rosca del acoplamiento. Los tamaños más comunes en México son 1.5" NH para mangueras de gabinete y 2.5" NH para hidrantes exteriores. Es fundamental verificar la compatibilidad de roscas antes de adquirir, ya que existen diferentes estándares (NH, NST, BSP) según el país y la época de instalación del sistema.' },
];

const structuredData = [
  buildOrganizationSchema(),
  buildProductCategorySchema({
    name: 'Chiflones de Manguera Contra Incendios',
    description: 'Chiflones de bronce para mangueras contra incendios. 1.5" y 2.5" NST. Aluminio y bronce. Stock permanente México.',
    image: '/img/conexiones-herrajes/adaptador-aluminio-elk-o-lite-4-frontal.avif',
    url: '/conexiones/chiflones',
    category: 'Conexiones y Herrajes Contra Incendios',
    brand: 'Elkhart Brass',
    reviewAuthor: 'Ing. Carlos Mendoza',
    reviewBody: 'Excelente calidad y respaldo técnico de Gama de México. Equipos certificados con entrega puntual.',
    reviewDate: '2025-03-15',
    ratingCount: 32,
    reviewCount: 32,
  }),
  buildBreadcrumbSchema([
    { name: 'Inicio', url: '/' },
    { name: 'Equipos', url: '/equipos' },
    { name: 'Conexiones y Herrajes', url: '/conexiones-herrajes-contra-incendios' },
  ]),
  buildFAQSchema(faqItems),
];

---

<Layout
  structuredData={structuredData}
  title="Chiflones de Tres Pasos Neblina y Chorro | México"
  description="Chiflones de tres pasos para control de patrón: cerrado, neblina y chorro directo. Serie Chief XD Elkhart Brass. UL 401. México."
  activePage="equipos"
  heroTitle="Chiflones de Tres Pasos"
  heroIntro="Boquillas de control manual con tres posiciones de operación: cerrado, neblina y chorro directo. Diseñados para gabinetes contra incendio y brigadas de primera respuesta que requieren control básico pero efectivo del patrón de descarga."
  heroBadge="Conexiones y Herrajes"
  heroMetrics={[
    { valor: "3", texto: "Posiciones" },
    { valor: "UL 401", texto: "Certificación" },
    { valor: "100", texto: "GPM máx." }
  ]}
  heroPrimaryText="Ver Catálogo"
  heroPrimaryLink="#catalogo"
  heroSecondaryText="Solicitar Cotización"
  heroSecondaryLink="#cotizar"
  heroShowRightContent={true}
>

  <!-- HERO CONTENT -->
  <Fragment slot="hero-content">
    <p>Los <strong>chiflones de tres pasos</strong> son boquillas de control manual que permiten alternar entre posición cerrada, patrón de neblina y chorro directo mediante un simple giro del cabezal. Son la solución ideal para gabinetes contra incendio en edificios comerciales, hospitales e industrias donde el personal de brigada necesita una herramienta intuitiva y confiable sin la complejidad de boquillas automáticas.</p>
    <p><strong>Gama de México</strong> distribuye chiflones certificados UL 401 de Elkhart Brass, fabricados en bronce cromado resistente a la corrosión. Estos dispositivos ofrecen flujos de 30 a 100 GPM dependiendo del modelo y presión de operación, con diseño ergonómico que facilita el agarre incluso con guantes. Ideales para complementar sistemas de manguera de 1-1/2" en instalaciones que cumplen NOM-002-STPS.</p>
  </Fragment>
  <!-- BREADCRUMB -->
  <Breadcrumb />



  <!-- CONTENT + SIDEBAR -->
  <section class="subcat-content">
    <div class="container">
      <div class="subcat-layout">

        <!-- MAIN CONTENT -->
        <main class="subcat-main">
          <div class="catalog-header">
            <div class="catalog-header__text">
              <h2 class="catalog-header__title">Catálogo de Chiflones de Tres Pasos</h2>
              <p class="catalog-header__desc">Selecciona el modelo que mejor se adapte a tu instalación</p>
            </div>
            <div class="catalog-header__count">
              <span class="catalog-header__number">{productosSubcategoria.length}</span>
              <span class="catalog-header__label">producto{productosSubcategoria.length !== 1 ? 's' : ''}</span>
            </div>
          </div>

          <!-- Products Grid -->
          <div class="categories__grid">
            {productosSubcategoria.map((producto) => (
              <SubcategoryProductCard
                title={producto.data.title}
                description={producto.data.description}
                brand={producto.data.marca}
                image={producto.data.imagen}
                productSlug={producto.id}
                flow={producto.data.flujo}
                material={producto.data.material}
                certifications={producto.data.certificaciones}
              />
            ))}
          </div>

          {productosSubcategoria.length === 0 && (
            <div class="catalog-empty">
              <div class="catalog-empty__icon">🔍</div>
              <h3 class="catalog-empty__title">Próximamente más opciones</h3>
              <p class="catalog-empty__text">Estamos agregando más chiflones de diferentes configuraciones. Solicita una cotización personalizada.</p>
              <a href="#cotizar" class="btn btn--primary">Solicitar Cotización</a>
            </div>
          )}

          <!-- Tech Info -->
          <div class="tech-info">
            <h3 class="tech-info__title">Especificaciones Técnicas de Chiflones</h3>
            <div class="tech-info__grid">
              <div class="tech-info__item">
                <span class="tech-info__label">Presión de trabajo</span>
                <span class="tech-info__value">100 PSI nominal</span>
              </div>
              <div class="tech-info__item">
                <span class="tech-info__label">Certificación</span>
                <span class="tech-info__value">UL 401 / NFPA 1964</span>
              </div>
              <div class="tech-info__item">
                <span class="tech-info__label">Flujo</span>
                <span class="tech-info__value">30–250 GPM</span>
              </div>
              <div class="tech-info__item">
                <span class="tech-info__label">Posiciones</span>
                <span class="tech-info__value">3 (cerrado, neblina, chorro)</span>
              </div>
              <div class="tech-info__item">
                <span class="tech-info__label">Conexión</span>
                <span class="tech-info__value">1" a 2.5" NH</span>
              </div>
              <div class="tech-info__item">
                <span class="tech-info__label">Material</span>
                <span class="tech-info__value">Bronce / Aluminio</span>
              </div>
            </div>
          </div>

          <!-- CTA Final -->
          <div class="subcat-cta-final">
            <div class="subcat-cta-final__content">
              <h3 class="subcat-cta-final__title">¿No encuentras la configuración que necesitas?</h3>
              <p class="subcat-cta-final__desc">Tenemos acceso al catálogo completo de Elkhart Brass. Contáctanos para chiflones en configuraciones especiales, flujos personalizados o conexiones no estándar.</p>
            </div>
            <a href="#cotizar" class="btn btn--primary">Solicitar Cotización Especial</a>
          </div>
        </main>

        <!-- SIDEBAR -->
        <ProductSidebar
          navTitulo="Tipos de Conexiones"
          subcategorias={subcategorias}
          baseUrl="/conexiones"
          backLinkHref="/conexiones-herrajes-contra-incendios"
          backLinkTexto="Ver todas las conexiones"
          certificaciones={[
            { siglas: "FM", nombre: "Factory Mutual" },
            { siglas: "UL", nombre: "UL Listed" },
            { siglas: "NOM", nombre: "NOM-002-STPS" }
          ]}
          marcas={["Dixon", "Elkhart Brass", "Harrington", "Action Coupling"]}
          aplicaciones={[
            "Descarga de agua",
            "Aplicaciones industriales",
            "Limpieza de áreas",
            "Gabinetes contra incendio"
          ]}
          productosRelacionados={[
            { href: "/gabinetes-hidrantes-contra-incendios", nombre: "Gabinetes e Hidrantes" },
            { href: "/mangueras-contra-incendios", nombre: "Mangueras Contra Incendios" },
            { href: "/valvulas-contra-incendios", nombre: "Válvulas Contra Incendios" },
            { href: "/boquillas-contra-incendios", nombre: "Boquillas Contra Incendios" }
          ]}
        />

      </div>
    </div>
  </section>

  <!-- RELATED PRODUCTS -->
  <RelatedProductsGrid
    titulo="Otras Conexiones y Herrajes"
    subtitulo="Explora más opciones para tu sistema contra incendios"
    productos={otrosProductos}
    maxProductos={3}
    verTodosLink="/conexiones-herrajes-contra-incendios"
    verTodosTexto="Ver todas las conexiones"
  />

  <CotizacionForm
    titulo="Cotiza Chiflones"
    tipoEquipo="Conexiones y herrajes"
    pagina="Conexiones Chiflones"
  />


  <!-- FAQ -->
  <section class="faq-section" id="faq" aria-labelledby="faq-title">
    <div class="container">
      <h2 id="faq-title" class="section-title">Preguntas Frecuentes</h2>
      <Faq items={faqItems} id="faq" />
    </div>
  </section>

</Layout>

<style>
  .faq-section {
    padding: var(--spacing-2xl, 4rem) 0;
    background: var(--color-surface, #fff);
  }
  .faq-section .section-title {
    font-size: var(--text-2xl, 1.75rem);
    font-weight: 700;
    margin-bottom: 2rem;
    text-align: center;
  }
</style>
