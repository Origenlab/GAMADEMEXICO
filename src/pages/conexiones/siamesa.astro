---
import Layout from '../../layouts/Base.astro';
import '../../styles/subcategory.css';
import { getCollection } from 'astro:content';
import SubcategoryProductCard from '../../components/SubcategoryProductCard.astro';
import ProductSidebar from '../../components/ProductSidebar.astro';
import RelatedProductsGrid from '../../components/RelatedProductsGrid.astro';
import CotizacionForm from '../../components/CotizacionForm.astro';
import Faq from '../../components/Faq.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import { buildProductCategorySchema, buildBreadcrumbSchema, buildFAQSchema, buildOrganizationSchema } from '../../lib/seo';


// 1. Obtener todos los productos de la categoría conexiones-herrajes
const todosProductos = (await getCollection('productos', ({ data }) =>
  data.categoria === 'conexiones-herrajes'
)).sort((a, b) => a.data.orden - b.data.orden);

// 2. Filtrar por subcategoría: Toma Siamesa FDC
const productosSubcategoria = todosProductos.filter(p => p.data.subcategoria === 'siamesa');

// 3. Obtener otros productos para sección de relacionados
const otrosProductos = todosProductos.filter(p => !productosSubcategoria.includes(p));

// 4. Definir subcategorías para navegación
const subcategorias = [
  { slug: 'adaptadores', nombre: 'Adaptadores de Bronce', descripcion: 'Conversión entre roscas NH, NPT, Storz', activo: false },
  { slug: 'wye', nombre: 'Conexión Y (Wye)', descripcion: 'Derivación en dos salidas', activo: false },
  { slug: 'siamesa', nombre: 'Toma Siamesa FDC', descripcion: 'Conexión para bomberos', activo: true },
  { slug: 'coples', nombre: 'Coples y Reducciones', descripcion: 'Conexión rápida Storz', activo: false },
  { slug: 'chiflones', nombre: 'Chiflones de Tres Pasos', descripcion: 'Control de patrón de descarga', activo: false },
  { slug: 'accesorios', nombre: 'Accesorios y Herrajes', descripcion: 'Tapones, caps, niples', activo: false },
];
const faqItems = [
  { pregunta: '¿Qué es una toma siamesa y para qué sirve?', respuesta: 'La toma siamesa (FDC - Fire Department Connection) es la conexión exterior de un edificio que permite a los bomberos inyectar agua adicional al sistema de rociadores o standpipe del edificio desde su camión cisterna. Es un componente obligatorio en edificios con sistemas automáticos de rociadores conforme a NFPA 13 y en sistemas de standpipe tipo I y III conforme a NFPA 14. Sin toma siamesa, los bomberos no pueden reforzar la presión interna del sistema.' },
  { pregunta: '¿Cuántas bocas tiene una toma siamesa estándar?', respuesta: 'La toma siamesa más común para edificios tiene dos bocas de 2.5" NST (por eso se llama siamesa - dos entradas). Para edificios de gran altura o instalaciones industriales con sistemas de alto caudal, se usan siamesas de tres o cuatro bocas o siamesas en Y con bocas de 4" o 5". El tamaño correcto lo define el ingeniero de protección contra incendios basándose en el caudal del sistema y los recursos del cuerpo de bomberos local.' },
  { pregunta: '¿Dónde se instala la toma siamesa en un edificio?', respuesta: 'La toma siamesa se instala en la fachada exterior del edificio, entre 60 cm y 1.20 m del nivel del piso, en un lugar visible y accesible para los vehículos de bomberos. NFPA 13 y 14 especifican que debe estar identificada con letras de no menos de 1" de altura indicando el tipo de sistema al que conecta (SPRINKLER, STANDPIPE). Debe estar protegida de daños mecánicos y libre de obstáculos en un radio de 1 metro.' },
];

const structuredData = [
  buildOrganizationSchema(),
  buildProductCategorySchema({
    name: 'Toma Siamesa FDC Contra Incendios',
    description: 'Toma siamesa FDC de bronce para rociadores y standpipe. 2 bocas 2.5" NST. NFPA 13 y 14. Envíos nacionales México.',
    image: '/img/conexiones-herrajes/adaptador-aluminio-elk-o-lite-4-frontal.avif',
    url: '/conexiones/siamesa',
    category: 'Conexiones y Herrajes Contra Incendios',
    brand: 'Elkhart Brass',
    reviewAuthor: 'Ing. Carlos Mendoza',
    reviewBody: 'Excelente calidad y respaldo técnico de Gama de México. Equipos certificados con entrega puntual.',
    reviewDate: '2025-03-15',
    ratingCount: 32,
    reviewCount: 32,
  }),
  buildBreadcrumbSchema([
    { name: 'Inicio', url: '/' },
    { name: 'Equipos', url: '/equipos' },
    { name: 'Conexiones y Herrajes', url: '/conexiones-herrajes-contra-incendios' },
  ]),
  buildFAQSchema(faqItems),
];

---

<Layout
  structuredData={structuredData}
  title="Toma Siamesa FDC Fire Department Connection | México"
  description="Toma siamesa FDC para conexión de bomberos. Modelos plain, clappered y con válvula de alivio. NFPA 14. Elkhart Brass UL/FM. México."
  activePage="equipos"
  heroTitle="Toma Siamesa FDC"
  heroIntro="Conexión para el Departamento de Bomberos (Fire Department Connection) que permite a las unidades de emergencia inyectar agua al sistema de rociadores o tuberías verticales del edificio. Componente obligatorio según NFPA 14 para edificios con sistemas de protección contra incendios."
  heroBadge="Conexiones y Herrajes"
  heroMetrics={[
    { valor: "NFPA 14", texto: "Normativa" },
    { valor: "2x2.5\"", texto: "Entradas NH" },
    { valor: "UL/FM", texto: "Certificación" }
  ]}
  heroPrimaryText="Ver Catálogo"
  heroPrimaryLink="#catalogo"
  heroSecondaryText="Solicitar Cotización"
  heroSecondaryLink="#cotizar"
  heroShowRightContent={true}
>

  <!-- HERO CONTENT -->
  <Fragment slot="hero-content">
    <p>La <strong>toma siamesa FDC</strong> (Fire Department Connection) es el punto de conexión donde los bomberos conectan sus mangueras para suplementar o presurizar el sistema contra incendios del edificio. Disponible en configuraciones plain (sin válvulas), clappered (con clapetas anti-retorno) y con válvula de alivio para proteger el sistema de sobrepresiones. Las entradas estándar de 2-1/2" NH permiten conexión directa desde las líneas de ataque.</p>
    <p><strong>Gama de México</strong> suministra tomas siamesas Elkhart Brass certificadas UL/FM en bronce fundido con acabado cromado o pintado. Ofrecemos modelos de pared, empotrados y de piso según los requerimientos arquitectónicos del proyecto. Cada unidad cumple NFPA 14 e incluye tapones y cadenas para protección contra vandalismo y acumulación de escombros.</p>
  </Fragment>
  <!-- BREADCRUMB -->
  <Breadcrumb />



  <!-- CONTENT + SIDEBAR -->
  <section class="subcat-content">
    <div class="container">
      <div class="subcat-layout">

        <!-- MAIN CONTENT -->
        <main class="subcat-main">
          <div class="catalog-header">
            <div class="catalog-header__text">
              <h2 class="catalog-header__title">Catálogo de Toma Siamesa FDC</h2>
              <p class="catalog-header__desc">Selecciona el modelo que mejor se adapte a tu instalación</p>
            </div>
            <div class="catalog-header__count">
              <span class="catalog-header__number">{productosSubcategoria.length}</span>
              <span class="catalog-header__label">producto{productosSubcategoria.length !== 1 ? 's' : ''}</span>
            </div>
          </div>

          <!-- Products Grid -->
          <div class="categories__grid">
            {productosSubcategoria.map((producto) => (
              <SubcategoryProductCard
                title={producto.data.title}
                description={producto.data.description}
                brand={producto.data.marca}
                image={producto.data.imagen}
                productSlug={producto.id}
                flow={producto.data.flujo}
                material={producto.data.material}
                certifications={producto.data.certificaciones}
              />
            ))}
          </div>

          {productosSubcategoria.length === 0 && (
            <div class="catalog-empty">
              <div class="catalog-empty__icon">🔍</div>
              <h3 class="catalog-empty__title">Próximamente más opciones</h3>
              <p class="catalog-empty__text">Estamos agregando más tomas siamesas de diferentes configuraciones. Solicita una cotización personalizada.</p>
              <a href="#cotizar" class="btn btn--primary">Solicitar Cotización</a>
            </div>
          )}

          <!-- Tech Info -->
          <div class="tech-info">
            <h3 class="tech-info__title">Especificaciones Técnicas de Toma Siamesa FDC</h3>
            <div class="tech-info__grid">
              <div class="tech-info__item">
                <span class="tech-info__label">Presión de trabajo</span>
                <span class="tech-info__value">175-300 PSI</span>
              </div>
              <div class="tech-info__item">
                <span class="tech-info__label">Presión de prueba</span>
                <span class="tech-info__value">500 PSI</span>
              </div>
              <div class="tech-info__item">
                <span class="tech-info__label">Entradas</span>
                <span class="tech-info__value">2x 2.5" NH</span>
              </div>
              <div class="tech-info__item">
                <span class="tech-info__label">Normativa</span>
                <span class="tech-info__value">NFPA 14</span>
              </div>
              <div class="tech-info__item">
                <span class="tech-info__label">Certificación</span>
                <span class="tech-info__value">UL/FM</span>
              </div>
              <div class="tech-info__item">
                <span class="tech-info__label">Material</span>
                <span class="tech-info__value">Bronce / Acero Inox</span>
              </div>
            </div>
          </div>

          <!-- CTA Final -->
          <div class="subcat-cta-final">
            <div class="subcat-cta-final__content">
              <h3 class="subcat-cta-final__title">¿No encuentras la configuración que necesitas?</h3>
              <p class="subcat-cta-final__desc">Tenemos acceso al catálogo completo de Elkhart Brass. Contáctanos para tomas siamesas con configuraciones especiales o acabados personalizados.</p>
            </div>
            <a href="#cotizar" class="btn btn--primary">Solicitar Cotización Especial</a>
          </div>
        </main>

        <!-- SIDEBAR -->
        <ProductSidebar
          navTitulo="Tipos de Conexiones"
          subcategorias={subcategorias}
          baseUrl="/conexiones"
          backLinkHref="/conexiones-herrajes-contra-incendios"
          backLinkTexto="Ver todas las conexiones"
          certificaciones={[
            { siglas: "FM", nombre: "Factory Mutual" },
            { siglas: "UL", nombre: "UL Listed" },
            { siglas: "NOM", nombre: "NOM-002-STPS" }
          ]}
          marcas={["Dixon", "Elkhart Brass", "Harrington", "Potter Roemer"]}
          aplicaciones={[
            "Tomas siamesas para bomberos",
            "Alimentación de rociadores",
            "Edificios comerciales",
            "Conexión de autobombas"
          ]}
          productosRelacionados={[
            { href: "/gabinetes-hidrantes-contra-incendios", nombre: "Gabinetes e Hidrantes" },
            { href: "/mangueras-contra-incendios", nombre: "Mangueras Contra Incendios" },
            { href: "/valvulas-contra-incendios", nombre: "Válvulas Contra Incendios" },
            { href: "/boquillas-contra-incendios", nombre: "Boquillas Contra Incendios" }
          ]}
        />

      </div>
    </div>
  </section>

  <!-- RELATED PRODUCTS -->
  <RelatedProductsGrid
    titulo="Otras Conexiones y Herrajes"
    subtitulo="Explora más opciones para tu sistema contra incendios"
    productos={otrosProductos}
    maxProductos={3}
    verTodosLink="/conexiones-herrajes-contra-incendios"
    verTodosTexto="Ver todas las conexiones"
  />

  <CotizacionForm
    titulo="Cotiza Conexiones Siamesa"
    tipoEquipo="Conexiones y herrajes"
    pagina="Conexiones Siamesa"
  />


  <!-- FAQ -->
  <section class="faq-section" id="faq" aria-labelledby="faq-title">
    <div class="container">
      <h2 id="faq-title" class="section-title">Preguntas Frecuentes</h2>
      <Faq items={faqItems} id="faq" />
    </div>
  </section>

</Layout>

<style>
  .faq-section {
    padding: var(--spacing-2xl, 4rem) 0;
    background: var(--color-surface, #fff);
  }
  .faq-section .section-title {
    font-size: var(--text-2xl, 1.75rem);
    font-weight: 700;
    margin-bottom: 2rem;
    text-align: center;
  }
</style>
