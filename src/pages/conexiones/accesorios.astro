---
import Layout from '../../layouts/Base.astro';
import '../../styles/subcategory.css';
import { getCollection } from 'astro:content';
import SubcategoryProductCard from '../../components/SubcategoryProductCard.astro';
import ProductSidebar from '../../components/ProductSidebar.astro';
import RelatedProductsGrid from '../../components/RelatedProductsGrid.astro';
import CotizacionForm from '../../components/CotizacionForm.astro';
import Faq from '../../components/Faq.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import { buildProductCategorySchema, buildBreadcrumbSchema, buildFAQSchema, buildOrganizationSchema } from '../../lib/seo';


// 1. Obtener todos los productos de la categoría conexiones-herrajes
const todosProductos = (await getCollection('productos', ({ data }) =>
  data.categoria === 'conexiones-herrajes'
)).sort((a, b) => a.data.orden - b.data.orden);

// 2. Filtrar por subcategoría: Accesorios y Herrajes
const productosSubcategoria = todosProductos.filter(p => p.data.subcategoria === 'accesorios');

// 3. Obtener otros productos para sección de relacionados
const otrosProductos = todosProductos.filter(p => !productosSubcategoria.includes(p));

// 4. Definir subcategorías para navegación
const subcategorias = [
  { slug: 'adaptadores', nombre: 'Adaptadores de Bronce', descripcion: 'Conversión entre roscas NH, NPT, Storz', activo: false },
  { slug: 'wye', nombre: 'Conexión Y (Wye)', descripcion: 'Derivación en dos salidas', activo: false },
  { slug: 'siamesa', nombre: 'Toma Siamesa FDC', descripcion: 'Conexión para bomberos', activo: false },
  { slug: 'coples', nombre: 'Coples y Reducciones', descripcion: 'Conexión rápida Storz', activo: false },
  { slug: 'chiflones', nombre: 'Chiflones de Tres Pasos', descripcion: 'Control de patrón de descarga', activo: false },
  { slug: 'accesorios', nombre: 'Accesorios y Herrajes', descripcion: 'Tapones, caps, niples', activo: true },
];
const faqItems = [
  { pregunta: '¿Qué accesorios de herraje se necesitan para completar un sistema de mangueras contra incendios?', respuesta: 'Un sistema de mangueras completo incluye: chiflón de entrada (para conectar al hidrante), mangueras certificadas, cople intermedio si se necesita extensión, adaptadores de compatibilidad si hay diferentes tipos de rosca en el sistema, llave de manguera para apriete correcto, y soporte o carro portamanguera. Para gabinetes de edificio también se requiere soporte de manguera enrollable o doblada y gabinete certificado.' },
  { pregunta: '¿Qué es una llave de manguera y es obligatoria?', respuesta: 'La llave de manguera es una herramienta de aluminio o bronce que facilita el apriete y afloje de las conexiones de manguera sin dañar las roscas. Si bien no está listada como equipo obligatorio en todas las normas, la NFPA 25 recomienda su uso en el mantenimiento de sistemas de mangueras para evitar daños en las roscas. Su costo es mínimo comparado con el costo de reponer una manguera o chiflón dañado.' },
  { pregunta: '¿Los herrajes y accesorios de bronce requieren algún mantenimiento especial?', respuesta: 'Los herrajes de bronce fundido son prácticamente de mantenimiento nulo en condiciones normales. La inspección anual recomendada incluye: verificación visual de corrosión o deformaciones, prueba de funcionamiento de válvulas de control, verificación de tapas de protección en bocas de hidrante no utilizadas y revisión de la correcta identificación de cada accesorio. En ambientes costeros, lavar con agua limpia después de exposición a agua salada.' },
];

const structuredData = [
  buildOrganizationSchema(),
  buildProductCategorySchema({
    name: 'Accesorios y Herrajes para Mangueras Contra Incendios',
    description: 'Accesorios completos para sistemas de mangueras: llaves, soportes, tapas y herrajes de bronce. NOM y NFPA. México.',
    image: '/img/conexiones-herrajes/adaptador-aluminio-elk-o-lite-4-frontal.avif',
    url: '/conexiones/accesorios',
    category: 'Conexiones y Herrajes Contra Incendios',
    brand: 'Elkhart Brass',
    reviewAuthor: 'Ing. Carlos Mendoza',
    reviewBody: 'Excelente calidad y respaldo técnico de Gama de México. Equipos certificados con entrega puntual.',
    reviewDate: '2025-03-15',
    ratingCount: 32,
    reviewCount: 32,
  }),
  buildBreadcrumbSchema([
    { name: 'Inicio', url: '/' },
    { name: 'Equipos', url: '/equipos' },
    { name: 'Conexiones y Herrajes', url: '/conexiones-herrajes-contra-incendios' },
  ]),
  buildFAQSchema(faqItems),
];

---

<Layout
  structuredData={structuredData}
  title="Accesorios y Herrajes Contra Incendios | México"
  description="Accesorios y herrajes de bronce: tapones, caps, niples, llaves de hidrante, soportes de manguera. Elkhart Brass UL Listed. México."
  activePage="equipos"
  heroTitle="Accesorios y Herrajes"
  heroIntro="Componentes complementarios esenciales para sistemas contra incendio: tapones protectores, caps con cadena, niples de extensión, llaves de hidrante y soportes de manguera. Fabricados en bronce fundido o aluminio de alta resistencia para servicio exterior e interior."
  heroBadge="Conexiones y Herrajes"
  heroMetrics={[
    { valor: "Bronce/Alum", texto: "Materiales" },
    { valor: "300", texto: "PSI máxima" },
    { valor: "UL", texto: "Certificación" }
  ]}
  heroPrimaryText="Ver Catálogo"
  heroPrimaryLink="#catalogo"
  heroSecondaryText="Solicitar Cotización"
  heroSecondaryLink="#cotizar"
  heroShowRightContent={true}
>

  <!-- HERO CONTENT -->
  <Fragment slot="hero-content">
    <p>Los <strong>accesorios y herrajes</strong> son componentes frecuentemente pasados por alto pero fundamentales para la operación y mantenimiento de sistemas contra incendio. Incluyen tapones protectores que evitan la entrada de suciedad, caps con cadena de seguridad para tomas siamesas, niples de extensión, llaves pentagonales para hidrantes y soportes de pared para almacenamiento de mangueras.</p>
    <p><strong>Gama de México</strong> mantiene inventario de accesorios Elkhart Brass en bronce fundido certificado UL y aluminio para aplicaciones donde el peso es crítico. Suministramos kits completos para gabinetes, juegos de tapones y cadenas para siamesas, y llaves de hidrante. Todos nuestros herrajes cumplen con NFPA para compatibilidad con sistemas existentes.</p>
  </Fragment>
  <!-- BREADCRUMB -->
  <Breadcrumb />



  <!-- CONTENT + SIDEBAR -->
  <section class="subcat-content">
    <div class="container">
      <div class="subcat-layout">

        <!-- MAIN CONTENT -->
        <main class="subcat-main">
          <div class="catalog-header">
            <div class="catalog-header__text">
              <h2 class="catalog-header__title">Catálogo de Accesorios y Herrajes</h2>
              <p class="catalog-header__desc">Selecciona el modelo que mejor se adapte a tu instalación</p>
            </div>
            <div class="catalog-header__count">
              <span class="catalog-header__number">{productosSubcategoria.length}</span>
              <span class="catalog-header__label">producto{productosSubcategoria.length !== 1 ? 's' : ''}</span>
            </div>
          </div>

          <!-- Products Grid -->
          <div class="categories__grid">
            {productosSubcategoria.map((producto) => (
              <SubcategoryProductCard
                title={producto.data.title}
                description={producto.data.description}
                brand={producto.data.marca}
                image={producto.data.imagen}
                productSlug={producto.id}
                flow={producto.data.flujo}
                material={producto.data.material}
                certifications={producto.data.certificaciones}
              />
            ))}
          </div>

          {productosSubcategoria.length === 0 && (
            <div class="catalog-empty">
              <div class="catalog-empty__icon">🔍</div>
              <h3 class="catalog-empty__title">Próximamente más opciones</h3>
              <p class="catalog-empty__text">Estamos agregando más accesorios y herrajes. Solicita una cotización personalizada.</p>
              <a href="#cotizar" class="btn btn--primary">Solicitar Cotización</a>
            </div>
          )}

          <!-- Tech Info -->
          <div class="tech-info">
            <h3 class="tech-info__title">Especificaciones Técnicas de Accesorios</h3>
            <div class="tech-info__grid">
              <div class="tech-info__item">
                <span class="tech-info__label">Presión de trabajo</span>
                <span class="tech-info__value">175–500 PSI</span>
              </div>
              <div class="tech-info__item">
                <span class="tech-info__label">Certificación</span>
                <span class="tech-info__value">UL Listed</span>
              </div>
              <div class="tech-info__item">
                <span class="tech-info__label">Diámetros</span>
                <span class="tech-info__value">1.5" a 2.5" NH</span>
              </div>
              <div class="tech-info__item">
                <span class="tech-info__label">Tipos</span>
                <span class="tech-info__value">Tapones, caps, niples, llaves</span>
              </div>
              <div class="tech-info__item">
                <span class="tech-info__label">Cadenas</span>
                <span class="tech-info__value">9" y 16" acero</span>
              </div>
              <div class="tech-info__item">
                <span class="tech-info__label">Material</span>
                <span class="tech-info__value">Bronce / Aluminio</span>
              </div>
            </div>
          </div>

          <!-- CTA Final -->
          <div class="subcat-cta-final">
            <div class="subcat-cta-final__content">
              <h3 class="subcat-cta-final__title">¿No encuentras la configuración que necesitas?</h3>
              <p class="subcat-cta-final__desc">Tenemos acceso al catálogo completo de Elkhart Brass. Contáctanos para accesorios especiales, kits personalizados o herrajes en materiales específicos.</p>
            </div>
            <a href="#cotizar" class="btn btn--primary">Solicitar Cotización Especial</a>
          </div>
        </main>

        <!-- SIDEBAR -->
        <ProductSidebar
          navTitulo="Tipos de Conexiones"
          subcategorias={subcategorias}
          baseUrl="/conexiones"
          backLinkHref="/conexiones-herrajes-contra-incendios"
          backLinkTexto="Ver todas las conexiones"
          certificaciones={[
            { siglas: "FM", nombre: "Factory Mutual" },
            { siglas: "UL", nombre: "UL Listed" },
            { siglas: "NOM", nombre: "NOM-002-STPS" }
          ]}
          marcas={["Dixon", "Elkhart Brass", "Harrington", "Action Coupling"]}
          aplicaciones={[
            "Complementos de sistemas",
            "Herrajes de manguera",
            "Accesorios de gabinete",
            "Mantenimiento de equipos"
          ]}
          productosRelacionados={[
            { href: "/gabinetes-hidrantes-contra-incendios", nombre: "Gabinetes e Hidrantes" },
            { href: "/mangueras-contra-incendios", nombre: "Mangueras Contra Incendios" },
            { href: "/valvulas-contra-incendios", nombre: "Válvulas Contra Incendios" },
            { href: "/boquillas-contra-incendios", nombre: "Boquillas Contra Incendios" }
          ]}
        />

      </div>
    </div>
  </section>

  <!-- RELATED PRODUCTS -->
  <RelatedProductsGrid
    titulo="Otras Conexiones y Herrajes"
    subtitulo="Explora más opciones para tu sistema contra incendios"
    productos={otrosProductos}
    maxProductos={3}
    verTodosLink="/conexiones-herrajes-contra-incendios"
    verTodosTexto="Ver todas las conexiones"
  />

  <CotizacionForm
    titulo="Cotiza Accesorios"
    tipoEquipo="Conexiones y herrajes"
    pagina="Conexiones Accesorios"
  />


  <!-- FAQ -->
  <section class="faq-section" id="faq" aria-labelledby="faq-title">
    <div class="container">
      <h2 id="faq-title" class="section-title">Preguntas Frecuentes</h2>
      <Faq items={faqItems} id="faq" />
    </div>
  </section>

</Layout>

<style>
  .faq-section {
    padding: var(--spacing-2xl, 4rem) 0;
    background: var(--color-surface, #fff);
  }
  .faq-section .section-title {
    font-size: var(--text-2xl, 1.75rem);
    font-weight: 700;
    margin-bottom: 2rem;
    text-align: center;
  }
</style>
