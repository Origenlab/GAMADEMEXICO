---
import Layout from '../../layouts/Base.astro';
import '../../styles/subcategory.css';
import { getCollection } from 'astro:content';
import SubcategoryProductCard from '../../components/SubcategoryProductCard.astro';
import ProductSidebar from '../../components/ProductSidebar.astro';
import RelatedProductsGrid from '../../components/RelatedProductsGrid.astro';
import CotizacionForm from '../../components/CotizacionForm.astro';
import Faq from '../../components/Faq.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import { buildProductCategorySchema, buildBreadcrumbSchema, buildFAQSchema, buildOrganizationSchema } from '../../lib/seo';


// 1. Obtener todos los productos de la categoría conexiones-herrajes
const todosProductos = (await getCollection('productos', ({ data }) =>
  data.categoria === 'conexiones-herrajes'
)).sort((a, b) => a.data.orden - b.data.orden);

// 2. Filtrar por subcategoría: Conexión Y (Wye)
const productosSubcategoria = todosProductos.filter(p => p.data.subcategoria === 'wye');

// 3. Obtener otros productos para sección de relacionados
const otrosProductos = todosProductos.filter(p => !productosSubcategoria.includes(p));

// 4. Definir subcategorías para navegación
const subcategorias = [
  { slug: 'adaptadores', nombre: 'Adaptadores de Bronce', descripcion: 'Conversión entre roscas NH, NPT, Storz', activo: false },
  { slug: 'wye', nombre: 'Conexión Y (Wye)', descripcion: 'Derivación en dos salidas', activo: true },
  { slug: 'siamesa', nombre: 'Toma Siamesa FDC', descripcion: 'Conexión para bomberos', activo: false },
  { slug: 'coples', nombre: 'Coples y Reducciones', descripcion: 'Conexión rápida Storz', activo: false },
  { slug: 'chiflones', nombre: 'Chiflones de Tres Pasos', descripcion: 'Control de patrón de descarga', activo: false },
  { slug: 'accesorios', nombre: 'Accesorios y Herrajes', descripcion: 'Tapones, caps, niples', activo: false },
];
const faqItems = [
  { pregunta: '¿Para qué se usa una conexión Y (Wye) en sistemas contra incendios?', respuesta: 'La conexión Y divide un suministro de agua de una sola manguera en dos salidas independientes, permitiendo que dos equipos (boquillas o mangueras) operen simultáneamente desde una sola toma de hidrante. Es usada por brigadas de bomberos cuando se necesita atacar un incendio desde dos frentes con una sola conexión al hidrante, o cuando se necesita una línea de ataque y una línea de enfriamiento simultáneamente.' },
  { pregunta: '¿Cómo aplica la conexión Wye en sistemas standpipe según NFPA 14?', respuesta: 'NFPA 14 contempla el uso de conexiones Wye en salidas de sistemas standpipe Clase III para permitir que el personal de bomberos conecte simultáneamente dos líneas de manguera de 1.5" a una sola salida de 2.5". Esto es especialmente útil en pisos de edificios altos donde el espacio limita el número de salidas standpipe. La conexión Wye debe estar listada (UL/FM) y ser compatible con las roscas NH del sistema.' },
  { pregunta: '¿Cuál es la diferencia entre un Wye con válvulas y uno sin válvulas?', respuesta: 'El Wye con válvulas (gated wye) tiene una válvula de cierre de cuarto de vuelta en cada salida, lo que permite controlar el caudal por línea de forma independiente o conectar/desconectar una manguera sin afectar la otra. El Wye plain (sin válvulas) tiene ambas salidas permanentemente abiertas y solo puede controlarse desde la fuente aguas arriba. Para operaciones de bomberos, el gated es el estándar; el plain se usa en instalaciones fijas donde ambas líneas operan siempre juntas.' },
  { pregunta: '¿Cuál es el diámetro estándar de una conexión Y?', respuesta: 'La conexión Y estándar para bomberos tiene entrada de 2.5" NST y dos salidas de 1.5" NST, que es la configuración más común para hidrantes municipales. También existen versiones de 2.5" a dos salidas de 2.5" para operaciones industriales de alto caudal. Disponemos de conexiones Y en aluminio y bronce según la aplicación y el tipo de ambiente.' },
  { pregunta: '¿Cómo se calcula la pérdida de presión en una conexión Wye?', respuesta: 'La pérdida de presión en un Wye se calcula usando el coeficiente de flujo (Cv) del dispositivo y el caudal total que pasa por él. Los fabricantes como Elkhart Brass publican tablas de pérdida de carga para cada modelo a distintos caudales. Como referencia, un Wye de bronce de 2.5" bien diseñado tiene una pérdida de aproximadamente 2-5 PSI a 250 GPM totales. Al dividir el flujo en dos salidas iguales, la pérdida por cada salida es menor que en una sola línea, lo que puede ser ventajoso en instalaciones con presión limitada.' },
  { pregunta: '¿La conexión Y tiene válvulas de cierre independientes en cada salida?', respuesta: 'Sí. Las conexiones Y profesionales tienen una válvula de cierre de cuarto de vuelta en cada salida, lo que permite controlar el caudal en cada línea de forma independiente. Esto es fundamental para ajustar el flujo según las necesidades del ataque y para conectar o desconectar una línea sin interrumpir la otra. Es el estándar para operaciones de bomberos industriales y cumple con los requerimientos de NFPA 14 para sistemas standpipe.' },
];

const structuredData = [
  buildOrganizationSchema(),
  buildProductCategorySchema({
    name: 'Conexión Y (Wye) para Mangueras Contra Incendios',
    description: 'Conexión Y de bronce y aluminio para dividir suministro en dos líneas. 2.5" a dos salidas 1.5" NST. Brigadas México.',
    image: '/img/conexiones-herrajes/adaptador-aluminio-elk-o-lite-4-frontal.avif',
    url: '/conexiones/wye',
    category: 'Conexiones y Herrajes Contra Incendios',
    brand: 'Elkhart Brass',
    reviewAuthor: 'Ing. Carlos Mendoza',
    reviewBody: 'Excelente calidad y respaldo técnico de Gama de México. Equipos certificados con entrega puntual.',
    reviewDate: '2025-03-15',
    ratingCount: 32,
    reviewCount: 32,
  }),
  buildBreadcrumbSchema([
    { name: 'Inicio', url: '/' },
    { name: 'Equipos', url: '/equipos' },
    { name: 'Conexiones y Herrajes', url: '/conexiones-herrajes-contra-incendios' },
  ]),
  buildFAQSchema(faqItems),
];

---

<Layout
  structuredData={structuredData}
  title="Conexión Y Wye Gated y Plain Elkhart Brass | NFPA 14 México"
  description="Conexión Y (Wye) gated y plain Elkhart Brass para sistemas standpipe NFPA 14. Modelos B-97-A y B-100-A, 2.5&quot; a 2×1.5&quot; NH, 300 PSI, UL/FM. Distribuidor México."
  activePage="equipos"
  heroTitle="Conexión Y (Wye)"
  heroIntro="Bifurcadores que permiten dividir una línea de manguera en dos salidas independientes, cada una con válvula de bola para control individual del flujo. Esenciales para operaciones de combate de incendios que requieren múltiples líneas de ataque desde una sola fuente de agua."
  heroBadge="Conexiones y Herrajes"
  heroMetrics={[
    { valor: "2", texto: "Salidas" },
    { valor: "1/4 vuelta", texto: "Válvulas" },
    { valor: "UL/FM", texto: "Certificación" }
  ]}
  heroPrimaryText="Ver Catálogo"
  heroPrimaryLink="#catalogo"
  heroSecondaryText="Solicitar Cotización"
  heroSecondaryLink="#cotizar"
  heroShowRightContent={true}
>

  <!-- HERO CONTENT -->
  <Fragment slot="hero-content">
    <p>Las <strong>conexiones Y (Wye)</strong> son dispositivos de bifurcación que dividen una línea de suministro en dos salidas independientes. Cada salida incorpora una válvula de bola de cuarto de vuelta que permite abrir o cerrar el flujo instantáneamente, facilitando el control táctico durante operaciones de combate. Los modelos B-97-A y B-100-A de Elkhart Brass son el estándar de la industria para aplicaciones de bomberos e industriales.</p>
    <p><strong>Gama de México</strong> ofrece conexiones Wye en bronce fundido y aluminio forjado, con configuraciones de entrada/salida en roscas NH de 2-1/2" x 1-1/2" y 2-1/2" x 2-1/2". Las válvulas de bola están diseñadas para operar a presiones de hasta 300 PSI con mínima caída de presión. Certificación UL/FM garantiza rendimiento confiable en las condiciones más exigentes de emergencia.</p>
  </Fragment>
  <!-- BREADCRUMB -->
  <Breadcrumb />



  <!-- CONTENT + SIDEBAR -->
  <section class="subcat-content">
    <div class="container">
      <div class="subcat-layout">

        <!-- MAIN CONTENT -->
        <main class="subcat-main">
          <div class="catalog-header">
            <div class="catalog-header__text">
              <h2 class="catalog-header__title">Catálogo de Conexiones Y (Wye)</h2>
              <p class="catalog-header__desc">Selecciona el modelo que mejor se adapte a tu instalación</p>
            </div>
            <div class="catalog-header__count">
              <span class="catalog-header__number">{productosSubcategoria.length}</span>
              <span class="catalog-header__label">producto{productosSubcategoria.length !== 1 ? 's' : ''}</span>
            </div>
          </div>

          <!-- Products Grid -->
          <div class="categories__grid">
            {productosSubcategoria.map((producto) => (
              <SubcategoryProductCard
                title={producto.data.title}
                description={producto.data.description}
                brand={producto.data.marca}
                image={producto.data.imagen}
                productSlug={producto.id}
                flow={producto.data.flujo}
                material={producto.data.material}
                certifications={producto.data.certificaciones}
              />
            ))}
          </div>

          {productosSubcategoria.length === 0 && (
            <div class="catalog-empty">
              <div class="catalog-empty__icon">🔍</div>
              <h3 class="catalog-empty__title">Próximamente más opciones</h3>
              <p class="catalog-empty__text">Estamos agregando más conexiones Wye de diferentes configuraciones. Solicita una cotización personalizada.</p>
              <a href="#cotizar" class="btn btn--primary">Solicitar Cotización</a>
            </div>
          )}

          <!-- Tech Info -->
          <div class="tech-info">
            <h3 class="tech-info__title">Especificaciones Técnicas de Conexiones Y (Wye)</h3>
            <div class="tech-info__grid">
              <div class="tech-info__item">
                <span class="tech-info__label">Presión de trabajo</span>
                <span class="tech-info__value">300 PSI</span>
              </div>
              <div class="tech-info__item">
                <span class="tech-info__label">Válvulas</span>
                <span class="tech-info__value">Bola 1/4 de vuelta</span>
              </div>
              <div class="tech-info__item">
                <span class="tech-info__label">Entrada</span>
                <span class="tech-info__value">2.5" NH hembra</span>
              </div>
              <div class="tech-info__item">
                <span class="tech-info__label">Salidas</span>
                <span class="tech-info__value">2x 1.5" o 2.5" NH</span>
              </div>
              <div class="tech-info__item">
                <span class="tech-info__label">Certificación</span>
                <span class="tech-info__value">UL Listed / FM</span>
              </div>
              <div class="tech-info__item">
                <span class="tech-info__label">Material</span>
                <span class="tech-info__value">Bronce / Aluminio</span>
              </div>
            </div>
          </div>

          <!-- CTA Final -->
          <div class="subcat-cta-final">
            <div class="subcat-cta-final__content">
              <h3 class="subcat-cta-final__title">¿No encuentras la configuración que necesitas?</h3>
              <p class="subcat-cta-final__desc">Tenemos acceso al catálogo completo de Elkhart Brass. Contáctanos para conexiones Wye en configuraciones especiales o diámetros no estándar.</p>
            </div>
            <a href="#cotizar" class="btn btn--primary">Solicitar Cotización Especial</a>
          </div>
        </main>

        <!-- SIDEBAR -->
        <ProductSidebar
          navTitulo="Tipos de Conexiones"
          subcategorias={subcategorias}
          baseUrl="/conexiones"
          backLinkHref="/conexiones-herrajes-contra-incendios"
          backLinkTexto="Ver todas las conexiones"
          certificaciones={[
            { siglas: "FM", nombre: "Factory Mutual" },
            { siglas: "UL", nombre: "UL Listed" },
            { siglas: "NOM", nombre: "NOM-002-STPS" }
          ]}
          marcas={["Dixon", "Elkhart Brass", "Harrington", "Action Coupling"]}
          aplicaciones={[
            "División de líneas",
            "Operaciones de bomberos",
            "Sistemas de rociadores",
            "Redes contra incendio"
          ]}
          productosRelacionados={[
            { href: "/gabinetes-hidrantes-contra-incendios", nombre: "Gabinetes e Hidrantes" },
            { href: "/mangueras-contra-incendios", nombre: "Mangueras Contra Incendios" },
            { href: "/valvulas-contra-incendios", nombre: "Válvulas Contra Incendios" },
            { href: "/boquillas-contra-incendios", nombre: "Boquillas Contra Incendios" }
          ]}
        />

      </div>
    </div>
  </section>

  <!-- RELATED PRODUCTS -->
  <RelatedProductsGrid
    titulo="Otras Conexiones y Herrajes"
    subtitulo="Explora más opciones para tu sistema contra incendios"
    productos={otrosProductos}
    maxProductos={3}
    verTodosLink="/conexiones-herrajes-contra-incendios"
    verTodosTexto="Ver todas las conexiones"
  />

  <CotizacionForm
    titulo="Cotiza Conexiones Wye"
    tipoEquipo="Conexiones y herrajes"
    pagina="Conexiones Wye"
  />


  <!-- FAQ -->
  <section class="faq-section" id="faq" aria-labelledby="faq-title">
    <div class="container">
      <h2 id="faq-title" class="section-title">Preguntas Frecuentes</h2>
      <Faq items={faqItems} id="faq" />
    </div>
  </section>

</Layout>

<style>
  .faq-section {
    padding: var(--spacing-2xl, 4rem) 0;
    background: var(--color-surface, #fff);
  }
</style>
