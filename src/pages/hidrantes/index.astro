---
import Faq from '../../components/Faq.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';

import Layout from '../../layouts/Base.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import CotizacionForm from '../../components/CotizacionForm.astro';
import { getCollection } from 'astro:content';
import '../../styles/hidrantes.css';


// Obtener todos los hidrantes
const hidrantes = await getCollection('hidrantes');

// Agrupar por estado
const hidrantesPorEstado = hidrantes.reduce((acc, hidrante) => {
  const estado = hidrante.data.estado;
  if (!acc[estado]) acc[estado] = [];
  acc[estado].push(hidrante);
  return acc;
}, {} as Record<string, typeof hidrantes>);

// Agrupar por ciudad
const hidrantesPorCiudad = hidrantes.reduce((acc, hidrante) => {
  const ciudad = hidrante.data.ciudad;
  if (!acc[ciudad]) acc[ciudad] = [];
  acc[ciudad].push(hidrante);
  return acc;
}, {} as Record<string, typeof hidrantes>);

// Contar por estado operativo
const hidrantesOperativos = hidrantes.filter(h => h.data.estadoOperativo === 'operativo').length;
const hidrantesMantenimiento = hidrantes.filter(h => h.data.estadoOperativo === 'mantenimiento').length;
const hidrantesFueraServicio = hidrantes.filter(h => h.data.estadoOperativo === 'fuera-servicio').length;

// Contar por tipo
const hidrantesPublicos = hidrantes.filter(h => h.data.tipo === 'publico').length;
const hidrantesPrivados = hidrantes.filter(h => h.data.tipo === 'privado').length;

// Mapeo de colores de código
const colorLabels: Record<string, string> = {
  rojo: 'Rojo (< 500 GPM)',
  amarillo: 'Amarillo (500-999 GPM)',
  verde: 'Verde (1000-1499 GPM)',
  azul: 'Azul (1500+ GPM)'
};

const colorDescriptions: Record<string, string> = {
  rojo: 'Flujo menor a 500 GPM. Adecuado para uso residencial básico.',
  amarillo: 'Flujo de 500 a 999 GPM. Uso residencial y comercial ligero.',
  verde: 'Flujo de 1000 a 1499 GPM. Uso comercial e industrial.',
  azul: 'Flujo mayor a 1500 GPM. Máxima capacidad para industria pesada.'
};

// Schema.org
const directorySchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "Directorio de Hidrantes en México",
  "description": "Mapa interactivo de hidrantes contra incendios públicos y privados en México. Ubicación, estado operativo y características técnicas.",
  "numberOfItems": hidrantes.length,
  "itemListElement": hidrantes.slice(0, 10).map((hidrante, index) => ({
    "@type": "ListItem",
    "position": index + 1,
    "item": {
      "@type": "Place",
      "name": `Hidrante ${hidrante.data.id}`,
      "address": {
        "@type": "PostalAddress",
        "addressLocality": hidrante.data.ciudad,
        "addressRegion": hidrante.data.estado,
        "addressCountry": "MX"
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": hidrante.data.latitud,
        "longitude": hidrante.data.longitud
      }
    }
  }))
};
const faqItems = [
  { pregunta: '¿Cuál es el estado de los hidrantes contra incendios en CDMX?', respuesta: 'Gama de México mantiene un mapa actualizado de hidrantes públicos y privados en Ciudad de México y zonas metropolitanas. Los hidrantes se clasifican por presión disponible, estado de conservación y accesibilidad para brigadas de emergencia y sistemas de protección privada.' },
  { pregunta: '¿Cómo puedo saber si el hidrante más cercano a mi instalación está operativo?', respuesta: 'Contáctanos por WhatsApp al 55 6529 8240 o consulta nuestra base de datos de hidrantes. Para proyectos de protección contra incendios, realizamos pruebas de flujo en hidrantes cercanos para determinar la presión y caudal disponibles en el punto de suministro.' },
  { pregunta: '¿Venden hidrantes privados para instalaciones industriales?', respuesta: 'Sí. Distribuimos hidrantes de banqueta y muro para instalaciones privadas conforme a NFPA 24. Están disponibles en hierro fundido y bronce en configuraciones de 4", 6" y 8". Cotizamos instalación completa incluyendo valvulería, accesorios y conexión a la red existente.' },
];
---


<Layout
  title="Mapa de Hidrantes en México | Directorio de Hidrantes Contra Incendios"
  description="Localiza hidrantes contra incendios en México. Mapa interactivo con ubicación, estado operativo, presión y características técnicas de hidrantes públicos y privados."
  activePage="hidrantes"
  heroTitle="Directorio de Hidrantes Contra Incendios"
  heroIntro="Mapa interactivo de hidrantes en México. Consulta ubicación, estado operativo, presión disponible y características técnicas de hidrantes públicos y privados."
  heroBadge="Mapa de Hidrantes"
  heroMetrics={[
    { valor: String(hidrantes.length), texto: "Hidrantes registrados" },
    { valor: String(hidrantesOperativos), texto: "Operativos" },
    { valor: String(Object.keys(hidrantesPorCiudad).length), texto: "Ciudades" }
  ]}
  heroPrimaryText="Reportar hidrante"
  heroPrimaryLink="#reportar"
  heroSecondaryText="Ver mapa completo"
  heroSecondaryLink="#mapa"
  structuredData={[directorySchema]}
>

  <!-- Estadísticas -->
  <section class="stats-section">
    <div class="container">
      <div class="stats-grid">
        <div class="stat-card stat-card--operativo">
          <span class="stat-card__number">{hidrantesOperativos}</span>
          <span class="stat-card__label">Operativos</span>
          <span class="stat-card__icon">✓</span>
        </div>
        <div class="stat-card stat-card--mantenimiento">
          <span class="stat-card__number">{hidrantesMantenimiento}</span>
          <span class="stat-card__label">En Mantenimiento</span>
          <span class="stat-card__icon">⚙️</span>
        </div>
        <div class="stat-card stat-card--fuera">
          <span class="stat-card__number">{hidrantesFueraServicio}</span>
          <span class="stat-card__label">Fuera de Servicio</span>
          <span class="stat-card__icon">✗</span>
        </div>
        <div class="stat-card stat-card--publicos">
          <span class="stat-card__number">{hidrantesPublicos}</span>
          <span class="stat-card__label">Públicos</span>
          <span class="stat-card__icon">🏛️</span>
        </div>
        <div class="stat-card stat-card--privados">
          <span class="stat-card__number">{hidrantesPrivados}</span>
          <span class="stat-card__label">Privados</span>
          <span class="stat-card__icon">🏢</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Mapa Placeholder -->
  <section class="map-section" id="mapa">
    <div class="container">
      <SectionHeader
        titulo="Mapa Interactivo de Hidrantes"
        subtitulo="Localiza hidrantes cercanos a cualquier ubicación en México"
        idTitulo="mapa-hidrantes"
      />

      <div class="map-container">
        <div class="map-placeholder" id="hidrantes-map">
          <div class="map-placeholder__content">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
              <circle cx="12" cy="10" r="3"/>
            </svg>
            <h3>Mapa Interactivo</h3>
            <p>Visualización de {hidrantes.length} hidrantes en tiempo real</p>
            <p class="map-placeholder__note">Próximamente con Leaflet</p>
          </div>
        </div>

        <div class="map-legend">
          <h4 class="map-legend__title">Código de Colores (NFPA)</h4>
          <div class="legend-items">
            <div class="legend-item">
              <span class="legend-color legend-color--rojo"></span>
              <span class="legend-text">Rojo: &lt; 500 GPM</span>
            </div>
            <div class="legend-item">
              <span class="legend-color legend-color--amarillo"></span>
              <span class="legend-text">Amarillo: 500-999 GPM</span>
            </div>
            <div class="legend-item">
              <span class="legend-color legend-color--verde"></span>
              <span class="legend-text">Verde: 1000-1499 GPM</span>
            </div>
            <div class="legend-item">
              <span class="legend-color legend-color--azul"></span>
              <span class="legend-text">Azul: 1500+ GPM</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Explorar por Estado -->
  <section class="explore-section">
    <div class="container">
      <SectionHeader
        titulo="Hidrantes por Estado"
        subtitulo="Selecciona un estado para ver hidrantes disponibles"
        idTitulo="por-estado"
      />

      <div class="states-grid">
        {Object.entries(hidrantesPorEstado)
          .sort((a, b) => b[1].length - a[1].length)
          .map(([estado, lista]) => {
            const estadoSlug = estado.toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g, '').replace(/\s+/g, '-');
            const operativos = lista.filter(h => h.data.estadoOperativo === 'operativo').length;
            return (
              <a href={`/hidrantes/estado/${estadoSlug}`} class="state-card">
                <div class="state-card__header">
                  <h3 class="state-card__title">{estado}</h3>
                  <span class="state-card__count">{lista.length}</span>
                </div>
                <div class="state-card__stats">
                  <span class="stat-mini stat-mini--green">{operativos} operativos</span>
                  <span class="stat-mini stat-mini--gray">{lista.length - operativos} otros</span>
                </div>
                <div class="state-card__cities">
                  {[...new Set(lista.map(h => h.data.ciudad))].slice(0, 3).join(', ')}
                </div>
              </a>
            );
          })}
      </div>
    </div>
  </section>

  <!-- Código de Colores -->
  <section class="color-code-section">
    <div class="container">
      <SectionHeader
        titulo="Sistema de Código de Colores NFPA"
        subtitulo="Identificación visual de capacidad de flujo en hidrantes"
        idTitulo="codigo-colores"
      />

      <div class="color-cards">
        {Object.entries(colorLabels).map(([color, label]) => (
          <div class={`color-card color-card--${color}`}>
            <div class="color-card__hydrant">
              <svg viewBox="0 0 24 36" class="hydrant-icon">
                <rect x="8" y="0" width="8" height="6" rx="1" fill="currentColor"/>
                <rect x="6" y="6" width="12" height="20" rx="2" fill="currentColor"/>
                <rect x="0" y="10" width="6" height="4" rx="1" fill="currentColor"/>
                <rect x="18" y="10" width="6" height="4" rx="1" fill="currentColor"/>
                <rect x="4" y="26" width="16" height="4" rx="1" fill="currentColor"/>
                <rect x="6" y="30" width="12" height="6" rx="1" fill="currentColor"/>
              </svg>
            </div>
            <h3 class="color-card__title">{label}</h3>
            <p class="color-card__desc">{colorDescriptions[color]}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Lista de Hidrantes Recientes -->
  <section class="recent-section">
    <div class="container">
      <SectionHeader
        titulo="Hidrantes Registrados Recientemente"
        subtitulo="Últimas actualizaciones del directorio"
        idTitulo="recientes"
      />

      <div class="hidrantes-table">
        <div class="table-header">
          <span class="col-id">ID</span>
          <span class="col-location">Ubicación</span>
          <span class="col-type">Tipo</span>
          <span class="col-pressure">Presión</span>
          <span class="col-status">Estado</span>
          <span class="col-action"></span>
        </div>
        {hidrantes.slice(0, 10).map((hidrante) => (
          <div class="table-row">
            <div class="col-id">
              <span class={`id-badge id-badge--${hidrante.data.colorCodigo || 'rojo'}`}>
                {hidrante.data.id}
              </span>
            </div>
            <div class="col-location">
              <strong>{hidrante.data.ubicacionDescripcion}</strong>
              <span>{hidrante.data.colonia}, {hidrante.data.ciudad}</span>
            </div>
            <div class="col-type">
              {hidrante.data.tipo === 'publico' ? '🏛️ Público' : '🏢 Privado'}
            </div>
            <div class="col-pressure">
              {hidrante.data.presionPsi ? `${hidrante.data.presionPsi} PSI` : 'N/A'}
            </div>
            <div class="col-status">
              <span class={`status-badge status-badge--${hidrante.data.estadoOperativo}`}>
                {hidrante.data.estadoOperativo === 'operativo' && '✓ Operativo'}
                {hidrante.data.estadoOperativo === 'mantenimiento' && '⚙️ Mantenimiento'}
                {hidrante.data.estadoOperativo === 'fuera-servicio' && '✗ Fuera de Servicio'}
              </span>
            </div>
            <div class="col-action">
              <a href={`/hidrantes/${hidrante.data.id.toLowerCase()}`} class="btn btn--sm btn--outline">
                Ver
              </a>
            </div>
          </div>
        ))}
      </div>

      {hidrantes.length > 10 && (
        <div class="view-all">
          <a href="/gabinetes-hidrantes-contra-incendios" class="btn btn--primary">
            Ver todos los hidrantes ({hidrantes.length})
          </a>
        </div>
      )}
    </div>
  </section>

  <!-- Reportar Hidrante -->
  <section class="report-section" id="reportar">
    <div class="container">
      <div class="report-content">
        <div class="report-info">
          <h2 class="report-title">¿Conoces un hidrante que no está registrado?</h2>
          <p class="report-text">
            Ayúdanos a mantener el directorio actualizado. Reporta hidrantes públicos o privados que no aparezcan en nuestro mapa.
          </p>
          <ul class="report-benefits">
            <li>Contribuye a la seguridad de tu comunidad</li>
            <li>Ayuda a los servicios de emergencia</li>
            <li>Información verificada por profesionales</li>
          </ul>
        </div>
        <div class="report-form-card">
          <h3>Información requerida</h3>
          <ul class="report-requirements">
            <li>📍 Ubicación exacta (dirección o coordenadas)</li>
            <li>📸 Fotografía del hidrante</li>
            <li>🔧 Estado aparente (operativo/dañado)</li>
            <li>📝 Observaciones adicionales</li>
          </ul>
          <a href="#cotizar" class="btn btn--primary btn--block">
            Reportar hidrante
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Formulario -->
  <CotizacionForm
    titulo="Reportar o solicitar información sobre hidrantes"
    producto="Reporte de Hidrante"
    pagina="Directorio de Hidrantes"
  />


  <section style="padding:3rem 0;background:#fff;">
    <div class="container" style="max-width:900px;margin:0 auto;padding:0 1rem;">
      <h2 style="font-size:1.5rem;font-weight:700;margin-bottom:1.5rem;">Preguntas Frecuentes</h2>
      <Faq items={faqItems} />
    </div>
  </section>
</Layout>


