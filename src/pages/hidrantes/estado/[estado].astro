---
import Layout from '../../../layouts/Base.astro';
import SectionHeader from '../../../components/SectionHeader.astro';
import CotizacionForm from '../../../components/CotizacionForm.astro';
import { getCollection } from 'astro:content';
import '../../../styles/hidrantes.css';


// Colores
const colorLabels: Record<string, string> = {
  rojo: 'Rojo (< 500 GPM)',
  amarillo: 'Amarillo (500-999 GPM)',
  verde: 'Verde (1000-1499 GPM)',
  azul: 'Azul (1500+ GPM)'
};

// Estado operativo
const estadoOpLabels: Record<string, string> = {
  operativo: 'Operativo',
  mantenimiento: 'En Mantenimiento',
  'fuera-servicio': 'Fuera de Servicio'
};

export async function getStaticPaths() {
  // Función definida aquí para estar disponible en build
  function createSlug(text: string): string {
    return text.toLowerCase()
      .normalize('NFD')
      .replace(/[\u0300-\u036f]/g, '')
      .replace(/\s+/g, '-');
  }

  const hidrantes = await getCollection('hidrantes');
  const estados = [...new Set(hidrantes.map(h => h.data.estado))];

  return estados.map(estado => ({
    params: { estado: createSlug(estado) },
    props: {
      hidrantes: hidrantes.filter(h => h.data.estado === estado),
      estadoNombre: estado
    }
  }));
}

const { hidrantes, estadoNombre } = Astro.props;

// Agrupar por ciudad
const hidrantesPorCiudad = hidrantes.reduce((acc, h) => {
  const ciudad = h.data.ciudad;
  if (!acc[ciudad]) acc[ciudad] = [];
  acc[ciudad].push(h);
  return acc;
}, {} as Record<string, typeof hidrantes>);

// Estadísticas
const operativos = hidrantes.filter(h => h.data.estadoOperativo === 'operativo').length;
const publicos = hidrantes.filter(h => h.data.tipo === 'publico').length;

// Schema.org
const itemListSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": `Hidrantes en ${estadoNombre}, México`,
  "description": `Directorio de ${hidrantes.length} hidrantes contra incendios en ${estadoNombre}. Mapa de ubicación, estado operativo y características técnicas.`,
  "numberOfItems": hidrantes.length,
  "itemListElement": hidrantes.slice(0, 10).map((h, index) => ({
    "@type": "ListItem",
    "position": index + 1,
    "item": {
      "@type": "Place",
      "name": `Hidrante ${h.data.id}`,
      "address": {
        "@type": "PostalAddress",
        "addressLocality": h.data.ciudad,
        "addressRegion": estadoNombre,
        "addressCountry": "MX"
      }
    }
  }))
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Inicio", "item": "https://gamademexico.com" },
    { "@type": "ListItem", "position": 2, "name": "Hidrantes", "item": "https://gamademexico.com/hidrantes" },
    { "@type": "ListItem", "position": 3, "name": estadoNombre }
  ]
};
---

<Layout
  title={`Hidrantes en ${estadoNombre} | Mapa de Hidrantes Contra Incendios`}
  description={`${hidrantes.length} hidrantes contra incendios en ${estadoNombre}. Consulta ubicación, estado operativo y características. ${operativos} operativos, ${publicos} públicos.`}
  activePage="hidrantes"
  heroTitle={`Hidrantes en ${estadoNombre}`}
  heroIntro={`Directorio de ${hidrantes.length} hidrantes contra incendios registrados en ${estadoNombre}. Consulta ubicación exacta, estado operativo y especificaciones técnicas.`}
  heroBadge={estadoNombre}
  heroMetrics={[
    { valor: String(hidrantes.length), texto: "Hidrantes registrados" },
    { valor: String(operativos), texto: "Operativos" },
    { valor: String(Object.keys(hidrantesPorCiudad).length), texto: "Ciudades" }
  ]}
  heroPrimaryText="Reportar hidrante"
  heroPrimaryLink="/hidrantes#reportar"
  heroSecondaryText="Ver todos los estados"
  heroSecondaryLink="/hidrantes#estados"
  structuredData={[itemListSchema, breadcrumbSchema]}
>

  <!-- Breadcrumb -->
  <nav class="breadcrumb">
    <div class="container">
      <ol class="breadcrumb__list">
        <li class="breadcrumb__item"><a href="/">Inicio</a></li>
        <li class="breadcrumb__item"><a href="/hidrantes">Hidrantes</a></li>
        <li class="breadcrumb__item breadcrumb__item--active">{estadoNombre}</li>
      </ol>
    </div>
  </nav>

  <!-- Por Ciudad -->
  <section class="cities-section">
    <div class="container">
      <SectionHeader
        titulo={`Ciudades en ${estadoNombre}`}
        subtitulo="Selecciona una ciudad para ver hidrantes disponibles"
        idTitulo="ciudades"
      />

      <div class="cities-grid">
        {Object.entries(hidrantesPorCiudad)
          .sort((a, b) => b[1].length - a[1].length)
          .map(([ciudad, lista]) => {
            const operativosEnCiudad = lista.filter(h => h.data.estadoOperativo === 'operativo').length;
            return (
              <div class="city-card">
                <div class="city-card__header">
                  <h3 class="city-card__title">{ciudad}</h3>
                  <span class="city-card__count">{lista.length}</span>
                </div>
                <div class="city-card__stats">
                  <span class="stat stat--green">{operativosEnCiudad} operativos</span>
                  {lista.length - operativosEnCiudad > 0 && (
                    <span class="stat stat--gray">{lista.length - operativosEnCiudad} otros</span>
                  )}
                </div>
                <ul class="city-card__list">
                  {lista.slice(0, 3).map(h => (
                    <li>
                      <a href={`/hidrantes/${h.data.id.toLowerCase()}`}>
                        <span class={`status-dot status-dot--${h.data.estadoOperativo}`}></span>
                        {h.data.id} - {h.data.ubicacionDescripcion.slice(0, 40)}...
                      </a>
                    </li>
                  ))}
                </ul>
                {lista.length > 3 && (
                  <span class="city-card__more">+{lista.length - 3} más</span>
                )}
              </div>
            );
          })}
      </div>
    </div>
  </section>

  <!-- Todos los Hidrantes -->
  <section class="all-section">
    <div class="container">
      <SectionHeader
        titulo={`Todos los Hidrantes en ${estadoNombre}`}
        subtitulo={`${hidrantes.length} hidrantes registrados`}
        idTitulo="todos"
      />

      <div class="filters-bar">
        <div class="filter-group">
          <label>Estado:</label>
          <select id="filter-status">
            <option value="all">Todos</option>
            <option value="operativo">Operativo</option>
            <option value="mantenimiento">En Mantenimiento</option>
            <option value="fuera-servicio">Fuera de Servicio</option>
          </select>
        </div>
        <div class="filter-group">
          <label>Tipo:</label>
          <select id="filter-type">
            <option value="all">Todos</option>
            <option value="publico">Público</option>
            <option value="privado">Privado</option>
          </select>
        </div>
        <div class="filter-group">
          <label>Ciudad:</label>
          <select id="filter-city">
            <option value="all">Todas</option>
            {Object.keys(hidrantesPorCiudad).map(ciudad => (
              <option value={ciudad}>{ciudad}</option>
            ))}
          </select>
        </div>
      </div>

      <div class="hidrantes-grid" id="hidrantes-grid">
        {hidrantes.map((h) => (
          <article class="hidrante-card" data-status={h.data.estadoOperativo} data-type={h.data.tipo} data-city={h.data.ciudad}>
            <div class="hidrante-card__header">
              <span class={`id-badge id-badge--${h.data.colorCodigo || 'rojo'}`}>
                {h.data.id}
              </span>
              <span class={`status-badge status-badge--${h.data.estadoOperativo}`}>
                {estadoOpLabels[h.data.estadoOperativo]}
              </span>
            </div>

            <div class="hidrante-card__location">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
                <circle cx="12" cy="10" r="3"/>
              </svg>
              <div>
                <strong>{h.data.ubicacionDescripcion}</strong>
                <span>{h.data.colonia}, {h.data.ciudad}</span>
              </div>
            </div>

            <div class="hidrante-card__specs">
              <div class="spec">
                <span class="spec__label">Tipo</span>
                <span class="spec__value">{h.data.tipo === 'publico' ? '🏛️ Público' : '🏢 Privado'}</span>
              </div>
              {h.data.presionPsi && (
                <div class="spec">
                  <span class="spec__label">Presión</span>
                  <span class="spec__value">{h.data.presionPsi} PSI</span>
                </div>
              )}
              {h.data.colorCodigo && (
                <div class="spec">
                  <span class="spec__label">Capacidad</span>
                  <span class="spec__value" style={`color: ${h.data.colorCodigo === 'rojo' ? '#c8102e' : h.data.colorCodigo === 'amarillo' ? '#f57c00' : h.data.colorCodigo === 'verde' ? '#2e7d32' : '#1565c0'}`}>
                    {colorLabels[h.data.colorCodigo].split(' ')[0]}
                  </span>
                </div>
              )}
            </div>

            <a href={`/hidrantes/${h.data.id.toLowerCase()}`} class="hidrante-card__link">
              Ver detalles →
            </a>
          </article>
        ))}
      </div>

      <p class="results-count" id="results-count">
        Mostrando <strong>{hidrantes.length}</strong> hidrantes
      </p>
    </div>
  </section>

  <!-- CTA -->
  <CotizacionForm
    titulo={`¿Conoces un hidrante en ${estadoNombre}?`}
    producto={`Reporte Hidrante ${estadoNombre}`}
    pagina={`Estado: ${estadoNombre}`}
  />

</Layout>

<script>
  const grid = document.getElementById('hidrantes-grid');
  const cards = grid?.querySelectorAll('.hidrante-card');
  const resultsCount = document.getElementById('results-count');

  const filterStatus = document.getElementById('filter-status') as HTMLSelectElement;
  const filterType = document.getElementById('filter-type') as HTMLSelectElement;
  const filterCity = document.getElementById('filter-city') as HTMLSelectElement;

  function applyFilters() {
    const status = filterStatus?.value;
    const type = filterType?.value;
    const city = filterCity?.value;
    let visibleCount = 0;

    cards?.forEach(card => {
      const cardStatus = card.getAttribute('data-status');
      const cardType = card.getAttribute('data-type');
      const cardCity = card.getAttribute('data-city');

      const matchesStatus = status === 'all' || cardStatus === status;
      const matchesType = type === 'all' || cardType === type;
      const matchesCity = city === 'all' || cardCity === city;

      if (matchesStatus && matchesType && matchesCity) {
        (card as HTMLElement).style.display = '';
        visibleCount++;
      } else {
        (card as HTMLElement).style.display = 'none';
      }
    });

    if (resultsCount) {
      resultsCount.innerHTML = `Mostrando <strong>${visibleCount}</strong> hidrantes`;
    }
  }

  filterStatus?.addEventListener('change', applyFilters);
  filterType?.addEventListener('change', applyFilters);
  filterCity?.addEventListener('change', applyFilters);
</script>


