---
// =============================================================================
// Blog Tag - Página de etiqueta
// =============================================================================

import Layout from '../../../layouts/Base.astro';
import { getCollection } from 'astro:content';
import BlogGrid from '../../../components/blog/BlogGrid.astro';
import BlogSidebar from '../../../components/blog/BlogSidebar.astro';
import { getAllTags, CATEGORY_LABELS, CATEGORY_SLUGS, slugifyTag } from '../../../lib/blogHelpers';
import { buildBreadcrumbSchema } from '../../../lib/seo';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);

  // Obtener todos los tags únicos
  const allTags = new Set<string>();
  posts.forEach((p) => p.data.tags?.forEach((t) => allTags.add(t)));

  return [...allTags].map((tag) => ({
    params: { tag: slugifyTag(tag) },
    props: {
      tag,
      posts: posts
        .filter((p) => p.data.tags?.includes(tag))
        .sort((a, b) => new Date(b.data.fecha).getTime() - new Date(a.data.fecha).getTime()),
    },
  }));
}

const { tag, posts } = Astro.props;

// Obtener todos los tags para la sidebar
const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const allTags = getAllTags(allPosts);

const toSidebarLink = (entry: typeof allPosts[number]) => ({
  title: entry.data.title,
  href: `/blog/${CATEGORY_SLUGS[entry.data.categoria] || entry.data.categoria}/${entry.id}`,
  categoryLabel: CATEGORY_LABELS[entry.data.categoria] || entry.data.categoria,
});

const sidebarTagPosts = posts.map(toSidebarLink).slice(0, 6);
const sidebarTagUrls = new Set(sidebarTagPosts.map((entry) => entry.href));
const sidebarFeaturedPosts = allPosts
  .sort((a, b) => {
    if (Boolean(b.data.destacado) !== Boolean(a.data.destacado)) {
      return Number(Boolean(b.data.destacado)) - Number(Boolean(a.data.destacado));
    }
    return new Date(b.data.fecha).getTime() - new Date(a.data.fecha).getTime();
  })
  .map(toSidebarLink)
  .filter((entry) => !sidebarTagUrls.has(entry.href))
  .slice(0, 4);

const sidebarHubs = [...new Set(posts.map((entry) => entry.data.categoria))]
  .slice(0, 4)
  .map((category) => ({
    title: `Más sobre ${CATEGORY_LABELS[category] || category}`,
    href: `/blog/${CATEGORY_SLUGS[category] || category}`,
    description: 'Accede a artículos técnicos relacionados en esta categoría.',
  }));

const legalGuideByCategory: Record<string, { href: string; title: string }> = {
  monitores: {
    href: '/blog/monitores-contra-incendios/lineamientos-monitor-contra-incendios-mexico',
    title: 'Lineamientos de monitores para empresas',
  },
  boquillas: {
    href: '/blog/boquillas-contra-incendios/cumplimiento-legal-boquillas-contra-incendios-mexico-2026',
    title: 'Cumplimiento legal de boquillas en México',
  },
  mangueras: {
    href: '/blog/mangueras-contra-incendios/lineamientos-mangueras-contra-incendios-empresas-mexico',
    title: 'Lineamientos de mangueras contra incendios',
  },
  valvulas: {
    href: '/blog/valvulas-contra-incendios/normativa-nfpa-valvulas-contra-incendios',
    title: 'Normativa NFPA para válvulas',
  },
  'gabinetes-hidrantes': {
    href: '/blog/gabinetes-hidrantes-contra-incendios/requisitos-legales-equipos-contra-incendios-mexico-empresas',
    title: 'Requisitos legales de equipos contra incendios',
  },
};

const categoryCounts = posts.reduce<Record<string, number>>((acc, entry) => {
  const key = entry.data.categoria;
  acc[key] = (acc[key] || 0) + 1;
  return acc;
}, {});

const dominantCategories = Object.entries(categoryCounts)
  .sort((a, b) => b[1] - a[1])
  .map(([slug]) => slug)
  .slice(0, 3);

const sidebarInterestModules = dominantCategories.map((slug) => {
  const categoryLabel = CATEGORY_LABELS[slug] || slug;
  const legalGuide = legalGuideByCategory[slug];

  if (legalGuide) {
    return {
      title: legalGuide.title,
      href: legalGuide.href,
      description: `Guía recomendada para reforzar cumplimiento y trazabilidad en ${categoryLabel.toLowerCase()}.`,
    };
  }

  return {
    title: `Guías clave de ${categoryLabel}`,
    href: `/blog/${CATEGORY_SLUGS[slug] || slug}`,
    description: 'Criterios de selección, operación y mantenimiento para proyectos empresariales.',
  };
});

// Schema breadcrumb
const breadcrumbSchema = buildBreadcrumbSchema([
  { name: 'Inicio', url: '/' },
  { name: 'Blog', url: '/blog' },
  { name: `Etiqueta: ${tag}`, url: `/blog/tag/${slugifyTag(tag)}` },
]);
---

<Layout
  title={`Artículos sobre "${tag}" | Blog Gama de México`}
  description={`${posts.length} artículos etiquetados con "${tag}" sobre equipos contra incendios, normatividad y seguridad industrial.`}
  heroTitle={`Etiqueta: ${tag}`}
  heroIntro={`${posts.length} ${posts.length === 1 ? 'artículo encontrado' : 'artículos encontrados'} con esta etiqueta`}
  heroBadge="Etiqueta"
  heroPrimaryText="Solicitar Asesoría"
  heroPrimaryLink="#cotizar"
  heroSecondaryText="Ver Todos"
  heroSecondaryLink="/blog"
  structuredData={[breadcrumbSchema]}
>
  <BlogGrid
    posts={posts}
    titulo={`Resultados para la etiqueta: ${tag}`}
    subtitulo={`${posts.length} ${posts.length === 1 ? 'artículo técnico encontrado' : 'artículos técnicos encontrados'} con esta etiqueta.`}
    columns={2}
    background="white"
    showCount={true}
  >
    <Fragment slot="sidebar">
      <BlogSidebar
        layoutVariant="tag"
        tags={allTags}
        showCTA={true}
        featuredPosts={sidebarFeaturedPosts}
        recentPosts={sidebarTagPosts}
        recentPostsTitle={`Más sobre "${tag}"`}
        interlinkHubs={sidebarHubs}
        interestModules={sidebarInterestModules}
        ctaTitulo="¿Necesitas asesoría para tu proyecto?"
        ctaTexto="Nuestro equipo técnico te ayuda a elegir equipos contra incendios compatibles con tu operación y normativa aplicable."
      />
    </Fragment>
  </BlogGrid>
</Layout>
