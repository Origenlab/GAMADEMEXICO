---
// =============================================================================
// Blog Category Index - Página de categoría /blog/[categoria-contra-incendios]
// Hero profesional de dos columnas como el index principal
// =============================================================================

import Layout from '../../../layouts/Base.astro';
import { getCollection } from 'astro:content';
import BlogGrid from '../../../components/blog/BlogGrid.astro';
import BlogSidebar from '../../../components/blog/BlogSidebar.astro';
import BlogCategories from '../../../components/blog/BlogCategories.astro';
import { CATEGORY_MAP } from '../../../lib/config';
import {
  getCategoriesWithCount,
  getAllTags,
  CATEGORY_LABELS,
  CATEGORY_SLUGS,
} from '../../../lib/blogHelpers';
import { buildBreadcrumbSchema } from '../../../lib/seo';

// Metadata completa de categorías para SEO y Hero
const CATEGORY_META: Record<string, {
  title: string;
  description: string;
  heroContent: string[];
  metrics: Array<{ valor: string; texto: string }>;
}> = {
  monitores: {
    title: 'Guías Técnicas de Monitores Contra Incendios',
    description: 'Artículos profesionales sobre selección, instalación y mantenimiento de monitores contra incendios. Normatividad NFPA 15, certificaciones FM/UL y mejores prácticas.',
    heroContent: [
      'Nuestros artículos sobre <strong>monitores contra incendios</strong> cubren desde la selección técnica según caudal y alcance, hasta procedimientos de mantenimiento preventivo conforme a NFPA 25. Contenido desarrollado por ingenieros con experiencia en instalaciones industriales, petroquímicas y de almacenamiento.',
      'Aprende a elegir entre monitores tipo corazón y cuello de cisne, entiende las diferencias entre certificaciones FM Approved y UL Listed, y conoce los criterios de posicionamiento para máxima cobertura. Guías prácticas para responsables de seguridad, instaladores y firmas de ingeniería.',
    ],
    metrics: [
      { valor: 'NFPA 15', texto: 'Normativa aplicable' },
      { valor: 'FM/UL', texto: 'Certificaciones' },
      { valor: '500-2000', texto: 'GPM típicos' },
    ],
  },
  boquillas: {
    title: 'Guías Técnicas de Boquillas Contra Incendios',
    description: 'Artículos sobre boquillas contra incendios: tipos, selección por GPM, patrones de descarga y certificaciones. Guías para brigadas y profesionales.',
    heroContent: [
      'Artículos técnicos sobre <strong>boquillas contra incendios</strong> para brigadas industriales, bomberos y responsables de seguridad. Desde boquillas tipo pistola hasta turbo jet, cubrimos selección por caudal, patrones de descarga y compatibilidad con mangueras.',
      'Conoce las diferencias entre boquillas de chorro sólido, niebla y espuma, entiende los rangos de operación en GPM y aprende a seleccionar el equipo correcto según el tipo de riesgo. Contenido basado en normatividad NFPA y especificaciones de fabricantes certificados.',
    ],
    metrics: [
      { valor: 'NFPA 1964', texto: 'Normativa aplicable' },
      { valor: '95-250', texto: 'GPM típicos' },
      { valor: 'UL Listed', texto: 'Certificación' },
    ],
  },
  mangueras: {
    title: 'Guías Técnicas de Mangueras Contra Incendios',
    description: 'Todo sobre mangueras contra incendios: tipos, selección, cuidado y normativa NFPA 1961. Guías para mantenimiento y pruebas hidrostáticas.',
    heroContent: [
      'Guías completas sobre <strong>mangueras contra incendios</strong>: desde la selección por diámetro y presión de trabajo, hasta procedimientos de prueba hidrostática conforme a NFPA 1962. Contenido para responsables de mantenimiento y brigadas industriales.',
      'Aprende las diferencias entre mangueras de chaqueta simple, doble forro y Blindex, conoce los criterios de almacenamiento y enrollado, y domina las inspecciones periódicas. Artículos prácticos con enfoque en cumplimiento normativo y vida útil del equipo.',
    ],
    metrics: [
      { valor: 'NFPA 1961', texto: 'Fabricación' },
      { valor: 'NFPA 1962', texto: 'Mantenimiento' },
      { valor: '300 PSI', texto: 'Presión típica' },
    ],
  },
  valvulas: {
    title: 'Guías Técnicas de Válvulas Contra Incendios',
    description: 'Artículos sobre válvulas para sistemas contra incendios: OS&Y, mariposa, retención y globe. Instalación, mantenimiento y certificaciones.',
    heroContent: [
      'Artículos técnicos sobre <strong>válvulas contra incendios</strong> para sistemas de rociadores, standpipes y redes hidráulicas. Cubrimos válvulas OS&Y, mariposa con supervisión, retención y globe conforme a NFPA 13 y NFPA 25.',
      'Conoce los requisitos de instalación, procedimientos de inspección trimestral y anual, y criterios de selección según aplicación. Guías para ingenieros de proyecto, instaladores certificados y responsables de mantenimiento de sistemas contra incendios.',
    ],
    metrics: [
      { valor: 'NFPA 13', texto: 'Diseño sistemas' },
      { valor: 'NFPA 25', texto: 'Inspección' },
      { valor: 'FM/UL', texto: 'Certificaciones' },
    ],
  },
  'conexiones-herrajes': {
    title: 'Guías Técnicas de Conexiones y Herrajes',
    description: 'Artículos sobre conexiones contra incendios: adaptadores, siamesas FDC, coples Storz, Wye y herrajes de bronce para sistemas hidráulicos.',
    heroContent: [
      'Guías técnicas sobre <strong>conexiones y herrajes</strong> para sistemas contra incendios: adaptadores NST/NH, coples Storz, tomas siamesas FDC, conexiones Y y reducciones. Contenido para instaladores y personal de mantenimiento.',
      'Aprende sobre compatibilidad de roscas, materiales adecuados según aplicación, y procedimientos de instalación conforme a NFPA 14. Artículos prácticos con especificaciones técnicas y mejores prácticas de la industria.',
    ],
    metrics: [
      { valor: 'NFPA 14', texto: 'Standpipes' },
      { valor: 'NST/Storz', texto: 'Roscas comunes' },
      { valor: 'Bronce', texto: 'Material típico' },
    ],
  },
  'gabinetes-hidrantes': {
    title: 'Guías Técnicas de Gabinetes e Hidrantes',
    description: 'Todo sobre gabinetes contra incendios e hidrantes: tipos, instalación, normativa NFPA 14 y equipamiento completo para edificios.',
    heroContent: [
      'Artículos sobre <strong>gabinetes e hidrantes</strong> contra incendios: desde gabinetes tipo 30ME hasta hidrantes de banqueta y poste. Cubrimos requisitos de instalación, equipamiento y mantenimiento conforme a NFPA 14.',
      'Conoce las especificaciones de gabinetes para edificios comerciales e industriales, requisitos de accesibilidad, componentes obligatorios y procedimientos de inspección. Guías para arquitectos, instaladores y responsables de seguridad.',
    ],
    metrics: [
      { valor: 'NFPA 14', texto: 'Standpipes' },
      { valor: 'Clase I/II/III', texto: 'Clasificación' },
      { valor: 'NOM', texto: 'Cumplimiento MX' },
    ],
  },
};

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  const categories = [...new Set(posts.map((p) => p.data.categoria))];

  return categories.map((category) => {
    const categorySlug = CATEGORY_SLUGS[category] || category;
    const categoryPosts = posts
      .filter((p) => p.data.categoria === category)
      .sort((a, b) => new Date(b.data.fecha).getTime() - new Date(a.data.fecha).getTime());

    return {
      params: { categoria: categorySlug },
      props: {
        category,
        categorySlug,
        posts: categoryPosts,
      },
    };
  });
}

const { category, categorySlug, posts } = Astro.props;

// Obtener metadata de la categoría
const defaultMeta = {
  title: `Artículos sobre ${CATEGORY_LABELS[category] || category}`,
  description: `Guías técnicas sobre ${CATEGORY_LABELS[category] || category} en el blog de Gama de México.`,
  heroContent: [
    `Artículos profesionales sobre <strong>${CATEGORY_LABELS[category] || category}</strong> desarrollados por nuestro equipo técnico. Contenido práctico con enfoque en normatividad y mejores prácticas de la industria.`,
    'Guías para profesionales de seguridad, instaladores certificados y responsables de mantenimiento de sistemas contra incendios en México.',
  ],
  metrics: [
    { valor: `${posts.length}`, texto: 'Artículos' },
    { valor: 'NFPA', texto: 'Normativas' },
    { valor: 'NOM', texto: 'Cumplimiento' },
  ],
};

const meta = CATEGORY_META[category] || defaultMeta;
const categoryLabel = CATEGORY_LABELS[category] || category;

// Obtener todas las categorías para navegación
const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const allCategories = getCategoriesWithCount(allPosts);
const allTags = getAllTags(allPosts);

const toSidebarLink = (entry: typeof allPosts[number]) => ({
  title: entry.data.title,
  href: `/blog/${CATEGORY_SLUGS[entry.data.categoria] || entry.data.categoria}/${entry.id}`,
  categoryLabel: CATEGORY_LABELS[entry.data.categoria] || entry.data.categoria,
});

const sidebarCategoryPosts = posts.slice(0, 6).map(toSidebarLink);
const sidebarCategoryPostUrls = new Set(sidebarCategoryPosts.map((entry) => entry.href));
const sidebarFeaturedPosts = allPosts
  .filter((entry) => entry.data.categoria !== category)
  .sort((a, b) => {
    if (Boolean(b.data.destacado) !== Boolean(a.data.destacado)) {
      return Number(Boolean(b.data.destacado)) - Number(Boolean(a.data.destacado));
    }
    return new Date(b.data.fecha).getTime() - new Date(a.data.fecha).getTime();
  })
  .map(toSidebarLink)
  .filter((entry) => !sidebarCategoryPostUrls.has(entry.href))
  .slice(0, 4);

const sidebarRecentPosts = allPosts
  .sort((a, b) => new Date(b.data.fecha).getTime() - new Date(a.data.fecha).getTime())
  .map(toSidebarLink)
  .filter((entry) => !sidebarCategoryPostUrls.has(entry.href))
  .slice(0, 6);

const categoryLandingUrl = category in CATEGORY_MAP
  ? CATEGORY_MAP[category as keyof typeof CATEGORY_MAP].url
  : '/equipos';

const strategicPattern = /(lineamientos|requisitos|manual|cumplimiento|auditoria|inspeccion|normativa|programa|guia)/i;
const sidebarInterestModules = posts
  .filter((entry) => strategicPattern.test(entry.id) || strategicPattern.test(entry.data.title))
  .slice(0, 3)
  .map((entry) => ({
    title: entry.data.title,
    href: `/blog/${CATEGORY_SLUGS[entry.data.categoria] || entry.data.categoria}/${entry.id}`,
    description: `Guía técnica de ${categoryLabel.toLowerCase()} para aplicación empresarial.`,
  }));

const sidebarInterlinkHubs = [
  {
    title: `Catálogo de ${categoryLabel}`,
    href: categoryLandingUrl,
    description: 'Modelos, especificaciones y aplicaciones por tipo de proyecto.',
  },
  {
    title: 'Asesoría técnica especializada',
    href: '/servicios/asesoria',
    description: 'Soporte para selección de equipos, compatibilidad y cumplimiento.',
  },
  {
    title: 'Mantenimiento de equipos',
    href: '/servicios/mantenimiento',
    description: 'Planes de inspección, evidencia documental y continuidad operativa.',
  },
  {
    title: 'Solicitar cotización empresarial',
    href: '/servicios/cotizaciones',
    description: 'Propuesta comercial con tiempos de entrega y soporte postventa.',
  },
];

// Schema breadcrumb
const breadcrumbSchema = buildBreadcrumbSchema([
  { name: 'Inicio', url: '/' },
  { name: 'Blog', url: '/blog' },
  { name: categoryLabel, url: `/blog/${categorySlug}` },
]);
---

<Layout
  title={`${meta.title} | Blog Gama de México`}
  description={meta.description}
  heroTitle={meta.title}
  heroIntro={meta.description}
  heroBadge="Blog Técnico Especializado"
  heroMetrics={meta.metrics}
  heroPrimaryText="Solicitar Asesoría"
  heroPrimaryLink="#cotizar"
  heroSecondaryText="Ver Equipos"
  heroSecondaryLink={`/${category === 'gabinetes-hidrantes' ? 'gabinetes-hidrantes' : category + '-contra-incendios'}`}
  heroShowRightContent={true}
  structuredData={[breadcrumbSchema]}
>
  <Fragment slot="hero-content">
    {meta.heroContent.map((paragraph) => (
      <p set:html={paragraph} />
    ))}
  </Fragment>

  <!-- Navegación de categorías -->
  <BlogCategories categories={allCategories} activeCategory={category} />

  <!-- Grid de artículos -->
  <BlogGrid
    posts={posts}
    titulo={`${posts.length} ${posts.length === 1 ? 'artículo' : 'artículos'} sobre ${categoryLabel}`}
    subtitulo="Contenido técnico desarrollado por ingenieros especializados"
    columns={3}
  >
    <Fragment slot="sidebar">
      <BlogSidebar
        layoutVariant="category"
        tags={allTags}
        showCTA={true}
        categorySlug={categorySlug}
        categoryPosts={sidebarCategoryPosts}
        featuredPosts={sidebarFeaturedPosts}
        recentPosts={sidebarRecentPosts}
        recentPostsTitle="Publicaciones Recientes"
        interestModules={sidebarInterestModules}
        interlinkHubs={sidebarInterlinkHubs}
        ctaTitulo={`¿Proyecto de ${categoryLabel}?`}
        ctaTexto="Recibe recomendación técnica de equipos, compatibilidades y tiempos de entrega para tu operación."
      />
    </Fragment>
  </BlogGrid>

  {posts.length === 0 && (
    <section class="blog-empty">
      <div class="container">
        <div class="blog-empty__content">
          <div class="blog-empty__icon">📝</div>
          <h2 class="blog-empty__title">Próximamente</h2>
          <p class="blog-empty__text">Estamos preparando artículos técnicos sobre {categoryLabel}.</p>
          <a href="/blog" class="btn btn--primary">Ver todos los artículos</a>
        </div>
      </div>
    </section>
  )}
</Layout>

<style>
  .blog-empty {
    padding: var(--spacing-3xl) 0;
    background: var(--color-accent);
  }

  .blog-empty__content {
    text-align: center;
    max-width: 500px;
    margin: 0 auto;
    padding: var(--spacing-2xl);
    background: var(--color-white);
    border-radius: var(--border-radius);
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.06);
  }

  .blog-empty__icon {
    font-size: 3rem;
    margin-bottom: var(--spacing-md);
  }

  .blog-empty__title {
    font-size: var(--font-size-xl);
    font-weight: 700;
    color: var(--color-secondary);
    margin: 0 0 var(--spacing-sm) 0;
  }

  .blog-empty__text {
    color: var(--color-text-light);
    margin-bottom: var(--spacing-lg);
  }
</style>
