---
import Layout from '../../layouts/Base.astro';
import '../../styles/subcategory.css';
import { getCollection } from 'astro:content';
import SubcategoryProductCard from '../../components/SubcategoryProductCard.astro';
import ProductSidebar from '../../components/ProductSidebar.astro';
import RelatedProductsGrid from '../../components/RelatedProductsGrid.astro';
import CotizacionForm from '../../components/CotizacionForm.astro';
import Faq from '../../components/Faq.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import { buildProductCategorySchema, buildBreadcrumbSchema, buildFAQSchema, buildOrganizationSchema } from '../../lib/seo';


// Obtener todos los monitores
const todosMonitores = (await getCollection('productos', ({ data }) => data.categoria === 'monitores')).sort((a, b) => a.data.orden - b.data.orden);

// Filtrar monitores industriales
const productosIndustriales = todosMonitores.filter(p => p.data.subcategoria === 'monitores-industriales');

// Otros monitores para la seccion de relacionados
const otrosMonitores = todosMonitores.filter(p => !productosIndustriales.includes(p));

// Subcategorias de monitores para el sidebar
const subcategorias = [
  {
    slug: 'tipo-corazon',
    nombre: 'Monitor Tipo Corazón',
    descripcion: 'Protección perimetral 360°',
    activo: false
  },
  {
    slug: 'cuello-cisne',
    nombre: 'Monitor Cuello de Cisne',
    descripcion: 'Protección de tanques elevados',
    activo: false
  },
  {
    slug: 'certificado-fm',
    nombre: 'Monitor Certificado FM',
    descripcion: 'Aprobación Factory Mutual',
    activo: false
  },
  {
    slug: 'ul-listed',
    nombre: 'Monitor UL Listed',
    descripcion: 'Certificación Underwriters Labs',
    activo: false
  },
  {
    slug: 'manuales',
    nombre: 'Monitores Manuales',
    descripcion: 'Vulcan, Stinger, RAM XD',
    activo: false
  },
  {
    slug: 'electricos',
    nombre: 'Monitores Eléctricos',
    descripcion: 'EXM2, Control Remoto',
    activo: false
  },
  {
    slug: 'industriales',
    nombre: 'Monitores Industriales',
    descripcion: 'FM Approved, Copperhead',
    activo: true
  },
];

const faqItems = [
  { pregunta: '¿Qué significa que un monitor sea FM Approved?', respuesta: 'FM Approved indica que el monitor fue probado y aprobado por Factory Mutual, una de las aseguradoras industriales más exigentes del mundo. La aprobación FM verifica que el equipo cumple con los estándares de desempeño bajo condiciones reales de incendio, incluyendo resistencia a corrosión, presión de trabajo y caudal mínimo. Las aseguradoras industriales en México y el mundo exigen equipos FM Approved para reducir primas y validar sistemas de protección.' },
  { pregunta: '¿En qué industrias se instalan monitores industriales?', respuesta: 'Los monitores industriales FM Approved se instalan en refinerías, plantas petroquímicas, terminales de almacenamiento de hidrocarburos, plantas de generación eléctrica (CFE), instalaciones de PEMEX y empresas privadas del sector energético. También se usan en hangares de aviación, muelles industriales y almacenes de materiales peligrosos. El monitor Copperhead de Elkhart Brass está diseñado específicamente para estos entornos corrosivos y de alto riesgo.' },
  { pregunta: '¿Qué mantenimiento requiere un monitor industrial según NFPA 25?', respuesta: 'NFPA 25 establece inspección visual trimestral, prueba funcional semestral (movimiento completo horizontal y vertical) y prueba de flujo anual. El mantenimiento incluye lubricación de mecanismos, verificación de sellos y juntas, limpieza de orificios de la boquilla y revisión de la base de montaje. Gama de México ofrece contratos de mantenimiento preventivo para monitores industriales instalados en México.' },
  { pregunta: '¿Qué ventaja tiene el Copperhead de Elkhart Brass frente a otros monitores industriales?', respuesta: 'El Copperhead está construido en aleación de aluminio marino con acabado anodizado duro y mecanismos sellados que eliminan la necesidad de lubricación periódica. Su diseño "low maintenance" reduce los costos de operación en instalaciones donde acceder al monitor para mantenimiento es costoso o implica parar procesos industriales. A diferencia de monitores convencionales que requieren lubricación mensual, el Copperhead puede operar años sin intervención en ambientes industriales controlados.' },
  { pregunta: '¿Los monitores industriales cumplen con las especificaciones NRF de PEMEX?', respuesta: 'Sí, con condiciones. Los monitores FM Approved de Elkhart Brass cumplen con los requisitos base de NFPA 15 y FM que las especificaciones NRF de PEMEX toman como referencia. Sin embargo, PEMEX puede tener requisitos adicionales de materiales, conexiones o configuración que deben verificarse contra la NRF específica del proyecto. En Gama de México asesoramos en la revisión de las NRF aplicables y la selección del modelo que cumple con todos los requisitos del proyecto.' },
  { pregunta: '¿Qué normas aplican al diseño de sistemas con monitores industriales?', respuesta: 'Para sistemas con monitores industriales aplican principalmente: NFPA 15 (sistemas de agua para riesgos especiales), NFPA 11 (sistemas de espuma), NFPA 25 (inspección y mantenimiento), FM Data Sheet 4-4N (criterios de diseño para monitores aprobados FM) y NOM-002-STPS-2010 para instalaciones en México. En refinería y petroquímica también aplica API 2030 para protección de tanques y las especificaciones propias del operador (PEMEX-NRF, Shell DEP, etc.). El diseño del sistema debe integrarse a la memoria de cálculo del ingeniero de seguridad del proyecto.' },
];

const structuredData = [
  buildOrganizationSchema(),
  buildProductCategorySchema({
    name: 'Monitores Industriales FM Approved Contra Incendios',
    description: 'Monitores industriales FM Approved Elkhart Brass para refinerias y petroquimica. Copperhead bajo mantenimiento, hasta 2,500 GPM. Distribuidor Mexico.',
    image: '/img/monitores-contra-incendios/elkhart-copperhead-mon-01.avif',
    url: '/monitores/industriales',
    category: 'Monitores Contra Incendios',
    brand: 'Elkhart Brass',
    reviewAuthor: 'Ing. Fernando Torres',
    reviewBody: 'Instalamos Copperhead en nuestra terminal de almacenamiento. Tres anos sin mantenimiento correctivo. Gama de Mexico cumplio con los tiempos de entrega.',
    reviewDate: '2025-05-12',
    ratingCount: 25,
    reviewCount: 25,
  }),
  buildBreadcrumbSchema([
    { name: 'Inicio', url: '/' },
    { name: 'Equipos', url: '/equipos' },
    { name: 'Monitores Contra Incendios', url: '/monitores-contra-incendios' },
    { name: 'Monitores Industriales', url: '/monitores/industriales' },
  ]),
  buildFAQSchema(faqItems),
];

---

<Layout
  structuredData={structuredData}
  title="Monitores Industriales FM Approved | Refinerías y Petroquímica"
  description="Monitores industriales FM Approved Elkhart Brass: Copperhead hasta 2,500 GPM. Para refinerías, PEMEX, CFE y terminales de almacenamiento. Bajo mantenimiento. México."
  activePage="equipos"
  heroTitle="Monitores Industriales"
  heroIntro="Monitores fijos FM Approved para instalaciones de alto riesgo: refinerías, plantas petroquímicas, terminales de almacenamiento y generación eléctrica. Construcción resistente a corrosión, bajo mantenimiento, caudales de hasta 2,500 GPM. Cumplimiento NFPA 15, FM 1421 y NOM-002-STPS."
  heroBadge="Monitores Contra Incendios"
  heroMetrics={[
    { valor: "FM", texto: "Factory Mutual" },
    { valor: "2,500", texto: "GPM máximo" },
    { valor: "NFPA 15", texto: "Cumplimiento" }
  ]}
  heroPrimaryText="Ver Catálogo"
  heroPrimaryLink="#catalogo"
  heroSecondaryText="Solicitar Cotización"
  heroSecondaryLink="#cotizar"
  heroShowRightContent={true}
>

  <!-- HERO CONTENT -->
  <Fragment slot="hero-content">
    <p>Los <strong>monitores industriales</strong> Elkhart Brass están diseñados para entornos donde la corrosión, las temperaturas extremas y la exposición continua a la intemperie destruirían un monitor convencional. El Copperhead, su modelo insignia para aplicaciones industriales, opera sin mantenimiento durante años gracias a su construcción sellada y materiales resistentes a ambientes químicos.</p>
    <p>En <strong>Gama de México</strong> suministramos monitores industriales FM Approved para proyectos de PEMEX, CFE, terminales privadas de almacenamiento y plantas petroquímicas. Asesoramos en la selección del modelo correcto según el caudal requerido, tipo de riesgo, agente extintor y requisitos de la aseguradora. Entregamos con documentación FM completa para verificación de protección civil.</p>
  </Fragment>
  <!-- BREADCRUMB -->
  <Breadcrumb />


  <!-- MAIN CONTENT WITH SIDEBAR -->
  <section class="subcat-content">
    <div class="container">
      <div class="subcat-layout">

        <!-- MAIN CONTENT (LEFT) -->
        <main class="subcat-main">

          <!-- CATALOG HEADER -->
          <div class="catalog-header" id="catalogo">
            <div class="catalog-header__text">
              <h2 class="catalog-header__title">Monitores Industriales FM Approved</h2>
              <p class="catalog-header__desc">Monitores Elkhart Brass para refinerías, petroquímica y terminales de almacenamiento</p>
            </div>
            <div class="catalog-header__count">
              <span class="catalog-header__number">{productosIndustriales.length}</span>
              <span class="catalog-header__label">producto{productosIndustriales.length !== 1 ? 's' : ''}</span>
            </div>
          </div>

          <!-- PRODUCTS GRID -->
          <div class="categories__grid">
            {productosIndustriales.map((producto) => (
              <SubcategoryProductCard
                title={producto.data.title}
                description={producto.data.description}
                brand={producto.data.marca}
                image={producto.data.imagen}
                productSlug={producto.id}
                flow={producto.data.flujo}
                material={producto.data.material}
                certifications={producto.data.certificaciones}
              />
            ))}
          </div>

          {productosIndustriales.length === 0 && (
            <div class="catalog-empty">
              <div class="catalog-empty__icon">🔍</div>
              <h3 class="catalog-empty__title">Próximamente más opciones</h3>
              <p class="catalog-empty__text">Estamos agregando fichas de monitores industriales. Solicita cotización con especificaciones para tu proyecto.</p>
              <a href="#cotizar" class="btn btn--primary">Solicitar Cotización</a>
            </div>
          )}

          <!-- TECHNICAL INFO -->
          <div class="tech-info">
            <h3 class="tech-info__title">Especificaciones Técnicas Generales</h3>
            <div class="tech-info__grid">
              <div class="tech-info__item">
                <span class="tech-info__label">Caudal</span>
                <span class="tech-info__value">500 - 2,500 GPM</span>
              </div>
              <div class="tech-info__item">
                <span class="tech-info__label">Certificación</span>
                <span class="tech-info__value">FM Approved</span>
              </div>
              <div class="tech-info__item">
                <span class="tech-info__label">Presión</span>
                <span class="tech-info__value">100 - 175 PSI</span>
              </div>
              <div class="tech-info__item">
                <span class="tech-info__label">Material</span>
                <span class="tech-info__value">Aluminio / Bronce naval</span>
              </div>
              <div class="tech-info__item">
                <span class="tech-info__label">Mantenimiento</span>
                <span class="tech-info__value">Diseño bajo mant.</span>
              </div>
              <div class="tech-info__item">
                <span class="tech-info__label">Norma</span>
                <span class="tech-info__value">NFPA 15 / NFPA 25</span>
              </div>
            </div>
          </div>

        </main>

        <!-- SIDEBAR (RIGHT) -->
        <ProductSidebar
          navTitulo="Tipos de Monitores"
          subcategorias={subcategorias}
          baseUrl="/monitores"
          backLinkHref="/monitores-contra-incendios"
          backLinkTexto="Ver todos los monitores"
          certificaciones={[
            { siglas: "FM", nombre: "Factory Mutual" },
            { siglas: "UL", nombre: "UL Listed" },
            { siglas: "NOM", nombre: "NOM-002-STPS" }
          ]}
          marcas={["Elkhart Brass", "Akron Brass", "Task Force Tips", "POK"]}
          aplicaciones={[
            "Refinerías (PEMEX)",
            "Plantas petroquímicas",
            "Terminales de almacenamiento",
            "Generación eléctrica (CFE)",
            "Hangares de aviación",
            "Muelles industriales"
          ]}
          productosRelacionados={[
            { href: "/boquillas-contra-incendios", nombre: "Boquillas Contra Incendios" },
            { href: "/mangueras-contra-incendios", nombre: "Mangueras Contra Incendios" },
            { href: "/valvulas-contra-incendios", nombre: "Válvulas Contra Incendios" },
            { href: "/conexiones-herrajes-contra-incendios", nombre: "Conexiones y Herrajes" }
          ]}
        />

      </div>
    </div>
  </section>

  <!-- RELATED MONITORS -->
  <RelatedProductsGrid
    titulo="Otros Tipos de Monitores"
    subtitulo="Monitores manuales y eléctricos para distintas aplicaciones"
    productos={otrosMonitores}
    maxProductos={3}
    verTodosLink="/monitores-contra-incendios"
    verTodosTexto="Ver todos los monitores"
  />

  <CotizacionForm
    titulo="Cotiza Monitores Industriales"
    tipoEquipo="Monitores"
    pagina="Monitores Industriales FM"
  />


  <!-- FAQ -->
  <section class="faq-section" id="faq" aria-labelledby="faq-title">
    <div class="container">
      <h2 id="faq-title" class="section-title">Preguntas Frecuentes</h2>
      <Faq items={faqItems} id="faq" />
    </div>
  </section>

</Layout>

<style>
  .faq-section {
    padding: var(--spacing-2xl, 4rem) 0;
    background: var(--color-surface, #fff);
  }
  .faq-section .section-title {
    font-size: var(--text-2xl, 1.75rem);
    font-weight: 700;
    margin-bottom: 2rem;
    text-align: center;
  }
</style>
