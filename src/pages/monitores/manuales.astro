---
import Layout from '../../layouts/Base.astro';
import '../../styles/subcategory.css';
import { getCollection } from 'astro:content';
import SubcategoryProductCard from '../../components/SubcategoryProductCard.astro';
import ProductSidebar from '../../components/ProductSidebar.astro';
import RelatedProductsGrid from '../../components/RelatedProductsGrid.astro';
import CotizacionForm from '../../components/CotizacionForm.astro';
import Faq from '../../components/Faq.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import { buildProductCategorySchema, buildBreadcrumbSchema, buildFAQSchema, buildOrganizationSchema } from '../../lib/seo';


// Obtener todos los monitores
const todosMonitores = (await getCollection('productos', ({ data }) => data.categoria === 'monitores')).sort((a, b) => a.data.orden - b.data.orden);

// Filtrar monitores manuales y portátiles
const productosManuales = todosMonitores.filter(p =>
  p.data.subcategoria === 'monitores-manuales' || p.data.subcategoria === 'monitores-portatiles'
);

// Otros monitores para la sección de relacionados
const otrosMonitores = todosMonitores.filter(p => !productosManuales.includes(p));

// Subcategorías de monitores para el sidebar
const subcategorias = [
  {
    slug: 'tipo-corazon',
    nombre: 'Monitor Tipo Corazón',
    descripcion: 'Protección perimetral 360°',
    activo: false
  },
  {
    slug: 'cuello-cisne',
    nombre: 'Monitor Cuello de Cisne',
    descripcion: 'Protección de tanques elevados',
    activo: false
  },
  {
    slug: 'certificado-fm',
    nombre: 'Monitor Certificado FM',
    descripcion: 'Aprobación Factory Mutual',
    activo: false
  },
  {
    slug: 'ul-listed',
    nombre: 'Monitor UL Listed',
    descripcion: 'Certificación Underwriters Labs',
    activo: false
  },
  {
    slug: 'manuales',
    nombre: 'Monitores Manuales',
    descripcion: 'Vulcan, Stinger, RAM XD',
    activo: true
  },
  {
    slug: 'electricos',
    nombre: 'Monitores Eléctricos',
    descripcion: 'EXM2, Control Remoto',
    activo: false
  },
  {
    slug: 'industriales',
    nombre: 'Monitores Industriales',
    descripcion: 'FM Approved para industria',
    activo: false
  },
];

const faqItems = [
  { pregunta: '¿Cual es la diferencia entre un monitor manual y uno electrico?', respuesta: 'El monitor manual se opera directamente por un bombero o brigadista mediante manivelas o palancas mecanicas. No requiere energia electrica ni sistemas de control, lo que lo hace confiable en escenarios donde la infraestructura esta comprometida. Los monitores electricos se operan a distancia con actuadores, lo que es preferible en zonas de alto riesgo donde no conviene que haya personal cerca del incendio.' },
  { pregunta: '¿Qué caudal manejan los monitores manuales Elkhart Brass?', respuesta: 'Los monitores manuales Elkhart Brass que distribuimos van desde 500 GPM en modelos compactos como el RAM XD hasta 1,500 GPM en el Vulcan. El caudal real depende de la presion disponible en tu red hidraulica y la boquilla instalada. Calculamos el caudal optimo segun las condiciones de tu sistema.' },
  { pregunta: '¿Los monitores portatiles Elkhart Brass son compatibles con mangueras estandar?', respuesta: 'Si. Los monitores portatiles como el Stinger 2.0 y el RAM XD usan conexiones NH estandar de 2½ o 3 pulgadas, compatibles con las mangueras que ya tienen los cuerpos de bomberos en Mexico. No requieren adaptadores especiales.' },
];

const structuredData = [
  buildOrganizationSchema(),
  buildProductCategorySchema({
    name: 'Monitores Manuales Contra Incendios',
    description: 'Monitores manuales y portatiles Elkhart Brass para cuerpos de bomberos y brigadas industriales. Modelos Vulcan, Stinger 2.0, Scorpion y RAM XD con certificacion UL/FM.',
    image: '/img/monitores-contra-incendios/elkhart-vulcan-mon-01.avif',
    url: '/monitores/manuales',
    category: 'Monitores Contra Incendios',
    brand: 'Elkhart Brass',
    reviewAuthor: 'Cmte. Roberto Hernandez',
    reviewBody: 'Monitores Elkhart Brass de calidad comprobada. Gama de Mexico nos asesoró en la seleccion del modelo correcto para nuestras unidades.',
    reviewDate: '2025-06-10',
    ratingCount: 28,
    reviewCount: 28,
  }),
  buildBreadcrumbSchema([
    { name: 'Inicio', url: '/' },
    { name: 'Equipos', url: '/equipos' },
    { name: 'Monitores Contra Incendios', url: '/monitores-contra-incendios' },
    { name: 'Monitores Manuales', url: '/monitores/manuales' },
  ]),
  buildFAQSchema(faqItems),
];

---

<Layout
  structuredData={structuredData}
  title="Monitores Manuales Contra Incendios | Venta México"
  description="Monitores manuales Elkhart Brass: Vulcan, Stinger 2.0, Scorpion, RAM XD. Para bomberos municipales e industria. Caudales 500-1500 GPM. Asesoría técnica."
  activePage="equipos"
  heroTitle="Monitores Manuales"
  heroIntro="Monitores de operacion manual para cuerpos de bomberos municipales, brigadas industriales y sistemas de primera respuesta. Desde monitores fijos de cubierta hasta portatiles de despliegue rapido, todos con certificacion UL y FM."
  heroBadge="Monitores Contra Incendios"
  heroMetrics={[
    { valor: "1,500", texto: "GPM máximo" },
    { valor: "100", texto: "PSI nominal" },
    { valor: "360°", texto: "Giro horizontal" }
  ]}
  heroPrimaryText="Ver Catálogo"
  heroPrimaryLink="#catalogo"
  heroSecondaryText="Solicitar Cotización"
  heroSecondaryLink="#cotizar"
  heroShowRightContent={true}
>

  <!-- HERO CONTENT -->
  <Fragment slot="hero-content">
    <p>Los <strong>monitores manuales</strong> Elkhart Brass son el equipo de referencia en los cuerpos de bomberos de Mexico. Se operan directamente por el brigadista con manivelas o palancas mecanicas, sin depender de energia electrica ni sistemas de control remoto. Esta simplicidad los hace especialmente confiables en escenarios donde la infraestructura esta comprometida o cuando se necesita un despliegue rapido.</p>
    <p>En <strong>Gama de Mexico</strong> distribuimos la linea completa de monitores manuales y portatiles Elkhart Brass: el Vulcan para aplicaciones de alto caudal, el Stinger 2.0 de doble proposito, el Scorpion de bajo perfil y el RAM XD para ataque rapido. Todos certificados UL y FM, con stock disponible en CDMX y Queretaro.</p>
  </Fragment>
  <!-- BREADCRUMB -->
  <Breadcrumb />


  <!-- MAIN CONTENT WITH SIDEBAR -->
  <section class="subcat-content">
    <div class="container">
      <div class="subcat-layout">

        <!-- MAIN CONTENT (LEFT) -->
        <main class="subcat-main">

          <!-- CATALOG HEADER -->
          <div class="catalog-header" id="catalogo">
            <div class="catalog-header__text">
              <h2 class="catalog-header__title">Monitores Manuales y Portatiles</h2>
              <p class="catalog-header__desc">Monitores Elkhart Brass de operacion manual para bomberos y brigadas</p>
            </div>
            <div class="catalog-header__count">
              <span class="catalog-header__number">{productosManuales.length}</span>
              <span class="catalog-header__label">producto{productosManuales.length !== 1 ? 's' : ''}</span>
            </div>
          </div>

          <!-- PRODUCTS GRID -->
          <div class="categories__grid">
            {productosManuales.map((producto) => (
              <SubcategoryProductCard
                title={producto.data.title}
                description={producto.data.description}
                brand={producto.data.marca}
                image={producto.data.imagen}
                productSlug={producto.id}
                flow={producto.data.flujo}
                material={producto.data.material}
                certifications={producto.data.certificaciones}
              />
            ))}
          </div>

          {productosManuales.length === 0 && (
            <div class="catalog-empty">
              <div class="catalog-empty__icon">🔍</div>
              <h3 class="catalog-empty__title">Proximamente mas opciones</h3>
              <p class="catalog-empty__text">Estamos agregando mas productos de monitores manuales. Mientras tanto, solicita una cotizacion personalizada.</p>
              <a href="#cotizar" class="btn btn--primary">Solicitar Cotización</a>
            </div>
          )}

          <!-- TECHNICAL INFO -->
          <div class="tech-info">
            <h3 class="tech-info__title">Monitores manuales vs. electricos: cuando usar cada uno</h3>
            <div class="tech-info__grid">
              <div class="tech-info__item">
                <span class="tech-info__label">Caudal</span>
                <span class="tech-info__value">500 - 1,500 GPM</span>
              </div>
              <div class="tech-info__item">
                <span class="tech-info__label">Operacion</span>
                <span class="tech-info__value">Manual / mecánica</span>
              </div>
              <div class="tech-info__item">
                <span class="tech-info__label">Energia</span>
                <span class="tech-info__value">No requiere</span>
              </div>
              <div class="tech-info__item">
                <span class="tech-info__label">Certificaciones</span>
                <span class="tech-info__value">UL Listed / FM Approved</span>
              </div>
              <div class="tech-info__item">
                <span class="tech-info__label">Uso tipico</span>
                <span class="tech-info__value">Bomberos y brigadas</span>
              </div>
              <div class="tech-info__item">
                <span class="tech-info__label">Material</span>
                <span class="tech-info__value">Aluminio / Bronce</span>
              </div>
            </div>
          </div>

        </main>

        <!-- SIDEBAR (RIGHT) -->
        <ProductSidebar
          navTitulo="Tipos de Monitores"
          subcategorias={subcategorias}
          baseUrl="/monitores"
          backLinkHref="/monitores-contra-incendios"
          backLinkTexto="Ver todos los monitores"
          certificaciones={[
            { siglas: "FM", nombre: "Factory Mutual" },
            { siglas: "UL", nombre: "UL Listed" },
            { siglas: "NOM", nombre: "NOM-002-STPS" }
          ]}
          marcas={["Elkhart Brass", "Akron Brass", "Task Force Tips", "POK"]}
          aplicaciones={[
            "Cuerpos de bomberos",
            "Brigadas industriales",
            "Unidades de rescate",
            "Primera respuesta",
            "Protección perimetral",
            "Terminales de combustible"
          ]}
          productosRelacionados={[
            { href: "/boquillas-contra-incendios", nombre: "Boquillas Contra Incendios" },
            { href: "/mangueras-contra-incendios", nombre: "Mangueras Contra Incendios" },
            { href: "/valvulas-contra-incendios", nombre: "Válvulas Contra Incendios" },
            { href: "/conexiones-herrajes-contra-incendios", nombre: "Conexiones y Herrajes" }
          ]}
        />

      </div>
    </div>
  </section>

  <!-- RELATED MONITORS -->
  <RelatedProductsGrid
    titulo="Otros Tipos de Monitores"
    subtitulo="Monitores fijos e industriales para distintas aplicaciones"
    productos={otrosMonitores}
    maxProductos={3}
    verTodosLink="/monitores-contra-incendios"
    verTodosTexto="Ver todos los monitores"
  />

  <CotizacionForm
    titulo="Cotiza Monitores Manuales"
    tipoEquipo="Monitores"
    pagina="Monitores Manuales"
  />


  <!-- FAQ -->
  <section class="faq-section" id="faq" aria-labelledby="faq-title">
    <div class="container">
      <h2 id="faq-title" class="section-title">Preguntas Frecuentes</h2>
      <Faq items={faqItems} id="faq" />
    </div>
  </section>

</Layout>

<style>
  .faq-section {
    padding: var(--spacing-2xl, 4rem) 0;
    background: var(--color-surface, #fff);
  }
  .faq-section .section-title {
    font-size: var(--text-2xl, 1.75rem);
    font-weight: 700;
    margin-bottom: 2rem;
    text-align: center;
  }
</style>
