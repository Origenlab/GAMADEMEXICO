---
import Layout from '../../layouts/Base.astro';
import '../../styles/subcategory.css';
import { getCollection } from 'astro:content';
import SubcategoryProductCard from '../../components/SubcategoryProductCard.astro';
import ProductSidebar from '../../components/ProductSidebar.astro';
import RelatedProductsGrid from '../../components/RelatedProductsGrid.astro';
import CotizacionForm from '../../components/CotizacionForm.astro';
import Faq from '../../components/Faq.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import { buildProductCategorySchema, buildBreadcrumbSchema, buildFAQSchema, buildOrganizationSchema } from '../../lib/seo';


// Obtener todos los monitores
const todosMonitores = (await getCollection('productos', ({ data }) => data.categoria === 'monitores')).sort((a, b) => a.data.orden - b.data.orden);

// Filtrar monitores electricos
const productosElectricos = todosMonitores.filter(p => p.data.subcategoria === 'monitores-electricos');

// Otros monitores para la seccion de relacionados
const otrosMonitores = todosMonitores.filter(p => !productosElectricos.includes(p));

// Subcategorias de monitores para el sidebar
const subcategorias = [
  {
    slug: 'tipo-corazon',
    nombre: 'Monitor Tipo Corazón',
    descripcion: 'Protección perimetral 360°',
    activo: false
  },
  {
    slug: 'cuello-cisne',
    nombre: 'Monitor Cuello de Cisne',
    descripcion: 'Protección de tanques elevados',
    activo: false
  },
  {
    slug: 'certificado-fm',
    nombre: 'Monitor Certificado FM',
    descripcion: 'Aprobación Factory Mutual',
    activo: false
  },
  {
    slug: 'ul-listed',
    nombre: 'Monitor UL Listed',
    descripcion: 'Certificación Underwriters Labs',
    activo: false
  },
  {
    slug: 'manuales',
    nombre: 'Monitores Manuales',
    descripcion: 'Vulcan, Stinger, RAM XD',
    activo: false
  },
  {
    slug: 'electricos',
    nombre: 'Monitores Eléctricos',
    descripcion: 'EXM2, Control Remoto',
    activo: true
  },
  {
    slug: 'industriales',
    nombre: 'Monitores Industriales',
    descripcion: 'FM Approved, Copperhead',
    activo: false
  },
];

const faqItems = [
  { pregunta: '¿Que ventaja tiene un monitor electrico sobre uno manual?', respuesta: 'El monitor electrico permite operacion a distancia mediante actuadores y joystick, eliminando la necesidad de que un operador este fisicamente junto al equipo durante la descarga. Esto es critico en plantas petroquimicas, terminales de gas y zonas clasificadas donde la exposicion del personal al fuego, calor radiante o atmosferas explosivas representa un riesgo inaceptable.' },
  { pregunta: '¿El sistema EXM2 de Elkhart Brass funciona en zonas clasificadas?', respuesta: 'Si. El sistema de control EXM2 de Elkhart Brass cuenta con certificacion UL Clase I Division 2 para operacion en atmosferas potencialmente explosivas. Los actuadores estan sellados y los componentes electricos cumplen con los requisitos de NFPA 70 (NEC) para instalaciones en areas peligrosas.' },
  { pregunta: '¿Que mantenimiento requiere un monitor electrico?', respuesta: 'El mantenimiento sigue los lineamientos de NFPA 25 para sistemas fijos de proteccion contra incendios. Incluye pruebas funcionales trimestrales del sistema de control, verificacion de actuadores y respuesta del joystick, inspeccion de sellos y conexiones electricas, y prueba de flujo anual. Gama de Mexico ofrece contratos de mantenimiento preventivo para monitores electricos instalados.' },
];

const structuredData = [
  buildOrganizationSchema(),
  buildProductCategorySchema({
    name: 'Monitores Electricos EXM2 Contra Incendios',
    description: 'Monitores electricos Elkhart Brass con sistema de control EXM2. Operacion remota, UL Clase I Division 2 para zonas clasificadas. Distribuidor Mexico.',
    image: '/img/monitores-contra-incendios/elkhart-vulcan-mon-01.avif',
    url: '/monitores/electricos',
    category: 'Monitores Contra Incendios',
    brand: 'Elkhart Brass',
    reviewAuthor: 'Ing. Luis Ramirez',
    reviewBody: 'El sistema EXM2 funciona impecable en nuestra terminal de gas. Gama de Mexico nos apoyo con la integracion al SCADA existente.',
    reviewDate: '2025-08-20',
    ratingCount: 22,
    reviewCount: 22,
  }),
  buildBreadcrumbSchema([
    { name: 'Inicio', url: '/' },
    { name: 'Equipos', url: '/equipos' },
    { name: 'Monitores Contra Incendios', url: '/monitores-contra-incendios' },
    { name: 'Monitores Eléctricos', url: '/monitores/electricos' },
  ]),
  buildFAQSchema(faqItems),
];

---

<Layout
  structuredData={structuredData}
  title="Monitores Eléctricos EXM2 Elkhart Brass | Control Remoto"
  description="Monitores electricos Elkhart Brass con sistema EXM2. Control remoto por joystick, UL Clase I Division 2. Para refineras, terminales de gas y zonas clasificadas. Mexico."
  activePage="equipos"
  heroTitle="Monitores Eléctricos EXM2"
  heroIntro="Monitores con actuadores electricos y sistema de control EXM2 para operacion remota. Certificados UL Clase I Division 2 para zonas clasificadas. Se integran con sistemas SCADA y paneles de control de planta."
  heroBadge="Monitores Contra Incendios"
  heroMetrics={[
    { valor: "EXM2", texto: "Sistema de control" },
    { valor: "360°", texto: "Control remoto" },
    { valor: "UL", texto: "Clase I Div 2" }
  ]}
  heroPrimaryText="Ver Catálogo"
  heroPrimaryLink="#catalogo"
  heroSecondaryText="Solicitar Cotización"
  heroSecondaryLink="#cotizar"
  heroShowRightContent={true}
>

  <!-- HERO CONTENT -->
  <Fragment slot="hero-content">
    <p>Los <strong>monitores electricos</strong> Elkhart Brass combinan la capacidad de descarga de un monitor industrial con operacion a distancia mediante el sistema de control EXM2. Los actuadores mueven el monitor en horizontal y vertical desde un joystick o panel de control, sin que ningun operador tenga que estar junto al equipo durante la emergencia.</p>
    <p>En <strong>Gama de Mexico</strong> distribuimos monitores electricos Elkhart Brass con certificacion UL Clase I Division 2, aptos para refineras, terminales de almacenamiento de gas, plantas petroquimicas y cualquier instalacion donde la operacion manual represente riesgo para el personal. Los integramos con sistemas SCADA, PLC y paneles de control existentes.</p>
  </Fragment>
  <!-- BREADCRUMB -->
  <Breadcrumb />


  <!-- MAIN CONTENT WITH SIDEBAR -->
  <section class="subcat-content">
    <div class="container">
      <div class="subcat-layout">

        <!-- MAIN CONTENT (LEFT) -->
        <main class="subcat-main">

          <!-- CATALOG HEADER -->
          <div class="catalog-header" id="catalogo">
            <div class="catalog-header__text">
              <h2 class="catalog-header__title">Monitores Electricos con Control Remoto</h2>
              <p class="catalog-header__desc">Monitores Elkhart Brass con sistema EXM2 para operacion a distancia</p>
            </div>
            <div class="catalog-header__count">
              <span class="catalog-header__number">{productosElectricos.length}</span>
              <span class="catalog-header__label">producto{productosElectricos.length !== 1 ? 's' : ''}</span>
            </div>
          </div>

          <!-- PRODUCTS GRID -->
          <div class="categories__grid">
            {productosElectricos.map((producto) => (
              <SubcategoryProductCard
                title={producto.data.title}
                description={producto.data.description}
                brand={producto.data.marca}
                image={producto.data.imagen}
                productSlug={producto.id}
                flow={producto.data.flujo}
                material={producto.data.material}
                certifications={producto.data.certificaciones}
              />
            ))}
          </div>

          {productosElectricos.length === 0 && (
            <div class="catalog-empty">
              <div class="catalog-empty__icon">🔍</div>
              <h3 class="catalog-empty__title">Proximamente mas opciones</h3>
              <p class="catalog-empty__text">Estamos agregando fichas de monitores electricos Elkhart Brass. Mientras tanto, solicita una cotizacion personalizada con especificaciones tecnicas.</p>
              <a href="#cotizar" class="btn btn--primary">Solicitar Cotización</a>
            </div>
          )}

          <!-- TECHNICAL INFO -->
          <div class="tech-info">
            <h3 class="tech-info__title">Especificaciones del Sistema EXM2</h3>
            <div class="tech-info__grid">
              <div class="tech-info__item">
                <span class="tech-info__label">Control</span>
                <span class="tech-info__value">Joystick / SCADA</span>
              </div>
              <div class="tech-info__item">
                <span class="tech-info__label">Certificacion</span>
                <span class="tech-info__value">UL Clase I Div 2</span>
              </div>
              <div class="tech-info__item">
                <span class="tech-info__label">Rotacion</span>
                <span class="tech-info__value">360° horizontal</span>
              </div>
              <div class="tech-info__item">
                <span class="tech-info__label">Elevacion</span>
                <span class="tech-info__value">-45° a +90°</span>
              </div>
              <div class="tech-info__item">
                <span class="tech-info__label">Caudal</span>
                <span class="tech-info__value">Hasta 2,000 GPM</span>
              </div>
              <div class="tech-info__item">
                <span class="tech-info__label">Alimentacion</span>
                <span class="tech-info__value">24 VDC / 120 VAC</span>
              </div>
            </div>
          </div>

        </main>

        <!-- SIDEBAR (RIGHT) -->
        <ProductSidebar
          navTitulo="Tipos de Monitores"
          subcategorias={subcategorias}
          baseUrl="/monitores"
          backLinkHref="/monitores-contra-incendios"
          backLinkTexto="Ver todos los monitores"
          certificaciones={[
            { siglas: "FM", nombre: "Factory Mutual" },
            { siglas: "UL", nombre: "UL Listed" },
            { siglas: "NOM", nombre: "NOM-002-STPS" }
          ]}
          marcas={["Elkhart Brass", "Akron Brass", "Task Force Tips", "POK"]}
          aplicaciones={[
            "Refinerías",
            "Terminales de gas",
            "Plantas petroquímicas",
            "Zonas clasificadas",
            "Plataformas offshore",
            "Terminales de almacenamiento"
          ]}
          productosRelacionados={[
            { href: "/boquillas-contra-incendios", nombre: "Boquillas Contra Incendios" },
            { href: "/mangueras-contra-incendios", nombre: "Mangueras Contra Incendios" },
            { href: "/valvulas-contra-incendios", nombre: "Válvulas Contra Incendios" },
            { href: "/conexiones-herrajes-contra-incendios", nombre: "Conexiones y Herrajes" }
          ]}
        />

      </div>
    </div>
  </section>

  <!-- RELATED MONITORS -->
  <RelatedProductsGrid
    titulo="Otros Tipos de Monitores"
    subtitulo="Monitores manuales e industriales para distintas aplicaciones"
    productos={otrosMonitores}
    maxProductos={3}
    verTodosLink="/monitores-contra-incendios"
    verTodosTexto="Ver todos los monitores"
  />

  <CotizacionForm
    titulo="Cotiza Monitores Eléctricos"
    tipoEquipo="Monitores"
    pagina="Monitores Eléctricos EXM2"
  />


  <!-- FAQ -->
  <section class="faq-section" id="faq" aria-labelledby="faq-title">
    <div class="container">
      <h2 id="faq-title" class="section-title">Preguntas Frecuentes</h2>
      <Faq items={faqItems} id="faq" />
    </div>
  </section>

</Layout>

<style>
  .faq-section {
    padding: var(--spacing-2xl, 4rem) 0;
    background: var(--color-surface, #fff);
  }
  .faq-section .section-title {
    font-size: var(--text-2xl, 1.75rem);
    font-weight: 700;
    margin-bottom: 2rem;
    text-align: center;
  }
</style>
