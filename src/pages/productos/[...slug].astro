---
import Layout from '../../layouts/Base.astro';
import '../../styles/subcategory.css';
import { getCollection, render } from 'astro:content';
import { CATEGORY_MAP, WHATSAPP_URL } from '../../lib/config';
import ProductSidebar from '../../components/ProductSidebar.astro';
import RelatedProductsGrid from '../../components/RelatedProductsGrid.astro';
import CotizacionForm from '../../components/CotizacionForm.astro';
import Faq from '../../components/Faq.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import { buildProductSchema, buildBreadcrumbSchema, buildFAQSchema, buildOrganizationSchema } from '../../lib/seo';
import { getOptimizedImageUrl, getThumbnailUrl } from '../../lib/images';

/* ── getStaticPaths ── */
export async function getStaticPaths() {
  const productos = await getCollection('productos');
  return productos.map((producto) => ({
    params: { slug: producto.id },
    props: { producto },
  }));
}

const { producto } = Astro.props;
const { Content } = await render(producto);

const cat = CATEGORY_MAP[producto.data.categoria];
const categoriaUrl = cat?.url ?? '/equipos';
const categoriaNombre = cat?.nombre ?? 'Equipos';

/* ── Productos relacionados ── */
const todosProductos = await getCollection('productos', ({ data }) => data.categoria === producto.data.categoria);
const relacionados = todosProductos
  .filter((p) => p.id !== producto.id)
  .sort((a, b) => a.data.orden - b.data.orden)
  .slice(0, 3);

/* ── Subcategorías dinámicas para el sidebar según categoría ── */
const subcategoriasMonitores = [
  { slug: 'tipo-corazon', nombre: 'Monitor Tipo Corazón', descripcion: 'Protección perimetral 360°', activo: false },
  { slug: 'cuello-cisne', nombre: 'Monitor Cuello de Cisne', descripcion: 'Protección de tanques elevados', activo: false },
  { slug: 'certificado-fm', nombre: 'Monitor Certificado FM', descripcion: 'Aprobación Factory Mutual', activo: false },
  { slug: 'ul-listed', nombre: 'Monitor UL Listed', descripcion: 'Certificación Underwriters Labs', activo: false },
  { slug: 'manuales', nombre: 'Monitores Manuales', descripcion: 'Vulcan, Stinger, RAM XD', activo: false },
  { slug: 'electricos', nombre: 'Monitores Eléctricos', descripcion: 'EXM2, Control Remoto', activo: false },
  { slug: 'industriales', nombre: 'Monitores Industriales', descripcion: 'FM Approved, Copperhead', activo: false },
];

const subcategoriasBoquillas = [
  { slug: 'tipo-pistola', nombre: 'Boquilla Tipo Pistola', descripcion: 'Control ergonómico seleccionable', activo: false },
  { slug: 'turbo-jet', nombre: 'Boquilla Turbo Jet', descripcion: 'Máximo alcance y penetración', activo: false },
  { slug: 'industrial', nombre: 'Boquilla Industrial', descripcion: 'Alto caudal para industria', activo: false },
  { slug: 'certificada', nombre: 'Boquilla Certificada', descripcion: 'Certificación UL/FM', activo: false },
  { slug: 'handline', nombre: 'Boquillas Handline XD', descripcion: 'Chief XD, Phantom XD', activo: false },
  { slug: 'master-stream', nombre: 'Master Stream', descripcion: 'X-Stream, gran caudal', activo: false },
];

const subcategoriasConexiones = [
  { slug: 'adaptadores', nombre: 'Adaptadores de Bronce', descripcion: 'Conversión entre roscas', activo: false },
  { slug: 'wye', nombre: 'Conexión Y (Wye)', descripcion: 'Derivación en dos salidas', activo: false },
  { slug: 'siamesa', nombre: 'Toma Siamesa FDC', descripcion: 'Conexión para bomberos', activo: false },
  { slug: 'coples', nombre: 'Coples y Reducciones', descripcion: 'Conexión rápida Storz', activo: false },
  { slug: 'chiflones', nombre: 'Chiflones de Tres Pasos', descripcion: 'Control de patrón de descarga', activo: false },
  { slug: 'accesorios', nombre: 'Accesorios y Herrajes', descripcion: 'Tapones, caps, niples', activo: false },
];

type SidebarConfig = {
  subcategorias: typeof subcategoriasMonitores;
  navTitulo: string;
  baseUrl: string;
  backLinkHref: string;
  backLinkTexto: string;
};

const sidebarMap: Record<string, SidebarConfig> = {
  monitores: { subcategorias: subcategoriasMonitores, navTitulo: 'Tipos de Monitores', baseUrl: '/monitores', backLinkHref: '/monitores-contra-incendios', backLinkTexto: 'Ver todos los monitores' },
  boquillas: { subcategorias: subcategoriasBoquillas, navTitulo: 'Tipos de Boquillas', baseUrl: '/boquillas', backLinkHref: '/boquillas-contra-incendios', backLinkTexto: 'Ver todas las boquillas' },
  'conexiones-herrajes': { subcategorias: subcategoriasConexiones, navTitulo: 'Tipos de Conexiones', baseUrl: '/conexiones', backLinkHref: '/conexiones-herrajes-contra-incendios', backLinkTexto: 'Ver todas las conexiones' },
};

const sidebarConfig = sidebarMap[producto.data.categoria] ?? {
  subcategorias: [],
  navTitulo: 'Categorías',
  baseUrl: '/equipos',
  backLinkHref: '/equipos',
  backLinkTexto: 'Ver todos los equipos',
};

/* ── FAQ dinámico según categoría ── */
function generarFaqProducto(data: typeof producto.data): { pregunta: string; respuesta: string }[] {
  const nombre = data.title.split(' | ')[0].trim();
  const marca = data.marca;
  const certs = data.certificaciones?.join(', ') || 'UL Listed, FM Approved';
  const flujo = data.flujo || '';
  const material = data.material || '';

  if (data.categoria === 'monitores') {
    return [
      { pregunta: `¿Que certificaciones tiene el ${nombre}?`, respuesta: `El ${nombre} de ${marca} cuenta con certificaciones ${certs}. Estas certificaciones garantizan que el equipo cumple con los estandares internacionales para sistemas fijos de proteccion contra incendios. Gama de Mexico entrega documentacion de certificacion con cada equipo.` },
      { pregunta: `¿Cual es el caudal del ${nombre}?`, respuesta: `El ${nombre} opera con un caudal de ${flujo || 'hasta 1,250 GPM a 100 PSI'}. El caudal real depende de la presion disponible en tu sistema hidraulico y la boquilla seleccionada. Contactanos para calcular el caudal optimo segun tu instalacion.` },
      { pregunta: `¿Puedo usar el ${nombre} con espuma AFFF?`, respuesta: `Si. Los monitores ${marca} con construccion en ${material || 'bronce fundido / aluminio'} son compatibles con agua, espuma AFFF y FFFP. Para aplicaciones con espuma se recomienda verificar la compatibilidad de la boquilla seleccionada con el agente espumante.` },
      { pregunta: `¿Gama de Mexico da servicio de instalacion para el ${nombre}?`, respuesta: `Si. Gama de Mexico ofrece asesoria tecnica para la seleccion, instalacion y mantenimiento de monitores ${marca} en toda la Republica Mexicana. Contamos con stock en CDMX y Queretaro para entregas rapidas.` },
    ];
  }

  if (data.categoria === 'boquillas') {
    return [
      { pregunta: `¿Que certificaciones tiene la ${nombre}?`, respuesta: `La ${nombre} de ${marca} cuenta con certificaciones ${certs}. Cumple con los estandares NFPA 1964 para boquillas de combate de incendios. Gama de Mexico entrega documentacion de conformidad con cada equipo.` },
      { pregunta: `¿Cual es el rango de flujo de la ${nombre}?`, respuesta: `La ${nombre} opera en un rango de ${flujo || '95 a 300 GPM'}. El flujo disponible depende del modelo y la configuracion seleccionada. Contactanos para determinar el modelo adecuado segun tu sistema hidraulico.` },
      { pregunta: `¿La ${nombre} es compatible con mis mangueras actuales?`, respuesta: `La ${nombre} tiene conexion NH estandar, compatible con mangueras de 1½ o 2½ pulgadas segun el modelo. ${marca} fabrica adaptadores para conexiones no estandar. Verificamos compatibilidad antes de cotizar.` },
      { pregunta: `¿Tienen stock de la ${nombre} en Mexico?`, respuesta: `Si. Gama de Mexico mantiene inventario de boquillas ${marca} en nuestras bodegas de CDMX y Queretaro. Los modelos de alta demanda como la ${nombre} se mantienen en stock permanente. Entregas en 24-48 horas en zona metropolitana.` },
    ];
  }

  return [
    { pregunta: `¿El ${nombre} tiene certificaciones internacionales?`, respuesta: `Si. El ${nombre} de ${marca} cuenta con certificaciones ${certs}. Gama de Mexico entrega toda la documentacion de certificacion con cada equipo vendido.` },
    { pregunta: `¿Hacen envios a toda la Republica?`, respuesta: `Si. Gama de Mexico envia a toda la Republica Mexicana. Contamos con bodegas en CDMX y Queretaro. Los tiempos de entrega varian segun ubicacion y disponibilidad del producto.` },
    { pregunta: `¿Ofrecen asesoria tecnica para seleccionar el ${nombre} correcto?`, respuesta: `Si. Nuestro equipo tecnico te ayuda a seleccionar el modelo y configuracion correcta del ${nombre} segun los requerimientos de tu proyecto. La asesoria no tiene costo.` },
  ];
}

const faqItems = generarFaqProducto(producto.data);

/* ── JSON-LD structured data ── */
const structuredData = [
  buildOrganizationSchema(),
  buildProductSchema({
    name: producto.data.title,
    description: producto.data.description,
    image: producto.data.imagen,
    brand: producto.data.marca,
    model: producto.data.modelo,
    category: categoriaNombre,
    price: producto.data.precioReferencia,
    url: `/productos/${producto.id}`,
    certifications: producto.data.certificaciones,
  }),
  buildBreadcrumbSchema([
    { name: 'Inicio', url: '/' },
    { name: 'Equipos', url: '/equipos' },
    { name: categoriaNombre, url: categoriaUrl },
    { name: producto.data.title, url: `/productos/${producto.id}` },
  ]),
  buildFAQSchema(faqItems),
];

/* ── Imagen principal optimizada ── */
const mainImageRaw = producto.data.imagen;
const mainImage = mainImageRaw
  ? getOptimizedImageUrl(mainImageRaw, { width: 800, quality: 84, strip: 'all' })
  : undefined;

/* ── Hero metrics dinámicos ── */
const heroMetrics = [
  { valor: producto.data.flujo?.split(' ')[0]?.replace(/,/g, ',') || 'Consultar', texto: 'Flujo' },
  { valor: producto.data.material?.split('/')[0]?.trim() || 'Aluminio', texto: 'Material' },
  { valor: producto.data.certificaciones?.[0] || 'UL Listed', texto: 'Certificación' },
];
---

<Layout
  structuredData={structuredData}
  title={`${producto.data.title} | Gama de México`}
  description={producto.data.description}
  activePage="equipos"
  heroTitle={producto.data.modelo || producto.data.title}
  heroBadge={`${producto.data.marca} | ${categoriaNombre}`}
  heroMetrics={heroMetrics}
  heroPrimaryText="Solicitar Cotización"
  heroPrimaryLink="#cotizar"
  heroSecondaryText="Ver más productos"
  heroSecondaryLink={categoriaUrl}
  heroShowRightContent={true}
>

  <!-- HERO CONTENT -->
  <Fragment slot="hero-content">
    <p>{producto.data.description}</p>
    {producto.data.flujo && <p><strong>Flujo:</strong> {producto.data.flujo}. <strong>Material:</strong> {producto.data.material || 'Consultar'}. <strong>Certificaciones:</strong> {producto.data.certificaciones?.join(', ') || 'Consultar'}.</p>}
  </Fragment>

  <!-- BREADCRUMB -->
  <Breadcrumb />

  <!-- MAIN CONTENT WITH SIDEBAR -->
  <section class="subcat-content">
    <div class="container">
      <div class="subcat-layout">

        <!-- MAIN CONTENT (LEFT) -->
        <main class="subcat-main">

          <!-- PRODUCT IMAGE -->
          {mainImage && (
            <div class="tech-info" style="padding: 0; overflow: hidden;">
              <img
                src={mainImage}
                alt={producto.data.title}
                width="800"
                height="600"
                loading="eager"
                decoding="async"
                style="width: 100%; height: auto; display: block; border-radius: var(--border-radius);"
              />
            </div>
          )}

          <!-- RENDERED MARKDOWN CONTENT -->
          <div class="tech-info">
            <div class="product-content">
              <Content />
            </div>
          </div>

          <!-- TECHNICAL SPECS -->
          <div class="tech-info">
            <h3 class="tech-info__title">Especificaciones Técnicas</h3>
            <div class="tech-info__grid">
              {producto.data.flujo && (
                <div class="tech-info__item">
                  <span class="tech-info__label">Caudal / Flujo</span>
                  <span class="tech-info__value">{producto.data.flujo}</span>
                </div>
              )}
              {producto.data.material && (
                <div class="tech-info__item">
                  <span class="tech-info__label">Material</span>
                  <span class="tech-info__value">{producto.data.material}</span>
                </div>
              )}
              <div class="tech-info__item">
                <span class="tech-info__label">Marca</span>
                <span class="tech-info__value">{producto.data.marca}</span>
              </div>
              {producto.data.modelo && (
                <div class="tech-info__item">
                  <span class="tech-info__label">Modelo</span>
                  <span class="tech-info__value">{producto.data.modelo}</span>
                </div>
              )}
              {producto.data.certificaciones && producto.data.certificaciones.length > 0 && (
                <div class="tech-info__item">
                  <span class="tech-info__label">Certificaciones</span>
                  <span class="tech-info__value">{producto.data.certificaciones.join(', ')}</span>
                </div>
              )}
              <div class="tech-info__item">
                <span class="tech-info__label">Categoría</span>
                <span class="tech-info__value">{categoriaNombre}</span>
              </div>
            </div>
          </div>

        </main>

        <!-- SIDEBAR (RIGHT) -->
        <ProductSidebar
          navTitulo={sidebarConfig.navTitulo}
          subcategorias={sidebarConfig.subcategorias}
          baseUrl={sidebarConfig.baseUrl}
          backLinkHref={sidebarConfig.backLinkHref}
          backLinkTexto={sidebarConfig.backLinkTexto}
          certificaciones={
            producto.data.certificaciones?.map((c: string) => ({
              siglas: c.split(' ')[0],
              nombre: c,
            })) ?? []
          }
          marcas={[producto.data.marca]}
          aplicaciones={
            producto.data.categoria === 'monitores'
              ? ['Refinerías', 'Plantas petroquímicas', 'Terminales de almacenamiento', 'Cuerpos de bomberos']
              : producto.data.categoria === 'boquillas'
                ? ['Cuerpos de bomberos', 'Brigadas industriales', 'Protección civil', 'Aeropuertos']
                : ['Edificios comerciales', 'Naves industriales', 'Hospitales', 'Centros comerciales']
          }
          productosRelacionados={[
            { href: '/monitores-contra-incendios', nombre: 'Monitores Contra Incendios' },
            { href: '/boquillas-contra-incendios', nombre: 'Boquillas Contra Incendios' },
            { href: '/mangueras-contra-incendios', nombre: 'Mangueras Contra Incendios' },
            { href: '/conexiones-herrajes-contra-incendios', nombre: 'Conexiones y Herrajes' },
          ]}
        />

      </div>
    </div>
  </section>

  <!-- RELATED PRODUCTS -->
  <RelatedProductsGrid
    titulo={`Otros ${categoriaNombre}`}
    subtitulo={`Explora más opciones de ${categoriaNombre.toLowerCase()} para tu proyecto`}
    productos={relacionados}
    maxProductos={3}
    verTodosLink={categoriaUrl}
    verTodosTexto={`Ver todos los ${categoriaNombre.toLowerCase()}`}
  />

  <!-- COTIZACIÓN -->
  <CotizacionForm
    titulo={`Cotiza ${producto.data.modelo || producto.data.title}`}
    producto={producto.data.title}
    pagina={`Producto: ${producto.data.title}`}
  />

  <!-- FAQ -->
  <section class="faq-section" id="faq" aria-labelledby="faq-title">
    <div class="container">
      <h2 id="faq-title" class="section-title">Preguntas Frecuentes</h2>
      <Faq items={faqItems} id="faq-producto" />
    </div>
  </section>

</Layout>

<style>
  .faq-section {
    padding: var(--spacing-2xl, 4rem) 0;
    background: var(--color-surface, #fff);
  }
  .faq-section .section-title {
    font-size: var(--text-2xl, 1.75rem);
    font-weight: 700;
    margin-bottom: 2rem;
    text-align: center;
  }
  .product-content :global(p) {
    font-size: 1rem;
    color: var(--color-text, #333);
    line-height: 1.8;
    margin-bottom: 1rem;
  }
  .product-content :global(h2) {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-secondary, #1a1a2e);
    margin: 1.5rem 0 0.75rem;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid var(--color-primary, #c8102e);
  }
  .product-content :global(h3) {
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--color-secondary, #1a1a2e);
    margin: 1.25rem 0 0.5rem;
  }
  .product-content :global(ul),
  .product-content :global(ol) {
    margin: 0 0 1rem;
    padding-left: 1.5rem;
  }
  .product-content :global(li) {
    font-size: 0.95rem;
    color: var(--color-text, #444);
    line-height: 1.7;
    margin-bottom: 0.35rem;
  }
  .product-content :global(strong) {
    color: var(--color-secondary, #1a1a2e);
  }
</style>
