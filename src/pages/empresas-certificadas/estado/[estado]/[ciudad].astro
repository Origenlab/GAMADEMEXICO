---
import Layout from '../../../../layouts/Base.astro';
import SectionHeader from '../../../../components/SectionHeader.astro';
import CategoryCard from '../../../../components/CategoryCard.astro';
import CtaCatalogo from '../../../../components/CtaCatalogo.astro';
import CotizacionForm from '../../../../components/CotizacionForm.astro';
import BlogRecent from '../../../../components/blog/BlogRecent.astro';
import { getCollection } from 'astro:content';
import '../../../../styles/empresas.css';


// Mapeo de giros
const giroLabels: Record<string, string> = {
  hotel: 'Hotel',
  restaurante: 'Restaurante',
  oficina: 'Oficina',
  almacen: 'Almacén',
  hospital: 'Hospital',
  escuela: 'Escuela',
  industria: 'Industria',
  comercio: 'Comercio',
  residencial: 'Residencial',
  otro: 'Otro'
};

const giroPlurales: Record<string, string> = {
  hotel: 'Hoteles',
  restaurante: 'Restaurantes',
  oficina: 'Oficinas',
  almacen: 'Almacenes',
  hospital: 'Hospitales',
  escuela: 'Escuelas',
  industria: 'Industrias',
  comercio: 'Comercios',
  residencial: 'Residenciales',
  otro: 'Otros'
};

// Mapeo de sistemas
const sistemaLabels: Record<string, string> = {
  'rociadores-automaticos': 'Rociadores Automáticos',
  'red-hidrantes': 'Red de Hidrantes',
  'extintores': 'Extintores',
  'deteccion-alarma': 'Detección y Alarma',
  'fm200': 'FM-200',
  'co2': 'CO2',
  'espuma': 'Espuma',
  'gabinetes': 'Gabinetes',
  'senalizacion': 'Señalización'
};

// Función para crear slugs
function createSlug(text: string): string {
  return text.toLowerCase()
    .normalize('NFD')
    .replace(/[\u0300-\u036f]/g, '')
    .replace(/\s+/g, '-');
}

export async function getStaticPaths() {
  function createSlug(text: string): string {
    return text.toLowerCase()
      .normalize('NFD')
      .replace(/[\u0300-\u036f]/g, '')
      .replace(/\s+/g, '-');
  }

  const empresas = await getCollection('empresasCertificadas');

  // Crear combinaciones únicas de estado-ciudad
  const combinaciones = new Map<string, { estado: string; ciudad: string; empresas: typeof empresas }>();

  empresas.forEach(empresa => {
    const estadoSlug = createSlug(empresa.data.estado);
    const ciudadSlug = createSlug(empresa.data.ciudad);
    const key = `${estadoSlug}/${ciudadSlug}`;

    if (!combinaciones.has(key)) {
      combinaciones.set(key, {
        estado: empresa.data.estado,
        ciudad: empresa.data.ciudad,
        empresas: []
      });
    }
    combinaciones.get(key)!.empresas.push(empresa);
  });

  return Array.from(combinaciones.entries()).map(([key, data]) => {
    const [estadoSlug, ciudadSlug] = key.split('/');
    return {
      params: { estado: estadoSlug, ciudad: ciudadSlug },
      props: {
        empresas: data.empresas,
        estadoNombre: data.estado,
        ciudadNombre: data.ciudad
      }
    };
  });
}

const { empresas, estadoNombre, ciudadNombre } = Astro.props;

// Agrupar por giro
const empresasPorGiro = empresas.reduce((acc, empresa) => {
  const giro = empresa.data.giro;
  if (!acc[giro]) acc[giro] = [];
  acc[giro].push(empresa);
  return acc;
}, {} as Record<string, typeof empresas>);

// Empresas ordenadas (destacadas primero)
const empresasOrdenadas = [...empresas].sort((a, b) => {
  if (a.data.destacado && !b.data.destacado) return -1;
  if (!a.data.destacado && b.data.destacado) return 1;
  if (a.data.verificado && !b.data.verificado) return -1;
  return 0;
});

const estadoSlug = createSlug(estadoNombre);

// Obtener todas las empresas para navegación
const todasEmpresas = await getCollection('empresasCertificadas');

// Otras ciudades del mismo estado
const otrasCiudades = todasEmpresas
  .filter(e => e.data.estado === estadoNombre && e.data.ciudad !== ciudadNombre)
  .reduce((acc, e) => {
    if (!acc.find(c => c.nombre === e.data.ciudad)) {
      acc.push({ nombre: e.data.ciudad, slug: createSlug(e.data.ciudad) });
    }
    return acc;
  }, [] as Array<{ nombre: string; slug: string }>);

// Otros estados para navegación
const otrosEstados = [...new Set(todasEmpresas.map(e => e.data.estado))]
  .filter(e => e !== estadoNombre)
  .sort()
  .slice(0, 6);

// Sistemas disponibles en esta ciudad
const sistemasEnCiudad = [...new Set(empresas.flatMap(e => e.data.tipoSistema))];

// Schema.org
const itemListSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": `Empresas con Sistemas Contra Incendios en ${ciudadNombre}, ${estadoNombre}`,
  "description": `Directorio de ${empresas.length} empresas con sistemas de protección contra incendios certificados en ${ciudadNombre}, ${estadoNombre}.`,
  "numberOfItems": empresas.length,
  "itemListElement": empresasOrdenadas.map((empresa, index) => ({
    "@type": "ListItem",
    "position": index + 1,
    "item": {
      "@type": "LocalBusiness",
      "name": empresa.data.nombre,
      "address": {
        "@type": "PostalAddress",
        "streetAddress": empresa.data.direccion,
        "addressLocality": ciudadNombre,
        "addressRegion": estadoNombre,
        "postalCode": empresa.data.codigoPostal,
        "addressCountry": "MX"
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": empresa.data.latitud,
        "longitude": empresa.data.longitud
      }
    }
  }))
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Inicio", "item": "https://gamademexico.com" },
    { "@type": "ListItem", "position": 2, "name": "Empresas Certificadas", "item": "https://gamademexico.com/empresas-certificadas" },
    { "@type": "ListItem", "position": 3, "name": estadoNombre, "item": `https://gamademexico.com/empresas-certificadas/estado/${estadoSlug}` },
    { "@type": "ListItem", "position": 4, "name": ciudadNombre }
  ]
};
---

<Layout
  title={`Empresas con Sistemas Contra Incendios en ${ciudadNombre}, ${estadoNombre} | Directorio Certificado`}
  description={`Directorio de ${empresas.length} empresas con sistemas contra incendios certificados en ${ciudadNombre}, ${estadoNombre}. Hoteles, restaurantes, oficinas y almacenes verificados por Gama de México con rociadores, hidrantes y detección de humo.`}
  activePage="directorio"
  heroTitle={`Empresas Certificadas en ${ciudadNombre}, ${estadoNombre}`}
  heroIntro={`Directorio completo de ${empresas.length} empresas con sistemas de protección contra incendios verificados en ${ciudadNombre}. Consulta hoteles, restaurantes, oficinas y almacenes con certificación vigente de rociadores automáticos, red de hidrantes y sistemas de detección.`}
  heroBadge={`${ciudadNombre}, ${estadoNombre}`}
  heroMetrics={[
    { valor: String(empresas.length), texto: "Empresas certificadas" },
    { valor: String(Object.keys(empresasPorGiro).length), texto: "Tipos de negocio" },
    { valor: String(sistemasEnCiudad.length), texto: "Sistemas instalados" }
  ]}
  heroPrimaryText="Registra tu empresa"
  heroPrimaryLink="/empresas-certificadas#registrar"
  heroSecondaryText={`Ver más en ${estadoNombre}`}
  heroSecondaryLink={`/empresas-certificadas/estado/${estadoSlug}`}
  heroShowRightContent={true}
  structuredData={[itemListSchema, breadcrumbSchema]}
>

  <!-- HERO CONTENT -->
  <Fragment slot="hero-content">
    <p><strong>{ciudadNombre}</strong> cuenta con <strong>{empresas.length} empresas certificadas</strong> en sistemas de protección contra incendios, incluyendo {Object.entries(empresasPorGiro).map(([giro, lista]) => `${lista.length} ${giroPlurales[giro].toLowerCase()}`).join(', ')}. Cada establecimiento ha sido verificado por especialistas de Gama de México, confirmando el correcto funcionamiento de sus sistemas de supresión, detección y evacuación.</p>
    <p>Las empresas certificadas en {ciudadNombre} cuentan con equipos que cumplen normativas <strong>NFPA</strong>, <strong>NOM-002-STPS</strong> y requerimientos de protección civil estatal. Los sistemas instalados incluyen: {sistemasEnCiudad.slice(0, 5).map(s => sistemaLabels[s]).join(', ')}. Consulta el directorio para verificar el estatus de certificación de cualquier establecimiento.</p>
  </Fragment>

  <!-- Contenido Principal con Sidebar -->
  <section class="directorio-content">
    <div class="container">
      <div class="directorio-layout">

        <!-- Columna Principal -->
        <main class="directorio-main">

          <!-- Filtros por Giro -->
          {Object.keys(empresasPorGiro).length > 1 && (
            <div class="filters-bar">
              <span class="filter-label">Filtrar por tipo:</span>
              <div class="filter-chips">
                <button class="chip chip--active" data-giro="all">Todos ({empresas.length})</button>
                {Object.entries(empresasPorGiro).map(([giro, lista]) => (
                  <button class="chip" data-giro={giro}>
                    {giroPlurales[giro]} ({lista.length})
                  </button>
                ))}
              </div>
            </div>
          )}

          <!-- Header de Sección -->
          <SectionHeader
            titulo={`${empresas.length} Empresas con Sistemas Contra Incendios Certificados en ${ciudadNombre}`}
            subtitulo={`Directorio verificado de establecimientos con protección contra incendios en ${ciudadNombre}, ${estadoNombre}`}
            idTitulo="empresas-ciudad"
            parrafo1={`El directorio de empresas certificadas en ${ciudadNombre} incluye establecimientos de diversos giros que han implementado sistemas profesionales de protección contra incendios. Cada empresa ha sido verificada por ingenieros especializados de Gama de México, confirmando la instalación correcta y funcionamiento óptimo de rociadores automáticos, red de hidrantes, sistemas de detección y alarma, gabinetes contra incendio y señalización de emergencia.`}
            parrafo2={`Las empresas listadas cumplen con normativas NFPA, NOM-002-STPS y requerimientos de protección civil del estado de ${estadoNombre}. La certificación vigente garantiza a clientes, aseguradoras y autoridades que el inmueble cuenta con los estándares de seguridad requeridos para su operación. Consulta cada empresa para conocer los sistemas específicos instalados y la fecha de última verificación.`}
          />

          <!-- Grid de Empresas -->
          <div class="empresas-grid" id="empresas-grid">
            {empresasOrdenadas.map((empresa) => (
              <CategoryCard
                titulo={empresa.data.nombre}
                subtitulo={`${giroLabels[empresa.data.giro]} · ${empresa.data.direccion}`}
                enlace={`/empresas-certificadas/${empresa.data.slug}`}
                subcategorias={empresa.data.tipoSistema.slice(0, 4).map((sistema) => ({
                  nombre: sistemaLabels[sistema],
                  enlace: `/empresas-certificadas/${empresa.data.slug}#${sistema}`
                }))}
                data-giro={empresa.data.giro}
              />
            ))}
          </div>

        </main>

        <!-- Sidebar -->
        <aside class="directorio-sidebar">

          <!-- Card: Resumen de la Ciudad -->
          <div class="sidebar-card sidebar-card--highlight">
            <h3 class="sidebar-card__title">Protección Contra Incendios en {ciudadNombre}</h3>
            <ul class="sidebar-stats">
              <li>
                <span class="stat-value">{empresas.length}</span>
                <span class="stat-label">Empresas certificadas</span>
              </li>
              <li>
                <span class="stat-value">{Object.keys(empresasPorGiro).length}</span>
                <span class="stat-label">Tipos de negocio</span>
              </li>
              <li>
                <span class="stat-value">{sistemasEnCiudad.length}</span>
                <span class="stat-label">Tipos de sistema</span>
              </li>
              <li>
                <span class="stat-value">{empresas.filter(e => e.data.certificacionVigente).length}</span>
                <span class="stat-label">Certificaciones vigentes</span>
              </li>
            </ul>
          </div>

          <!-- Card: Por Tipo de Negocio -->
          <div class="sidebar-card">
            <h3 class="sidebar-card__title">Por Tipo de Negocio</h3>
            <ul class="sidebar-links">
              {Object.entries(empresasPorGiro).map(([giro, lista]) => (
                <li>
                  <a href={`/empresas-certificadas/giro/${giro}`}>
                    {giroPlurales[giro]}
                    <span class="link-count">{lista.length}</span>
                  </a>
                </li>
              ))}
            </ul>
          </div>

          <!-- Card: Otras Ciudades del Estado -->
          {otrasCiudades.length > 0 && (
            <div class="sidebar-card">
              <h3 class="sidebar-card__title">Otras Ciudades en {estadoNombre}</h3>
              <ul class="sidebar-links">
                {otrasCiudades.slice(0, 6).map((ciudad) => (
                  <li>
                    <a href={`/empresas-certificadas/estado/${estadoSlug}/${ciudad.slug}`}>
                      {ciudad.nombre}
                    </a>
                  </li>
                ))}
                <li class="sidebar-links__more">
                  <a href={`/empresas-certificadas/estado/${estadoSlug}`}>
                    Ver todas las ciudades en {estadoNombre} →
                  </a>
                </li>
              </ul>
            </div>
          )}

          <!-- Card: Otros Estados -->
          <div class="sidebar-card">
            <h3 class="sidebar-card__title">Otros Estados</h3>
            <ul class="sidebar-links">
              {otrosEstados.map((estado) => (
                <li>
                  <a href={`/empresas-certificadas/estado/${createSlug(estado)}`}>
                    {estado}
                  </a>
                </li>
              ))}
              <li class="sidebar-links__more">
                <a href="/empresas-certificadas#estados">Ver todos los estados →</a>
              </li>
            </ul>
          </div>

          <!-- Card: Sistemas Instalados -->
          <div class="sidebar-card">
            <h3 class="sidebar-card__title">Sistemas en {ciudadNombre}</h3>
            <div class="sidebar-tags">
              {sistemasEnCiudad.map((sistema) => (
                <span class="sidebar-tag">{sistemaLabels[sistema]}</span>
              ))}
            </div>
          </div>

          <!-- Card: Registra tu Empresa -->
          <div class="sidebar-card sidebar-card--cta">
            <h3 class="sidebar-card__title">¿Tu empresa está en {ciudadNombre}?</h3>
            <p>Registra tu negocio en el directorio y obtén el badge de certificación para mostrar a tus clientes.</p>
            <a href="/empresas-certificadas#registrar" class="btn btn--primary btn--block">
              Solicitar certificación
            </a>
          </div>

        </aside>

      </div>
    </div>
  </section>

  <!-- Artículos Relacionados -->
  <BlogRecent
    titulo={`Guías de Protección Contra Incendios para Empresas en ${estadoNombre}`}
    subtitulo="Recursos técnicos para cumplir con normativas de protección civil y seguridad patrimonial"
    limit={3}
    columns={3}
    background="white"
    showViewAll={true}
  />

  <!-- CTA -->
  <CtaCatalogo
    titulo={`¿Tu negocio en ${ciudadNombre} necesita certificación contra incendios?`}
    subtitulo="Verificación profesional · Badge de certificación · Aparece en el directorio"
    textoBoton="Solicitar certificación"
    enlace="#cotizar"
  />

  <!-- Formulario de contacto -->
  <CotizacionForm
    titulo={`Certifica tu empresa en ${ciudadNombre}`}
    producto={`Certificación en ${ciudadNombre}, ${estadoNombre}`}
    pagina={`Ciudad: ${ciudadNombre}, ${estadoNombre}`}
  />

</Layout>

<script>
  // Filtros de giro
  const chips = document.querySelectorAll('.chip');
  const empresasGrid = document.getElementById('empresas-grid');
  const empresaCards = empresasGrid?.querySelectorAll('[data-giro]');

  chips.forEach(chip => {
    chip.addEventListener('click', () => {
      const giro = chip.getAttribute('data-giro');

      // Actualizar chips activos
      chips.forEach(c => c.classList.remove('chip--active'));
      chip.classList.add('chip--active');

      // Filtrar empresas
      empresaCards?.forEach(card => {
        const cardGiro = card.getAttribute('data-giro');
        if (giro === 'all' || cardGiro === giro) {
          (card as HTMLElement).style.display = '';
        } else {
          (card as HTMLElement).style.display = 'none';
        }
      });
    });
  });
</script>


