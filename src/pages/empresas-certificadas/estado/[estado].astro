---
import Layout from '../../../layouts/Base.astro';
import SectionHeader from '../../../components/SectionHeader.astro';
import CategoryCard from '../../../components/CategoryCard.astro';
import CtaCatalogo from '../../../components/CtaCatalogo.astro';
import CotizacionForm from '../../../components/CotizacionForm.astro';
import BlogRecent from '../../../components/blog/BlogRecent.astro';
import { getCollection } from 'astro:content';
import '../../../styles/empresas.css';


// Mapeo de giros
const giroLabels: Record<string, string> = {
  hotel: 'Hoteles',
  restaurante: 'Restaurantes',
  oficina: 'Oficinas',
  almacen: 'Almacenes',
  hospital: 'Hospitales',
  escuela: 'Escuelas',
  industria: 'Industrias',
  comercio: 'Comercios',
  residencial: 'Residenciales',
  otro: 'Otros'
};

// Mapeo de sistemas
const sistemaLabels: Record<string, string> = {
  'rociadores-automaticos': 'Rociadores Automáticos',
  'red-hidrantes': 'Red de Hidrantes',
  'extintores': 'Extintores',
  'deteccion-alarma': 'Detección y Alarma',
  'fm200': 'FM-200',
  'co2': 'CO2',
  'espuma': 'Espuma',
  'gabinetes': 'Gabinetes',
  'senalizacion': 'Señalización'
};

// Función para crear slugs
function createSlug(text: string): string {
  return text.toLowerCase()
    .normalize('NFD')
    .replace(/[\u0300-\u036f]/g, '')
    .replace(/\s+/g, '-');
}

export async function getStaticPaths() {
  function createEstadoSlug(estado: string): string {
    return estado.toLowerCase()
      .normalize('NFD')
      .replace(/[\u0300-\u036f]/g, '')
      .replace(/\s+/g, '-');
  }

  const empresas = await getCollection('empresasCertificadas');
  const estados = [...new Set(empresas.map(e => e.data.estado))];

  return estados.map(estado => ({
    params: { estado: createEstadoSlug(estado) },
    props: {
      empresas: empresas.filter(e => e.data.estado === estado),
      estadoNombre: estado
    }
  }));
}

const { empresas, estadoNombre } = Astro.props;

// Agrupar por ciudad
const empresasPorCiudad = empresas.reduce((acc, empresa) => {
  const ciudad = empresa.data.ciudad;
  if (!acc[ciudad]) acc[ciudad] = [];
  acc[ciudad].push(empresa);
  return acc;
}, {} as Record<string, typeof empresas>);

// Agrupar por giro
const empresasPorGiro = empresas.reduce((acc, empresa) => {
  const giro = empresa.data.giro;
  if (!acc[giro]) acc[giro] = [];
  acc[giro].push(empresa);
  return acc;
}, {} as Record<string, typeof empresas>);

// Empresas ordenadas
const empresasOrdenadas = [...empresas].sort((a, b) => {
  if (a.data.destacado && !b.data.destacado) return -1;
  if (!a.data.destacado && b.data.destacado) return 1;
  if (a.data.verificado && !b.data.verificado) return -1;
  return 0;
});

// Schema.org
const itemListSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": `Empresas con Sistemas Contra Incendios Certificados en ${estadoNombre}`,
  "description": `Directorio de ${empresas.length} empresas con sistemas de protección contra incendios certificados en ${estadoNombre}, México. Hoteles, restaurantes, oficinas, almacenes y más.`,
  "numberOfItems": empresas.length,
  "itemListElement": empresasOrdenadas.slice(0, 10).map((empresa, index) => ({
    "@type": "ListItem",
    "position": index + 1,
    "item": {
      "@type": "LocalBusiness",
      "name": empresa.data.nombre,
      "address": {
        "@type": "PostalAddress",
        "addressLocality": empresa.data.ciudad,
        "addressRegion": estadoNombre,
        "addressCountry": "MX"
      }
    }
  }))
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Inicio", "item": "https://gamademexico.com" },
    { "@type": "ListItem", "position": 2, "name": "Empresas Certificadas", "item": "https://gamademexico.com/empresas-certificadas" },
    { "@type": "ListItem", "position": 3, "name": estadoNombre }
  ]
};
---

<Layout
  title={`Empresas con Sistemas Contra Incendios Certificados en ${estadoNombre} | Directorio`}
  description={`${empresas.length} empresas con sistemas contra incendios certificados en ${estadoNombre}. Hoteles, restaurantes, oficinas y almacenes protegidos por Gama de México en ${Object.keys(empresasPorCiudad).length} ciudades.`}
  activePage="directorio"
  heroTitle={`Empresas con Sistemas Contra Incendios Certificados en ${estadoNombre}`}
  heroIntro={`Directorio de ${empresas.length} hoteles, restaurantes, oficinas y almacenes con sistemas de protección contra incendios certificados en ${estadoNombre}. Verificados por Gama de México.`}
  heroBadge={estadoNombre}
  heroMetrics={[
    { valor: String(empresas.length), texto: "Empresas certificadas" },
    { valor: String(Object.keys(empresasPorCiudad).length), texto: "Ciudades" },
    { valor: String(Object.keys(empresasPorGiro).length), texto: "Tipos de negocio" }
  ]}
  heroPrimaryText="Registra tu empresa"
  heroPrimaryLink="/empresas-certificadas#registrar"
  heroSecondaryText="Ver todos los estados"
  heroSecondaryLink="/empresas-certificadas#estados"
  heroShowRightContent={true}
  structuredData={[itemListSchema, breadcrumbSchema]}
>

  <!-- HERO CONTENT -->
  <Fragment slot="hero-content">
    <p>El <strong>Directorio de Empresas Certificadas en {estadoNombre}</strong> reúne establecimientos que han implementado y verificado sus sistemas de protección contra incendios. Desde hoteles y restaurantes hasta almacenes industriales y oficinas corporativas, cada empresa listada cuenta con certificación vigente que acredita el cumplimiento de normativas NFPA y NOM.</p>
    <p>Consulta empresas por ciudad o tipo de negocio. Toda la información está verificada por ingenieros especializados de Gama de México.</p>
  </Fragment>

  <!-- Contenido Principal con Sidebar -->
  <section class="main-content">
    <div class="container">
      <div class="main-content__grid">

        <!-- Columna Principal -->
        <div class="main-content__primary">
          <SectionHeader
            titulo={`${Object.keys(empresasPorCiudad).length} Ciudades con Empresas Certificadas en ${estadoNombre}`}
            subtitulo="Selecciona una ciudad para ver el directorio completo de empresas con sistemas contra incendios verificados"
            idTitulo="ciudades"
            parrafo1={`El estado de ${estadoNombre} cuenta con ${empresas.length} empresas que han certificado sus sistemas de protección contra incendios con Gama de México. Estas empresas están distribuidas en ${Object.keys(empresasPorCiudad).length} ciudades, abarcando sectores como hotelería, restaurantes, oficinas corporativas, almacenes industriales, hospitales y centros educativos. Cada establecimiento ha sido verificado por ingenieros especializados.`}
            parrafo2={`La certificación incluye verificación de sistemas de rociadores automáticos, redes de hidrantes, sistemas de detección y alarma, gabinetes contra incendio, señalización de emergencia y planes de evacuación. Los sistemas están instalados conforme a normativas NFPA, NOM-002-STPS y requerimientos de protección civil estatales y municipales de ${estadoNombre}.`}
          />

          <div class="cities-grid">
            {Object.entries(empresasPorCiudad)
              .sort((a, b) => b[1].length - a[1].length)
              .map(([ciudad, lista]) => {
                const ciudadSlug = createSlug(ciudad);
                const estadoSlug = createSlug(estadoNombre);
                return (
                  <CategoryCard
                    titulo={`Empresas Certificadas en ${ciudad}`}
                    subtitulo={`${lista.length} empresas con sistemas contra incendios verificados en ${ciudad}, ${estadoNombre}`}
                    enlace={`/empresas-certificadas/estado/${estadoSlug}/${ciudadSlug}`}
                    subcategorias={lista.slice(0, 4).map((emp) => ({
                      nombre: emp.data.nombre,
                      enlace: `/empresas-certificadas/${emp.data.slug}`
                    }))}
                  />
                );
              })}
          </div>
        </div>

        <!-- Sidebar -->
        <aside class="main-content__sidebar">

          <!-- Por Tipo de Negocio -->
          <div class="sidebar-card">
            <h3 class="sidebar-card__title">Por Tipo de Negocio</h3>
            <nav class="giro-nav">
              {Object.entries(empresasPorGiro)
                .sort((a, b) => b[1].length - a[1].length)
                .map(([giro, lista]) => (
                  <a href={`/empresas-certificadas/giro/${giro}`} class="giro-nav__link">
                    <span>{giroLabels[giro]}</span>
                    <span class="giro-nav__count">{lista.length}</span>
                  </a>
                ))}
            </nav>
          </div>

          <!-- Explorar Directorio -->
          <div class="sidebar-card">
            <h3 class="sidebar-card__title">Explorar Directorio</h3>
            <nav class="directory-nav">
              <a href="/empresas-certificadas" class="directory-nav__link">
                <span>Todas las empresas certificadas</span>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M9 18l6-6-6-6"/>
                </svg>
              </a>
              <a href="/empresas-certificadas#estados" class="directory-nav__link">
                <span>Ver otros estados</span>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M9 18l6-6-6-6"/>
                </svg>
              </a>
              <a href="/empresas-certificadas#giros" class="directory-nav__link">
                <span>Buscar por tipo de negocio</span>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M9 18l6-6-6-6"/>
                </svg>
              </a>
            </nav>
          </div>

          <!-- CTA Sidebar -->
          <div class="sidebar-card sidebar-card--cta">
            <h3 class="sidebar-card__title">¿Tu empresa está en {estadoNombre}?</h3>
            <p class="sidebar-cta__text">Verifica tus sistemas contra incendios y aparece en nuestro directorio oficial.</p>
            <a href="#cotizar" class="sidebar-cta__btn">Solicitar certificación</a>
          </div>

        </aside>
      </div>
    </div>
  </section>

  <!-- Artículos Relacionados -->
  <BlogRecent
    titulo={`Guías Técnicas sobre Protección Contra Incendios y Normativas en ${estadoNombre}`}
    subtitulo="Recursos de nuestro equipo de ingenieros especializados"
    limit={3}
    columns={3}
    background="white"
    showViewAll={true}
  />

  <!-- CTA -->
  <CtaCatalogo
    titulo={`¿Tu empresa en ${estadoNombre} tiene sistema contra incendios?`}
    subtitulo="Verificación profesional · Certificado digital · Inclusión en directorio"
    textoBoton="Solicitar certificación"
    enlace="#cotizar"
  />

  <!-- Formulario -->
  <CotizacionForm
    titulo={`Certifica tu empresa en ${estadoNombre}`}
    producto={`Certificación en ${estadoNombre}`}
    pagina={`Estado: ${estadoNombre}`}
  />

</Layout>


