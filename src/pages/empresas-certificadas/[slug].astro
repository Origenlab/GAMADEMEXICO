// Seleccionar 2-3 reviews variados por empresa
const reviewCount = (slugHash % 2) + 2; // 2 o 3
const selectedReviews = giroReviews.slice(0, reviewCount).map((r, i) => {
  const stars = [5, 5, 4][i] || 5;
  return {
    "@type": "Review" as const,
    "author": { "@type": "Person" as const, "name": `${r.author}` },
    "reviewRating": { "@type": "Rating" as const, "ratingValue": String(stars), "bestRating": "5" },
    "reviewBody": r.body
  };
});

