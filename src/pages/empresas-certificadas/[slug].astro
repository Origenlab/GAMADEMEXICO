---
import Layout from '../../layouts/Base.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import CategoryCard from '../../components/CategoryCard.astro';
import CtaCatalogo from '../../components/CtaCatalogo.astro';
import CotizacionForm from '../../components/CotizacionForm.astro';
import BlogRecent from '../../components/blog/BlogRecent.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const empresas = await getCollection('empresasCertificadas');
  return empresas.map((empresa) => ({
    params: { slug: empresa.data.slug },
    props: { empresa },
  }));
}

const { empresa } = Astro.props;
const { Content } = await render(empresa);

// Mapeo de giros
const giroLabels: Record<string, string> = {
  hotel: 'Hotel',
  restaurante: 'Restaurante',
  oficina: 'Oficina',
  almacen: 'Almacén',
  hospital: 'Hospital',
  escuela: 'Escuela',
  industria: 'Industria',
  comercio: 'Comercio',
  residencial: 'Residencial',
  otro: 'Otro'
};

// Mapeo de sistemas a contenido SEO completo
const sistemaInfo: Record<string, { label: string; intro: string; caracteristicas: string[]; normativa: string; equipos: string }> = {
  'rociadores-automaticos': {
    label: 'Sistema de Rociadores Automáticos',
    intro: 'El sistema de rociadores automáticos instalado proporciona protección activa contra incendios mediante la descarga automática de agua cuando se detecta calor excesivo. Los rociadores están diseñados para activarse individualmente al alcanzar su temperatura de fusión, conteniendo el fuego en su etapa inicial y evitando su propagación.',
    caracteristicas: [
      'Rociadores con certificación UL/FM de respuesta rápida',
      'Cobertura completa de áreas de almacenamiento y oficinas',
      'Sistema húmedo con presión constante para activación inmediata',
      'Válvulas de control con supervisión electrónica',
      'Conexión a bomba contra incendios certificada'
    ],
    normativa: 'Instalación conforme a NFPA 13 (Instalación de Sistemas de Rociadores) y NOM-002-STPS-2010.',
    equipos: 'Rociadores Tyco, Viking o equivalente certificado UL/FM.'
  },
  'red-hidrantes': {
    label: 'Red de Hidrantes y Gabinetes Contra Incendio',
    intro: 'La red de hidrantes proporciona puntos de conexión estratégicamente ubicados para que brigadas internas y cuerpos de bomberos puedan combatir incendios con agua a alta presión. Los gabinetes interiores permiten una primera respuesta inmediata por parte del personal capacitado.',
    caracteristicas: [
      'Hidrantes exteriores con conexiones siamesas para bomberos',
      'Gabinetes interiores con manguera de 1½" y 30 metros de longitud',
      'Válvulas anguladas de latón certificadas UL/FM',
      'Boquillas de chorro/niebla ajustables',
      'Extintor portátil incluido en cada gabinete'
    ],
    normativa: 'Conforme a NFPA 14 (Sistemas de Tuberías Verticales y Mangueras) y NFPA 24 (Instalación de Tuberías para Servicio Privado de Incendios).',
    equipos: 'Válvulas Elkhart Brass, mangueras certificadas UL, gabinetes fabricados conforme a NOM.'
  },
  'extintores': {
    label: 'Extintores Portátiles Certificados',
    intro: 'Los extintores portátiles constituyen la primera línea de defensa contra conatos de incendio. Están ubicados estratégicamente para que cualquier persona pueda acceder a uno en menos de 15 metros de recorrido, permitiendo una respuesta inmediata ante emergencias.',
    caracteristicas: [
      'Extintores tipo ABC de polvo químico seco para riesgos generales',
      'Extintores tipo K para áreas de cocina y preparación de alimentos',
      'Extintores de CO2 para equipos eléctricos y electrónicos',
      'Señalización visible y altura de montaje conforme a norma',
      'Programa de mantenimiento y recarga semestral'
    ],
    normativa: 'Conforme a NOM-002-STPS-2010 y NFPA 10 (Extintores Portátiles Contra Incendios).',
    equipos: 'Extintores certificados con capacidad de 4.5 kg a 9 kg según área de cobertura.'
  },
  'deteccion-alarma': {
    label: 'Sistema de Detección y Alarma Contra Incendios',
    intro: 'El sistema de detección y alarma proporciona vigilancia continua 24/7 mediante sensores distribuidos en toda la instalación. Al detectar humo, calor o llama, el sistema activa automáticamente las alarmas audibles y visuales, notifica a la central de monitoreo y puede activar sistemas de supresión automática.',
    caracteristicas: [
      'Detectores de humo fotoeléctricos en áreas generales',
      'Detectores térmicos en cocinas y áreas con vapor',
      'Estaciones manuales de alarma en rutas de evacuación',
      'Sirenas y luces estroboscópicas para notificación',
      'Panel de control inteligente con comunicador a central de monitoreo'
    ],
    normativa: 'Conforme a NFPA 72 (Código Nacional de Alarmas de Incendio y Señalización) y NOM-002-STPS-2010.',
    equipos: 'Panel de detección direccionable, detectores inteligentes con autodiagnóstico.'
  },
  'fm200': {
    label: 'Sistema de Supresión FM-200 (Agente Limpio)',
    intro: 'El sistema FM-200 proporciona supresión de incendios mediante un agente gaseoso que no deja residuos, siendo ideal para proteger equipos electrónicos, servidores, archivos importantes y obras de arte. La descarga se realiza en menos de 10 segundos, extinguiendo el fuego sin dañar los equipos.',
    caracteristicas: [
      'Agente HFC-227ea (FM-200) ecológicamente seguro',
      'Descarga total en menos de 10 segundos',
      'Sin residuos ni daño a equipos electrónicos',
      'Sistema de prealarma para evacuación del área',
      'Cilindros de almacenamiento con supervisión de presión'
    ],
    normativa: 'Conforme a NFPA 2001 (Sistemas de Extinción de Incendios con Agentes Limpios).',
    equipos: 'Sistema completo con cilindros, válvulas, tuberías y boquillas de descarga certificadas.'
  },
  'co2': {
    label: 'Sistema de Supresión con CO2',
    intro: 'El sistema de dióxido de carbono proporciona supresión efectiva mediante desplazamiento de oxígeno, siendo especialmente efectivo para fuegos de clase B (líquidos inflamables) y C (equipos eléctricos). Requiere procedimientos de evacuación previos a la descarga.',
    caracteristicas: [
      'Descarga total o local según configuración',
      'Efectivo para fuegos clase B y C',
      'No deja residuos tras la descarga',
      'Sistema de retardo para evacuación del personal',
      'Alarma previa obligatoria antes de descarga'
    ],
    normativa: 'Conforme a NFPA 12 (Sistemas de Extinción con Dióxido de Carbono).',
    equipos: 'Cilindros de alta presión, válvulas direccionales y boquillas de descarga.'
  },
  'espuma': {
    label: 'Sistema de Supresión con Espuma AFFF',
    intro: 'El sistema de espuma AFFF (Aqueous Film Forming Foam) está diseñado para combatir incendios de líquidos inflamables mediante la formación de una película acuosa que sofoca las llamas y previene la reignición. Es ideal para hangares, plantas químicas y áreas de almacenamiento de combustibles.',
    caracteristicas: [
      'Concentrado AFFF al 3% o 6% según aplicación',
      'Cámaras de espuma para tanques de almacenamiento',
      'Monitores de espuma para áreas abiertas',
      'Sistema de proporcionamiento automático',
      'Reserva de concentrado para múltiples descargas'
    ],
    normativa: 'Conforme a NFPA 11 (Sistemas de Espuma de Baja, Media y Alta Expansión) y NFPA 16.',
    equipos: 'Proporcionadores, cámaras de espuma, monitores y concentrado AFFF certificado UL.'
  },
  'gabinetes': {
    label: 'Gabinetes Contra Incendio Equipados',
    intro: 'Los gabinetes contra incendio proporcionan equipos de primera respuesta accesibles para el personal capacitado. Cada gabinete contiene los elementos necesarios para combatir conatos de incendio y facilitar la evacuación, ubicados estratégicamente en pasillos y rutas de evacuación.',
    caracteristicas: [
      'Gabinete metálico con vidrio de seguridad',
      'Manguera de 1½" x 30 metros con carrete giratorio',
      'Válvula angulada de latón con conexión NST',
      'Boquilla de niebla/chorro ajustable',
      'Extintor portátil y hacha de bombero incluidos'
    ],
    normativa: 'Conforme a NFPA 14 y especificaciones de protección civil locales.',
    equipos: 'Gabinetes fabricados en acero al carbón con acabado en pintura electrostática roja.'
  },
  'senalizacion': {
    label: 'Señalización de Emergencia y Rutas de Evacuación',
    intro: 'El sistema de señalización de emergencia guía al personal y visitantes hacia las salidas de emergencia y puntos de reunión mediante señales fotoluminiscentes que permanecen visibles incluso durante cortes de energía eléctrica. La señalización cumple con códigos de colores y pictogramas internacionales.',
    caracteristicas: [
      'Señales fotoluminiscentes visibles hasta 8 horas sin luz',
      'Identificación de rutas de evacuación principales y alternas',
      'Señalización de ubicación de equipos contra incendio',
      'Puntos de reunión claramente identificados',
      'Planos de evacuación en cada nivel'
    ],
    normativa: 'Conforme a NOM-003-SEGOB-2011 y NOM-026-STPS-2008 (Colores y Señales de Seguridad).',
    equipos: 'Señales de PVC fotoluminiscente con soporte y fijación permanente.'
  }
};

// Schema.org LocalBusiness
const businessSchema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": empresa.data.nombre,
  "description": empresa.data.descripcion || `${empresa.data.nombre} cuenta con sistema de protección contra incendios certificado por Gama de México.`,
  "address": {
    "@type": "PostalAddress",
    "streetAddress": empresa.data.direccion,
    "addressLocality": empresa.data.ciudad,
    "addressRegion": empresa.data.estado,
    "postalCode": empresa.data.codigoPostal,
    "addressCountry": "MX"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": empresa.data.latitud,
    "longitude": empresa.data.longitud
  },
  ...(empresa.data.telefono && { "telephone": empresa.data.telefono }),
  ...(empresa.data.email && { "email": empresa.data.email }),
  ...(empresa.data.website && { "url": empresa.data.website })
};

// Breadcrumb Schema
const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Inicio", "item": "https://gamademexico.com" },
    { "@type": "ListItem", "position": 2, "name": "Empresas Certificadas", "item": "https://gamademexico.com/empresas-certificadas" },
    { "@type": "ListItem", "position": 3, "name": empresa.data.nombre }
  ]
};

// Obtener empresas relacionadas (mismo giro o misma ciudad)
const todasEmpresas = await getCollection('empresasCertificadas');
const empresasRelacionadas = todasEmpresas
  .filter(e => e.data.slug !== empresa.data.slug && (e.data.giro === empresa.data.giro || e.data.ciudad === empresa.data.ciudad))
  .slice(0, 3);

// Formatear fecha
const formatDate = (dateStr: string) => {
  return new Date(dateStr).toLocaleDateString('es-MX', { day: 'numeric', month: 'long', year: 'numeric' });
};
---

<Layout
  title={`${empresa.data.nombre} | Sistema Contra Incendios Certificado en ${empresa.data.ciudad}`}
  description={empresa.data.descripcion || `${empresa.data.nombre} cuenta con sistema de protección contra incendios certificado por Gama de México en ${empresa.data.ciudad}, ${empresa.data.estado}. Verificación de ${empresa.data.tipoSistema.length} sistemas activos.`}
  activePage="directorio"
  heroTitle={empresa.data.nombre}
  heroIntro={`Sistema de protección contra incendios certificado en ${empresa.data.ciudad}, ${empresa.data.estado}. ${empresa.data.tipoSistema.length} sistemas verificados por Gama de México.`}
  heroBadge={empresa.data.certificacionVigente ? 'Certificación Vigente' : 'Certificación Vencida'}
  heroMetrics={[
    { valor: String(empresa.data.tipoSistema.length), texto: 'Sistemas certificados' },
    { valor: formatDate(empresa.data.fechaCertificacion).split(' ')[2], texto: 'Año certificación' },
    { valor: giroLabels[empresa.data.giro], texto: 'Tipo de negocio' }
  ]}
  heroPrimaryText="Ver ubicación en mapa"
  heroPrimaryLink={`https://www.google.com/maps/search/?api=1&query=${empresa.data.latitud},${empresa.data.longitud}`}
  heroSecondaryText="Solicitar certificación"
  heroSecondaryLink="#cotizar"
  heroShowRightContent={true}
  structuredData={[businessSchema, breadcrumbSchema]}
>

  <!-- HERO CONTENT -->
  <Fragment slot="hero-content">
    <p><strong>{empresa.data.nombre}</strong> cuenta con un sistema integral de protección contra incendios verificado por Gama de México. La instalación incluye {empresa.data.tipoSistema.map(s => sistemaInfo[s]?.label || s).join(', ')}, todos certificados conforme a normativas NFPA, NOM-002-STPS y requerimientos de protección civil.</p>
    {empresa.data.descripcion && <p>{empresa.data.descripcion}</p>}
    <div class="empresa-ubicacion">
      <strong>{empresa.data.direccion}</strong><br/>
      {empresa.data.colonia}, {empresa.data.ciudad}, {empresa.data.estado} C.P. {empresa.data.codigoPostal}
    </div>
    {(empresa.data.telefono || empresa.data.website) && (
      <div class="empresa-contacto">
        {empresa.data.telefono && <a href={`tel:${empresa.data.telefono}`}>{empresa.data.telefono}</a>}
        {empresa.data.website && <a href={empresa.data.website} target="_blank" rel="noopener noreferrer">Sitio web</a>}
      </div>
    )}
  </Fragment>

  <!-- Contenido Principal con Sidebar -->
  <section class="main-content">
    <div class="container">
      <div class="main-content__grid">

        <!-- Columna Principal -->
        <div class="main-content__primary">
          <SectionHeader
            titulo={`Sistemas de Protección Contra Incendios Certificados en ${empresa.data.nombre}`}
            subtitulo={`${empresa.data.tipoSistema.length} sistemas verificados por Gama de México con equipos certificados UL y FM`}
            idTitulo="sistemas-certificados"
            parrafo1={`${empresa.data.nombre} ha implementado un sistema integral de protección contra incendios que incluye ${empresa.data.tipoSistema.map(s => sistemaInfo[s]?.label || s).join(', ')}. Cada componente ha sido verificado por ingenieros especializados de Gama de México, confirmando su correcto funcionamiento y cumplimiento con normativas NFPA, NOM-002-STPS y requerimientos de protección civil.`}
            parrafo2="Los sistemas instalados utilizan equipos certificados UL y FM de marcas reconocidas como Elkhart Brass, garantizando la máxima confiabilidad en caso de emergencia. La verificación periódica asegura que todos los componentes se encuentren operativos y listos para proteger vidas y patrimonio."
          />

          <!-- Sistemas Detallados -->
          <div class="sistemas-content">
            {empresa.data.tipoSistema.map((sistema, index) => (
              <article class="sistema-detail" id={sistema}>
                <header class="sistema-detail__header">
                  <span class="sistema-detail__number">{String(index + 1).padStart(2, '0')}</span>
                  <h3 class="sistema-detail__title">{sistemaInfo[sistema]?.label || sistema}</h3>
                </header>

                <p class="sistema-detail__intro">{sistemaInfo[sistema]?.intro}</p>

                <div class="sistema-detail__specs">
                  <h4 class="sistema-detail__subtitle">Características del sistema instalado:</h4>
                  <ul class="sistema-detail__list">
                    {sistemaInfo[sistema]?.caracteristicas.map((car) => (
                      <li>{car}</li>
                    ))}
                  </ul>
                </div>

                <div class="sistema-detail__footer">
                  <div class="sistema-detail__normativa">
                    <strong>Normativa aplicable:</strong> {sistemaInfo[sistema]?.normativa}
                  </div>
                  <div class="sistema-detail__equipos">
                    <strong>Equipos utilizados:</strong> {sistemaInfo[sistema]?.equipos}
                  </div>
                </div>

                <a href={`/equipos?sistema=${sistema}`} class="sistema-detail__link">
                  Ver equipos relacionados en nuestro catálogo →
                </a>
              </article>
            ))}
          </div>

          <!-- Contenido del Markdown (si existe) -->
          {Content && (
            <div class="content-wrapper">
              <Content />
            </div>
          )}
        </div>

        <!-- Sidebar -->
        <aside class="main-content__sidebar">

          <!-- Tarjeta de Certificación -->
          <div class="sidebar-card sidebar-card--cert">
            <div class="sidebar-card__header">
              <h3 class="sidebar-card__title">Certificación Oficial</h3>
              <span class={`cert-badge ${empresa.data.certificacionVigente ? 'cert-badge--active' : 'cert-badge--expired'}`}>
                {empresa.data.certificacionVigente ? 'Vigente' : 'Vencida'}
              </span>
            </div>
            <dl class="cert-data">
              <div class="cert-data__row">
                <dt>Certificado por</dt>
                <dd>{empresa.data.certificadoPor}</dd>
              </div>
              <div class="cert-data__row">
                <dt>Fecha certificación</dt>
                <dd>{formatDate(empresa.data.fechaCertificacion)}</dd>
              </div>
              {empresa.data.fechaVencimiento && (
                <div class="cert-data__row">
                  <dt>Vencimiento</dt>
                  <dd>{formatDate(empresa.data.fechaVencimiento)}</dd>
                </div>
              )}
              <div class="cert-data__row">
                <dt>Sistemas verificados</dt>
                <dd><strong>{empresa.data.tipoSistema.length}</strong> activos</dd>
              </div>
              <div class="cert-data__row">
                <dt>Tipo de negocio</dt>
                <dd>{giroLabels[empresa.data.giro]}</dd>
              </div>
            </dl>
          </div>

          <!-- Mapa y Ubicación -->
          <div class="sidebar-card">
            <h3 class="sidebar-card__title">Ubicación</h3>
            <a
              href={`https://www.google.com/maps/search/?api=1&query=${empresa.data.latitud},${empresa.data.longitud}`}
              target="_blank"
              rel="noopener noreferrer"
              class="map-preview"
            >
              <span class="map-preview__icon">
                <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
                  <circle cx="12" cy="10" r="3"/>
                </svg>
              </span>
              <span class="map-preview__text">Ver en Google Maps</span>
            </a>
            <address class="location-address">
              <strong>{empresa.data.direccion}</strong><br/>
              {empresa.data.colonia}<br/>
              {empresa.data.ciudad}, {empresa.data.estado}<br/>
              C.P. {empresa.data.codigoPostal}
            </address>
          </div>

          <!-- Contacto -->
          {(empresa.data.telefono || empresa.data.website || empresa.data.email) && (
            <div class="sidebar-card">
              <h3 class="sidebar-card__title">Contacto</h3>
              <div class="contact-links">
                {empresa.data.telefono && (
                  <a href={`tel:${empresa.data.telefono}`} class="contact-link">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
                    </svg>
                    {empresa.data.telefono}
                  </a>
                )}
                {empresa.data.email && (
                  <a href={`mailto:${empresa.data.email}`} class="contact-link">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                      <polyline points="22,6 12,13 2,6"/>
                    </svg>
                    Enviar correo
                  </a>
                )}
                {empresa.data.website && (
                  <a href={empresa.data.website} target="_blank" rel="noopener noreferrer" class="contact-link">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <circle cx="12" cy="12" r="10"/>
                      <line x1="2" y1="12" x2="22" y2="12"/>
                      <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
                    </svg>
                    Visitar sitio web
                  </a>
                )}
              </div>
            </div>
          )}

          <!-- Explorar Directorio -->
          <div class="sidebar-card sidebar-card--nav">
            <h3 class="sidebar-card__title">Explorar Directorio</h3>
            <nav class="directory-nav">
              <a href="/empresas-certificadas" class="directory-nav__link">
                <span>Todas las empresas certificadas</span>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M9 18l6-6-6-6"/>
                </svg>
              </a>
              <a href={`/empresas-certificadas/giro/${empresa.data.giro}`} class="directory-nav__link">
                <span>Más {giroLabels[empresa.data.giro]}s certificados</span>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M9 18l6-6-6-6"/>
                </svg>
              </a>
              <a href={`/empresas-certificadas/estado/${empresa.data.estado.toLowerCase().replace(/ /g, '-')}`} class="directory-nav__link">
                <span>Empresas en {empresa.data.estado}</span>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M9 18l6-6-6-6"/>
                </svg>
              </a>
            </nav>
          </div>

          <!-- CTA Sidebar -->
          <div class="sidebar-card sidebar-card--cta">
            <h3 class="sidebar-card__title">¿Tu empresa necesita certificación?</h3>
            <p class="sidebar-cta__text">Verifica tus sistemas contra incendios y aparece en nuestro directorio oficial.</p>
            <a href="#cotizar" class="sidebar-cta__btn">Solicitar certificación</a>
          </div>

        </aside>
      </div>
    </div>
  </section>

  <!-- Empresas Relacionadas -->
  {empresasRelacionadas.length > 0 && (
    <section class="related-section">
      <div class="container">
        <SectionHeader
          titulo={`Más Empresas con Sistemas Contra Incendios Certificados en ${empresa.data.ciudad}`}
          subtitulo="Directorio de establecimientos verificados con protección contra incendios en la misma zona"
          idTitulo="empresas-relacionadas"
        />

        <div class="related-grid">
          {empresasRelacionadas.map((rel) => (
            <CategoryCard
              titulo={rel.data.nombre}
