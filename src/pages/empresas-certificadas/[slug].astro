  ],
  escuela: [
    { q: `¿Qué protección contra incendios tiene esta institución educativa?`, a: `Este proyecto educativo cuenta con ${nSistemas} sistemas verificados: ${listaSistemas}. Los sistemas están diseñados para instituciones con alta ocupación.` },
    { q: '¿La institución cumple con protección civil para el ciclo escolar?', a: `Los sistemas instalados en este proyecto están verificados por Gama de México y cumplen con NOM-002-STPS y los requisitos de protección civil para instituciones educativas.` },
    { q: '¿Gama de México capacita al personal de la escuela?', a: 'Sí. Gama de México ofrece capacitación en uso de extintores, evacuación y primeros auxilios para personal docente y administrativo. La capacitación se programa en horarios que no interrumpan las actividades escolares.' },
  ],
  comercio: [
    { q: `¿Qué sistemas contra incendios tiene este establecimiento comercial?`, a: `Este proyecto comercial tiene ${nSistemas} sistemas verificados: ${listaSistemas}. Todos conforme a NFPA y NOM-002-STPS para establecimientos comerciales.` },
    { q: `¿Los sistemas de este establecimiento están activos?`, a: `Sí. Los ${nSistemas} sistemas instalados están verificados y en operación. Gama de México entregó el certificado digital y la carpeta técnica requerida por la aseguradora.` },
    { q: '¿Cómo obtengo la certificación para mi tienda o local comercial?', a: 'Contacta a Gama de México al 55 6529 8240. Un ingeniero evaluará tu local, te indicará los sistemas que necesitas para cumplir con protección civil y te entregará una cotización. La instalación se puede hacer fuera de horario comercial.' },
  ],
  residencial: [
    { q: `¿Qué protección tiene este desarrollo residencial?`, a: `Este proyecto residencial cuenta con ${nSistemas} sistemas verificados: ${listaSistemas}. Los sistemas cumplen con normativas aplicables a uso residencial.` },
    { q: '¿Los condominios requieren sistema contra incendios?', a: 'Sí. Los desarrollos residenciales con más de 3 niveles o estacionamiento subterráneo requieren sistemas de detección, gabinetes contra incendio y señalización conforme a NOM-002-STPS y el reglamento de construcción local.' },
    { q: '¿Cómo certifico mi condominio o desarrollo residencial?', a: 'Gama de México evalúa la instalación existente, identifica qué falta o está fuera de norma, y entrega un proyecto para cumplir los requerimientos. Llama al 55 6529 8240 o usa el formulario en esta página.' },
  ],
  otro: [
    { q: `¿Qué sistemas incluye este proyecto?`, a: `Este proyecto cuenta con ${nSistemas} sistemas verificados: ${listaSistemas}. Todos verificados por Gama de México conforme a NFPA y NOM-002-STPS.` },
    { q: `¿Los sistemas de este proyecto están activos?`, a: `Sí. Los sistemas instalados en este proyecto están verificados y operativos. Gama de México realizó la verificación técnica en ${anio}.` },
    { q: '¿Cómo solicito la verificación de mi empresa?', a: 'Contacta a Gama de México al 55 6529 8240 o envía el formulario en esta página. Un ingeniero visitará tu instalación y te entregará un diagnóstico con los sistemas necesarios.' },
  ],
};

const faqItems = faqsByGiro[empresa.data.giro] || faqsByGiro['otro'];


// Imagen por giro para el directorio
const giroImagenes: Record<string, string> = {
  hotel: '/img/directorio/directorio-hotel-sistema-contra-incendios.avif',
  restaurante: '/img/directorio/directorio-restaurante-sistema-contra-incendios.avif',
  industria: '/img/directorio/directorio-industria-sistema-contra-incendios.avif',
  almacen: '/img/directorio/directorio-almacen-sistema-contra-incendios.avif',
  hospital: '/img/directorio/directorio-hospital-sistema-contra-incendios.avif',
  escuela: '/img/directorio/directorio-escuela-sistema-contra-incendios.avif',
  comercio: '/img/directorio/directorio-comercio-sistema-contra-incendios.avif',
  oficina: '/img/directorio/directorio-oficina-sistema-contra-incendios.avif',
  residencial: '/img/directorio/directorio-oficina-sistema-contra-incendios.avif',
  otro: '/img/directorio/directorio-certificacion-gama-mexico.avif',
};
const empresaImagen = empresa.data.imagen && empresa.data.imagen !== '/img/gama-de-mexico.avif' 
  ? empresa.data.imagen 
  : (giroImagenes[empresa.data.giro] || '/img/directorio/directorio-certificacion-gama-mexico.avif');

// Galería de 8 imágenes — usa fotos únicas si existen, fallback a genéricas por giro
const slug = empresa.data.slug;
const galeriaBase = `/img/directorio/empresas/galeria/${slug}`;

// Intentar usar imágenes únicas de la empresa (generadas desde Google Maps)
// Fallback: imágenes genéricas por giro
const allGiroImgs = [
  '/img/directorio/directorio-hotel-sistema-contra-incendios.avif',
  '/img/directorio/directorio-industria-sistema-contra-incendios.avif',
  '/img/directorio/directorio-hospital-sistema-contra-incendios.avif',
  '/img/directorio/directorio-comercio-sistema-contra-incendios.avif',
  '/img/directorio/directorio-oficina-sistema-contra-incendios.avif',
  '/img/directorio/directorio-almacen-sistema-contra-incendios.avif',
  '/img/directorio/directorio-escuela-sistema-contra-incendios.avif',
  '/img/directorio/directorio-restaurante-sistema-contra-incendios.avif',
  '/img/directorio/directorio-infraestructura-industrial.avif',
  '/img/directorio/directorio-certificacion-gama-mexico.avif',
];
const giroImg = giroImagenes[empresa.data.giro] || '';
const fallbackImgs = allGiroImgs.filter(img => img !== giroImg && img !== empresaImagen).slice(0, 8);

// Verificar si existen imágenes únicas de galería
import fs from 'node:fs';
const galeriaDir = `public/img/directorio/empresas/galeria`;
const hasGaleria = fs.existsSync(`${galeriaDir}/${slug}-1.avif`);

// Contar exactamente cuántas fotos existen para no generar paths de imágenes inexistentes
let galeriaCount = 0;
if (hasGaleria) {
  while (fs.existsSync(`${galeriaDir}/${slug}-${galeriaCount + 1}.avif`)) {
    galeriaCount++;
  }
}

const galeriaImgs = galeriaCount > 0
  ? Array.from({length: galeriaCount}, (_, i) => `${galeriaBase}-${i + 1}.avif`)
  : fallbackImgs;

const galeriaAlts = [
  `${giroLabels[empresa.data.giro]} en ${empresa.data.ciudad} — sistema contra incendios instalado por Gama de México`,
  `Área interior con protección contra incendios verificada por Gama de México`,
  `Sistemas de protección activos en ${empresa.data.sector || giroLabels[empresa.data.giro]} — ${empresa.data.estado}`,
  `Gabinete contra incendio certificado — proyecto apoyado por Gama de México`,
  `Señalización de emergencia conforme a NOM — ${empresa.data.ciudad}, ${empresa.data.estado}`,
  `Área técnica con sistemas de protección contra incendios NFPA`,
  `Instalación de sistemas contra incendios apoyada por Gama de México`,
  `Vista general de instalación con protección activa — ${empresa.data.estado}`,
];

// Schema.org Service — sin identificar empresa tercera (FASE 1 · 2026-07-01)
// Se usa Service en lugar de LocalBusiness porque el sujeto es el servicio prestado
// por Gama de México, no la empresa cliente (que es anónima).
const businessSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": `Instalación Sistema Contra Incendios — ${empresa.data.sector || giroLabels[empresa.data.giro]}`,
  "description": empresa.data.descripcion || `Proyecto de protección contra incendios en ${empresa.data.giro} ubicado en ${empresa.data.ciudad}, ${empresa.data.estado}. ${empresa.data.tipoSistema.length} sistemas instalados y verificados por Gama de México conforme a NFPA y NOM-002-STPS.`,
  "serviceType": "Protección Contra Incendios",
  "provider": {
    "@type": "LocalBusiness",
    "name": "Gama de México",
    "url": "https://gamademexico.com"
  },
  "areaServed": {
    "@type": "State",
    "name": empresa.data.estado,
    "containedInPlace": {
      "@type": "Country",
      "name": "México"
    }
  },
  "url": `https://gamademexico.com/empresas-certificadas/${empresa.data.slug}`,
};

// FAQPage Schema
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqItems.map(item => ({
    "@type": "Question",
    "name": item.q,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": item.a
    }
  }))
};

// Breadcrumb Schema
const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Inicio", "item": "https://gamademexico.com" },
    { "@type": "ListItem", "position": 2, "name": "Empresas Certificadas", "item": "https://gamademexico.com/empresas-certificadas" },
    { "@type": "ListItem", "position": 3, "name": empresa.data.nombre }
  ]
};

// Title optimizado a ≤60 chars
const titleFull = `${empresa.data.nombre} | Contra Incendios ${empresa.data.ciudad}`;
const titleShort = `${empresa.data.nombre} | Contra Incendios`;
const pageTitle = titleFull.length <= 60 ? titleFull : (titleShort.length <= 60 ? titleShort : `${empresa.data.nombre.slice(0, 35)}... | Contra Incendios`);

// Meta description truncada a 155 chars
const rawDesc = empresa.data.descripcion
  || `Proyecto de protección contra incendios apoyado por Gama de México en ${empresa.data.ciudad}, ${empresa.data.estado}. ${empresa.data.tipoSistema.length} sistemas verificados: ${empresa.data.tipoSistema.map(s => sistemaInfo[s]?.label || s).join(', ')}.`;
const pageDesc = rawDesc.length > 155 ? rawDesc.slice(0, 152).trimEnd() + '...' : rawDesc;
---

<Layout
  title={pageTitle}
  description={pageDesc}
  activePage="directorio"
  heroTitle={empresa.data.nombre}
  heroIntro={`Proyecto de protección contra incendios apoyado por Gama de México en ${empresa.data.ciudad}, ${empresa.data.estado}. ${empresa.data.tipoSistema.length} sistemas verificados conforme a NFPA y NOM-002-STPS.`}
  heroBadge={empresa.data.sector || giroLabels[empresa.data.giro]}
  heroMetrics={[
    { valor: String(empresa.data.tipoSistema.length), texto: 'Sistemas instalados' },
    { valor: empresa.data.anioProyecto || '2024', texto: 'Año del proyecto' },
    { valor: giroLabels[empresa.data.giro], texto: 'Sector' }
  ]}
  heroPrimaryText="Solicitar proyecto similar"
  heroPrimaryLink="#cotizar"
  heroSecondaryText="Ver catálogo de equipos"
  heroSecondaryLink="/equipos"
  heroShowRightContent={true}
  structuredData={[businessSchema, breadcrumbSchema, faqSchema]}
>

  <!-- HERO CONTENT -->
  <Fragment slot="hero-content">
    <p>Proyecto de protección contra incendios apoyado por Gama de México en <strong>{empresa.data.ciudad}, {empresa.data.estado}</strong>. La instalación incluye {empresa.data.tipoSistema.map(s => sistemaInfo[s]?.label || s).join(', ')}, todos verificados conforme a normativas NFPA, NOM-002-STPS y requerimientos de protección civil.</p>
    {empresa.data.descripcion && <p>{empresa.data.descripcion}</p>}
  </Fragment>

  <!-- Contenido Principal con Sidebar -->
  <section class="main-content">
    <div class="container">
      <div class="main-content__grid">

        <!-- Columna Principal -->
        <div class="main-content__primary">

          <!-- Imagen principal de la empresa -->
          <div class="empresa-imagen-wrapper">
            <img
              src={empresaImagen}
              alt={`Sistema de protección contra incendios certificado en ${empresa.data.nombre}, ${empresa.data.ciudad}`}
              class="empresa-imagen-hero"
              width="800"
              height="450"
              loading="eager"
              decoding="async"
            />
          </div>

          <!-- Galería de imágenes -->
          <div class="empresa-galeria">
            {galeriaImgs.map((img, i) => (
              <img
                src={img}
                alt={`${galeriaAlts[i] || 'Sistema contra incendios'} — ${empresa.data.nombre}`}
                class="empresa-galeria__img"
                width="280"
                height="158"
                loading="lazy"
                decoding="async"
              />
            ))}
          </div>

          <SectionHeader
            titulo={`Sistemas de Protección Contra Incendios Certificados en ${empresa.data.nombre}`}
            subtitulo={`${empresa.data.tipoSistema.length} sistemas verificados por Gama de México con equipos certificados UL y FM`}
            idTitulo="sistemas-certificados"
            parrafo1={`${empresa.data.nombre} ha implementado un sistema integral de protección contra incendios que incluye ${empresa.data.tipoSistema.map(s => sistemaInfo[s]?.label || s).join(', ')}. Cada componente ha sido verificado por ingenieros especializados de Gama de México, confirmando su correcto funcionamiento y cumplimiento con normativas NFPA, NOM-002-STPS y requerimientos de protección civil.`}
            parrafo2="Los sistemas instalados utilizan equipos certificados UL y FM de marcas reconocidas como Elkhart Brass, garantizando la máxima confiabilidad en caso de emergencia. La verificación periódica asegura que todos los componentes se encuentren operativos y listos para proteger vidas y patrimonio."
          />

          <!-- Sistemas Detallados -->
          <div class="sistemas-content">
            {empresa.data.tipoSistema.map((sistema, index) => (
              <article class="sistema-detail" id={sistema}>
                <header class="sistema-detail__header">
                  <span class="sistema-detail__number">{String(index + 1).padStart(2, '0')}</span>
                  <h3 class="sistema-detail__title">{sistemaInfo[sistema]?.label || sistema}</h3>
                </header>

                <p class="sistema-detail__intro">{sistemaInfo[sistema]?.intro}</p>

                <div class="sistema-detail__specs">
                  <h4 class="sistema-detail__subtitle">Características del sistema instalado:</h4>
                  <ul class="sistema-detail__list">
                    {sistemaInfo[sistema]?.caracteristicas.map((car) => (
                      <li>{car}</li>
                    ))}
                  </ul>
                </div>

                <div class="sistema-detail__footer">
                  <div class="sistema-detail__normativa">
                    <strong>Normativa aplicable:</strong> {sistemaInfo[sistema]?.normativa}
                  </div>
                  <div class="sistema-detail__equipos">
                    <strong>Equipos utilizados:</strong> {sistemaInfo[sistema]?.equipos}
                  </div>
                </div>

                <a href={`/equipos?sistema=${sistema}`} class="sistema-detail__link">
                  Ver equipos relacionados en nuestro catálogo →
                </a>
              </article>
            ))}
          </div>

          <!-- Contenido del Markdown (si existe) -->
          {Content && (
            <div class="content-wrapper">
              <Content />
            </div>
          )}
        </div>

        <!-- Sidebar Mejorado -->
        <SidebarDirectorio empresa={empresa.data} />
      </div>
    </div>
  </section>

  <!-- Empresas Recomendadas (Sistema Inteligente) -->
  <EmpresasRecomendadas
    empresaActual={{
      slug: empresa.data.slug,
      giro: empresa.data.giro,
      ciudad: empresa.data.ciudad,
      estado: empresa.data.estado,
      tipoSistema: empresa.data.tipoSistema
    }}
    titulo={`Empresas con Protección Similar en ${empresa.data.estado}`}
    subtitulo="Otros establecimientos certificados con sistemas de protección contra incendios relacionados"
    limit={6}
  />

  <!-- Artículos Relevantes (Diversificados por contexto) -->
  <ArticulosRelevantes
    sistemas={empresa.data.tipoSistema}
    giro={empresa.data.giro}
    empresaSlug={empresa.data.slug}
    titulo="Recursos Técnicos para tu Sistema de Protección"
    subtitulo="Guías y normativas relevantes según los sistemas instalados en esta empresa"
    limit={3}
    columns={3}
    background="white"
  />

  <!-- CTA: Certifica tu empresa -->
  <CtaCatalogo
    titulo="¿Tu empresa necesita certificación de sistemas contra incendios?"
    subtitulo="Verificación profesional · Certificado digital · Inclusión en directorio"
    textoBoton="Solicitar certificación"
    enlace="#cotizar"
  />

  <!-- Formulario de contacto -->
  <CotizacionForm
    titulo="Solicita certificación para tu empresa"
    producto="Certificación Sistema Contra Incendios"
    pagina={`Empresa: ${empresa.data.nombre}`}
  />

</Layout>


