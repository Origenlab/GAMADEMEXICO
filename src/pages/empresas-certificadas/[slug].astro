    { q: '¿Los detectores de humo cubren todos los pisos?', a: empresa.data.tipoSistema.includes('deteccion-alarma') ? `Sí, el sistema de detección y alarma instalado en ${empresa.data.nombre} cubre todas las áreas con detectores fotoeléctricos, estaciones manuales y sirenas de notificación conforme a NFPA 72.` : `${empresa.data.nombre} cuenta con ${empresa.data.tipoSistema.length} sistemas certificados. Para detalles sobre detección en oficinas, contacta a Gama de México.` },
    { q: '¿Cómo contactar a Gama de México para certificar mi oficina?', a: 'Usa el formulario en esta página o llama al 55 6529 8240. Un ingeniero evaluará tu edificio y te entregará el proyecto con los sistemas necesarios para cumplir protección civil y obtener tu certificación.' },
  ],
  escuela: [
    { q: `¿Qué protección contra incendios tiene ${empresa.data.nombre}?`, a: `${empresa.data.nombre} cuenta con ${empresa.data.tipoSistema.length} sistemas certificados: ${empresa.data.tipoSistema.map(s => sistemaInfo[s]?.label || s).join(', ')}. Los sistemas están diseñados para instituciones educativas con alta ocupación.` },
    { q: '¿La escuela cumple con protección civil para el ciclo escolar?', a: `${empresa.data.nombre} tiene certificación emitida el ${empresa.data.fechaCertificacion} por ${empresa.data.certificadoPor}. Los sistemas verificados cumplen con NOM-002-STPS y los requisitos de protección civil para instituciones educativas.` },
    { q: '¿Gama de México capacita al personal de la escuela?', a: 'Sí. Gama de México ofrece capacitación en uso de extintores, evacuación y primeros auxilios para personal docente y administrativo. La capacitación se programa en horarios que no interrumpan las actividades escolares.' },
  ],
  comercio: [
    { q: `¿Qué sistemas contra incendios tiene ${empresa.data.nombre}?`, a: `${empresa.data.nombre} tiene ${empresa.data.tipoSistema.length} sistemas certificados: ${empresa.data.tipoSistema.map(s => sistemaInfo[s]?.label || s).join(', ')}. Todos verificados conforme a NFPA y NOM-002-STPS para establecimientos comerciales.` },
    { q: `¿${empresa.data.nombre} tiene certificación vigente?`, a: empresa.data.certificacionVigente ? `Sí. La certificación se encuentra vigente, emitida el ${empresa.data.fechaCertificacion} por ${empresa.data.certificadoPor}. Los equipos son certificados UL y FM.` : `La certificación fue emitida el ${empresa.data.fechaCertificacion}. Se recomienda contactar a Gama de México para verificar el estatus actual y programar reinspección.` },
    { q: '¿Cómo obtengo la certificación para mi tienda o local comercial?', a: 'Contacta a Gama de México al 55 6529 8240. Un ingeniero evaluará tu local, te indicará los sistemas que necesitas para cumplir con protección civil y te entregará una cotización. La instalación se puede hacer fuera de horario comercial.' },
  ],
  residencial: [
    { q: `¿Qué protección tiene ${empresa.data.nombre}?`, a: `${empresa.data.nombre} cuenta con ${empresa.data.tipoSistema.length} sistemas certificados: ${empresa.data.tipoSistema.map(s => sistemaInfo[s]?.label || s).join(', ')}. Los sistemas cumplen con normativas aplicables a uso residencial.` },
    { q: '¿Los condominios requieren sistema contra incendios?', a: 'Sí. Los desarrollos residenciales con más de 3 niveles o estacionamiento subterráneo requieren sistemas de detección, gabinetes contra incendio y señalización conforme a NOM-002-STPS y el reglamento de construcción local.' },
    { q: '¿Cómo certifico mi condominio o desarrollo residencial?', a: 'Gama de México evalúa la instalación existente, identifica qué falta o está fuera de norma, y entrega un proyecto para cumplir los requerimientos. Llama al 55 6529 8240 o usa el formulario en esta página.' },
  ],
  otro: [
    { q: `¿Qué sistemas tiene ${empresa.data.nombre}?`, a: `${empresa.data.nombre} cuenta con ${empresa.data.tipoSistema.length} sistemas certificados: ${empresa.data.tipoSistema.map(s => sistemaInfo[s]?.label || s).join(', ')}. Todos verificados por ${empresa.data.certificadoPor}.` },
    { q: `¿La certificación de ${empresa.data.nombre} está vigente?`, a: empresa.data.certificacionVigente ? `Sí. Certificación vigente emitida el ${empresa.data.fechaCertificacion} por ${empresa.data.certificadoPor}.` : `La certificación fue emitida el ${empresa.data.fechaCertificacion}. Contacta a Gama de México para verificar el estatus actual.` },
    { q: '¿Cómo solicito la certificación de mi empresa?', a: 'Contacta a Gama de México al 55 6529 8240 o envía el formulario en esta página. Un ingeniero visitará tu instalación y te entregará un diagnóstico con los sistemas necesarios.' },
  ],
};

const faqItems = faqsByGiro[empresa.data.giro] || faqsByGiro['otro'];


// Imagen por giro para el directorio
const giroImagenes: Record<string, string> = {
  hotel: '/img/directorio/directorio-hotel-sistema-contra-incendios.avif',
  restaurante: '/img/directorio/directorio-restaurante-sistema-contra-incendios.avif',
  industria: '/img/directorio/directorio-industria-sistema-contra-incendios.avif',
  almacen: '/img/directorio/directorio-almacen-sistema-contra-incendios.avif',
  hospital: '/img/directorio/directorio-hospital-sistema-contra-incendios.avif',
  escuela: '/img/directorio/directorio-escuela-sistema-contra-incendios.avif',
  comercio: '/img/directorio/directorio-comercio-sistema-contra-incendios.avif',
  oficina: '/img/directorio/directorio-oficina-sistema-contra-incendios.avif',
  residencial: '/img/directorio/directorio-oficina-sistema-contra-incendios.avif',
  otro: '/img/directorio/directorio-certificacion-gama-mexico.avif',
};
const empresaImagen = empresa.data.imagen && empresa.data.imagen !== '/img/gama-de-mexico.avif' 
  ? empresa.data.imagen 
  : (giroImagenes[empresa.data.giro] || '/img/directorio/directorio-certificacion-gama-mexico.avif');

// Schema.org LocalBusiness
const businessSchema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": empresa.data.nombre,
  "description": empresa.data.descripcion || `${empresa.data.nombre} cuenta con sistema de protección contra incendios certificado por Gama de México.`,
  "address": {
    "@type": "PostalAddress",
    "streetAddress": empresa.data.direccion,
    "addressLocality": empresa.data.ciudad,
    "addressRegion": empresa.data.estado,
    "postalCode": empresa.data.codigoPostal,
    "addressCountry": "MX"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": empresa.data.latitud,
    "longitude": empresa.data.longitud
  },
  ...(empresa.data.telefono && { "telephone": empresa.data.telefono }),
  ...(empresa.data.email && { "email": empresa.data.email }),
  "url": empresa.data.website || `https://gamademexico.com/empresas-certificadas/${empresa.data.slug}`,
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": String(ratingValue),
    "bestRating": "5",
    "worstRating": "1",
    "ratingCount": String(ratingCount)
  },
  "review": selectedReviews
};

// FAQPage Schema
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqItems.map(item => ({
    "@type": "Question",
    "name": item.q,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": item.a
    }
  }))
};

// Breadcrumb Schema
const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Inicio", "item": "https://gamademexico.com" },
    { "@type": "ListItem", "position": 2, "name": "Empresas Certificadas", "item": "https://gamademexico.com/empresas-certificadas" },
    { "@type": "ListItem", "position": 3, "name": empresa.data.nombre }
  ]
};

// Formatear fecha
const formatDate = (dateStr: string) => {
  return new Date(dateStr).toLocaleDateString('es-MX', { day: 'numeric', month: 'long', year: 'numeric' });
};

// Title optimizado a ≤60 chars
const titleFull = `${empresa.data.nombre} | Contra Incendios ${empresa.data.ciudad}`;
const titleShort = `${empresa.data.nombre} | Contra Incendios`;
const pageTitle = titleFull.length <= 60 ? titleFull : (titleShort.length <= 60 ? titleShort : `${empresa.data.nombre.slice(0, 35)}... | Contra Incendios`);
---

<Layout
  title={pageTitle}
  description={empresa.data.descripcion || `${empresa.data.nombre} cuenta con sistema de protección contra incendios certificado por Gama de México en ${empresa.data.ciudad}, ${empresa.data.estado}. Verificación de ${empresa.data.tipoSistema.length} sistemas activos.`}
  activePage="directorio"
  heroTitle={empresa.data.nombre}
  heroIntro={`Sistema de protección contra incendios certificado en ${empresa.data.ciudad}, ${empresa.data.estado}. ${empresa.data.tipoSistema.length} sistemas verificados por Gama de México.`}
  heroBadge={empresa.data.certificacionVigente ? 'Certificación Vigente' : 'Certificación Vencida'}
  heroMetrics={[
    { valor: String(empresa.data.tipoSistema.length), texto: 'Sistemas certificados' },
    { valor: formatDate(empresa.data.fechaCertificacion).split(' ')[2], texto: 'Año certificación' },
    { valor: giroLabels[empresa.data.giro], texto: 'Tipo de negocio' }
  ]}
  heroPrimaryText="Ver ubicación en mapa"
  heroPrimaryLink={`https://www.google.com/maps/search/?api=1&query=${empresa.data.latitud},${empresa.data.longitud}`}
  heroSecondaryText="Solicitar certificación"
  heroSecondaryLink="#cotizar"
  heroShowRightContent={true}
  structuredData={[businessSchema, breadcrumbSchema, faqSchema]}
>

  <!-- HERO CONTENT -->
  <Fragment slot="hero-content">
    <p><strong>{empresa.data.nombre}</strong> cuenta con un sistema integral de protección contra incendios verificado por Gama de México. La instalación incluye {empresa.data.tipoSistema.map(s => sistemaInfo[s]?.label || s).join(', ')}, todos certificados conforme a normativas NFPA, NOM-002-STPS y requerimientos de protección civil.</p>
    {empresa.data.descripcion && <p>{empresa.data.descripcion}</p>}
    <div class="empresa-ubicacion">
      <strong>{empresa.data.direccion}</strong><br/>
      {empresa.data.colonia}, {empresa.data.ciudad}, {empresa.data.estado} C.P. {empresa.data.codigoPostal}
    </div>
    {empresa.data.telefono && (
      <div class="empresa-contacto">
        <a href={`tel:${empresa.data.telefono}`}>{empresa.data.telefono}</a>
      </div>
    )}
    {empresa.data.website && (
      <div class="empresa-contacto">
        <a href={empresa.data.website} target="_blank" rel="noopener noreferrer">Sitio web</a>
      </div>
    )}
  </Fragment>

  <!-- Imagen de la empresa -->
  <section class="empresa-imagen-section">
    <div class="container">
      <img
        src={empresaImagen}
        alt={`Sistema de protección contra incendios certificado en ${empresa.data.nombre}, ${empresa.data.ciudad}`}
        class="empresa-imagen-hero"
        width="1200"
        height="675"
        loading="eager"
        decoding="async"
      />
    </div>
  </section>

  <!-- Contenido Principal con Sidebar -->
  <section class="main-content">
    <div class="container">
      <div class="main-content__grid">

        <!-- Columna Principal -->
        <div class="main-content__primary">
          <SectionHeader
            titulo={`Sistemas de Protección Contra Incendios Certificados en ${empresa.data.nombre}`}
            subtitulo={`${empresa.data.tipoSistema.length} sistemas verificados por Gama de México con equipos certificados UL y FM`}
            idTitulo="sistemas-certificados"
            parrafo1={`${empresa.data.nombre} ha implementado un sistema integral de protección contra incendios que incluye ${empresa.data.tipoSistema.map(s => sistemaInfo[s]?.label || s).join(', ')}. Cada componente ha sido verificado por ingenieros especializados de Gama de México, confirmando su correcto funcionamiento y cumplimiento con normativas NFPA, NOM-002-STPS y requerimientos de protección civil.`}
            parrafo2="Los sistemas instalados utilizan equipos certificados UL y FM de marcas reconocidas como Elkhart Brass, garantizando la máxima confiabilidad en caso de emergencia. La verificación periódica asegura que todos los componentes se encuentren operativos y listos para proteger vidas y patrimonio."
          />

          <!-- Sistemas Detallados -->
          <div class="sistemas-content">
            {empresa.data.tipoSistema.map((sistema, index) => (
              <article class="sistema-detail" id={sistema}>
                <header class="sistema-detail__header">
                  <span class="sistema-detail__number">{String(index + 1).padStart(2, '0')}</span>
                  <h3 class="sistema-detail__title">{sistemaInfo[sistema]?.label || sistema}</h3>
                </header>

                <p class="sistema-detail__intro">{sistemaInfo[sistema]?.intro}</p>

                <div class="sistema-detail__specs">
                  <h4 class="sistema-detail__subtitle">Características del sistema instalado:</h4>
                  <ul class="sistema-detail__list">
                    {sistemaInfo[sistema]?.caracteristicas.map((car) => (
                      <li>{car}</li>
                    ))}
                  </ul>
                </div>

                <div class="sistema-detail__footer">
                  <div class="sistema-detail__normativa">
                    <strong>Normativa aplicable:</strong> {sistemaInfo[sistema]?.normativa}
                  </div>
                  <div class="sistema-detail__equipos">
                    <strong>Equipos utilizados:</strong> {sistemaInfo[sistema]?.equipos}
                  </div>
                </div>

                <a href={`/equipos?sistema=${sistema}`} class="sistema-detail__link">
                  Ver equipos relacionados en nuestro catálogo →
                </a>
              </article>
            ))}
          </div>

          <!-- Contenido del Markdown (si existe) -->
          {Content && (
            <div class="content-wrapper">
              <Content />
            </div>
          )}
        </div>

        <!-- Sidebar Mejorado -->
        <SidebarDirectorio empresa={empresa.data} />
      </div>
    </div>
  </section>

  <!-- Empresas Recomendadas (Sistema Inteligente) -->
  <EmpresasRecomendadas
    empresaActual={{
      slug: empresa.data.slug,
      giro: empresa.data.giro,
      ciudad: empresa.data.ciudad,
      estado: empresa.data.estado,
      tipoSistema: empresa.data.tipoSistema
    }}
    titulo={`Empresas con Protección Similar en ${empresa.data.estado}`}
    subtitulo="Otros establecimientos certificados con sistemas de protección contra incendios relacionados"
    limit={6}
  />

  <!-- Artículos Relevantes (Diversificados por contexto) -->
  <ArticulosRelevantes
    sistemas={empresa.data.tipoSistema}
    giro={empresa.data.giro}
    empresaSlug={empresa.data.slug}
    titulo="Recursos Técnicos para tu Sistema de Protección"
    subtitulo="Guías y normativas relevantes según los sistemas instalados en esta empresa"
    limit={3}
    columns={3}
    background="white"
  />

  <!-- CTA: Certifica tu empresa -->
  <CtaCatalogo
    titulo="¿Tu empresa necesita certificación de sistemas contra incendios?"
    subtitulo="Verificación profesional · Certificado digital · Inclusión en directorio"
    textoBoton="Solicitar certificación"
    enlace="#cotizar"
  />

  <!-- Formulario de contacto -->
  <CotizacionForm
    titulo="Solicita certificación para tu empresa"
    producto="Certificación Sistema Contra Incendios"
    pagina={`Empresa: ${empresa.data.nombre}`}
  />

</Layout>


