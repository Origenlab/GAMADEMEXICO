---
import Layout from '../layouts/Base.astro';
import { getCollection } from 'astro:content';
import Faq from '../components/Faq.astro';
import { getBackgroundImageUrl } from '../lib/images';
import {
  buildProductCategorySchema,
  buildFAQSchema,
  buildBreadcrumbSchema,
  buildOrganizationSchema,
} from '../lib/seo';

const productos = (await getCollection('productos', ({ data }) => data.categoria === 'mangueras')).sort((a, b) => a.data.orden - b.data.orden);
const cardImage = (path?: string) =>
  path
    ? getBackgroundImageUrl(path, {
        width: 960,
        quality: 78,
        strip: 'all',
      })
    : undefined;
const detailImage = (path: string) =>
  getBackgroundImageUrl(path, {
    width: 1280,
    quality: 80,
    strip: 'all',
  });
const faqItems = [
  {
    "pregunta": "¿Qué tipos de manguera contra incendio para gabinete e industrial venden?",
    "respuesta": "Ofrecemos cuatro tipos especializados de manguera contra incendio para gabinete, bombero e industrial: 1) Manguera Millhose ideal para gabinetes con presión de trabajo de 250-300 PSI y conexiones para hidrante; 2) Manguera Blindex multicapa para aplicaciones industriales de alto riesgo; 3) Manguera de succión para bombero con refuerzo helicoidal; y 4) Manguera forestal ultraligera para brigadas. Todas incluyen accesorios y conexiones compatibles con sistemas de gabinete e hidrante estándar. Disponibles en diámetros de 1.5\" y 2.5\" con presión 250 PSI, en rollos de 15 o 30 metros."
  },
  {
    "pregunta": "¿Las mangueras cuentan con certificación NFPA 1961?",
    "respuesta": "Sí. Nuestras mangueras Millhose y Blindex cuentan con certificación NFPA 1961, el estándar internacional para mangueras de sistemas contra incendios. Este estándar especifica requisitos de presión de prueba hidrostática (mínimo 600 PSI), resistencia a la abrasión, compatibilidad con acoplamientos y desempeño bajo condiciones operativas extremas. Proporcionamos documentación técnica del fabricante que incluye certificados de conformidad, fichas técnicas con especificaciones completas y declaratorias de cumplimiento normativo para respaldar verificaciones de protección civil, auditorías de aseguradoras y procesos de licitación. Las mangueras de succión y forestales cumplen con especificaciones técnicas del fabricante y normativas aplicables a sus respectivas aplicaciones."
  },
  {
    "pregunta": "¿Cuál es la diferencia entre manguera Millhose y manguera Blindex?",
    "respuesta": "La manguera Millhose es de construcción estándar con doble forro sintético y recubrimientos de EPDM o NBR, diseñada para uso general en gabinetes tipo 30ME, edificios comerciales y aplicaciones industriales convencionales. La manguera Blindex es de construcción reforzada con cuatro capas de refuerzo textil y recubrimientos especiales de Hypalon (exterior) y NBR (interior), diseñada específicamente para aplicaciones de alto riesgo. La diferencia principal radica en la resistencia térmica —Blindex soporta exposición a flamas hasta 600°C versus temperaturas convencionales de Millhose— y en la resistencia química: Blindex es compatible con hidrocarburos, ácidos y agentes químicos industriales, mientras que Millhose está diseñada para uso con agua y espuma estándar. Ambas operan a 300 PSI de presión de trabajo y cumplen NFPA 1961, pero Blindex ofrece mayor factor de seguridad y durabilidad en ambientes hostiles."
  },
  {
    "pregunta": "¿Qué diámetro de manguera contra incendio necesito para gabinete e hidrante?",
    "respuesta": "El diámetro de la manguera contra incendio depende del caudal y presión de tu sistema de gabinete o hidrante. Los gabinetes tipo 30ME bombero en edificios comerciales utilizan manguera de 1.5 pulgadas con presión 250 PSI y conexiones estándar. Para aplicaciones industriales o hidrantes donde se requiere mayor caudal, se utiliza manguera de 2.5 pulgadas con accesorios y conexiones compatibles. Las mangueras de succión para bombero están disponibles en diámetros desde 2\" hasta 6\". Nuestros asesores te ayudan a determinar el diámetro correcto para gabinete industrial, incluyendo conexiones y accesorios según normativa NOM-002-STPS, NFPA 14."
  },
  {
    "pregunta": "¿En qué longitudes están disponibles las mangueras contra incendios?",
    "respuesta": "Las mangueras Millhose y Blindex están disponibles en rollos de 15 metros o 30 metros según tu preferencia. Los gabinetes tipo 30ME típicamente se equipan con rollos de 30 metros para garantizar radio de cobertura adecuado. Para aplicaciones industriales con múltiples puntos de conexión o proyectos que requieren longitudes específicas, podemos coordinar cortes personalizados. Las mangueras de succión se suministran en tramos de 3 a 6 metros con acoplamientos instalados en fábrica, permitiendo ensamblaje modular según la profundidad de succión requerida. Las mangueras forestales están disponibles en rollos de 15 o 30 metros optimizados para portabilidad. Todas las mangueras se entregan con los extremos preparados para instalación de acoplamientos tipo rosca NST o storz según especifiques. Si tu proyecto requiere longitudes no estándar o configuraciones especiales, consúltanos para evaluar disponibilidad."
  },
  {
    "pregunta": "¿Cuánto tiempo de vida útil tienen las mangueras contra incendios?",
    "respuesta": "La vida útil de una manguera contra incendios depende de las condiciones de almacenamiento, frecuencia de uso y exposición ambiental. En condiciones normales —manguera almacenada en gabinete protegido de luz solar directa, sin exposición continua a químicos, con enrollado adecuado y pruebas hidrostáticas anuales— una manguera Millhose o Blindex puede durar entre 10 y 15 años. La norma NFPA 1962 establece que las mangueras deben ser probadas hidrostáticamente cada año y retiradas de servicio cuando muestren señales de deterioro como cortes, abrasión excesiva, dureza del recubrimiento, fugas en prueba o pérdida de flexibilidad. Las mangueras forestales, por su construcción ligera y uso intensivo en campo, típicamente tienen vida útil más corta (5-7 años). Las de succión, por su construcción robusta con refuerzo metálico y uso intermitente, pueden durar 15 años o más con mantenimiento adecuado. Recomendamos inspección visual trimestral y prueba hidrostática anual conforme NFPA 1962."
  },
  {
    "pregunta": "¿Cómo solicito cotización de manguera contra incendio con conexiones y accesorios?",
    "respuesta": "Puedes solicitar cotización de manguera contra incendio para gabinete, bombero o industrial de tres formas: 1) Formulario en esta página, 2) WhatsApp 55 6529 8240, o 3) Correo ventas@gamademexico.com. Necesitamos saber: tipo de manguera para gabinete o hidrante (Millhose, Blindex, succión o forestal), diámetro, cantidad de metros, y si requieres conexiones y accesorios adicionales. Respondemos en menos de 24 horas con precios de mangueras 250 PSI, conexiones para hidrante, accesorios y disponibilidad. Si no estás seguro del tipo de manguera industrial que necesitas, solicita asesoría para gabinete bombero según normativa aplicable a tu proyecto."
  }
];

const structuredData = [
  buildOrganizationSchema(),
  buildProductCategorySchema({
    name: 'Mangueras Contra Incendios Certificadas NFPA 1961',
    description: 'Mangueras contra incendio para gabinete, bombero e industrial. Certificadas 250-300 PSI. Millhose, Blindex, succión y forestal en México.',
    image: '/img/mangueras-contra-incendios/manguera-forestal-contra-incendios-vista-lateral-06.avif',
    url: '/mangueras-contra-incendios',
    category: 'Mangueras Contra Incendios',
    brand: 'Gama de México',
    reviewAuthor: 'Ing. Carlos Ramírez',
    reviewBody: 'Mangueras Blindex de excelente calidad para nuestra planta industrial. Resistencia térmica superior y documentación NFPA 1961 completa. Gama de México siempre cumple en tiempos de entrega.',
    reviewDate: '2025-04-18',
    ratingCount: 39,
    reviewCount: 39,
  }),
  buildBreadcrumbSchema([
    { name: 'Inicio', url: '/' },
    { name: 'Equipos', url: '/equipos' },
    { name: 'Mangueras Contra Incendios', url: '/mangueras-contra-incendios' },
  ]),
  buildFAQSchema(faqItems),
];
---

<Layout
  title="Mangueras Contra Incendio Certificadas NFPA | Gama de México"
  description="Mangueras contra incendio Millhose, Blindex y succión. 250-300 PSI, certificación NFPA 1961. Stock en México. Cotiza con asesoría técnica gratuita."
  activePage="equipos"
  structuredData={structuredData}
  heroTitle="Mangueras Contra Incendios"
  heroBadge="Equipos Contra Incendios"
  heroShowRightContent={true}
>
  <Fragment slot="hero-content">
    <p>Ofrecemos mangueras contra incendios certificadas NFPA 1961 para aplicaciones en gabinetes, brigadas de bomberos e industria. Nuestro catalogo incluye mangueras Millhose de doble forro sintetico, Blindex multicapa resistente a altas temperaturas, mangueras de succion con refuerzo helicoidal y modelos forestales ultraligeros para zonas de dificil acceso.</p>
    <p>Todas nuestras mangueras soportan presiones de trabajo de 250 a 300 PSI y estan disponibles en diametros de 1.5 y 2.5 pulgadas. Te apoyamos en la seleccion del tipo correcto segun condiciones ambientales, presion del sistema y normativa aplicable a tu proyecto.</p>
  </Fragment>

  <!-- BREADCRUMB -->
  <nav class="breadcrumb" aria-label="Navegación de migas de pan">
    <div class="container">
      <ol class="breadcrumb__list">
        <li class="breadcrumb__item"><a href="/" class="breadcrumb__link">Inicio</a></li>
        <li class="breadcrumb__item"><a href="/equipos" class="breadcrumb__link">Equipos</a></li>
        <li class="breadcrumb__item breadcrumb__item--active" aria-current="page">Mangueras Contra Incendios</li>
      </ol>
    </div>
  </nav><!-- PRODUCTOS DINAMICOS -->
  <section class="categories" id="mangueras" aria-labelledby="products-title">
    <div class="container">
      <div class="section-header">
        <h2 id="products-title" class="section-title">Tipos de Mangueras Contra Incendios</h2>
        <p class="section-subtitle">Selecciona un tipo de manguera para conocer especificaciones técnicas y cotizar precios y disponibilidad</p>
      </div>
      <div class="categories__grid">
        {productos.map((producto) => (
          <article class="category-card">
            <div
              class="category-card__image"
              role="img"
              aria-label={producto.data.title}
              style={producto.data.imagen ? `background-image: url('${cardImage(producto.data.imagen)}'); background-size: cover; background-position: center;` : undefined}
            ></div>
            <div class="category-card__body">
              <h3 class="category-card__title">{producto.data.title}</h3>
              <p class="category-card__sub">{producto.data.description}</p>
              <ul class="category-card__products">
                {producto.data.material && <li>{producto.data.material}</li>}
                {producto.data.flujo && <li>{producto.data.flujo}</li>}
                {producto.data.certificaciones && producto.data.certificaciones.length > 0 && <li>Certificaciones: {producto.data.certificaciones.join(', ')}</li>}
                <li>Marca: {producto.data.marca}</li>
              </ul>
              <div class="category-card__ctas">
                <a href={`/productos/${producto.id}`} class="btn btn--primary btn--sm">Ver especificaciones</a>
                <a href="#cotizar" class="btn btn--outline btn--sm">Cotizar este producto</a>
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- PRODUCT DETAILS -->
  <section class="service-details" aria-labelledby="service-details-title">
    <div class="container">
      <div class="section-header">
        <h2 id="service-details-title" class="section-title">Detalle de Cada Tipo de Manguera Contra Incendios</h2>
      </div>

      <div class="service-detail" id="detalle-millhose">
        <div class="service-detail__content">
          <h3 class="service-detail__title">Manguera Millhose Doble Forro Sintético</h3>
          <p class="service-detail__text">La manguera Millhose es la opción estándar para sistemas contra incendios en edificios comerciales, naves industriales y gabinetes tipo 30ME. Fabricada con <strong>doble forro de poliéster de alta tenacidad</strong> y recubierta con compuestos de EPDM o NBR, ofrece excelente resistencia a la abrasión, flexibilidad en temperaturas extremas y compatibilidad con agua y espuma.</p>
          <ul class="service-detail__list">
            <li class="service-detail__list-item">Doble forro sintético de poliéster de alta resistencia</li>
            <li class="service-detail__list-item">Recubrimiento interior y exterior de EPDM o NBR</li>
            <li class="service-detail__list-item">Presión de trabajo de 300 PSI (20.7 bar)</li>
            <li class="service-detail__list-item">Diámetros disponibles: 1.5" (38 mm) y 2.5" (64 mm)</li>
            <li class="service-detail__list-item">Certificación NFPA 1961 para sistemas contra incendios</li>
            <li class="service-detail__list-item">Rollos de 15 o 30 metros según requerimiento</li>
          </ul>
          <div class="service-detail__ctas">
            <a href="/mangueras/millhose" class="btn btn--outline">Ver catálogo completo</a>
            <a href="#cotizar" class="btn btn--primary">Cotizar manguera Millhose</a>
          </div>
        </div>
        <div class="service-detail__image" role="img" aria-label="Manguera Millhose doble forro sintético" style={`background-image: url('${detailImage('/img/mangueras-contra-incendios/manguera-millhose-1-5-30m-frontal.avif')}'); background-size: cover; background-position: center;`}></div>
      </div>

      <div class="service-detail" id="detalle-blindex">
        <div class="service-detail__content">
          <h3 class="service-detail__title">Manguera Blindex Multicapa 4 Capas</h3>
          <p class="service-detail__text">La manguera Blindex representa el nivel superior de resistencia para aplicaciones industriales de alto riesgo. Construida con <strong>cuatro capas de refuerzo textil</strong> y recubrimientos de Hypalon y NBR, soporta exposición a flamas hasta 600°C, resistencia química, abrasión extrema y presiones de trabajo de 300 PSI con factores de seguridad elevados.</p>
          <ul class="service-detail__list">
            <li class="service-detail__list-item">Construcción multicapa con 4 capas de refuerzo textil</li>
            <li class="service-detail__list-item">Recubrimiento exterior Hypalon resistente a flamas hasta 600°C</li>
            <li class="service-detail__list-item">Recubrimiento interior NBR resistente a químicos y abrasión</li>
            <li class="service-detail__list-item">Presión de trabajo de 300 PSI con alto factor de seguridad</li>
            <li class="service-detail__list-item">Resistencia a hidrocarburos, ácidos y agentes químicos</li>
            <li class="service-detail__list-item">Ideal para plantas petroquímicas y zonas de riesgo extremo</li>
          </ul>
          <div class="service-detail__ctas">
            <a href="/mangueras/blindex" class="btn btn--outline">Ver catálogo completo</a>
            <a href="#cotizar" class="btn btn--primary">Cotizar manguera Blindex</a>
          </div>
        </div>
        <div class="service-detail__image" role="img" aria-label="Manguera Blindex multicapa resistente a altas temperaturas" style={`background-image: url('${detailImage('/img/mangueras-contra-incendios/manguera-blindex-2-5-15m-frontal.avif')}'); background-size: cover; background-position: center;`}></div>
      </div>

      <div class="service-detail" id="detalle-succion">
        <div class="service-detail__content">
          <h3 class="service-detail__title">Manguera de Succión con Refuerzo Helicoidal</h3>
          <p class="service-detail__text">Las mangueras de succión están diseñadas específicamente para operación en vacío, permitiendo la extracción de agua desde fuentes naturales, cisternas, pozos o cuerpos de agua sin colapso por presión negativa. El <strong>refuerzo helicoidal de acero galvanizado</strong> mantiene la estructura circular bajo condiciones de succión continua.</p>
          <ul class="service-detail__list">
            <li class="service-detail__list-item">Refuerzo helicoidal de alambre de acero galvanizado</li>
            <li class="service-detail__list-item">Construcción rígida que mantiene forma bajo vacío</li>
            <li class="service-detail__list-item">Capacidad de operación en vacío hasta -0.8 bar</li>
            <li class="service-detail__list-item">Diámetros desde 2" hasta 6" según aplicación</li>
            <li class="service-detail__list-item">Uso en bombas portátiles, pipas y equipos de emergencia</li>
            <li class="service-detail__list-item">Acoplamiento tipo storz o rosca NST según preferencia</li>
          </ul>
          <div class="service-detail__ctas">
            <a href="/mangueras/succion" class="btn btn--outline">Ver catálogo completo</a>
            <a href="#cotizar" class="btn btn--primary">Cotizar manguera de succión</a>
          </div>
        </div>
        <div class="service-detail__image" role="img" aria-label="Manguera de succión con refuerzo helicoidal para bombas" style={`background-image: url('${detailImage('/img/mangueras-contra-incendios/manguera-succion-6-3m-frontal.avif')}'); background-size: cover; background-position: center;`}></div>
      </div>

      <div class="service-detail" id="detalle-forestal">
        <div class="service-detail__content">
          <h3 class="service-detail__title">Manguera Forestal Ultraligera de Un Forro</h3>
          <p class="service-detail__text">Las mangueras forestales están optimizadas para <strong>portabilidad extrema</strong> en operaciones de combate de incendios en zonas de difícil acceso. Con construcción de un solo forro sintético y recubrimiento ligero, pesan hasta <strong>40% menos</strong> que mangueras convencionales, facilitando el despliegue rápido en campo por brigadas forestales y unidades de respuesta rápida.</p>
          <ul class="service-detail__list">
            <li class="service-detail__list-item">Construcción ultraligera de un solo forro sintético</li>
            <li class="service-detail__list-item">40% más ligera que mangueras convencionales</li>
            <li class="service-detail__list-item">Presión de trabajo entre 200 y 250 PSI</li>
            <li class="service-detail__list-item">Alta flexibilidad y capacidad de enrollado compacto</li>
            <li class="service-detail__list-item">Recomendada por CONAFOR para combate de incendios forestales</li>
            <li class="service-detail__list-item">Diámetros 1.5" para operación manual en terrenos irregulares</li>
          </ul>
          <div class="service-detail__ctas">
            <a href="/mangueras/forestal" class="btn btn--outline">Ver catálogo completo</a>
            <a href="#cotizar" class="btn btn--primary">Cotizar manguera forestal</a>
          </div>
        </div>
        <div class="service-detail__image" role="img" aria-label="Manguera forestal ultraligera para brigadas de emergencia" style={`background-image: url('${detailImage('/img/mangueras-contra-incendios/manguera-forestal-contra-incendios-vista-lateral-06.avif')}'); background-size: cover; background-position: center;`}></div>
      </div>

    </div>
  </section>

  <!-- TRUST -->
  <section class="trust" aria-labelledby="trust-title">
    <div class="container">
      <div class="section-header">
        <h2 id="trust-title" class="section-title">Por Qué Comprar Mangueras Contra Incendios en Gama de México</h2>
        <p class="section-subtitle">Calidad certificada, inventario disponible y asesoría técnica especializada</p>
      </div>
      <div class="trust__grid">
        <div class="trust__item">
          <h3 class="trust__item-title">Certificación NFPA 1961</h3>
          <p class="trust__item-desc">Todas nuestras mangueras industriales cumplen con el estándar NFPA 1961 para mangueras contra incendios, garantizando rendimiento y durabilidad comprobados.</p>
        </div>
        <div class="trust__item">
          <h3 class="trust__item-title">4 tipos especializados de mangueras</h3>
          <p class="trust__item-desc">Catálogo completo desde mangueras Millhose estándar hasta Blindex de alto riesgo, succión y forestales para cada aplicación específica.</p>
        </div>
        <div class="trust__item">
          <h3 class="trust__item-title">Inventario permanente</h3>
          <p class="trust__item-desc">Stock disponible de diámetros 1.5" y 2.5" en rollos de 15 y 30 metros para entregas inmediatas sin tiempos de espera.</p>
        </div>
        <div class="trust__item">
          <h3 class="trust__item-title">Resistencia térmica y química</h3>
          <p class="trust__item-desc">Mangueras Blindex con resistencia a flamas hasta 600°C y compatibilidad con hidrocarburos, ácidos y agentes químicos industriales.</p>
        </div>
        <div class="trust__item">
          <h3 class="trust__item-title">Asesoría técnica sin costo</h3>
          <p class="trust__item-desc">Te ayudamos a seleccionar el tipo de manguera correcto según presión de trabajo, condiciones ambientales y normativa aplicable a tu proyecto.</p>
        </div>
        <div class="trust__item">
          <h3 class="trust__item-title">Precios por volumen</h3>
          <p class="trust__item-desc">Cotizaciones corporativas con descuentos especiales para proyectos de gran escala, desarrollos inmobiliarios y compras recurrentes.</p>
        </div>
      </div>

      <div class="trust__testimonials-header">
        <h3 class="trust__testimonials-title">Lo que dicen nuestros clientes</h3>
        <p class="trust__testimonials-subtitle">Empresas de todo México confían en nuestras mangueras contra incendios</p>
      </div>
      <div class="trust__testimonials">
        <blockquote class="testimonial">
          <div class="testimonial__stars" aria-label="5 estrellas">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
          <p class="testimonial__text">"Compramos 400 metros de manguera Millhose 2.5" para equipar los gabinetes contra incendios de un desarrollo de naves industriales. La certificación NFPA 1961 pasó sin problemas la inspección de protección civil y la calidad de manufactura es evidente. Precio competitivo y entrega coordinada a tiempo."</p>
          <div class="testimonial__author">
            <div class="testimonial__avatar"></div>
            <div class="testimonial__info">
              <span class="testimonial__name">Ing. Roberto Salinas D.</span>
              <span class="testimonial__role">Director de Proyecto</span>
              <span class="testimonial__company">Constructora Industrial, Querétaro</span>
            </div>
          </div>
        </blockquote>
        <blockquote class="testimonial">
          <div class="testimonial__stars" aria-label="5 estrellas">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
          <p class="testimonial__text">"Necesitábamos mangueras Blindex para la zona de tanques de almacenamiento de nuestra planta petroquímica. La resistencia a 600°C y la compatibilidad química son exactamente lo que requieren nuestros protocolos de seguridad. Gama de México nos entregó documentación completa del fabricante y certificados de calidad."</p>
          <div class="testimonial__author">
            <div class="testimonial__avatar"></div>
            <div class="testimonial__info">
              <span class="testimonial__name">Ing. Patricia Rojas S.</span>
              <span class="testimonial__role">Gerente de Seguridad Industrial</span>
              <span class="testimonial__company">Planta Petroquímica, Veracruz</span>
            </div>
          </div>
        </blockquote>
        <blockquote class="testimonial">
          <div class="testimonial__stars" aria-label="5 estrellas">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
          <p class="testimonial__text">"Equipamos a la brigada forestal del municipio con mangueras forestales ultraligeras. La reducción de peso es real y facilita enormemente el despliegue en terrenos irregulares. Cumplen con las especificaciones de CONAFOR y llegaron con factura y certificación. Proveedor confiable para equipo crítico."</p>
          <div class="testimonial__author">
            <div class="testimonial__avatar"></div>
            <div class="testimonial__info">
              <span class="testimonial__name">Téc. Miguel Ángel Ortiz</span>
              <span class="testimonial__role">Coordinador de Brigada Forestal</span>
              <span class="testimonial__company">Gobierno Municipal, Chiapas</span>
            </div>
          </div>
        </blockquote>
        <blockquote class="testimonial">
