---
import Layout from '../layouts/Base.astro';
import { getCollection } from 'astro:content';
import Faq from '../components/Faq.astro';
import { getBackgroundImageUrl } from '../lib/images';
import {
  buildProductCategorySchema,
  buildFAQSchema,
  buildBreadcrumbSchema,
  buildOrganizationSchema,
} from '../lib/seo';

const productos = (await getCollection('productos', ({ data }) => data.categoria === 'conexiones-herrajes')).sort((a, b) => a.data.orden - b.data.orden);
const cardImage = (path?: string) =>
  path
    ? getBackgroundImageUrl(path, {
        width: 960,
        quality: 78,
        strip: 'all',
      })
    : undefined;
const detailImage = (path: string) =>
  getBackgroundImageUrl(path, {
    width: 1280,
    quality: 80,
    strip: 'all',
  });
const faqItems = [
  {
    "pregunta": "¿Cuál es la diferencia entre rosca NH y NPT?",
    "respuesta": "NH (National Hose) es rosca recta diseñada para mangueras contra incendios, usa empaque de goma y permite conexión rápida sin sellador. NPT (National Pipe Tapered) es rosca cónica para tuberías industriales que sella por interferencia metal-metal. Son incompatibles entre sí: los adaptadores de conversión NH a NPT son necesarios para conectar equipos con diferentes estándares. Venta con precio competitivo y cotización inmediata."
  },
  {
    "pregunta": "¿Qué ventajas ofrecen los coples Storz sobre conexiones roscadas?",
    "respuesta": "Los coples Storz ofrecen beneficios significativos: acoplamiento de cuarto de vuelta que reduce tiempo de despliegue en 50%, operación con guantes de bombero, y pestillos de seguridad que evitan desconexión accidental bajo presión. Son estándar en aeropuertos, industrias petroquímicas y cuerpos de bomberos modernos. Requieren adaptadores Storz-NH para conectar con hidrantes existentes."
  },
  {
    "pregunta": "¿Qué es una toma siamesa FDC y es obligatoria?",
    "respuesta": "La toma siamesa FDC (Fire Department Connection) es conexión exterior que permite a bomberos alimentar el sistema desde autobombas. Es obligatoria según NFPA 14 en edificios con tubería vertical y según NFPA 13 en sistemas de rociadores. Configuración estándar: dos entradas 2.5\" NH con válvulas check certificadas UL/FM."
  },
  {
    "pregunta": "¿Qué presión de trabajo soportan las conexiones de bronce?",
    "respuesta": "La presión varía según tipo: Adaptadores 250-300 PSI, Conexiones Y 200 PSI continua, Tomas siamesas 175 PSI en válvulas check, Coples Storz 250-300 PSI según material. Nuestros asesores te ayudan a seleccionar la especificación correcta según el diseño de tu proyecto con cotización detallada y precio transparente."
  },
  {
    "pregunta": "¿Las conexiones vienen con certificaciones UL y FM?",
    "respuesta": "Sí. Todas nuestras conexiones cuentan con certificaciones UL Listed y FM Approved. Con cada venta entregamos documentación completa: ficha técnica, certificados UL/FM y manual de instalación. Esta documentación es fundamental para verificaciones de protección civil, auditorías de aseguradoras y procesos de licitación. Proveedor profesional con experiencia."
  },
  {
    "pregunta": "¿Qué diámetros de conexiones tienen disponibles?",
    "respuesta": "Manejamos rango completo de diámetros: 1\", 1.5\", 2\", 2.5\", 3\", 4\" y 5\" según tipo de conexión. Los adaptadores están disponibles en todas las combinaciones NH/NPT/Storz. Mantenemos stock permanente de diámetros más solicitados (1.5\", 2.5\", 3\") para entregas inmediatas cerca de tu ubicación con costo competitivo."
  },
  {
    "pregunta": "¿Cómo puedo solicitar una cotización de conexiones?",
    "respuesta": "Puedes cotizar de tres formas: 1) Formulario en esta página (se envía a WhatsApp), 2) WhatsApp directo 55 6529 8240, o 3) Email ventas@gamademexico.com. Solo necesitamos: tipo de conexión, diámetros, cantidad y ubicación de entrega. Respondemos en menos de 24 horas con precio, disponibilidad y opciones de envío. Precios especiales por volumen."
  }
];

const structuredData = [
  buildOrganizationSchema(),
  buildProductCategorySchema({
    name: 'Conexiones y Herrajes Contra Incendio en Bronce',
    description: 'Conexiones y herrajes contra incendio. Adaptadores bronce, toma siamesa FDC, Wye, coples Storz. Certificados UL/FM. Distribuidor Elkhart Brass México.',
    image: '/img/conexiones-herrajes-contra-incendios/toma-siamesa-fdc-bronce-contra-incendios-bomberos-dos-bocas-01.avif',
    url: '/conexiones-herrajes-contra-incendios',
    category: 'Conexiones y Herrajes Contra Incendios',
    brand: 'Elkhart Brass',
    reviewAuthor: 'Arq. Patricia Sánchez',
    reviewBody: 'Conexiones de bronce de primera calidad. La toma siamesa FDC cumplió perfectamente con los requisitos de Protección Civil para nuestro edificio corporativo. Excelente servicio.',
    reviewDate: '2025-06-05',
    ratingCount: 36,
    reviewCount: 36,
  }),
  buildBreadcrumbSchema([
    { name: 'Inicio', url: '/' },
    { name: 'Equipos', url: '/equipos' },
    { name: 'Conexiones y Herrajes', url: '/conexiones-herrajes-contra-incendios' },
  ]),
  buildFAQSchema(faqItems),
];
---

<Layout
  title="Conexiones y Herrajes Contra Incendio | México"
  description="Conexiones y herrajes contra incendio. Adaptadores bronce, toma siamesa, Wye, coples Storz. Certificados UL/FM. Distribuidor Elkhart Brass México."
  activePage="equipos"
  structuredData={structuredData}
  heroTitle="Conexiones y Herrajes"
  heroBadge="Equipos Contra Incendios"
  heroShowRightContent={true}
>
  <Fragment slot="hero-content">
    <p>Ofrecemos conexiones y herrajes contra incendios fabricados en bronce de alta calidad para integrar mangueras, hidrantes y equipos de bombeo en sistemas de protección completos. Nuestro catálogo incluye adaptadores de conversión NH/NPT/Storz, conexiones Y con válvulas de bola, tomas siamesas FDC certificadas y coples de acoplamiento rápido.</p>
    <p>Todos nuestros herrajes cuentan con certificación UL y FM, garantizando compatibilidad universal y operación confiable bajo presión. Como distribuidor autorizado Elkhart Brass, proporcionamos productos originales con documentación completa para auditorías y cumplimiento normativo.</p>
  </Fragment>

  <!-- BREADCRUMB -->
  <nav class="breadcrumb" aria-label="Navegación de migas de pan">
    <div class="container">
      <ol class="breadcrumb__list">
        <li class="breadcrumb__item"><a href="/" class="breadcrumb__link">Inicio</a></li>
        <li class="breadcrumb__item"><a href="/equipos" class="breadcrumb__link">Equipos</a></li>
        <li class="breadcrumb__item breadcrumb__item--active" aria-current="page">Conexiones y Herrajes</li>
      </ol>
    </div>
  </nav><!-- PRODUCTOS DINAMICOS -->
  <section class="categories" id="conexiones">
    <div class="container">
      <div class="section-header">
        <h2 class="section-title">Tipos de Herraje Accesorio y Conexiones Bronce Incendio</h2>
        <p class="section-subtitle">Selecciona un tipo de herraje o conexión manguera para conocer especificaciones técnicas y solicitar cotización</p>
      </div>
      <div class="categories__grid">
        {productos.map((producto) => (
          <article class="category-card">
            <div
              class="category-card__image"
              role="img"
              aria-label={producto.data.title}
              style={producto.data.imagen ? `background-image: url('${cardImage(producto.data.imagen)}'); background-size: cover; background-position: center;` : undefined}
            ></div>
            <div class="category-card__body">
              <h3 class="category-card__title">{producto.data.title}</h3>
              <p class="category-card__sub">{producto.data.description}</p>
              <ul class="category-card__products">
                {producto.data.material && <li class="category-card__product">{producto.data.material}</li>}
                {producto.data.flujo && <li class="category-card__product">{producto.data.flujo}</li>}
                {producto.data.certificaciones && producto.data.certificaciones.length > 0 && <li class="category-card__product">Certificaciones: {producto.data.certificaciones.join(', ')}</li>}
                <li class="category-card__product">Marca: {producto.data.marca}</li>
              </ul>
              <div class="category-card__ctas">
                <a href={`/productos/${producto.id}`} class="btn btn--primary btn--sm">Ver especificaciones</a>
                <a href="#cotizar" class="btn btn--outline btn--sm">Cotizar</a>
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- SERVICE DETAILS -->
  <section class="service-details" aria-labelledby="service-details-title">
    <div class="container">
      <div class="section-header">
        <h2 id="service-details-title" class="section-title">Detalle de Cada Herraje Accesorio y Conexión Bronce</h2>
      </div>

      <div class="service-detail" id="detalle-adaptadores">
        <div class="service-detail__content">
          <h3 class="service-detail__title">Adaptadores de Bronce para Conversión de Roscas</h3>
          <p class="service-detail__text">Los <strong>adaptadores de bronce</strong> son piezas de conversión profesionales que permiten conectar equipos con diferentes estándares de rosca (NH, NPT) y acoplamientos rápidos (Storz). Fabricados en bronce forjado de alta calidad, garantizan compatibilidad universal entre mangueras, hidrantes, monitores y equipos de bombeo. Venta con precio competitivo y cotización inmediata.</p>
          <ul class="service-detail__list">
            <li class="service-detail__list-item">Conversión NH (National Hose) a NPT (National Pipe Tapered)</li>
            <li class="service-detail__list-item">Adaptadores NH/NPT a Storz para conexión rápida</li>
            <li class="service-detail__list-item">Bronce forjado con tratamiento anticorrosión</li>
            <li class="service-detail__list-item">Presión de trabajo 250-300 PSI según modelo</li>
            <li class="service-detail__list-item">Diámetros: 1", 1.5", 2", 2.5", 3", 4" y 5"</li>
            <li class="service-detail__list-item">Certificaciones UL Listed según estándares NFPA</li>
          </ul>
          <div class="service-detail__ctas">
            <a href="#cotizar" class="btn btn--primary">Cotizar adaptadores</a>
            <a href="/conexiones/adaptadores" class="btn btn--outline">Ver catálogo completo →</a>
          </div>
        </div>
        <div class="service-detail__image" role="img" aria-label="Adaptadores de bronce NH NPT Storz Elkhart Brass" style={`background-image: url('${detailImage('/img/conexiones-herrajes/adaptador-bronce-nh-npt-2-5-frontal.avif')}'); background-size: cover; background-position: center;`}></div>
      </div>

      <div class="service-detail" id="detalle-conexion-y">
        <div class="service-detail__content">
          <h3 class="service-detail__title">Conexión Y (Wye) con Válvulas de Bola</h3>
          <p class="service-detail__text">La <strong>conexión Y o Wye</strong> es una pieza de ramificación profesional que permite dividir una línea de alimentación principal en dos líneas de ataque independientes con control individual mediante válvulas de bola de cuarto de vuelta. El modelo B-97-A de Elkhart Brass es el estándar de la industria con recubrimiento Elk-O-Lite para máxima durabilidad. Costo competitivo disponible.</p>
          <ul class="service-detail__list">
            <li class="service-detail__list-item">Modelo Elkhart B-97-A con válvulas de bola integradas</li>
            <li class="service-detail__list-item">Entrada 2.5" NH hembra, dos salidas 1.5" NH macho</li>
            <li class="service-detail__list-item">Válvulas de cuarto de vuelta para operación rápida</li>
            <li class="service-detail__list-item">Bronce forjado con recubrimiento Elk-O-Lite</li>
            <li class="service-detail__list-item">Presión de trabajo 200 PSI continua</li>
            <li class="service-detail__list-item">Certificación UL Listed según NFPA</li>
          </ul>
          <div class="service-detail__ctas">
            <a href="#cotizar" class="btn btn--primary">Cotizar conexión Y</a>
            <a href="/conexiones/wye" class="btn btn--outline">Ver catálogo completo →</a>
          </div>
        </div>
        <div class="service-detail__image" role="img" aria-label="Conexión Y Elkhart B-97-A con válvulas de bola" style={`background-image: url('${detailImage('/img/conexiones-herrajes/conexion-wye-b100a-frontal.avif')}'); background-size: cover; background-position: center;`}></div>
      </div>

      <div class="service-detail" id="detalle-siamesa">
        <div class="service-detail__content">
          <h3 class="service-detail__title">Toma Siamesa FDC (Fire Department Connection)</h3>
          <p class="service-detail__text">La <strong>toma siamesa FDC</strong> es una conexión de alimentación exterior profesional que permite a bomberos suministrar agua al sistema contra incendios desde autobombas. Configuración de dos entradas 2.5" NH hembra con válvulas check integradas que evitan retorno de agua. Beneficios de protección y cumplimiento NFPA 14. Precio y cotización disponible.</p>
          <ul class="service-detail__list">
            <li class="service-detail__list-item">Dos entradas 2.5" NH hembra con válvulas check</li>
            <li class="service-detail__list-item">Prevención de retorno y protección de sobrepresiones</li>
            <li class="service-detail__list-item">Capacidad hasta 500 GPM por entrada (1,000 GPM total)</li>
            <li class="service-detail__list-item">Bronce forjado con acabado pulido o cromado</li>
            <li class="service-detail__list-item">Incluye tapones de protección con cadena</li>
            <li class="service-detail__list-item">Certificación UL Listed y FM Approved según NFPA 14</li>
          </ul>
          <div class="service-detail__ctas">
            <a href="#cotizar" class="btn btn--primary">Cotizar toma siamesa</a>
            <a href="/conexiones/siamesa" class="btn btn--outline">Ver catálogo completo →</a>
          </div>
        </div>
        <div class="service-detail__image" role="img" aria-label="Toma siamesa FDC para bomberos" style={`background-image: url('${detailImage('/img/conexiones-herrajes/toma-siamesa-2a-plain-frontal.avif')}'); background-size: cover; background-position: center;`}></div>
      </div>

      <div class="service-detail" id="detalle-storz">
        <div class="service-detail__content">
          <h3 class="service-detail__title">Coples Storz y Reducciones de Acoplamiento Rápido</h3>
          <p class="service-detail__text">Los <strong>coples Storz</strong> son acoplamientos rápidos profesionales de cuarto de vuelta que permiten conectar mangueras sin roscar, reduciendo tiempo de despliegue en 50%. Sistema de guías y pestillos de seguridad que garantiza conexión hermética bajo presión. Disponibles en aluminio anodizado y bronce forjado con precio competitivo.</p>
          <ul class="service-detail__list">
            <li class="service-detail__list-item">Acoplamiento de cuarto de vuelta (90 grados)</li>
            <li class="service-detail__list-item">Coples simétricos: 2.5", 3", 4", 5"</li>
            <li class="service-detail__list-item">Reducciones asimétricas: 3" x 2.5", 4" x 3", 5" x 4"</li>
            <li class="service-detail__list-item">Aluminio anodizado o bronce forjado</li>
            <li class="service-detail__list-item">Empaque EPDM resistente a temperaturas extremas</li>
            <li class="service-detail__list-item">Presión de trabajo 250-300 PSI según material</li>
          </ul>
          <div class="service-detail__ctas">
            <a href="#cotizar" class="btn btn--primary">Cotizar coples Storz</a>
            <a href="/conexiones/coples" class="btn btn--outline">Ver catálogo completo →</a>
          </div>
        </div>
        <div class="service-detail__image" role="img" aria-label="Coples Storz de cuarto de vuelta" style={`background-image: url('${detailImage('/img/conexiones-herrajes/cople-storz-4-aluminio-frontal.avif')}'); background-size: cover; background-position: center;`}></div>
      </div>

      <div class="service-detail" id="detalle-chiflones">
        <div class="service-detail__content">
          <h3 class="service-detail__title">Chiflones de Tres Pasos Chief XD</h3>
          <p class="service-detail__text">Los <strong>chiflones de tres pasos</strong> son boquillas de control manual que permiten ajustar el patrón de descarga entre chorro directo, niebla y cierre completo. El modelo Chief XD de Elkhart Brass ofrece flujo ajustable de 75-200 GPM con certificación UL 401 para máximo rendimiento en combate de incendios.</p>
          <ul class="service-detail__list">
            <li class="service-detail__list-item">Tres posiciones: chorro directo, niebla y cierre</li>
            <li class="service-detail__list-item">Flujo ajustable 75-200 GPM</li>
            <li class="service-detail__list-item">Conexión 1" y 1½" NH</li>
            <li class="service-detail__list-item">Construcción aluminio o bronce</li>
            <li class="service-detail__list-item">Tecnología Chief XD de Elkhart Brass</li>
            <li class="service-detail__list-item">Certificación UL 401</li>
          </ul>
          <div class="service-detail__ctas">
            <a href="#cotizar" class="btn btn--primary">Cotizar chiflones</a>
            <a href="/conexiones/chiflones" class="btn btn--outline">Ver catálogo completo →</a>
          </div>
        </div>
        <div class="service-detail__image" role="img" aria-label="Chiflones de tres pasos Chief XD" style={`background-image: url('${detailImage('/img/conexiones-herrajes/chiflon-chief-xd-1-5-frontal.avif')}'); background-size: cover; background-position: center;`}></div>
      </div>

      <div class="service-detail" id="detalle-accesorios">
        <div class="service-detail__content">
          <h3 class="service-detail__title">Herraje Accesorio Bronce Incendio NST</h3>
          <p class="service-detail__text">Los <strong>herraje y accesorio bronce</strong> son componentes complementarios esenciales para sistemas contra incendio: tapones ciegos para sellado, caps de protección toma siamés con cadena, niples de extensión y conexiones de montaje NST. Fabricados en bronce para manguera y despliegue con presiones de trabajo de 175-500 PSI según modelo.</p>
          <ul class="service-detail__list">
            <li class="service-detail__list-item">Tapones ciegos NH y NPT</li>
            <li class="service-detail__list-item">Caps de protección con cadena</li>
            <li class="service-detail__list-item">Niples de extensión en bronce</li>
            <li class="service-detail__list-item">Herrajes de montaje y sujeción</li>
            <li class="service-detail__list-item">Tamaños de 1" a 6"</li>
            <li class="service-detail__list-item">Roscas NH y NPT disponibles</li>
          </ul>
          <div class="service-detail__ctas">
            <a href="#cotizar" class="btn btn--primary">Cotizar accesorios</a>
            <a href="/conexiones/accesorios" class="btn btn--outline">Ver catálogo completo →</a>
          </div>
        </div>
        <div class="service-detail__image" role="img" aria-label="Accesorios y herrajes contra incendio" style={`background-image: url('${detailImage('/img/conexiones-herrajes/soporte-manguera-despliegue-frontal.avif')}'); background-size: cover; background-position: center;`}></div>
      </div>

    </div>
  </section>

  <!-- TRUST -->
  <section class="trust" aria-labelledby="trust-title">
    <div class="container">
      <div class="section-header">
        <h2 id="trust-title" class="section-title">Por Qué Comprar Herraje Accesorio y Conexiones Bronce Incendio</h2>
        <p class="section-subtitle">Calidad certificada, inventario disponible y asesoría técnica especializada</p>
      </div>
      <div class="trust__grid">
        <div class="trust__item">
          <h3 class="trust__item-title">Certificaciones UL y FM Listed</h3>
          <p class="trust__item-desc">Todas nuestras conexiones y herrajes cuentan con certificación UL Listed y FM Approved, garantizando cumplimiento NFPA y operación confiable.</p>
        </div>
        <div class="trust__item">
          <h3 class="trust__item-title">Proveedor Elkhart Brass Original</h3>
          <p class="trust__item-desc">Distribuidor autorizado Elkhart Brass con más de 125 años de experiencia. Productos originales con garantía de fábrica y soporte técnico profesional.</p>
        </div>
        <div class="trust__item">
          <h3 class="trust__item-title">Venta con Stock Permanente</h3>
          <p class="trust__item-desc">Inventario disponible de adaptadores, conexiones Y, tomas siamesas, coples Storz y accesorios para entrega inmediata cerca de tu ubicación.</p>
        </div>
        <div class="trust__item">
          <h3 class="trust__item-title">Cotización y Precio Competitivo</h3>
          <p class="trust__item-desc">Cotización inmediata con precio y costo competitivo. Precios especiales por volumen para proyectos de gran escala y compras recurrentes.</p>
        </div>
        <div class="trust__item">
          <h3 class="trust__item-title">Asesoría Técnica Especializada</h3>
          <p class="trust__item-desc">Experiencia profesional en selección de conexiones según estándar de rosca, presión de trabajo, diámetro y compatibilidad con equipos existentes.</p>
        </div>
        <div class="trust__item">
          <h3 class="trust__item-title">Documentación para Auditorías</h3>
          <p class="trust__item-desc">Fichas técnicas, certificados UL/FM, manuales y cartas de conformidad incluidos con cada venta para cumplimiento normativo y protección civil.</p>
        </div>
      </div>

      <div class="trust__testimonials-header">
        <h3 class="trust__testimonials-title">Lo que dicen nuestros clientes</h3>
        <p class="trust__testimonials-subtitle">Empresas de todo México confían en nuestras conexiones y herrajes</p>
      </div>
      <div class="trust__testimonials">
        <blockquote class="testimonial">
          <div class="testimonial__stars" aria-label="5 estrellas">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
          <p class="testimonial__text">"Los adaptadores NH a Storz han sido fundamentales para modernizar nuestro equipo. Ahora conectamos mangueras nuevas con acoplamiento Storz a hidrantes municipales NH en menos de 5 segundos. Excelente proveedor con precio justo."</p>
          <div class="testimonial__author">
            <div class="testimonial__avatar"></div>
            <div class="testimonial__info">
              <span class="testimonial__name">Comandante Roberto Mendoza</span>
              <span class="testimonial__role">Bomberos Municipales</span>
              <span class="testimonial__company">Querétaro</span>
            </div>
          </div>
        </blockquote>
        <blockquote class="testimonial">
          <div class="testimonial__stars" aria-label="5 estrellas">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
          <p class="testimonial__text">"La conexión Y Elkhart B-97-A es increíblemente robusta. Las válvulas de bola operan suavemente incluso con 150 PSI de presión. Llevamos 3 años usándolas sin falla. Cotización rápida y costo muy accesible."</p>
          <div class="testimonial__author">
            <div class="testimonial__avatar"></div>
            <div class="testimonial__info">
              <span class="testimonial__name">Ing. Patricia Ramírez</span>
              <span class="testimonial__role">Jefe de Seguridad Industrial</span>
              <span class="testimonial__company">Grupo Químico del Norte</span>
            </div>
          </div>
        </blockquote>
        <blockquote class="testimonial">
          <div class="testimonial__stars" aria-label="5 estrellas">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
          <p class="testimonial__text">"Instalamos tomas siamesas FDC en 5 edificios corporativos. La calidad del bronce y el acabado cromado son excepcionales. Las válvulas check funcionan perfectamente. Venta profesional con documentación completa."</p>
          <div class="testimonial__author">
            <div class="testimonial__avatar"></div>
            <div class="testimonial__info">
              <span class="testimonial__name">Arq. Fernando Gutiérrez</span>
