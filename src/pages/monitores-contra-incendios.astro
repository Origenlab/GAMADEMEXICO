---
import Layout from '../layouts/Base.astro';
import SectionHeader from '../components/SectionHeader.astro';
import { getCollection } from 'astro:content';
import { getBackgroundImageUrl } from '../lib/images';
import Faq from '../components/Faq.astro';
import {
  buildProductCategorySchema,
  buildFAQSchema,
  buildBreadcrumbSchema,
  buildOrganizationSchema,
} from '../lib/seo';

const productos = (await getCollection('productos', ({ data }) => data.categoria === 'monitores')).sort((a, b) => a.data.orden - b.data.orden);
const cdnImage = (path: string) =>
  getBackgroundImageUrl(path, {
    width: 960,
    quality: 80,
    strip: 'all',
  });
const faqItems = [
  {
    "pregunta": "¿Qué tipos de monitores contra incendios vende Gama de México?",
    "respuesta": "Distribuimos cuatro tipos principales de monitores de marcas líderes como Elkhart Brass, Akron, Potter Roemer y Task Force Tips: 1) Monitores tipo corazón, ideales para protección perimetral con rotación 360° y caudales hasta 2,000 GPM; 2) Monitores tipo cuello de cisne en versión autosoportada y soportada para protección de tanques desde arriba, con caudales de 500-2,000 GPM; 3) Monitores certificados FM que cumplen estándar FM 1421 para instalaciones de alto riesgo; y 4) Monitores UL Listed reconocidos por Protección Civil en México. Todos tienen construcción forjada de una pieza e incluyen certificación y documentación completa."
  },
  {
    "pregunta": "¿Cuál es la diferencia entre un monitor certificado FM y uno UL Listed?",
    "respuesta": "La certificación FM (Factory Mutual) es el estándar más riguroso para equipos en instalaciones industriales de alto riesgo - cumple estándar FM 1421, requiere inspecciones trimestrales en fábrica, y es exigido por aseguradoras para refinerías, petroquímicas y terminales de almacenamiento. La certificación UL Listed (Underwriters Laboratories) certifica seguridad y rendimiento mediante pruebas integrales y es ampliamente aceptado por autoridades de Protección Civil en México para aplicaciones comerciales e industriales. Muchos monitores Elkhart Brass tienen doble certificación FM y UL, ofreciendo máxima flexibilidad."
  },
  {
    "pregunta": "¿Qué caudal manejan los monitores contra incendios?",
    "respuesta": "Los monitores que distribuimos manejan caudales desde 500 hasta 2,000 GPM (1,893 a 7,571 litros por minuto) según el modelo. Los monitores tipo corazón Copperhead tienen capacidad hasta 1,250 GPM, ideales para la mayoría de aplicaciones de protección perimetral. Los monitores tipo cuello de cisne están disponibles en diferentes alturas y caudales - los modelos para tanques grandes pueden alcanzar hasta 2,000 GPM. El caudal necesario se determina según el riesgo a proteger, la distancia de proyección requerida y los códigos NFPA aplicables. Nuestros ingenieros te ayudan a calcular el caudal correcto sin costo."
  },
  {
    "pregunta": "¿De qué materiales están fabricados los monitores?",
    "respuesta": "Los monitores que distribuimos están disponibles en tres materiales según el ambiente de operación: 1) Bronce forjado - recomendado para ambientes marinos, plantas químicas con vapores corrosivos, y aplicaciones donde se requiere máxima resistencia a corrosión; 2) Acero inoxidable 316 - para aplicaciones con espuma o agentes químicos que pueden atacar el bronce; y 3) Hierro dúctil - para aplicaciones con agua dulce donde la corrosión no es preocupación. Todas las marcas que manejamos tienen construcción forjada de una sola pieza sin juntas débiles. Te asesoramos en la selección del material correcto."
  },
  {
    "pregunta": "¿En qué tipo de aplicaciones se utilizan los monitores contra incendios?",
    "respuesta": "Los monitores tipo corazón se utilizan en protección perimetral de áreas de proceso en refinerías de petróleo, plantas petroquímicas, terminales de almacenamiento de hidrocarburos, muelles de carga/descarga de líquidos inflamables, hangares de aviación, y almacenes de productos químicos. Los monitores tipo cuello de cisne se utilizan específicamente para protección de tanques atmosféricos de almacenamiento, tanques de GLP, esferas de almacenamiento, y recipientes a presión elevados. En general, cualquier instalación con riesgo de incendio clase B que requiera proyección de grandes volúmenes de agua a distancia."
  },
  {
    "pregunta": "¿Cómo sé qué tipo de monitor necesito para mi aplicación?",
    "respuesta": "La selección del monitor correcto depende de varios factores: 1) Tipo de riesgo a proteger - corazón para perímetro horizontal, cuello de cisne para tanques; 2) Caudal requerido según códigos NFPA y tamaño del riesgo; 3) Alcance de proyección necesario; 4) Requisitos de certificación - FM para instalaciones de alto riesgo, UL para aplicaciones generales; 5) Material según ambiente corrosivo o no; y 6) Operación manual o remota. Nuestros ingenieros realizan esta evaluación sin costo - compártenos detalles de tu aplicación y te recomendamos el modelo óptimo."
  },
  {
    "pregunta": "¿Los monitores incluyen documentación para trámites con Protección Civil?",
    "respuesta": "Sí, cada monitor incluye documentación completa aceptada por autoridades mexicanas: certificado FM original o UL Listed según modelo, fichas técnicas en español con especificaciones completas, manuales de instalación y operación traducidos, cartas de conformidad con NOM-002-STPS-2010, y dibujos dimensionales. Esta documentación es exactamente lo que solicitan en auditorías de Protección Civil, verificaciones de aseguradoras, y dictámenes de unidades de verificación. Muchos clientes nos comentan que la calidad de nuestra documentación facilita enormemente los trámites."
  }
];

const structuredData = [
  buildOrganizationSchema(),
  buildProductCategorySchema({
    name: 'Monitores Contra Incendios Industriales FM/UL',
    description: 'Monitores contra incendio tipo corazón y cuello de cisne. Elkhart Brass, Akron. Caudal hasta 2000 GPM, rotación 360°. Certificación FM/UL.',
    image: '/img/monitores-contra-incendios/monitor-tipo-corazon-contra-incendios-industrial-tres-cuartos-10.avif',
    url: '/monitores-contra-incendios',
    category: 'Monitores Contra Incendios',
    brand: 'Elkhart Brass',
    reviewAuthor: 'Ing. Fernando Torres',
    reviewBody: 'Monitores Elkhart Brass de calidad excepcional para nuestra refinería. La certificación FM fue fundamental para cumplir con aseguradora. Asesoría técnica y entrega sin fallas.',
    reviewDate: '2025-02-28',
    ratingCount: 44,
    reviewCount: 44,
  }),
  buildBreadcrumbSchema([
    { name: 'Inicio', url: '/' },
    { name: 'Equipos', url: '/equipos' },
    { name: 'Monitores Contra Incendios', url: '/monitores-contra-incendios' },
  ]),
  buildFAQSchema(faqItems),
];
---

<Layout
  title="Monitores Contra Incendios Certificados | Gama de México"
  description="Monitores contra incendio Elkhart Brass y Akron: corazón, cuello de cisne, hasta 2000 GPM. Certificación FM/UL. Stock y envíos nacionales. Cotiza hoy."
  activePage="equipos"
  structuredData={structuredData}
  ogImage="/img/categorias/monitores-contra-incendios-hero.avif"
  heroTitle="Monitores Contra Incendios para Protección Industrial"
  heroIntro="Monitores tipo corazón para protección perimetral y cuello de cisne para tanques elevados. Elkhart Brass, Akron, Potter Roemer. Caudales de 500 a 2,000 GPM con certificación FM y UL."
  heroBadge="Monitores Contra Incendios"
  heroMetrics={[
    { valor: "360°", texto: "Cobertura horizontal" },
    { valor: "2,000", texto: "GPM máximo" },
    { valor: "FM/UL", texto: "Certificaciones disponibles" }
  ]}
  heroPrimaryText="Ver Catálogo"
  heroPrimaryLink="#monitores"
  heroSecondaryText="Solicitar Cotización"
  heroSecondaryLink="#cotizar"
  heroShowRightContent={true}
  heroImage="/img/categorias/monitores-contra-incendios-hero.avif"

  showLeadCapture={true}
>
  <Fragment slot="hero-content">
    <p>Si tu proyecto requiere monitores contra incendio — ya sea para protección perimetral en una refinería, enfriamiento de tanques en una terminal de almacenamiento o un sistema fijo para una planta química — tenemos modelos de Elkhart Brass, Akron y Potter Roemer con stock en México. No necesitas esperar 10 semanas de importación.</p>
    <p>Te ayudamos a elegir el monitor correcto: tipo corazón o cuello de cisne, caudal necesario, material según tu ambiente de operación, y la certificación que pide tu aseguradora o protección civil. Sin costo y sin compromiso.</p>
  </Fragment>

  <!-- PRODUCTOS DINAMICOS -->
  <section class="categories" id="monitores">
    <div class="container">
      <SectionHeader
        titulo="Catálogo de Monitores Contra Incendios por Tipo"
        subtitulo="Selecciona un tipo de monitor para conocer especificaciones técnicas y solicitar cotización"
        idTitulo="monitores-title"
        parrafo1="Cuatro tipos de monitor, cada uno para un problema distinto. El tipo corazón cubre perímetro en planta. El cuello de cisne protege tanques desde arriba. Los modelos FM pasan la auditoría de tu aseguradora. Los UL Listed te resuelven el dictamen de protección civil. Todos con documentación en español."
        parrafo2="Nuestros clientes son refinerías, terminales de almacenamiento, plantas petroquímicas, firmas de ingeniería e instaladores que necesitan equipo real con certificado real — no genéricos sin respaldo."
      />
      <div class="categories__grid">
        <article class="category-card">
          <div class="category-card__image" role="img" aria-label="Monitor Tipo Corazón" style={`background-image: url('${cdnImage('/img/monitores-contra-incendios/monitor-tipo-corazon-contra-incendios-industrial-frontal-02.avif')}'); background-size: cover; background-position: center;`}></div>
          <div class="category-card__body">
            <h3 class="category-card__title">Monitor Tipo Corazón</h3>
            <p class="category-card__sub">Protección perimetral con rotación 360° y caudales hasta 2,000 GPM</p>
            <ul class="category-card__products">
              <li class="category-card__product">Rotación horizontal 360°</li>
              <li class="category-card__product">Caudal: 500 - 2,000 GPM</li>
              <li class="category-card__product">Certificaciones: FM, UL</li>
              <li class="category-card__product">Multimarca disponible</li>
            </ul>
            <div class="category-card__ctas">
              <a href="/monitores/tipo-corazon" class="btn btn--primary btn--sm">Ver catálogo</a>
              <a href="#cotizar" class="btn btn--outline btn--sm">Cotizar</a>
            </div>
          </div>
        </article>
        <article class="category-card">
          <div class="category-card__image" role="img" aria-label="Monitor Cuello de Cisne" style={`background-image: url('${cdnImage('/img/monitores-contra-incendios/monitor-cuello-cisne-contra-incendios-lateral-derecha-01.avif')}'); background-size: cover; background-position: center;`}></div>
          <div class="category-card__body">
            <h3 class="category-card__title">Monitor Cuello de Cisne</h3>
            <p class="category-card__sub">Protección de tanques elevados con proyección desde arriba</p>
            <ul class="category-card__products">
              <li class="category-card__product">Elevación 10 - 111 pies</li>
              <li class="category-card__product">Caudal: 500 - 2,000 GPM</li>
              <li class="category-card__product">Certificaciones: FM, UL</li>
              <li class="category-card__product">Control desde piso</li>
            </ul>
            <div class="category-card__ctas">
              <a href="/monitores/cuello-cisne" class="btn btn--primary btn--sm">Ver catálogo</a>
              <a href="#cotizar" class="btn btn--outline btn--sm">Cotizar</a>
            </div>
          </div>
        </article>
        <article class="category-card">
          <div class="category-card__image" role="img" aria-label="Monitor Certificado FM" style={`background-image: url('${cdnImage('/img/monitores-contra-incendios/monitor-certificado-fm-contra-incendios-vista-urbana-01.avif')}'); background-size: cover; background-position: center;`}></div>
          <div class="category-card__body">
            <h3 class="category-card__title">Monitor Certificado FM</h3>
            <p class="category-card__sub">Aprobación Factory Mutual para instalaciones de alto riesgo</p>
            <ul class="category-card__products">
              <li class="category-card__product">Estándar FM 1421</li>
              <li class="category-card__product">Inspección trimestral en fábrica</li>
              <li class="category-card__product">Requerido por aseguradoras</li>
              <li class="category-card__product">Certificado original incluido</li>
            </ul>
            <div class="category-card__ctas">
              <a href="/monitores/certificado-fm" class="btn btn--primary btn--sm">Ver catálogo</a>
              <a href="#cotizar" class="btn btn--outline btn--sm">Cotizar</a>
            </div>
          </div>
        </article>
        <article class="category-card">
          <div class="category-card__image" role="img" aria-label="Monitor UL Listed" style={`background-image: url('${cdnImage('/img/monitores-contra-incendios/monitor-ul-listed-contra-incendios-estacion-bomberos-01.avif')}'); background-size: cover; background-position: center;`}></div>
          <div class="category-card__body">
            <h3 class="category-card__title">Monitor UL Listed</h3>
            <p class="category-card__sub">Certificación Underwriters Laboratories para máxima confiabilidad</p>
            <ul class="category-card__products">
              <li class="category-card__product">Pruebas integrales UL</li>
              <li class="category-card__product">Reconocido por Protección Civil</li>
              <li class="category-card__product">Facilita obtención de seguros</li>
              <li class="category-card__product">Documentación en español</li>
            </ul>
            <div class="category-card__ctas">
              <a href="/monitores/ul-listed" class="btn btn--primary btn--sm">Ver catálogo</a>
              <a href="#cotizar" class="btn btn--outline btn--sm">Cotizar</a>
            </div>
          </div>
        </article>
      </div>
    </div>
  </section>

  <!-- PRODUCT DETAILS -->
  <section class="service-details" aria-labelledby="service-details-title">
    <div class="container">
      <SectionHeader
        titulo="Detalle de Cada Tipo de Monitor Contra Incendios"
        subtitulo="Conoce las características técnicas y aplicaciones de cada configuración"
        idTitulo="service-details-title"
      />

      <div class="service-detail" id="detalle-corazon">
        <div class="service-detail__content">
          <h3 class="service-detail__title">Monitor Tipo Corazón — Protección Perimetral de Alto Caudal</h3>
          <p class="service-detail__text">Los monitores contra incendio tipo corazón son equipos de protección perimetral con base fija que permite <strong>rotación horizontal de 360°</strong> y ajuste vertical desde -45° hasta +90°. Ofrecemos modelos de marcas líderes como Elkhart Brass, Akron Brass y Potter Roemer, todos con construcción robusta en latón forjado de una sola pieza, resistencia a la corrosión y control preciso del flujo de agua.</p>
          <ul class="service-detail__list">
            <li class="service-detail__list-item">Caudal de 500 a 2,000 GPM según modelo</li>
            <li class="service-detail__list-item">Presión de trabajo de 200 a 300 PSI</li>
            <li class="service-detail__list-item">Rotación horizontal 360° y movimiento vertical -45° a +90°</li>
            <li class="service-detail__list-item">Construcción en latón forjado (bronce) de alta calidad</li>
            <li class="service-detail__list-item">Conexiones de entrada 2.5" y 3" NPT o NH</li>
            <li class="service-detail__list-item">Marcas: Elkhart Brass, Akron, Potter Roemer, Task Force Tips</li>
          </ul>
          <div class="service-detail__ctas">
            <a href="/monitores/tipo-corazon" class="btn btn--primary">Ver catálogo completo</a>
            <a href="#cotizar" class="btn btn--outline">Cotizar</a>
          </div>
        </div>
        <div class="service-detail__image" role="img" aria-label="Monitor tipo corazón para protección industrial" style={`background-image: url('${cdnImage('/img/monitores-contra-incendios/monitor-tipo-corazon-contra-incendios-industrial-perspectiva-04.avif')}'); background-size: cover; background-position: center;`}></div>
      </div>

      <div class="service-detail" id="detalle-cuello-cisne">
        <div class="service-detail__content">
          <h3 class="service-detail__title">Monitor Tipo Cuello de Cisne — Protección de Tanques Elevados</h3>
          <p class="service-detail__text">Los monitores contra incendio tipo cuello de cisne son sistemas fijos elevados diseñados para <strong>protección de tanques de almacenamiento</strong> y estructuras altas, permitiendo proyectar un chorro de agua desde arriba hacia abajo para combatir incendios de gran escala. Disponibles en versión autosoportada (freestanding) y soportada, con control manual desde nivel de piso. Múltiples marcas disponibles con precio bajo cotización.</p>
          <ul class="service-detail__list">
            <li class="service-detail__list-item">Caudal de 500 a 2,000 GPM según modelo para alta capacidad</li>
            <li class="service-detail__list-item">Elevación disponible de 10 a 111 pies</li>
            <li class="service-detail__list-item">Control desde nivel de piso sin necesidad de subir</li>
            <li class="service-detail__list-item">Versión autosoportada (freestanding) y soportada</li>
            <li class="service-detail__list-item">Marcas: Elkhart Brass, Akron, Potter Roemer</li>
            <li class="service-detail__list-item">Ideal para tanques GLP, líquidos inflamables y esferas</li>
          </ul>
          <div class="service-detail__ctas">
            <a href="/monitores/cuello-cisne" class="btn btn--primary">Ver catálogo completo</a>
            <a href="#cotizar" class="btn btn--outline">Cotizar</a>
          </div>
        </div>
        <div class="service-detail__image" role="img" aria-label="Monitor tipo cuello de cisne para tanques industriales" style={`background-image: url('${cdnImage('/img/monitores-contra-incendios/monitor-cuello-cisne-contra-incendios-perspectiva-frontal-05.avif')}'); background-size: cover; background-position: center;`}></div>
      </div>

      <div class="service-detail" id="detalle-fm">
        <div class="service-detail__content">
          <h3 class="service-detail__title">Monitor Certificado FM — Aprobación Factory Mutual Industrial</h3>
          <p class="service-detail__text">La <strong>certificación FM (Factory Mutual)</strong> es el estándar de aprobación más riguroso para equipos de protección contra incendios en instalaciones industriales de alto riesgo. Los monitores certificados FM cumplen estándar FM 1421 y son sometidos a inspecciones trimestrales de calidad en fábrica. Disponemos monitores FM de múltiples fabricantes reconocidos.</p>
          <ul class="service-detail__list">
            <li class="service-detail__list-item">Cumplimiento de estándar FM 1421 para monitores</li>
            <li class="service-detail__list-item">Inspecciones trimestrales en fábrica del fabricante</li>
            <li class="service-detail__list-item">Obligatorio para aseguradoras en riesgo industrial alto</li>
            <li class="service-detail__list-item">Certificado FM original incluido con cada unidad</li>
            <li class="service-detail__list-item">Compatible con NOM-002-STPS-2010 y códigos NFPA</li>
            <li class="service-detail__list-item">Marcas certificadas FM: Elkhart Brass, Akron, Potter Roemer</li>
          </ul>
          <div class="service-detail__ctas">
            <a href="/monitores/certificado-fm" class="btn btn--primary">Ver catálogo completo</a>
            <a href="#cotizar" class="btn btn--outline">Cotizar</a>
          </div>
        </div>
        <div class="service-detail__image" role="img" aria-label="Monitor certificado FM Factory Mutual" style={`background-image: url('${cdnImage('/img/monitores-contra-incendios/monitor-certificado-fm-contra-incendios-estacion-bomberos-03.avif')}'); background-size: cover; background-position: center;`}></div>
      </div>

      <div class="service-detail" id="detalle-ul">
        <div class="service-detail__content">
          <h3 class="service-detail__title">Monitor UL Listed — Certificación Underwriters Laboratories</h3>
          <p class="service-detail__text">La <strong>certificación UL Listed</strong> es otorgada por Underwriters Laboratories tras pruebas integrales de seguridad, rendimiento y durabilidad. En México, la certificación UL es ampliamente aceptada por autoridades de Protección Civil y facilita trámites de permisos y dictámenes para proyectos comerciales e industriales. Ofrecemos monitores UL de diversas marcas reconocidas.</p>
          <ul class="service-detail__list">
            <li class="service-detail__list-item">Certificación UL Listed con pruebas integrales</li>
            <li class="service-detail__list-item">Reconocido por Protección Civil en toda la República</li>
            <li class="service-detail__list-item">Compatible con NOM-002-STPS-2010 y códigos NFPA</li>
            <li class="service-detail__list-item">Certificado UL y fichas técnicas en español incluidos</li>
            <li class="service-detail__list-item">Facilita obtención de seguros y reduce primas</li>
            <li class="service-detail__list-item">Marcas UL Listed: Elkhart Brass, Akron, Task Force Tips</li>
          </ul>
          <div class="service-detail__ctas">
            <a href="/monitores/ul-listed" class="btn btn--primary">Ver catálogo completo</a>
            <a href="#cotizar" class="btn btn--outline">Cotizar</a>
          </div>
        </div>
        <div class="service-detail__image" role="img" aria-label="Monitor UL Listed Underwriters Laboratories" style={`background-image: url('${cdnImage('/img/monitores-contra-incendios/monitor-ul-listed-contra-incendios-camion-fondo-02.avif')}'); background-size: cover; background-position: center;`}></div>
      </div>

    </div>
  </section>

  <!-- TRUST -->
  <section class="trust" aria-labelledby="trust-title">
    <div class="container">
      <SectionHeader
        titulo="Por Qué Comprar Monitores Contra Incendios en Gama de México"
        subtitulo="Calidad certificada, inventario disponible y asesoría técnica especializada"
        idTitulo="trust-title"
      />
      <div class="trust__grid">
        <div class="trust__item">
          <h3 class="trust__item-title">Construcción Robusta en Latón Forjado</h3>
          <p class="trust__item-desc">Monitores contra incendio fabricados en latón (bronce) forjado de una sola pieza con alta resistencia a la corrosión, garantizando operación libre de fugas durante décadas.</p>
        </div>
        <div class="trust__item">
          <h3 class="trust__item-title">Doble Certificación FM y UL</h3>
          <p class="trust__item-desc">Todos nuestros monitores cuentan con certificación FM Approved y UL Listed. Incluimos certificados originales y documentación en español.</p>
        </div>
        <div class="trust__item">
          <h3 class="trust__item-title">Venta con Disponibilidad Inmediata</h3>
          <p class="trust__item-desc">Stock permanente para venta de monitores en México. Precio competitivo y entregas en 24-48 horas. Evita importaciones de 8-12 semanas con nuestro inventario local.</p>
        </div>
        <div class="trust__item">
          <h3 class="trust__item-title">Asesoría y Cotización Profesional</h3>
          <p class="trust__item-desc">Experiencia profesional para seleccionar el monitor contra incendio correcto. Cotización detallada con especificaciones técnicas y precio sin compromiso.</p>
        </div>
        <div class="trust__item">
          <h3 class="trust__item-title">Materiales Confiables para Cada Entorno</h3>
          <p class="trust__item-desc">Equipos de alta confiabilidad: bronce para ambientes marinos, acero inoxidable para espuma. Ideal para aplicaciones industriales exigentes.</p>
        </div>
        <div class="trust__item">
          <h3 class="trust__item-title">Documentación para Auditorías</h3>
          <p class="trust__item-desc">Certificados FM/UL originales, fichas técnicas en español, manuales y cartas de conformidad con NOM-002-STPS incluidos.</p>
        </div>
      </div>

      <SectionHeader
        titulo="Lo que dicen nuestros clientes"
        subtitulo="Empresas de todo México confían en nuestros monitores contra incendios"
        idTitulo="testimonials-title"
      />
      <div class="trust__testimonials">
        <blockquote class="testimonial">
          <div class="testimonial__stars" aria-label="5 estrellas">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
          <p class="testimonial__text">"Instalamos 8 monitores tipo corazón en el perímetro de nuestra planta petroquímica. La construcción forjada y la certificación FM fueron requisitos de nuestra aseguradora. Gama de México nos asesoró con las mejores opciones del mercado y entregó en 48 horas con toda la documentación."</p>
